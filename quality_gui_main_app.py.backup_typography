    def _format_file_size(self, size_bytes):
        """UTILITY: Smart file size formatting"""
        try:
            if size_bytes < 1024:
                return f"{size_bytes} B"
            elif size_bytes < 1024**2:
                return f"{size_bytes/1024:.1f} KB"
            elif size_bytes < 1024**3:
                return f"{size_bytes/(1024**2):.1f} MB"
            else:
                return f"{size_bytes/(1024**3):.1f} GB"
        except:
            return "Unknown"
    
    def _get_smart_upload_advice(self, file_type):
        """SMART: Get contextual advice based on upload status"""
        try:
            source_count = len(self.uploaded_files['source'])
            trans_count = len(self.uploaded_files['translation'])
            
            if file_type == "source":
                if trans_count == 0:
                    return "Next: Upload corresponding translation files"
                elif trans_count < source_count:
                    return f"Balance: Consider uploading {source_count - trans_count} more translation file(s)"
                else:
                    return "Ready: All files uploaded - Start quality analysis!"
            else:  # translation
                if source_count == 0:
                    return "Next: Upload corresponding source files"
                elif source_count < trans_count:
                    return f"Balance: Consider uploading {trans_count - source_count} more source file(s)"
                else:
                    return "Ready: All files uploaded - Start quality analysis!"
        except:
            return "Files uploaded successfully"
    
