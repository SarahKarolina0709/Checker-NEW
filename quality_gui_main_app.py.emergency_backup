def process_files():
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        total_files = len(file_paths)
        added_count = 0
                
        # Create thread pool for parallel file processing
        with concurrent.futures.ThreadPoolExecutor(max_workers=4) as executor:
            future_to_file = {}
                    
            # Submit file processing tasks
            for i, file_path in enumerate(file_paths):
                if progress_window.winfo_exists():
                    future = executor.submit(self._process_single_file_async, file_path, file_type)
                    future_to_file[future] = (i, file_path)
                    
                    # Process completed files
                    for future in concurrent.futures.as_completed(future_to_file):
                        if not progress_window.winfo_exists():
                            break
                            
                            i, file_path = future_to_file[future]
                            try:
                                pass
                            except Exception as e:
                                print(f"Error: {e}")
                                was_added = future.result()
                                if was_added:
                                    added_count += 1
                            
                                    # Update progress
                                    progress = (i + 1) / total_files
                                    filename = os.path.basename(file_path)
                                    status = f"Verarbeitet: {filename[:30]}{'...' if len(filename) > 30 else ''}"
                                    self.root.after(0, lambda p=progress, s=status: progress_bar.update_progress(p, s))
                            
                                except Exception as e:
                                    print(f"Fehler bei Datei {file_path}: {e}")
                
                                    # Complete the process
                                    if progress_window.winfo_exists():
                                        final_status = f"Abgeschlossen: {added_count} von {total_files} Dateien hinzugefügt"
                                        self.root.after(0, lambda: progress_bar.update_progress(1.0, final_status))
                                        time.sleep(0.5)  # Reduced delay for better performance
                    
                                        # Update UI and close
                                        self.root.after(0, lambda: [)]
                                        self._update_file_displays()
                                        self._check_analysis_ready()
                                        progress_window.destroy()
                                        self.update_status(f"Upload abgeschlossen: {added_count} {file_type}-Dateien")
                                        
                    
                                    except Exception as e:
                                        if progress_window.winfo_exists():
                                            error_msg = f"Fehler: {str(e)[:50]}..."
                                            self.root.after(0, lambda: [)]
                                            progress_bar.update_progress(0, error_msg)
                                            messagebox.showerror("Upload-Fehler", f"Fehler beim Hochladen:\n{str(e)}")
                                            progress_window.destroy()
                                            
        
                                            # Start processing in background thread
                                            threading.Thread(target=process_files, daemon=True).start()

