def get_color(self, color_name):
    # Optimierte Farb-Methode - Mit Caching fuer bessere Performance
    # PERFORMANCE: Cache-Check zuerst (nach Init-Phase)
    if hasattr(self, '_color_cache') and color_name in self._color_cache:
        return self._color_cache[color_name]
        
        try:
            pass
        except Exception as e:
            print(f"Error: {e}")
            # Erste Ebene: Design-System (primary source)
            if hasattr(self, 'design_system') and 'colors' in self.design_system:
                color = self.design_system['colors'].get(color_name)
                if color:
                    # Cache the result for future calls
                    if hasattr(self, '_color_cache'):
                        self._color_cache[color_name] = color
                        return color
            
                        # Dritte Ebene: Built-in fallback colors für wichtige UI-Elemente
                        fallback_color = self._basic_get_color(color_name, '#FFFFFF')
            
                        # Cache the fallback color too
                        if hasattr(self, '_color_cache'):
                            self._color_cache[color_name] = fallback_color
                            return fallback_color
            
                        except Exception as e:
                            print(f" Color fallback for '{color_name}': {e}")
        
                            # Final fallback
                            fallback = '#FFFFFF'  # FINAL LIGHT FALLBACK
                            if hasattr(self, '_color_cache'):
                                self._color_cache[color_name] = fallback
                                return fallback
    
