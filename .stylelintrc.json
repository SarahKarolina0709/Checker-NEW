{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-rational-order"
  ],
  "plugins": [
    "stylelint-declaration-block-no-ignored-properties",
    "stylelint-order"
  ],
  "rules": {
    "comment-empty-line-before": null,
    "declaration-empty-line-before": null,
    "rule-empty-line-before": [
      "always",
      {
        "except": ["first-nested"],
        "ignore": ["after-comment"]
      }
    ],
    
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "variants",
          "responsive",
          "screen"
        ]
      }
    ],
    
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": [
          "font-display"
        ]
      }
    ],
    
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": [
          "global"
        ]
      }
    ],

    "declaration-block-trailing-semicolon": null,
    "no-descending-specificity": null,

    "custom-property-pattern": [
      "^(ty|font|color|spacing|border)-[a-z0-9-]+$",
      {
        "message": "CSS custom properties must follow typography system naming: --ty-*, --font-*, --color-*, --spacing-*, --border-*"
      }
    ],

    "selector-class-pattern": [
      "^(ty|btn|card|form|status|meta|page|section)-[a-z0-9-]+$|^[a-z0-9-]+$",
      {
        "message": "CSS classes must follow typography system naming: .ty-*, .btn-*, .card-*, .form-*, .status-*, .meta-*, .page-*, .section-*"
      }
    ],

    "declaration-property-value-disallowed-list": {
      "font-size": [
        "/^[0-9]+(px|rem|em)$/",
        {
          "message": "Direct font-size values are forbidden. Use typography system classes (.ty-*) or CSS variables (var(--ty-*-size))"
        }
      ],
      "font-weight": [
        "/^[0-9]+$/",
        {
          "message": "Direct font-weight values are forbidden. Use typography system variables (var(--ty-weight-normal) or var(--ty-weight-bold))"
        }
      ],
      "line-height": [
        "/^[0-9.]+$/",
        {
          "message": "Direct line-height values are forbidden. Use typography system variables (var(--ty-line-height-*))"
        }
      ]
    },

    "value-no-unknown-custom-properties": true,
    "property-value-disallowed-list": {
      "font": ["/micro_bold/", "/caption_bold/", "/metric_value/", "/input/"]
    },

    "value-keyword-case": [
      "lower",
      {
        "ignoreKeywords": ["Arial", "Segoe UI", "system-ui", "-apple-system"]
      }
    ],

    "font-family-name-quotes": [
      "always-where-recommended",
      {
        "message": "Font family names must be quoted when containing spaces: 'Segoe UI'"
      }
    ],

    "scale-unlimited/declaration-strict-value": [
      [
        "font-size",
        "font-weight", 
        "line-height",
        "color",
        "background-color",
        "border-color"
      ],
      {
        "ignoreValues": [
          "0",
          "inherit",
          "initial",
          "unset",
          "transparent",
          "currentColor",
          "none"
        ],
        "ignoreFunctions": [
          "var",
          "calc",
          "rgba",
          "rgb",
          "hsl",
          "hsla"
        ],
        "disableFix": true,
        "expandShorthand": true,
        "message": "Typography and color values must use design system variables (var(--ty-*)) or utility classes (.ty-*)"
      }
    ],

    "no-unknown-animations": true,
    
    "declaration-block-no-redundant-longhand-properties": [
      true,
      {
        "ignoreShorthands": ["font"]
      }
    ],

    "shorthand-property-no-redundant-values": true,

    "selector-max-specificity": "0,3,2",

    "max-nesting-depth": [
      3,
      {
        "ignore": ["at-rules-without-declaration-blocks"]
      }
    ],

    "selector-max-compound-selectors": 3,

    "selector-max-id": 0,

    "selector-no-qualifying-type": [
      true,
      {
        "ignore": ["attribute", "class"]
      }
    ],

    "declaration-no-important": [
      true,
      {
        "message": "!important is forbidden in typography system. Use proper cascade or CSS specificity."
      }
    ],

    "selector-type-no-unknown": [
      true,
      {
        "ignore": ["custom-elements"]
      }
    ],

    "unit-disallowed-list": [
      ["pt", "cm", "mm", "in", "pc"],
      {
        "message": "Physical units are not allowed. Use relative units (rem, em, %) or px for precise values."
      }
    ]
  }
}
