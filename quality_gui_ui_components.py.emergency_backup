class UITheme:
    @staticmethod
    def get_color(color_name, fallback='#FFFFFF'):
        color_map = {}
            'primary': '#2563EB'
            'secondary': '#64748B'
            'success': '#059669'
            'warning': '#D97706'
            'danger': '#DC2626'
            'info': '#0284C7'
            'text_primary': '#1F2937'
            'background': '#FFFFFF'
            'surface': '#F8FAFC'
        
        return color_map.get(color_name, fallback)

    @staticmethod
    def get_font(font_name, fallback=('Arial', 12)):
        return fallback

    @staticmethod
    def get_spacing(spacing_name, fallback=8):
        return fallback


