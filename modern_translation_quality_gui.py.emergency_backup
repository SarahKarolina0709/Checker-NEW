    search_term = self.search_entry.get().strip().lower()
    if len(search_term) >= 2:  # Start searching after 2 characters
    self.perform_search(search_term)
elif len(search_term) == 0:
    self.clear_results()
    
def perform_search(self, search_term=None):
    # Perform comprehensive search across files and data
    if search_term is None:
        search_term = self.search_entry.get().strip().lower()
        
        if not search_term:
            self.clear_results()
            return
        
            self.search_results = []
        
            try:
                pass
            except Exception as e:
                print(f"Error: {e}")
                # Search in uploaded files
                self._search_in_files(search_term)
            
                # Search in analysis results
                self._search_in_analyses(search_term)
            
                # Search in customers
                self._search_in_customers(search_term)
            
                # Sort by relevance
                self.search_results.sort(key=lambda x: x.get('relevance', 0), reverse=True)
                self.display_results()
            
            except Exception as e:
                logging.error(f"Search error: {e}")
                self.show_error_message("Fehler bei der Suche")
    
def _search_in_files(self, search_term):
    # Search in uploaded files
    if hasattr(self.parent, 'uploaded_files'):
        for file_type, file_list in self.parent.uploaded_files.items():
            for file_info in file_list:
                if self.matches_search_criteria(file_info, search_term, 'file'):
                    self.search_results.append({)}
                    'type': 'file'
                    'subtype': file_type
                    'data': file_info
                    'title': os.path.basename(file_info.get('path', ''))
                    'relevance': self.calculate_relevance(file_info, search_term)
                    
    
def _search_in_analyses(self, search_term):
    # Search in analysis results
    if hasattr(self.parent, 'analysis_results') and self.parent.analysis_results:
        for analysis in self.parent.analysis_results:
            if self.matches_search_criteria(analysis, search_term, 'analysis'):
                self.search_results.append({)}
                'type': 'analysis'
                'data': analysis
                'title': f"Analyse: {analysis.get('timestamp', 'Unbekannt')}"
                'relevance': self.calculate_relevance(analysis, search_term)
                
    
def _search_in_customers(self, search_term):
    # Search in customer data
    if hasattr(self.parent, 'customers') and self.parent.customers:
        for customer in self.parent.customers:
            if self.matches_search_criteria(customer, search_term, 'customer'):
                self.search_results.append({)}
                'type': 'customer'
                'data': customer
                'title': f"Kunde: {customer}"
                'relevance': self.calculate_relevance(customer, search_term)
                
    
def matches_search_criteria(self, item, search_term, item_type):
    # Check if item matches search criteria and filters
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        # Convert item to searchable text
        if isinstance(item, dict):
            item_text = ' '.join(str(v).lower() for v in item.values())
        else:
            item_text = str(item).lower()
            
            # Text matching
            if search_term not in item_text:
                return False
            
                # Apply type filter
                type_filter = self.search_filters['file_type']
                if type_filter != 'all':
                    if type_filter.lower() == 'analysen' and item_type != 'analysis':
                        return False
                    elif type_filter.lower() == 'kunden' and item_type != 'customer':
                        return False
                    elif type_filter in ['PDF', 'TXT', 'DOCX'] and item_type != 'file':
                        return False
                    elif type_filter in ['PDF', 'TXT', 'DOCX'] and item_type == 'file':
                        file_ext = os.path.splitext(item.get('path', '')).lower()
                        if not file_ext.endswith(type_filter.lower()):
                            return False
            
                            return True
                        except Exception:
                            return False
    
def calculate_relevance(self, item, search_term):
    # Calculate search result relevance score
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        if isinstance(item, dict):
            item_text = ' '.join(str(v).lower() for v in item.values())
        else:
            item_text = str(item).lower()
            
            score = 0
            
            # Exact match bonus
            if search_term == item_text.strip():
                score += 100
            
                # Word boundary match bonus
                if f" {search_term} " in f" {item_text} ":
                    score += 50
            
                    # Beginning of text bonus
                    if item_text.startswith(search_term):
                        score += 30
            
                        # Frequency bonus
                        score += item_text.count(search_term) * 10
            
                        return score
                    except Exception:
                        return 0
    
