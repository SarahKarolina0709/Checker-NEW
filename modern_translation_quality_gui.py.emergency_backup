        # Refresh file lists
        if hasattr(self, 'uploaded_files'):
            for file_type in self.uploaded_files:
                # Re-validate file existence
                valid_files = []
                for file_path in self.uploaded_files[file_type]:
                    if os.path.exists(file_path):
                        valid_files.append(file_path)
                        self.uploaded_files[file_type] = valid_files
            
                        # Refresh current view
                        current_view = getattr(self, 'current_view', 'home')
                        if current_view == 'files':
                            self.show_files_view()
