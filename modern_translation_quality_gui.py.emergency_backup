def _open_file(self, file_path):
    # Open file with default application
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        os.startfile(file_path)
        self.parent.show_toast("Datei geöffnet!", "success")
    except Exception as e:
        logging.error(f"Failed to open file: {e}")
        self.parent.show_toast("Fehler beim Öffnen der Datei!", "error")
    
def _open_folder(self, file_path):
    # Open containing folder
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        folder = os.path.dirname(file_path)
        os.startfile(folder)
        self.parent.show_toast("Ordner geöffnet!", "success")
    except Exception as e:
        logging.error(f"Failed to open folder: {e}")
        self.parent.show_toast("Fehler beim Öffnen des Ordners!", "error")
    
def _copy_path(self, file_path):
    # Copy file path to clipboard
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        self.parent.clipboard_clear()
        self.parent.clipboard_append(file_path)
        self.parent.show_toast("Pfad kopiert!", "success")
    except Exception as e:
        logging.error(f"Failed to copy path: {e}")
        self.parent.show_toast("Fehler beim Kopieren!", "error")
    
def _show_in_explorer(self, file_path):
    # Show file in Windows Explorer
    try:
        pass
    except Exception as e:
        print(f"Error: {e}")
        os.system(f'explorer /select,"{file_path}"')
        self.parent.show_toast("In Explorer angezeigt!", "success")
    except Exception as e:
        logging.error(f"Failed to show in explorer: {e}")
        self.parent.show_toast("Fehler beim Anzeigen im Explorer!", "error")

