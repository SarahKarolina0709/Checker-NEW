    def _create_project_folder_navigation(self, parent):
        """📂 VISUELLER ORDNER-BROWSER: Projektstruktur-Navigation mit Tree-View"""
        try:
            # Ordner-Navigation Header
            nav_title = ctk.CTkLabel(
                parent,
                text="Projekte",
                font=ctk.CTkFont(*self.get_typography('subheading')),
                text_color=self.get_color('gray_700')
            )
            nav_title.pack(pady=(0, 15))
            
            # Navigation Container
            nav_container = ctk.CTkFrame(
                parent,
                fg_color=self.get_color('surface'),
                corner_radius=8,
                border_width=1,
                border_color=self.get_color('surface_border')
            )
            nav_container.pack(fill="x", pady=(0, 20))
            
            nav_content = ctk.CTkFrame(nav_container, fg_color="transparent")
            nav_content.pack(fill="x", padx=15, pady=15)
            # Suchfeld (neu) – ermöglicht Filterung nach Kunde oder Datum
            self._project_nav_search_var = ctk.StringVar() if not hasattr(self, '_project_nav_search_var') else self._project_nav_search_var
            search_entry = ctk.CTkEntry(
                nav_content,
                textvariable=self._project_nav_search_var,
                placeholder_text='Suche...',
                height=32
            )
            search_entry.pack(fill="x", pady=(0, 10))
            search_entry.bind("<KeyRelease>", lambda e: self._on_project_nav_search())
            search_entry.bind("<Return>", lambda e: self._open_first_project_nav_match())
            search_entry.bind("<FocusIn>", lambda e: self._on_project_nav_focus_in())
            search_entry.bind("<FocusOut>", lambda e: self._on_project_nav_focus_out())
            self._project_nav_search_entry = search_entry

            # Sichtbarer Default-Text (Workaround, da placeholder optisch nicht sichtbar war)
            if not self._project_nav_search_var.get():
                self._project_nav_search_var.set('Suche...')

            # Globale Shortcuts nur einmal binden
            if not hasattr(self, '_project_nav_shortcuts_bound'):
                try:
                    toplevel = self.winfo_toplevel() if hasattr(self, 'winfo_toplevel') else None
                    target = toplevel or getattr(self, 'root', None) or search_entry
                    if target:
                        target.bind_all('<Control-f>', lambda e: self._focus_project_nav_search())
                        target.bind_all('<Control-F>', lambda e: self._focus_project_nav_search())
                        target.bind_all('<Escape>', lambda e: self._clear_project_nav_search())
                    self._project_nav_shortcuts_bound = True
                except Exception:
                    pass

            # Container für dynamische Liste
            self._project_nav_list_frame = ctk.CTkFrame(nav_content, fg_color="transparent")
            self._project_nav_list_frame.pack(fill="x")

            # Alle Projekte cachen (neueste zuerst) und initial rendern
            self._all_projects_cache = self._get_current_projects()
            self._render_project_nav_items()  # zeigt zunächst wie zuvor nur die letzten 3
            
            # Schnellzugriff-Buttons
            quick_actions_frame = ctk.CTkFrame(nav_content, fg_color="transparent")
            quick_actions_frame.pack(fill="x", pady=(10, 0))
            quick_actions_frame.grid_columnconfigure((0, 1, 2), weight=1)
            
            # Projekte-Ordner öffnen
            projects_button = self._create_button(
                quick_actions_frame,
                text="Alle Projekte",
                command=self._open_projects_folder,
                kind="primary",
                height=36
            )
            projects_button.grid(row=0, column=0, sticky="ew", padx=(0, 5))
            
            # Neues Projekt
            new_project_button = self._create_button(
                quick_actions_frame,
                text="Neues Projekt",
                command=self._create_new_project_dialog,
                kind="primary",
                height=36
            )
            new_project_button.grid(row=0, column=1, sticky="ew", padx=5)
            
            # Struktur validieren
            validate_button = self._create_button(
                quick_actions_frame,
                text="Struktur prüfen",
                command=self._validate_all_projects,
                kind="primary",
                height=36
            )
            validate_button.grid(row=0, column=2, sticky="ew", padx=(5, 0))
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.folder_nav",
                user_message=self._t("Ordner-Navigation Fehler") if hasattr(self, '_t') else "Ordner Navigation Fehler"
            )
    
    # -------------------------------
    # 📂 PROJEKT-NAVIGATION – SUCH/RENDER HELFER (additiv, keine bestehende Logik verändert)
    # -------------------------------
    def _on_project_nav_search(self):
        """🔍 Event-Handler bei Tastatureingabe im Projekt-Suchfeld."""
        try:
            self._render_project_nav_items()
        except Exception as e:
            self._handle_error(e, context="ui.folder_nav.search.event")

    def _render_project_nav_items(self):
        """🧩 Dynamisches Rendering der Projektliste mit optionalem Suchfilter.

        Standard: Zeigt wie bisher nur die letzten 3 Projekte.
        Bei aktivem Suchtext: Zeigt alle Treffer (max. 50) nach Kunde oder Datum.
        """
        try:
            if not hasattr(self, '_project_nav_list_frame') or self._project_nav_list_frame is None:
                return
            frame = self._project_nav_list_frame
            # Vorherige Einträge entfernen
            for child in list(frame.winfo_children()):
                try:
                    child.destroy()
                except Exception:
                    pass

            projects = getattr(self, '_all_projects_cache', [])
            raw_query = ''
            if hasattr(self, '_project_nav_search_var') and self._project_nav_search_var:
                raw_query = (self._project_nav_search_var.get() or '').strip()
            if raw_query:
                q_cf = raw_query.casefold()
                filtered = [p for p in projects if q_cf in p['customer'].casefold() or q_cf in p['date'].casefold()]
                display_projects = filtered[:50]
            else:
                display_projects = projects[:3]

            # Liste für Enter-Shortcut merken
            self._project_nav_last_displayed = display_projects

            if not display_projects:
                info_label = ctk.CTkLabel(
                    frame,
                    text="Keine Projekte gefunden" if projects else "Noch keine Projekte erstellt.",
                    font=ctk.CTkFont(*self.get_typography('caption')),
                    text_color=self.get_color('gray_500')
                )
                info_label.pack(pady=4)
                return

            # Einzelne Projekt-Cards rendern
            for project in display_projects:
                project_frame = ctk.CTkFrame(
                    frame,
                    fg_color=self.get_color('surface'),
                    corner_radius=6,
                    border_width=1,
                    border_color=self.get_color('surface_border')
                )
                project_frame.pack(fill="x", pady=6)
                project_frame.grid_columnconfigure(0, weight=1)

                inner = ctk.CTkFrame(project_frame, fg_color="transparent")
                inner.pack(fill="x", padx=12, pady=8)
                inner.grid_columnconfigure(0, weight=1)

                marker = self._format_project_status_marker(project)
                display_name = f"{marker} {project['customer']}" if marker else project['customer']
                project_name_label = ctk.CTkLabel(
                    inner,
                    text=display_name,
                    font=ctk.CTkFont(*self.get_typography('label_bold')),
                    text_color=self.get_color('gray_700'),
                    anchor='w'
                )
                project_name_label.grid(row=0, column=0, sticky='w')

                project_meta_label = ctk.CTkLabel(
                    inner,
                    text=project['date'],
                    font=ctk.CTkFont(*self.get_typography('caption')),
                    text_color=self.get_color('gray_500'),
                    anchor='w'
                )
                project_meta_label.grid(row=1, column=0, sticky='w', pady=(2,0))

                open_button = self._create_button(
                    inner,
                    text="Öffnen",
                    command=lambda p=project: self._open_project_folder(p),
                    kind="primary",
                    height=32,
                    width=90
                )
                open_button.grid(row=0, column=1, rowspan=2, sticky='e', padx=(12,0))

        except Exception as e:
            self._handle_error(
                e,
                context="ui.folder_nav.render",
                user_message=self._t("Projekt-Navigation konnte nicht aktualisiert werden") if hasattr(self, '_t') else "Projektliste Render Fehler"
            )

    def _focus_project_nav_search(self):
        """🎯 Fokus direkt ins Projekt-Suchfeld setzen (Strg+F)."""
        try:
            if hasattr(self, '_project_nav_search_entry') and self._project_nav_search_entry:
                self._project_nav_search_entry.focus_set()
                # Inhalt markieren für schnelle Überschreibung
                try:
                    self._project_nav_search_entry.select_range(0, 'end')
                except Exception:
                    pass
        except Exception as e:
            self._handle_error(e, context='ui.folder_nav.search.focus')

    def _clear_project_nav_search(self):
        """🧹 Suchfeld leeren (ESC) und Standardliste zeigen."""
        try:
            if hasattr(self, '_project_nav_search_var') and self._project_nav_search_var:
                if self._project_nav_search_var.get():
                    self._project_nav_search_var.set('')
                    self._render_project_nav_items()
        except Exception as e:
            self._handle_error(e, context='ui.folder_nav.search.clear')

    def _open_first_project_nav_match(self):
        """↩️ Enter im Suchfeld öffnet erstes gefiltertes Projekt (falls eindeutig)."""
        try:
            matches = getattr(self, '_project_nav_last_displayed', [])
            if matches:
                self._open_project_folder(matches[0])
        except Exception as e:
            self._handle_error(e, context='ui.folder_nav.search.open_first')

    def _on_project_nav_focus_in(self):
        """Fokus-In: Platzhalter-Text markieren zur schnellen Überschreibung."""
        try:
            if (hasattr(self, '_project_nav_search_var') and 
                self._project_nav_search_var.get().lower() in ('suche...', 'suche')):
                # Neu: Sofort leeren damit direkt geschrieben werden kann
                self._project_nav_search_var.set('')
                # Render zurück auf Standard (zeigt 3 letzte)
                self._render_project_nav_items()
        except Exception as e:
            self._handle_error(e, context='ui.folder_nav.search.focus_in')

    def _on_project_nav_focus_out(self):
        """Fokus-Out: Wenn Feld leer, Platzhalter-Text wiederherstellen."""
        try:
            if hasattr(self, '_project_nav_search_var'):
                if not self._project_nav_search_var.get().strip():
                    self._project_nav_search_var.set('Suche...')
                    # Standardliste anzeigen
                    self._render_project_nav_items()
        except Exception as e:
            self._handle_error(e, context='ui.folder_nav.search.focus_out')

    def _get_current_projects(self):
        """📂 Aktuelle Projekte aus bestehender Checker-Ordnerstruktur ermitteln"""
        try:
            projects = []
            projects_path = "Checker_Projekte"
            
            if not os.path.exists(projects_path):
                return projects
            
            for customer_folder in os.listdir(projects_path):
                customer_path = os.path.join(projects_path, customer_folder)
                if os.path.isdir(customer_path):
                    for date_folder in os.listdir(customer_path):
                        date_path = os.path.join(customer_path, date_folder)
                        if os.path.isdir(date_path):
                            projects.append({
                                'customer': customer_folder,
                                'date': date_folder,
                                'path': date_path,
                                'full_name': f"{customer_folder}/{date_folder}"
                            })
            
            # Nach Datum sortieren (neueste zuerst)
            projects.sort(key=lambda x: x['date'], reverse=True)
            return projects
            
        except Exception as e:
            self._handle_error(
                e,
                context="projects.discovery",
                user_message=self._t("Projekte konnten nicht ermittelt werden") if hasattr(self, '_t') else "Projekte konnten nicht ermittelt werden"
            )
            return []
    
    def _open_project_folder(self, project):
        """📂 Projekt-Ordner im Explorer öffnen"""
        try:
            project_path = project['path']
            if os.path.exists(project_path):
                self._open_in_file_manager(project_path)
                try:
                    self.show_toast((self._t("Projekt-Ordner geöffnet:") + f" {project['full_name']}") if hasattr(self,'_t') else f"Projekt-Ordner geöffnet: {project['full_name']}", "info")
                except Exception:
                    pass
            else:
                self.show_toast(self._t("Projekt-Ordner nicht gefunden") if hasattr(self,'_t') else "Projekt-Ordner nicht gefunden", "error")
                
        except Exception as e:
            self._handle_error(
                e,
                context="projects.open.single",
                user_message=self._t("Projekt-Ordner konnte nicht geöffnet werden") if hasattr(self, '_t') else "Projekt-Ordner Öffnen Fehler"
            )
            self.show_toast("Fehler beim Öffnen des Ordners", "error")
    
    def _open_projects_folder(self):
        """📂 Hauptprojekte-Ordner im Explorer öffnen (Checker_Projekte)"""
        try:
            projects_path = self.PROJECTS_ROOT
            
            # Ordner erstellen falls nicht vorhanden
            if not os.path.exists(projects_path):
                os.makedirs(projects_path, exist_ok=True)
            
            self._open_in_file_manager(projects_path)
            try:
                self.show_toast(self._t("Projekte-Ordner geöffnet") if hasattr(self,'_t') else "Projekte-Ordner geöffnet", "info")
            except Exception:
                pass
            
        except Exception as e:
            self._handle_error(
                e,
                context="projects.open.base",
                user_message=self._t("Projekte-Verzeichnis konnte nicht geöffnet werden") if hasattr(self, '_t') else "Projekte-Verzeichnis Fehler"
            )
            self.show_toast("Fehler beim Öffnen des Ordners", "error")
    
    def _create_new_project_dialog(self):
        """📂 Dialog für neues Projekt mit Design-System (kein simpledialog).

        Verbesserungen:
        - Konsistentes Design-System (Farben, Abstände, Typografie)
        - ESC schließt, ENTER bestätigt
        - Leere Eingabe zeigt Toast statt still zu schließen
        - Automatisches Trimmen & Normalisieren (Spaces -> _)
        - Zentrierung des Fensters
        - Single Responsibility (innere Helper) ohne bestehende Logik zu ändern
        """
        try:
            import datetime
            import tkinter as tk  # für Toplevel Geometrie-Hilfen
            import customtkinter as ctk
            from design_system import get_color, get_spacing, get_font, create_button, create_card

            # Falls schon geöffnet → Fokus statt Duplikat
            if hasattr(self, '_new_project_win') and self._new_project_win and self._new_project_win.winfo_exists():
                try:
                    self._new_project_win.focus_force()
                except Exception:
                    pass
                return

            parent = getattr(self, 'root', None)
            self._new_project_win = ctk.CTkToplevel(parent) if parent else ctk.CTkToplevel()
            win = self._new_project_win
            win.title("Neues Projekt")
            try:
                win.transient(parent)
                win.grab_set()  # modal
            except Exception:
                pass

            # Basis-Layout
            spacing_md = get_spacing('md')
            spacing_sm = get_spacing('sm')
            card_cfg = create_card()
            container = ctk.CTkFrame(win, **card_cfg)
            container.pack(fill='both', expand=True, padx=spacing_md, pady=spacing_md)
            container.grid_rowconfigure(0, weight=0)
            container.grid_rowconfigure(1, weight=0)
            container.grid_rowconfigure(2, weight=1)
            container.grid_columnconfigure(0, weight=1)

            # Label
            lbl = ctk.CTkLabel(
                container,
                text="Kundenname für neues Projekt",
                text_color=get_color('text_primary'),
                font=ctk.CTkFont(*get_font('label')) if hasattr(self, 'get_font') else ctk.CTkFont(*get_font('label'))
            )
            lbl.grid(row=0, column=0, sticky='w', padx=spacing_md, pady=(spacing_md, spacing_sm))

            # Entry
            entry_style = {
                'fg_color': get_color('input_bg'),
                'border_color': get_color('input_border'),
                'border_width': 1,
                'text_color': get_color('input_text'),
                'corner_radius': 4,
                'font': ctk.CTkFont(*get_font('body_md'))
            }
            name_var = tk.StringVar()
            entry = ctk.CTkEntry(container, textvariable=name_var, **entry_style)
            entry.grid(row=1, column=0, sticky='ew', padx=spacing_md)
            entry.focus_set()

            # Button-Leiste
            btn_frame = ctk.CTkFrame(container, fg_color='transparent')
            btn_frame.grid(row=2, column=0, sticky='ew', padx=spacing_md, pady=(spacing_sm, spacing_md))
            btn_frame.grid_columnconfigure(0, weight=1)
            btn_frame.grid_columnconfigure(1, weight=0)
            btn_frame.grid_columnconfigure(2, weight=0)

            def _close():
                try:
                    win.destroy()
                except Exception:
                    pass

            def _submit(event=None):  # noqa: D401
                raw = name_var.get().strip()
                if not raw:
                    try:
                        self.show_toast(self._t("Bitte Namen eingeben") if hasattr(self,'_t') else "Bitte Namen eingeben", "warning")
                    except Exception:
                        pass
                    return
                # Namen säubern: verbotene Zeichen ersetzen, Mehrfach-Unterstriche reduzieren
                tmp = re.sub(r'[<>:"/\\|?*]+', '_', raw)
                tmp = re.sub(r'\s+', '_', tmp)
                tmp = re.sub(r'_+', '_', tmp).strip('_')
                clean_name = tmp or 'unbenannt'
                project_date = datetime.datetime.now().strftime('%Y-%m-%d')
                created_path = self.create_project_structure(clean_name, project_date)
                if created_path:
                    try:
                        self.show_toast((self._t("Neues Projekt erstellt:") + f" {clean_name}") if hasattr(self,'_t') else f"Neues Projekt erstellt: {clean_name}", "success")
                    except Exception:
                        pass
                    self._refresh_project_navigation()
                    _close()
                else:
                    try:
                        self.show_toast(self._t("Fehler beim Erstellen des Projekts") if hasattr(self,'_t') else "Fehler beim Erstellen des Projekts", "error")
                    except Exception:
                        pass

            # Buttons (Primary + Abbrechen)
            ok_cfg = create_button(style='primary', text='Erstellen', command=_submit)
            cancel_cfg = create_button(style='secondary', text='Abbrechen', command=_close)
            ok_btn = ctk.CTkButton(btn_frame, **ok_cfg)
            cancel_btn = ctk.CTkButton(btn_frame, **cancel_cfg)
            # Rechts ausrichten
            cancel_btn.grid(row=0, column=1, padx=(0, spacing_sm), pady=0, sticky='e')
            ok_btn.grid(row=0, column=2, pady=0, sticky='e')

            # Key-Bindings
            win.bind('<Escape>', lambda e: _close())
            win.bind('<Return>', _submit)

            # Zentrieren (nach idle, damit width/height bekannt)
            def _center():
                try:
                    win.update_idletasks()
                    w = win.winfo_width()
                    h = win.winfo_height()
                    pw = parent.winfo_width() if parent else win.winfo_screenwidth()
                    ph = parent.winfo_height() if parent else win.winfo_screenheight()
                    px = parent.winfo_rootx() if parent else 0
                    py = parent.winfo_rooty() if parent else 0
                    x = px + (pw - w) // 2
                    y = py + (ph - h) // 3
                    win.geometry(f"{w}x{h}+{x}+{y}")
                except Exception:
                    pass
            win.after(50, _center)

        except Exception as e:  # Fehler robust anzeigen
            self._handle_error(
                e,
                context="projects.create.dialog",
                user_message=self._t("Neues Projekt konnte nicht erstellt werden") if hasattr(self, '_t') else "Projekt erstellen Fehler"
            )
            try:
                self.show_toast("Fehler beim Erstellen des Projekts", "error")
            except Exception:
                pass

    def _open_customer_selection_dialog(self):  # noqa: D401
        """Kundenauswahl-Dialog (leichtgewichtig) zum Setzen von current_customer.

        - Verwendet Design-System
        - Doppelklick oder ENTER bestätigt
        - ESC schließt ohne Änderung
        - Nach Auswahl: Badge aktualisiert sich automatisch (Polling) + Navigation optional refresh
    Erweiterungen (verbessert):
    - Live-Suche / Filter (Tippen reduziert Liste)
    - F5 lädt Kundenliste neu
    - Sofortige Badge-Aktualisierung ohne auf Polling zu warten
    - Helper _set_current_customer nutzt zentrale Logik
        """
        try:
            import customtkinter as ctk
            import tkinter as tk
            from design_system import get_color, get_font, get_spacing, create_card, create_button
            if hasattr(self, '_customer_select_win') and self._customer_select_win and self._customer_select_win.winfo_exists():
                try:
                    self._customer_select_win.focus_force()
                except Exception:
                    pass
                return
            # Kundenliste ermitteln
            customers = []
            try:
                if os.path.exists('customers.json'):
                    with open('customers.json','r',encoding='utf-8') as f:
                        data = json.load(f)
                    if isinstance(data, dict) and 'customers' in data:
                        customers = [c.get('name') for c in data['customers'] if isinstance(c, dict) and c.get('name')]
                    elif isinstance(data, list):
                        customers = [c.get('name') for c in data if isinstance(c, dict) and c.get('name')]
                    else:
                        # Legacy Keys
                        customers = [k for k in data.keys() if k not in ('favorites','last_updated','_meta','customers')]
            except Exception:
                customers = []
            customers = sorted(set(filter(None, customers)))
            if not customers:
                try:
                    self.show_toast('Keine Kunden vorhanden', 'info')
                except Exception:
                    pass
                return
            parent = getattr(self,'root', None)
            win = ctk.CTkToplevel(parent) if parent else ctk.CTkToplevel()
            self._customer_select_win = win
            win.title('Kunde auswählen')
            # Fenster-Größe für bessere Listendarstellung
            try:
                win.geometry("900x700")  # Größeres Fenster für bessere Übersicht
            except Exception:
                pass
            try:
                win.transient(parent); win.grab_set()
            except Exception:
                pass
            spacing_md = get_spacing('md')
            spacing_sm = get_spacing('sm')
            card_cfg = create_card()
            container = ctk.CTkFrame(win, **card_cfg)
            container.pack(fill='both', expand=True, padx=spacing_md, pady=spacing_md)
            # Container-Grid-Konfiguration - mit Default-Wert für list_row_index
            list_row_index = 2  # Default-Wert falls kein Schnellzugriff vorhanden
            container.grid_rowconfigure(list_row_index, weight=1)
            container.grid_columnconfigure(0, weight=1)
            # Header + Suchfeld
            header_frame = ctk.CTkFrame(container, fg_color='transparent')
            header_frame.grid(row=0, column=0, sticky='ew', padx=spacing_md, pady=(spacing_md, spacing_sm))
            # Column Layout aktualisiert: 0=Title, 1=Stretch, 2=Search, 3=Leeren, 4=Neu, 5=Reload
            header_frame.grid_columnconfigure(0, weight=0)
            header_frame.grid_columnconfigure(1, weight=1)
            header_frame.grid_columnconfigure(2, weight=0)
            header_frame.grid_columnconfigure(3, weight=0)
            header_frame.grid_columnconfigure(4, weight=0)
            header_frame.grid_columnconfigure(5, weight=0)
            # 📌 Kompaktere, professionellere Überschrift
            lbl = ctk.CTkLabel(
                header_frame,
                text='Kunde auswählen',
                text_color=get_color('text_primary'),
                font=ctk.CTkFont(*get_font('heading_lg'))  # Größer und prominenter
            )
            lbl.grid(row=0,column=0, sticky='w', padx=(0, spacing_md))
            # Info Label (Count + Aktiver Kunde)
            # Einfache, elegante Info-Zeile statt störender Badges
            info_var = tk.StringVar()
            info_label = ctk.CTkLabel(
                header_frame,
                textvariable=info_var,
                text_color=get_color('text_secondary'),
                font=ctk.CTkFont(*get_font('body_md'))
            )
            info_label.grid(row=1, column=0, columnspan=6, sticky='w', pady=(6,0))
            
            def _update_info():  # noqa: D401
                total = len(customers)
                try:
                    visible = lb.size()
                except Exception:
                    visible = total
                active = getattr(self,'current_customer', None) or 'Kein'
                try:
                    sel_indices = lb.curselection()
                    sel_name = lb.get(sel_indices[0]) if sel_indices else 'Kein'
                    if sel_name.endswith(' (aktiv)'):
                        sel_name = sel_name[:-8]
                except Exception:
                    sel_name='Kein'
                # Kompakte, professionelle Anzeige
                info_var.set(f"Sichtbar: {visible}/{total} • Aktiver Kunde: {active} • Auswahl: {sel_name}")
            # Options-Zeile unterhalb des Headers
            # Options-Bereich: Kompakter mit besserer Zentrierung
            options_frame = ctk.CTkFrame(container, fg_color='transparent')
            options_frame.grid(row=1, column=0, sticky='ew', padx=spacing_md, pady=(spacing_sm,spacing_sm))
            options_frame.grid_columnconfigure(1, weight=1)  # Mittlerer Bereich expandiert für Zentrierung
            sort_mode = tk.StringVar(value='asc')
            if not hasattr(self, '_recent_customers'):
                self._recent_customers = []
            # Flache, moderne Segmented Controls
            def _segment_style(active: bool):
                if active:
                    return {
                        'fg_color': get_color('primary'),
                        'text_color': get_color('white'),
                        'border_color': get_color('primary'),
                        'hover_color': get_color('primary_hover'),
                        'border_width': 0,  # Kein Border für sauberere Optik
                        'height': 32,
                        'corner_radius': 6,  # Weniger rund
                        'font': ctk.CTkFont(*get_font('body_md'))
                    }
                return {
                    'fg_color': get_color('surface'),
                    'text_color': get_color('text_secondary'),
                    'border_color': get_color('surface_border'),
                    'hover_color': get_color('surface_hover'),
                    'border_width': 1,
                    'height': 32,
                    'corner_radius': 6,
                    'font': ctk.CTkFont(*get_font('body_md'))
                }
            # Sortier-Buttons links
            sort_frame = ctk.CTkFrame(options_frame, fg_color='transparent')
            sort_frame.grid(row=0, column=0, sticky='w')
            
            btn_asc = ctk.CTkButton(sort_frame, **create_button(style='secondary', text='A→Z', command=lambda: _set_sort('asc')))
            btn_desc = ctk.CTkButton(sort_frame, **create_button(style='secondary', text='Z→A', command=lambda: _set_sort('desc')))
            btn_recent = ctk.CTkButton(sort_frame, **create_button(style='secondary', text='Zuletzt', command=lambda: _set_sort('recent')))
            
            # Auto-Auswahl Checkbox rechts
            auto_var = tk.BooleanVar(value=True)
            try:
                auto_cb = ctk.CTkCheckBox(
                    options_frame, 
                    text='Auto bei 1 Treffer auswählen', 
                    variable=auto_var,
                    text_color=get_color('text_secondary'), 
                    font=ctk.CTkFont(*get_font('body_md'))
                )
                auto_cb.grid(row=0, column=2, sticky='e')
            except Exception:
                auto_var.set(True)
            for b in (btn_asc, btn_desc, btn_recent):
                b.pack(side='left', padx=(0,1))  # Minimaler Abstand für Segmented Look
            
            def _refresh_sort_buttons():  # noqa: D401
                mode = sort_mode.get()
                for b, key in ((btn_asc,'asc'),(btn_desc,'desc'),(btn_recent,'recent')):
                    try:
                        cfg = _segment_style(mode == key)
                        b.configure(**cfg)
                        if key == 'recent':
                            if self._recent_customers:
                                b.configure(state='normal')
                            else:
                                b.configure(state='disabled')
                    except Exception:
                        pass
            def _set_sort(mode: str):  # noqa: D401
                try:
                    if mode == 'recent' and not self._recent_customers:
                        return
                    sort_mode.set(mode)
                    _on_filter(); _update_info(); _refresh_sort_buttons()
                except Exception:
                    pass
            _refresh_sort_buttons()
            # Suchfeld
            search_var = tk.StringVar()
            empty_state_label = None  # wird nach Erstellung der Listbox gesetzt
            def _on_filter(*_):  # noqa: D401
                term = search_var.get().strip().lower()
                lb.delete(0,'end')
                mode = sort_mode.get()
                if mode == 'asc':
                    ordered = sorted(customers)
                elif mode == 'desc':
                    ordered = sorted(customers, reverse=True)
                else:  # recent
                    recent = [c for c in self._recent_customers if c in customers]
                    remaining = [c for c in customers if c not in recent]
                    ordered = recent + sorted(remaining)
                for c in ordered:
                    if not term or term in c.lower():
                        label = f"{c} (aktiv)" if getattr(self,'current_customer',None)==c else c
                        lb.insert('end', label)
                if getattr(self,'current_customer',None):
                    try:
                        names_list = list(lb.get(0,'end'))
                        cur = self.current_customer
                        if cur in names_list:
                            idx = names_list.index(cur)
                        elif f"{cur} (aktiv)" in names_list:
                            idx = names_list.index(f"{cur} (aktiv)")
                        else:
                            idx = None
                        if idx is not None:
                            lb.selection_set(idx); lb.see(idx)
                    except Exception:
                        pass
                # Auto-Auswahl wenn genau 1 Treffer
                try:
                    if auto_var.get() and lb.size()==1:
                        lb.selection_set(0)
                        _update_info()
                        # leichte Verzögerung für UI-Stabilität
                        win.after(120, lambda: _apply())
                except Exception:
                    pass
                # Empty-State Anzeige steuern
                try:
                    if empty_state_label is not None:
                        if lb.size() == 0:
                            empty_state_label.place(relx=0.5, rely=0.5, anchor='center')
                        else:
                            empty_state_label.place_forget()
                except Exception:
                    pass
                
                # Hover-Zustand zurücksetzen nach Filter
                try:
                    nonlocal hover_index
                    hover_index = None
                    # Alle Einträge auf Standard-Farben zurücksetzen
                    for i in range(lb.size()):
                        lb.itemconfig(i,
                                    background=get_color('surface'),
                                    foreground=get_color('text_primary'))
                except Exception:
                    pass
                    
                _update_info()
            # 📌 Readability Upgrade: Suchfeld mit größerem Body-Font
            search_entry = ctk.CTkEntry(
                header_frame,
                placeholder_text='Suchen...',
                fg_color=get_color('input_bg'),
                text_color=get_color('input_text'),
                font=ctk.CTkFont(*get_font('body_lg'))  # Größer
            )
            search_entry.grid(row=0, column=2, sticky='e', padx=(spacing_sm,0))
            try:
                search_entry.configure(width=220)
            except Exception:
                pass
            # Clear-Filter Button (sekundär-outline Style)
            def _clear_filter():  # noqa: D401
                try:
                    if search_var.get():
                        search_var.set('')
                        search_entry.delete(0,'end')
                        _on_filter(); _update_info()
                    search_entry.focus_set()
                except Exception:  # pragma: no cover
                    pass
            clear_btn_cfg = create_button(style='secondary', text='Leeren', command=_clear_filter)
            clear_btn = ctk.CTkButton(header_frame, **clear_btn_cfg)
            try:
                clear_btn.configure(fg_color=get_color('surface'), text_color=get_color('primary'), border_color=get_color('primary'), border_width=1, hover_color=get_color('surface_hover'), height=32)
            except Exception:
                pass
            clear_btn.grid(row=0, column=3, padx=(spacing_sm,0))
            try:
                # Hinterlege Variable manuell (CTkEntry hat own variable Param, hier minimal)
                def _sync_var(e):
                    search_var.set(search_entry.get()); _on_filter(); _update_info()
                search_entry.bind('<KeyRelease>', _sync_var)
            except Exception:
                pass

            # Buttons Neu & Aktualisieren (Outline Sekundär)
            def _open_new():  # noqa: D401
                try:
                    self._create_new_project_dialog()
                    # Nach möglicher Kundenerstellung Kundenliste reloaden
                    _reload()
                except Exception:
                    pass
            new_btn_cfg = create_button(style='secondary', text='Neu', command=_open_new)
            reload_btn_cfg = create_button(style='secondary', text='Aktualisieren', command=lambda: (_reload(), _update_info()))
            new_btn = ctk.CTkButton(header_frame, **new_btn_cfg)
            reload_btn = ctk.CTkButton(header_frame, **reload_btn_cfg)
            for b in (clear_btn, new_btn, reload_btn):
                try:
                    b.configure(
                        fg_color=get_color('surface'),
                        text_color=get_color('primary'),
                        border_color=get_color('primary'),
                        border_width=1,
                        hover_color=get_color('surface_hover'),
                        height=32,
                        width=120,
                        font=ctk.CTkFont(*get_font('button_lg'))
                    )
                except Exception:
                    pass
            new_btn.grid(row=0, column=4, padx=(spacing_sm,0))
            reload_btn.grid(row=0, column=5, padx=(spacing_sm,0))

            # --- Schnellzugriff: Aktiver & Zuletzt verwendete Kunden (oben vor Liste) ---
            try:
                has_active = bool(getattr(self, 'current_customer', None))
                recent_candidates = []
                if not hasattr(self, '_recent_customers'):
                    self._recent_customers = []  # safety
                if self._recent_customers:
                    # Nur Kunden die noch existieren und nicht doppelt (aktiver zuerst separat)
                    for rc in self._recent_customers:
                        if rc and rc in customers and rc != getattr(self, 'current_customer', None):
                            recent_candidates.append(rc)
                    recent_candidates = recent_candidates[:5]
                if has_active or recent_candidates:
                    # Oberfläche leicht angehoben (surface_elevated falls vorhanden)
                    try:
                        q_fg = get_color('surface_elevated')
                    except Exception:
                        q_fg = get_color('surface')
                    quick_frame = ctk.CTkFrame(
                        container,
                        fg_color=q_fg,
                        border_width=1,
                        border_color=get_color('surface_border'),
                        corner_radius=6
                    )
                    quick_frame.grid(row=2, column=0, sticky='ew', padx=spacing_md, pady=(0, spacing_sm))
                    quick_frame.grid_columnconfigure(0, weight=1)
                    # Überschrift / Label
                    qlbl = ctk.CTkLabel(
                        quick_frame,
                        text='Schnellauswahl',
                        text_color=get_color('text_secondary'),
                        font=ctk.CTkFont(*get_font('body_md'))
                    )
                    qlbl.pack(side='left', padx=(spacing_sm, spacing_sm))
                    def _quick_pick(name):  # noqa: D401
                        try:
                            # Auswahl in Listbox setzen (nach Filter ggf. neu rendern)
                            _on_filter()  # sicherstellen dass Liste aktuell
                            items = list(lb.get(0, 'end'))
                            target_idx = None
                            for i, it in enumerate(items):
                                base = it.replace(' (aktiv)', '')
                                if base == name:
                                    target_idx = i; break
                            if target_idx is not None:
                                lb.selection_clear(0, 'end')
                                lb.selection_set(target_idx)
                                lb.see(target_idx)
                                _update_info()
                        except Exception:
                            pass
                    # Aktiver Kunde Button
                    if has_active:
                        try:
                            active_btn_cfg = create_button(style='secondary', text=f"Aktiv: {self.current_customer}", command=lambda: _quick_pick(self.current_customer))
                            active_btn = ctk.CTkButton(quick_frame, **active_btn_cfg)
                            active_btn.configure(
                                fg_color=get_color('surface'), text_color=get_color('primary'),
                                border_color=get_color('primary'), border_width=1,
                                hover_color=get_color('surface_hover'), height=26,
                                font=ctk.CTkFont(*get_font('button_md'))
                            )
                            active_btn.pack(side='left', padx=(0, spacing_sm))
                        except Exception:
                            pass
                    # Recent Buttons
                    for rc in recent_candidates:
                        try:
                            rc_btn_cfg = create_button(style='secondary', text=rc, command=lambda n=rc: _quick_pick(n))
                            rc_btn = ctk.CTkButton(quick_frame, **rc_btn_cfg)
                            rc_btn.configure(
                                fg_color=get_color('surface'), text_color=get_color('primary'),
                                border_color=get_color('primary'), border_width=1,
                                hover_color=get_color('surface_hover'), height=26,
                                font=ctk.CTkFont(*get_font('button_md'))
                            )
                            rc_btn.pack(side='left', padx=(0, spacing_sm))
                        except Exception:
                            pass
                    # Divider unter Schnellzugriff für klare Abtrennung
                    try:
                        divider = ctk.CTkFrame(container, fg_color=get_color('surface_border'), height=1)
                        divider.grid(row=3, column=0, sticky='ew', padx=spacing_md, pady=(0, spacing_sm))
                    except Exception:
                        pass
                    # Verschiebe nachfolgende Zeilen (Listbox-Bereich) eine Reihe nach unten
                    # Ursprüngliche list_frame Row war 2 -> jetzt 4, Button-Bar 5
                    list_row_index = 4
                    container.grid_rowconfigure(list_row_index, weight=1)  # Update Grid-Config
                else:
                    list_row_index = 2
                    container.grid_rowconfigure(list_row_index, weight=1)  # Update Grid-Config
            except Exception:
                list_row_index = 2
                container.grid_rowconfigure(list_row_index, weight=1)  # Update Grid-Config

            list_frame = ctk.CTkFrame(
                container,
                fg_color=get_color('surface'),
                border_width=1,
                border_color=get_color('surface_border'),
                corner_radius=8
            )
            list_frame.grid(row=list_row_index, column=0, sticky='nsew', padx=spacing_md, pady=(0,spacing_md))
            list_frame.grid_rowconfigure(0, weight=1)
            list_frame.grid_columnconfigure(0, weight=1)
            
            # 📌 Deutlich verbesserte Listbox: Größere Schrift, mehr Höhe, bessere Farben
            try:
                listbox_font = ('Segoe UI', 22, 'normal')  # Viel größere, lesbarere Schrift
            except Exception:
                listbox_font = ('Segoe UI', 20, 'normal')  # Fallback immer noch groß
            
            lb = tk.Listbox(
                list_frame,
                activestyle='none',
                exportselection=False,
                selectmode='browse',
                font=listbox_font,
                relief='flat',
                borderwidth=0,
                highlightthickness=0,
                height=12  # Mehr Zeilen sichtbar
            )
            
            # 📌 Moderne, kontrastreiche Farben für bessere Sichtbarkeit
            try:
                lb.configure(
                    selectbackground=get_color('primary'),
                    selectforeground=get_color('white'),
                    bg=get_color('surface'),
                    fg=get_color('text_primary'),
                    # Zusätzliche Verbesserungen für Windows
                    activestyle='none',
                    selectborderwidth=0
                )
                # Zeilenhöhe durch Listbox-interne Optionen optimieren (falls verfügbar)
                try:
                    lb.configure(font=listbox_font)
                except Exception:
                    pass
            except Exception:
                pass
            
            # 📌 Hover-Effekte für bessere Benutzerinteraktion
            hover_index = None
            
            def _on_mouse_motion(event):
                nonlocal hover_index
                try:
                    # Ermittle Index unter Mauszeiger
                    y = event.y
                    index = lb.nearest(y)
                    if 0 <= index < lb.size():
                        if hover_index != index:
                            # Entferne alten Hover
                            if hover_index is not None and hover_index < lb.size():
                                try:
                                    # Reset auf normale Farben (falls nicht selektiert)
                                    if hover_index not in lb.curselection():
                                        lb.itemconfig(hover_index, 
                                                    background=get_color('surface'),
                                                    foreground=get_color('text_primary'))
                                except Exception:
                                    pass
                            
                            # Setze neuen Hover (falls nicht selektiert)
                            if index not in lb.curselection():
                                try:
                                    lb.itemconfig(index,
                                                background=get_color('surface_hover'),
                                                foreground=get_color('text_primary'))
                                except Exception:
                                    pass
                            hover_index = index
                except Exception:
                    pass
            
            def _on_mouse_leave(event):
                nonlocal hover_index
                try:
                    # Entferne Hover-Effekt beim Verlassen der Listbox
                    if hover_index is not None and hover_index < lb.size():
                        if hover_index not in lb.curselection():
                            lb.itemconfig(hover_index,
                                        background=get_color('surface'),
                                        foreground=get_color('text_primary'))
                    hover_index = None
                except Exception:
                    pass
            
            def _on_selection_change(event=None):
                nonlocal hover_index
                try:
                    # Reset aller Einträge auf Standard-Farben
                    for i in range(lb.size()):
                        if i not in lb.curselection():
                            lb.itemconfig(i,
                                        background=get_color('surface'),
                                        foreground=get_color('text_primary'))
                    
                    # Setze Hover wieder falls Maus noch über Element
                    if hover_index is not None and hover_index not in lb.curselection():
                        lb.itemconfig(hover_index,
                                    background=get_color('surface_hover'),
                                    foreground=get_color('text_primary'))
                    
                    _update_info()
                except Exception:
                    pass
            
            # Event-Bindungen für Hover-Effekte
            lb.bind('<Motion>', _on_mouse_motion)
            lb.bind('<Leave>', _on_mouse_leave)
            lb.bind('<<ListboxSelect>>', _on_selection_change)
            scrollbar = tk.Scrollbar(list_frame, orient='vertical', command=lb.yview)
            lb.configure(yscrollcommand=scrollbar.set)
            lb.grid(row=0,column=0, sticky='nsew')
            scrollbar.grid(row=0,column=1, sticky='ns')
            for c in customers:
                lb.insert('end', c)
            # Empty State Label (verdeckt Listbox wenn kein Treffer)
            try:
                empty_state_label = ctk.CTkLabel(
                    list_frame,
                    text='Keine Treffer',
                    text_color=get_color('text_secondary'),
                    font=ctk.CTkFont(*get_font('body_md'))
                )
            except Exception:
                empty_state_label = None
            _update_info()
            # Vorselektiere aktuellen Kunden
            if getattr(self,'current_customer', None) in customers:
                try:
                    idx = customers.index(self.current_customer)
                    lb.selection_set(idx)
                    lb.see(idx)
                except Exception as ex_customer_preselect:
                    try:
                        self._record_suppressed_error('customer.select.preselect', ex_customer_preselect)
                    except Exception:
                        pass
            btn_bar = ctk.CTkFrame(container, fg_color='transparent')
            btn_bar.grid(row=list_row_index+1,column=0, sticky='ew', padx=spacing_md, pady=(spacing_sm,spacing_md))
            btn_bar.grid_columnconfigure(1, weight=1)  # Mittlerer Bereich expandiert
            def _close():
                try: win.destroy()
                except Exception as ex_close_customer_select:
                    try:
                        self._record_suppressed_error('customer.select.close', ex_close_customer_select)
                    except Exception:
                        pass
            def _apply(event=None):  # noqa: D401
                try:
                    sel = lb.curselection()
                    if not sel:
                        self.show_toast('Bitte Kunde wählen', 'warning')
                        return
                    name = lb.get(sel[0])
                    if name.endswith(' (aktiv)'):
                        name = name[:-8]
                    # Recent pflegen
                    try:
                        if name in self._recent_customers:
                            self._recent_customers.remove(name)
                        self._recent_customers.insert(0, name)
                        if len(self._recent_customers) > 10:
                            self._recent_customers = self._recent_customers[:10]
                    except Exception as ex_recent_update:
                        try:
                            self._record_suppressed_error('customer.select.recent_update', ex_recent_update)
                        except Exception:
                            pass
                    self._set_current_customer(name)
                    _close()
                except Exception as ex_customer_apply:
                    try:
                        self._record_suppressed_error('customer.select.apply', ex_customer_apply)
                    except Exception:
                        pass
            ok_cfg = create_button(style='primary', text='Auswählen', command=_apply)
            cancel_cfg = create_button(style='secondary', text='Abbrechen', command=_close)
            btn_cancel = ctk.CTkButton(btn_bar, **cancel_cfg)
            btn_ok = ctk.CTkButton(btn_bar, **ok_cfg)
            # Neuer Utility-Button: Ordner öffnen
            def _open_folder():  # noqa: D401
                try:
                    sel = lb.curselection()
                    name = lb.get(sel[0]) if sel else getattr(self,'current_customer', None)
                    if not name:
                        self.show_toast('Kein Kunde ausgewählt', 'warning')
                        return
                    base = getattr(self, 'projects_base_path', None)
                    if not base:
                        self.show_toast('Basis-Pfad nicht gesetzt', 'error')
                        return
                    path = os.path.join(base, name)
                    if not os.path.isdir(path):
                        self.show_toast('Ordner nicht vorhanden', 'warning')
                        return
                    try:
                        import subprocess  # Lazy Import (Design-Richtlinie: keine unnötigen Top-Level Imports)
                        subprocess.Popen(['explorer', path])  # Windows Explorer
                        self.show_toast('Ordner geöffnet', 'info')
                    except Exception:
                        self.show_toast('Ordner konnte nicht geöffnet werden', 'error')
                except Exception:
                    pass
            open_folder_cfg = create_button(style='secondary', text='Ordner öffnen', command=_open_folder)
            btn_open_folder = ctk.CTkButton(btn_bar, **open_folder_cfg)
            # 📌 Verbesserte Button-Stile für einheitliche Höhen
            try:
                btn_open_folder.configure(
                    fg_color=get_color('surface'), 
                    text_color=get_color('primary'), 
                    border_color=get_color('primary'), 
                    border_width=1, 
                    hover_color=get_color('surface_hover'), 
                    height=38,  # Einheitliche Höhe
                    font=ctk.CTkFont(*get_font('button_md'))
                )
                btn_cancel.configure(height=38, font=ctk.CTkFont(*get_font('button_md')))
                btn_ok.configure(height=38, font=ctk.CTkFont(*get_font('button_md')))
            except Exception:
                pass
            # 📌 Modernere Button-Anordnung: Links Utility, Rechts Haupt-Aktionen
            btn_open_folder.grid(row=0, column=0, sticky='w')
            
            # Shortcut-Hinweis zentriert
            try:
                shortcut_lbl = ctk.CTkLabel(
                    btn_bar,
                    text='Enter=Auswählen | ESC=Schließen | F5=Aktualisieren',
                    text_color=get_color('text_secondary'),
                    font=ctk.CTkFont(*get_font('caption'))  # Kleiner für diskrete Anzeige
                )
                shortcut_lbl.grid(row=0, column=1, padx=spacing_md)
            except Exception:
                pass
            
            # Haupt-Aktionen rechts
            btn_cancel.grid(row=0, column=2, padx=(spacing_sm,0))
            btn_ok.grid(row=0, column=3, padx=(spacing_sm,0))
            lb.bind('<Double-1>', _apply)
            lb.bind('<Return>', _apply)
            # lb.bind('<<ListboxSelect>>', lambda e: _update_info())  # Bereits oben in _on_selection_change
            # F5 Reload
            def _reload(event=None):  # noqa: D401
                try:
                    # re-read file
                    new_list = []
                    if os.path.exists('customers.json'):
                        with open('customers.json','r',encoding='utf-8') as f:
                            data = json.load(f)
                        if isinstance(data, dict) and 'customers' in data:
                            new_list = [c.get('name') for c in data['customers'] if isinstance(c, dict) and c.get('name')]
                        elif isinstance(data, list):
                            new_list = [c.get('name') for c in data if isinstance(c, dict) and c.get('name')]
                        else:
                            new_list = [k for k in data.keys() if k not in ('favorites','last_updated','_meta','customers')]
                    if new_list:
                        nonlocal customers
                        customers = sorted(set(filter(None, new_list)))
                        _on_filter()
                        _update_info()
                        self.show_toast('Kundenliste aktualisiert', 'info')
                except Exception:
                    pass
            win.bind('<F5>', _reload)
            win.bind('<Escape>', lambda e: _close())
            # Fokus initial auf Suchfeld für direkte Eingabe
            try:
                search_entry.focus_set()
            except Exception:
                lb.focus_set()
            # Tastenkürzel / Accelerators
            try:
                win.bind('<Alt-s>', lambda e: (search_entry.focus_set(), search_entry.select_range(0,'end')))
                win.bind('<Alt-S>', lambda e: (search_entry.focus_set(), search_entry.select_range(0,'end')))
                win.bind('<Alt-n>', lambda e: _open_new())
                win.bind('<Alt-N>', lambda e: _open_new())
                win.bind('<Alt-r>', lambda e: _reload())
                win.bind('<Alt-R>', lambda e: _reload())
                win.bind('<Alt-l>', lambda e: _clear_filter())
                win.bind('<Alt-L>', lambda e: _clear_filter())
                win.bind('<Control-f>', lambda e: (search_entry.focus_set(), search_entry.select_range(0,'end')))
                win.bind('<Alt-o>', lambda e: _open_folder())
                win.bind('<Alt-O>', lambda e: _open_folder())
            except Exception:
                try:
                    self._record_suppressed_error('customer.list.bind_shortcuts', Exception('bind.shortcuts.failed'))
                except Exception:
                    pass
            # Center mit angepasster Größe
            def _center():
                try:
                    win.update_idletasks()
                    w, h = 900, 700  # Feste Größen für Konsistenz
                    pw = parent.winfo_width() if parent else win.winfo_screenwidth()
                    ph = parent.winfo_height() if parent else win.winfo_screenheight()
                    px = parent.winfo_rootx() if parent else 0
                    py = parent.winfo_rooty() if parent else 0
                    x = px + (pw - w)//2; y = py + (ph - h)//3
                    win.geometry(f"{w}x{h}+{x}+{y}")
                except Exception as ex_center:
                    try:
                        self._record_suppressed_error('customer.list.center', ex_center)
                    except Exception:
                        pass
            win.after(60,_center)
        except Exception as e:
            self._handle_error(e, context='customer.selection.dialog', user_message='Kundenauswahl fehlgeschlagen')
            try: self.show_toast('Kundenauswahl Fehler', 'error')
            except Exception: pass

    # -------- CUSTOMER BADGE & STATE HELPERS (nicht-destruktiv) --------
    def _refresh_customer_badge(self):  # noqa: D401
        """Aktualisiert sofort das Kunden-Badge (ohne Poll warten)."""
        try:
            if hasattr(self, '_customer_badge') and self._customer_badge:
                name = getattr(self, 'current_customer', None)
                txt = f"Kunde: {name}" if name else "Kunde: -"
                if self._customer_badge.cget('text') != txt:
                    self._customer_badge.configure(text=txt)
        except Exception:
            pass

    def _set_current_customer(self, name: str):  # noqa: D401
        """Setzt aktuellen Kunden + UI Feedback.

        Nicht invasiv – ersetzt keine bestehenden direkten Zuweisungen,
        kann aber künftig zentral verwendet werden.
        """
        try:
            self.current_customer = name
            self._refresh_customer_badge()
            try:
                self.show_toast(f'Aktiver Kunde: {name}', 'success')
            except Exception:
                pass
            try:
                self._refresh_project_navigation()
            except Exception:
                pass
        except Exception:
            pass
    
    def _validate_all_projects(self):
        """📂 Alle Projektstrukturen validieren und reparieren"""
        try:
            projects = self._get_current_projects()
            repaired_count = 0
            
            for project in projects:
                if not self.validate_project_structure(project['path']):
                    repaired_count += 1
            
            if repaired_count > 0:
                self.show_toast(f"{repaired_count} Projektstrukturen repariert", "success")
            else:
                self.show_toast("Alle Projektstrukturen sind vollständig", "info")
            
        except Exception as e:
            self._handle_error(
                e,
                context="projects.structure.validate",
                user_message=self._t("Projektstruktur ungültig") if hasattr(self, '_t') else "Struktur Validierung Fehler"
            )
            self.show_toast("Fehler bei der Struktur-Validierung", "error")
    
    def _refresh_project_navigation(self):
        """📂 Projekt-Navigation aktualisieren (vollständiger Rebuild der Welcome-Ansicht)."""
        try:
            if hasattr(self, '_show_enhanced_welcome_output'):
                try:
                    self._show_enhanced_welcome_output()
                except Exception:
                    pass
            # Statuslabel aktualisieren falls vorhanden
            if hasattr(self, 'output_status_label'):
                try:
                    self.output_status_label.configure(text=self._t("● Ready"))  # ✅ Konsistenter Status mit Punkt
                except Exception:
                    pass
            self.logger.info("📂 Projekt-Navigation aktualisiert")
        except Exception as e:
            self._handle_error(
                e,
                context="projects.navigation.update",
                user_message=self._t("Navigation konnte nicht aktualisiert werden") if hasattr(self, '_t') else "Navigation Update Fehler",
                toast=False
            )

    def _show_project_navigation_dashboard(self):  # noqa: D401
        """📂 Projekte-Ansicht anzeigen (Menüband Aktion) - Wrapper mit Fallback."""
        try:
            # Versuche bevorzugt die erweiterte Welcome-Ansicht zu nutzen
            if hasattr(self, '_show_enhanced_welcome_output'):
                try:
                    self._show_enhanced_welcome_output()
                except Exception:
                    pass
            else:
                # Fallback: Refresh Navigation
                try:
                    self._refresh_project_navigation()
                except Exception:
                    pass
            # Optional: Toast
            try:
                self.show_toast(self._t('Projekte geladen') if hasattr(self, '_t') else 'Projekte geladen', 'info')
            except Exception:
                pass
        except Exception as e:
            self._handle_error(e, context='projects.dashboard.show', toast=False)
    
    # 📂 AUTOMATISCHE MIGRATION - Bestehende Projekte migrieren
    
    def _migrate_existing_projects_on_startup(self):
        """📂 Migriert bestehende Projekte bei Anwendungsstart"""
        try:
            # Migration nur beim ersten Start nach Update durchführen
            migration_marker = "migration_v1_completed.marker"
            
            if os.path.exists(migration_marker):
                return  # Migration bereits durchgeführt
            
            self.logger.info("📂 Starte automatische Projekt-Migration...")
            
            # Bestehende Dateien und Ordner scannen (später deduplizieren)
            legacy_files = self._scan_for_legacy_files()
            try:  # ✅ Dedup nach Pfad
                if legacy_files:
                    seen_paths = set()
                    unique = []
                    for lf in legacy_files:
                        p = lf.get('path')
                        if p and p not in seen_paths:
                            seen_paths.add(p)
                            unique.append(lf)
                    legacy_files = unique
            except Exception:
                pass
            
            if legacy_files:
                migrated_count = self._migrate_legacy_files(legacy_files)
                
                if migrated_count > 0:
                    self.logger.info(f"✅ Migration abgeschlossen: {migrated_count} Dateien migriert")
                    self.show_toast(f"Migration abgeschlossen: {migrated_count} Dateien organisiert", "success")
            
            # Migration als abgeschlossen markieren
            with open(migration_marker, "w", encoding="utf-8") as f:
                f.write(f"Migration completed at: {time.strftime('%Y-%m-%d %H:%M:%S')}")  # ✅ Zeitstempel
            
        except Exception as e:
            self._handle_error(
                e,
                context="migration.auto",
                user_message=self._t("Automatische Migration fehlgeschlagen") if hasattr(self, '_t') else "Auto-Migration Fehler"
            )
    
    def _scan_for_legacy_files(self):
        """📂 Scannt nach bestehenden Dateien die migriert werden sollen"""
        try:
            legacy_files = []  # Sammlung
            
            # Potentielle Legacy-Ordner und Dateien
            legacy_locations = [
                "uploads",
                "source_files", 
                "translations",
                "output",
                "analysis",
                "reports"
            ]
            
            for location in legacy_locations:
                if os.path.exists(location) and os.path.isdir(location):
                    for root, dirs, files in os.walk(location):
                        for file in files:
                            if file.lower().endswith(('.pdf', '.docx', '.txt', '.doc', '.rtf', '.odt')):
                                fp = os.path.join(root, file)
                                legacy_files.append({
                                    'path': fp,
                                    'location': location,
                                    'filename': file,
                                    'type': self._classify_legacy_file(fp)
                                })
            
            # Auch lose Dateien im Hauptverzeichnis
            for file in os.listdir("."):
                if file.lower().endswith(('.pdf', '.docx', '.txt', '.doc', '.rtf', '.odt')):
                    legacy_files.append({
                        'path': file,
                        'location': 'root',
                        'filename': file,
                        'type': self._classify_legacy_file(file)
                    })
            
            return legacy_files
            
        except Exception as e:
            self._handle_error(
                e,
                context="migration.legacy.scan",
                user_message=self._t("Legacy-Dateien konnten nicht gescannt werden") if hasattr(self, '_t') else "Legacy Scan Fehler",
                toast=False
            )
            return []
    
    def _classify_legacy_file(self, file_path):
        """📂 Klassifiziert Legacy-Dateien für Migration"""
        filename = os.path.basename(file_path).lower()
        
        # Übersetzungs-Keywords
        translation_keywords = ['translation', 'trans', 'übersetzung', 'target', 'tgt', 'output', 'result']
        if any(keyword in filename for keyword in translation_keywords):
            return 'translation'
        
        # Report/Analysis-Keywords  
        analysis_keywords = ['report', 'analysis', 'quality', 'bericht', 'analyse', 'result']
        if any(keyword in filename for keyword in analysis_keywords):
            return 'analysis'
        
        # Standard: Ausgangstext
        return 'source'
    
    def _migrate_legacy_files(self, legacy_files):
        """📂 Migriert Legacy-Dateien in neue Projektstruktur"""
        try:
            import shutil
            import datetime
            import os
            
            migrated_count = 0
            migration_customer = "Legacy_Migration"
            migration_date = datetime.datetime.now().strftime("%Y-%m-%d")
            
            # Migration-Projektstruktur erstellen (bestehende Struktur)
            migration_path = self.create_project_structure(migration_customer, migration_date)
            if not migration_path:
                return 0
            
            project_paths = self.get_project_paths(migration_customer, migration_date)
            
            for file_info in legacy_files:
                try:
                    source_path = file_info['path']
                    filename = file_info['filename']
                    
                    # Alle Dateien gehen in 01_Ausgangstext (bestehende Struktur)
                    target_folder = project_paths['ausgangstext']
                    
                    target_path = os.path.join(target_folder, filename)
                    
                    # Datei kopieren (nicht verschieben für Sicherheit)
                    shutil.copy2(source_path, target_path)
                    migrated_count += 1
                    
                    self.logger.info(f"📂 Migriert: {filename} → 01_Ausgangstext")
                    
                except Exception as e:
                    # Einzeldatei-Migrationsfehler ohne Toast (Spam-Prävention)
                    self._handle_error(
                        e,
                        context="migration.legacy.file",
                        user_message=None,
                        toast=False
                    )
                    # Weiter mit nächster Datei
            
            return migrated_count
            
        except Exception as e:
            self._handle_error(
                e,
                context="migration.legacy.apply",
                user_message=self._t("Legacy-Migration fehlgeschlagen") if hasattr(self, '_t') else "Legacy Migration Fehler"
            )
            return 0
    
    def manual_migration_dialog(self):
        """📂 Manueller Migrations-Dialog für Benutzer"""
        try:
            # Nicht-blockierender Dialog statt messagebox.askyesno
            self._show_non_blocking_confirm(
                title=self._t("Projekt-Migration") if hasattr(self, '_t') else "Projekt-Migration",
                message=(
                    self._t("Sollen bestehende Dateien in die neue Projektstruktur migriert werden?") if hasattr(self, '_t') else "Sollen bestehende Dateien in die neue Projektstruktur migriert werden?"
                ) + "\n\n" + (
                    self._t("Dies organisiert alle vorhandenen Dokumente in der standardisierten Ordnerstruktur.") if hasattr(self, '_t') else "Dies organisiert alle vorhandenen Dokumente in der standardisierten Ordnerstruktur."
                ) + "\n" + (
                    self._t("Original-Dateien bleiben unverändert.") if hasattr(self, '_t') else "Original-Dateien bleiben unverändert."
                ),
                confirm_text=self._t("Migrieren") if hasattr(self, '_t') else "Migrieren",
                cancel_text=self._t("Abbrechen") if hasattr(self, '_t') else "Abbrechen",
                on_confirm=lambda: self._execute_manual_migration(),
            )
            
        except Exception as e:
            self._handle_error(
                e,
                context="migration.manual.dialog",
                user_message=self._t("Migrations-Dialog fehlgeschlagen") if hasattr(self, '_t') else "Migrations Dialog Fehler"
            )
            try:
                self.toast_system.show_error(self._t("Migration fehlgeschlagen"))
            except Exception:
                pass

    def _execute_manual_migration(self):
        """Führt die eigentliche Migration nach Bestätigung asynchron aus."""
        try:
            legacy_files = self._scan_for_legacy_files()
            if legacy_files:
                migrated_count = self._migrate_legacy_files(legacy_files)
                msg = (
                    self._t("Migration erfolgreich: {count} Dateien organisiert.").format(count=migrated_count)
                    if hasattr(self, '_t') else f"Migration erfolgreich: {migrated_count} Dateien organisiert."
                )
                self.show_toast(msg, "success")  # ✅ Einheitliche Toast-Wrapper-Nutzung
            else:
                msg = self._t("Keine Dateien für Migration gefunden.") if hasattr(self, '_t') else "Keine Dateien für Migration gefunden."
                self.show_toast(msg, "info")
        except Exception as e:
            self._handle_error(
                e,
                context="migration.manual.execute",
                user_message=self._t("Migration fehlgeschlagen") if hasattr(self, '_t') else "Migration fehlgeschlagen"
            )
            try:
                self.show_toast(self._t("Migration fehlgeschlagen"), "error")
            except Exception:
                pass

    def _show_non_blocking_confirm(self, title: str, message: str, confirm_text: str, cancel_text: str, on_confirm, width: int = 520):
        """Generischer nicht-blockierender Bestätigungsdialog (Design-System konform)."""
        try:
            dialog = ctk.CTkToplevel(self.root)
            dialog.title(title)
            dialog.transient(self.root)
            dialog.grab_set()  # Modal Verhalten, ohne mainloop zu blockieren
            try:
                dialog.attributes('-topmost', True)
            except Exception:
                pass

            # Layout
            dialog.geometry(f"{width}x220")
            frame = ctk.CTkFrame(dialog, fg_color=self.get_color('surface'), corner_radius=8, border_width=1, border_color=self.get_color('surface_border'))
            frame.pack(fill='both', expand=True, padx=12, pady=12)

            title_lbl = ctk.CTkLabel(frame, text=title, font=ctk.CTkFont(*self.get_typography('subheading')), text_color=self.get_color('gray_700'))
            title_lbl.pack(anchor='w', padx=16, pady=(16, 4))

            msg_lbl = ctk.CTkLabel(frame, text=message, font=ctk.CTkFont(*self.get_typography('body')), text_color=self.get_color('gray_600'), justify='left', wraplength=width-64)
            msg_lbl.pack(fill='x', padx=16, pady=(0, 20))

            btn_bar = ctk.CTkFrame(frame, fg_color='transparent')
            btn_bar.pack(fill='x', padx=16, pady=(0, 12))
            btn_bar.pack_propagate(False)

            def close_dialog():
                try:
                    dialog.destroy()
                except Exception:
                    pass

            # ✅ UX: Abbrechen links, Primäraktion rechts
            cancel_btn = self._create_button(
                btn_bar,
                text=cancel_text,
                command=close_dialog,
                kind="outline-primary",
                height=36
            )
            cancel_btn.pack(side='left')

            confirm_btn = self._create_button(
                btn_bar,
                text=confirm_text,
                command=lambda: (close_dialog(), on_confirm()),
                kind="primary",
                height=36
            )
            confirm_btn.pack(side='right')

            # Keyboard Shortcuts
            dialog.bind('<Return>', lambda e: (close_dialog(), on_confirm()))
            dialog.bind('<Escape>', lambda e: close_dialog())

            # Zentrieren (bestehenden Helper wiederverwenden wenn vorhanden)
            try:
                self._center_window(dialog)
            except Exception:
                pass
        except Exception as e:
            self._handle_error(e, context="ui.confirm.dialog", user_message=None)
    
