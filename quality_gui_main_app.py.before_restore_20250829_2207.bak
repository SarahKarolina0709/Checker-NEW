                for code, msg in samples.items():
                    row = ctk.CTkFrame(block, fg_color=self.get_color('gray_50'), corner_radius=4)
                    row.pack(fill="x", padx=16, pady=3)
                    ctk.CTkLabel(row, text=f"{code}: {msg}", font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_600'), justify="left", anchor="w").pack(fill="x", padx=6, pady=4)
        except Exception:
            pass

    def _ui_add_phase3_structural_block(self, parent, phase3_report: dict):
        """UI Helper: Fügt Phase 3 (Semantik / Risiko / Lesbarkeit) Block hinzu (additiv)."""
        try:
            block = ctk.CTkFrame(parent, fg_color=self.get_color('white'), corner_radius=8, border_width=1, border_color=self.get_color('surface_border'))
            block.pack(fill="x", pady=12)
            header = ctk.CTkLabel(block, text=self._t("Semantik & Risiko (Phase 3)"), font=ctk.CTkFont(*self.get_typography('section_label')), text_color=self.get_color('gray_700'), anchor="w")
            header.pack(fill="x", padx=16, pady=(14,4))
            if phase3_report.get('skipped'):
                ctk.CTkLabel(block, text=self._t("Deaktiviert oder übersprungen"), font=ctk.CTkFont(*self.get_typography('body')), text_color=self.get_color('gray_500')).pack(padx=16, pady=(0,16), anchor="w")
                return
            sev = phase3_report.get('by_severity', {})
            score = phase3_report.get('advanced2_score', 1.0)
            meta_frame = ctk.CTkFrame(block, fg_color=self.get_color('transparent'))
            meta_frame.pack(fill="x", padx=12, pady=(4,10))
            meta_frame.grid_columnconfigure((0,1,2,3), weight=1)
            def _kv(r,c,label,val):
                cell = ctk.CTkFrame(meta_frame, fg_color=self.get_color('gray_50'), corner_radius=6, border_width=1, border_color=self.get_color('surface_border'))
                cell.grid(row=r,column=c,sticky="nsew", padx=6)
                ctk.CTkLabel(cell, text=label, font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_500'), anchor="w").pack(fill="x", padx=8, pady=(6,0))
                ctk.CTkLabel(cell, text=val, font=ctk.CTkFont(*self.get_typography('heading_sm')), text_color=self.get_color('primary'), anchor="w").pack(fill="x", padx=8, pady=(2,6))
            _kv(0,0,self._t("Score"), f"{round(score*100,1)}%")
            _kv(0,1,self._t("Issues"), str(phase3_report.get('issue_total',0)))
            _kv(0,2,self._t("Critical"), str(sev.get('critical',0)))
            _kv(0,3,self._t("Major/Minor"), f"{sev.get('major',0)}/{sev.get('minor',0)}")
            samples = phase3_report.get('samples', {})
            if samples:
                sep = ctk.CTkFrame(block, fg_color=self.get_color('surface_border'), height=1)
                sep.pack(fill="x", padx=12, pady=(4,6))
                ctk.CTkLabel(block, text=self._t("Beispiele"), font=ctk.CTkFont(*self.get_typography('section_label')), text_color=self.get_color('gray_700'), anchor="w").pack(fill="x", padx=16)
                for code, msg in samples.items():
                    row = ctk.CTkFrame(block, fg_color=self.get_color('gray_50'), corner_radius=4)
                    row.pack(fill="x", padx=16, pady=3)
                    ctk.CTkLabel(row, text=f"{code}: {msg}", font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_600'), justify="left", anchor="w").pack(fill="x", padx=6, pady=4)
        except Exception:
            pass

    def _ui_add_phase6_suggestions_block(self, parent, phase6_report: dict):
        """UI Helper: Zeigt Vorschlagsblock (Phase 6) – additiv, rein lesend."""
        try:
            block = ctk.CTkFrame(parent, fg_color=self.get_color('white'), corner_radius=8, border_width=1, border_color=self.get_color('surface_border'))
            block.pack(fill="x", pady=12)
            header = ctk.CTkLabel(block, text=self._t("Verbesserungsvorschläge (Phase 6)"), font=ctk.CTkFont(*self.get_typography('section_label')), text_color=self.get_color('gray_700'), anchor="w")
            header.pack(fill="x", padx=16, pady=(14,4))
            # Action Row (Refresh / Export)
            action_row = ctk.CTkFrame(block, fg_color=self.get_color('transparent'))
            action_row.pack(fill="x", padx=14, pady=(0,6))
            def _do_refresh():
                try:
                    if not hasattr(self, '_phase6_runtime_context'):
                        self.show_toast(self._t("Keine Laufzeitdaten für Phase 6"), "warning", duration=2500) if hasattr(self,'show_toast') else None
                        return
                    ctx = self._phase6_runtime_context
                    from quality_gui_phase6_suggestions import run_phase6_suggestions  # type: ignore
                    _pairs = ctx.get('pairs') or []
                    # Rekonstruiere pseudo Issues (minimale Felder) → einfache Namespace Klasse
                    class _TmpIssue:
                        def __init__(self, d):
                            self.code=d.get('code'); self.severity=d.get('severity'); self.category=d.get('category'); self.message=d.get('message'); self.source_text=d.get('source_text'); self.target_text=d.get('target_text')
                    _issues = [_TmpIssue(d) for d in (ctx.get('issues') or [])]
                    cfg = ctx.get('cfg') or {}
                    _sugs = run_phase6_suggestions(_pairs, _issues, max_suggestions=cfg.get('max',40), enable_llm=cfg.get('llm', False))
                    self._phase6_suggestions_last = [s.__dict__ for s in _sugs]
                    self.show_toast(self._t("Vorschläge aktualisiert"), "success", duration=2200) if hasattr(self,'show_toast') else None
                    # UI neu aufbauen: einfache Strategie – gesamten parent neu rendern (nur Block)
                    try:
                        for w in block.winfo_children():
                            w.destroy()
                    except Exception:
                        pass
                    # Rekursiv denselben Block mit neuem Report (samples regenerieren)
                    _by_cat = {}
                    for s in _sugs: _by_cat[s['category']] = _by_cat.get(s['category'],0)+1 if isinstance(s, dict) else _by_cat.get(s.category,0)+1
                    new_report = {
                        'suggestion_total': len(_sugs),
                        'by_category': _by_cat,
                        'samples': [
                            {'message': (s['message'] if isinstance(s, dict) else s.message), 'category': (s['category'] if isinstance(s, dict) else s.category), 'priority': (s['priority'] if isinstance(s, dict) else s.priority)}
                            for s in (self._phase6_suggestions_last[:6])
                        ],
                        'llm_enabled': cfg.get('llm', False)
                    }
                    self._ui_add_phase6_suggestions_block(parent, new_report)
                except Exception as _r_err:
                    self.show_toast(self._t("Refresh Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
            def _do_export():
                try:
                    if not hasattr(self, '_phase6_suggestions_last') or not self._phase6_suggestions_last:
                        self.show_toast(self._t("Keine Vorschläge"), "warning", duration=2500) if hasattr(self,'show_toast') else None
                        return
                    import json, datetime, os
                    base_dir = getattr(self, 'projects_base_path', '.')
                    out_dir = os.path.join(base_dir, '_analysis_exports')
                    os.makedirs(out_dir, exist_ok=True)
                    ts = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
                    path = os.path.join(out_dir, f'phase6_suggestions_{ts}.json')
                    with open(path, 'w', encoding='utf-8') as f:
                        json.dump(self._phase6_suggestions_last, f, ensure_ascii=False, indent=2)
                    self.show_toast(self._t("Export erstellt"), "success", duration=2500) if hasattr(self,'show_toast') else None
                except Exception:
                    self.show_toast(self._t("Export Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
            try:
                refresh_btn = ctk.CTkButton(action_row, text=self._t("Vorschläge aktualisieren"), command=_do_refresh, fg_color=self.get_color('primary'), hover_color=self.get_color('primary_hover'), text_color=self.get_color('white'))
                refresh_btn.pack(side='left', padx=(0,8))
                export_btn = ctk.CTkButton(action_row, text=self._t("Export JSON"), command=_do_export, fg_color=self.get_color('secondary'), hover_color=self.get_color('secondary_hover'), text_color=self.get_color('white'))
                export_btn.pack(side='left')
                # CSV Export
                def _export_csv():
                    try:
                        if not getattr(self, '_phase6_suggestions_last', None):
                            self.show_toast(self._t("Keine Vorschläge"), "warning", duration=2500) if hasattr(self,'show_toast') else None
                            return
                        import csv, os, datetime
                        base_dir = getattr(self, 'projects_base_path', '.')
                        out_dir = os.path.join(base_dir, '_analysis_exports')
                        os.makedirs(out_dir, exist_ok=True)
                        ts = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
                        path = os.path.join(out_dir, f'phase6_suggestions_{ts}.csv')
                        fields = ['id','category','message','rationale','priority','confidence']
                        with open(path, 'w', encoding='utf-8', newline='') as f:
                            w = csv.writer(f, delimiter=';')
                            w.writerow(fields)
                            for s in self._phase6_suggestions_last:
                                w.writerow([s.get(k,'') if isinstance(s, dict) else getattr(s,k,'') for k in fields])
                        self.show_toast(self._t("CSV Export erstellt"), "success", duration=2500) if hasattr(self,'show_toast') else None
                    except Exception:
                        self.show_toast(self._t("CSV Export Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
                export_csv_btn = ctk.CTkButton(action_row, text=self._t("Export CSV"), command=_export_csv, fg_color=self.get_color('secondary'), hover_color=self.get_color('secondary_hover'), text_color=self.get_color('white'))
                export_csv_btn.pack(side='left', padx=(8,0))
                # Batch Quick Fix Button
                trim_var = ctk.BooleanVar(value=False)
                try:
                    trim_chk = ctk.CTkCheckBox(action_row, text=self._t("Trim Leerraum"), variable=trim_var)
                    trim_chk.pack(side='left', padx=(8,0))
                except Exception:
                    pass
                def _batch_quick_fix():
                    try:
                        if not hasattr(self, '_phase6_runtime_context'):
                            self.show_toast(self._t("Keine Laufzeitdaten"), "warning", duration=2500) if hasattr(self,'show_toast') else None
                            return
                        ctx = self._phase6_runtime_context
                        pairs = ctx.get('pairs') or []
                        file_records = ctx.get('file_records') or []
                        # Konfig Flags laden (optional)
                        try:
                            from config_manager import ConfigManager as _P6Cfg  # type: ignore
                            _p6cfg = _P6Cfg()
                            enable_multi_space = bool(_p6cfg.get('analysis.phase6.quickfix.multi_space', True))
                            enable_zero_width = bool(_p6cfg.get('analysis.phase6.quickfix.zero_width', True))
                            enable_punct_norm = bool(_p6cfg.get('analysis.phase6.quickfix.punctuation', True))
                            enable_blank_collapse = bool(_p6cfg.get('analysis.phase6.quickfix.blank_collapse', True))
                            undo_limit = int(_p6cfg.get('analysis.phase6.quickfix.undo_limit', 10) or 10)
                        except Exception:
                            enable_multi_space = enable_zero_width = enable_punct_norm = enable_blank_collapse = True
                            undo_limit = 10
                        # Undo Stack push
                        try:
                            if not hasattr(self, '_phase6_batch_snapshots'):
                                self._phase6_batch_snapshots = []  # type: ignore
                            self._phase6_batch_snapshots.append([ (p[0], p[1]) for p in pairs ])  # type: ignore
                            if len(self._phase6_batch_snapshots) > undo_limit:
                                self._phase6_batch_snapshots.pop(0)
                        except Exception:
                            pass
                        modified = []
                        import re, json, os, datetime, difflib
                        zero_width_re = re.compile('[\u200B\u200C\u200D\uFEFF]') if enable_zero_width else None
                        duplicate_punct_re = re.compile(r'([!?\.]){2,}') if enable_punct_norm else None
                        multi_blank_lines_re = re.compile(r'\n{3,}') if enable_blank_collapse else None
                        for idx,(src,tgt) in enumerate(pairs):
                            if tgt is None:
                                continue
                            orig = tgt
                            new_tgt = tgt
                            if enable_multi_space:
                                new_tgt = re.sub(r' {2,}',' ', new_tgt)
                            if zero_width_re:
                                new_tgt = zero_width_re.sub('', new_tgt)
                            if enable_punct_norm:
                                try:
                                    new_tgt = re.sub(r'\s+([,.;:!?])', r'\1', new_tgt)
                                    new_tgt = re.sub(r'([,.;:!?])(?![\s\n])', r'\1 ', new_tgt)
                                    if duplicate_punct_re:
                                        new_tgt = duplicate_punct_re.sub(lambda m: m.group(1), new_tgt)
                                except Exception:
                                    pass
                            if enable_blank_collapse and multi_blank_lines_re:
                                new_tgt = multi_blank_lines_re.sub('\n\n', new_tgt)
                            if trim_var.get():
                                try:
                                    new_tgt = new_tgt.strip()
                                except Exception:
                                    pass
                            if new_tgt != orig:
                                modified.append(idx)
                                pairs[idx] = (src, new_tgt)
                        if not modified:
                            self.show_toast(self._t("Keine Änderungen notwendig"), "info", duration=2200) if hasattr(self,'show_toast') else None
                            return
                        # Persist Runtime
                        ctx['pairs'] = pairs
                        self._phase6_runtime_context = ctx
                        # Export Gesamtänderungen
                        try:
                            base_dir = getattr(self,'projects_base_path','.')
                            out_dir = os.path.join(base_dir,'_analysis_exports')
                            os.makedirs(out_dir, exist_ok=True)
                            ts = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
                            batch_path = os.path.join(out_dir, f'phase6_pairs_after_batch_{ts}.json')
                            with open(batch_path,'w',encoding='utf-8') as f:
                                json.dump({'pairs': pairs, 'modified_indices': modified, 'trim_applied': bool(trim_var.get()), 'rules': {
                                    'multi_space': enable_multi_space,
                                    'zero_width': enable_zero_width,
                                    'punctuation': enable_punct_norm,
                                    'blank_collapse': enable_blank_collapse
                                }}, f, ensure_ascii=False, indent=2)
                            # Einzel-Diffs
                            for mi in modified:
                                try:
                                    fr = file_records[mi] if mi < len(file_records) else None
                                    trg_path = fr.get('translation') if isinstance(fr, dict) else None
                                    if trg_path and os.path.isfile(trg_path):
                                        try:
                                            with open(trg_path,'r',encoding='utf-8', errors='ignore') as trf:
                                                old_content = trf.read()
                                        except Exception:
                                            old_content = ''
                                        new_content = pairs[mi][1] or ''
                                        # Diff erstellen
                                        diff_lines = list(difflib.unified_diff(old_content.splitlines(), new_content.splitlines(), fromfile='old', tofile='new', lineterm=''))
                                        diff_path = os.path.join(out_dir, f'diff_{mi}_{ts}.patch')
                                        with open(diff_path,'w',encoding='utf-8') as df:
                                            df.write('\n'.join(diff_lines))
                                        # Datei überschreiben
                                        try:
                                            with open(trg_path,'w',encoding='utf-8', errors='ignore') as trw:
                                                trw.write(new_content)
                                        except Exception:
                                            pass
                                except Exception:
                                    continue
                        except Exception:
                            pass
                        self.show_toast(self._t("Quick Fixes angewendet")+f" ({len(modified)})", "success", duration=2800) if hasattr(self,'show_toast') else None
                    except Exception:
                        self.show_toast(self._t("Batch Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
                batch_btn = ctk.CTkButton(action_row, text=self._t("Batch Quick Fix"), command=_batch_quick_fix, fg_color=self.get_color('warning'), hover_color=self.get_color('warning_hover') if hasattr(self,'get_color') else self.get_color('warning'), text_color=self.get_color('white'))
                batch_btn.pack(side='left', padx=(8,0))
                # Undo Button
                def _undo_batch():
                    try:
                        stack = getattr(self,'_phase6_batch_snapshots', None)
                        if not stack or not isinstance(stack, list) or len(stack)==0:
                            self.show_toast(self._t("Kein Undo verfügbar"), "warning", duration=2200) if hasattr(self,'show_toast') else None
                            return
                        prev = stack.pop()  # letzte Version
                        if not hasattr(self,'_phase6_runtime_context'):
                            return
                        self._phase6_runtime_context['pairs'] = [ (p[0], p[1]) for p in prev ]
                        # Rückschreiben in Dateien (Undo)
                        try:
                            ctx = self._phase6_runtime_context
                            file_records = ctx.get('file_records') or []
                            base_dir = getattr(self,'projects_base_path','.')
                            out_dir = os.path.join(base_dir,'_analysis_exports')
                            os.makedirs(out_dir, exist_ok=True)
                            import json, os, datetime
                            ts = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
                            undo_path = os.path.join(out_dir, f'phase6_pairs_after_undo_{ts}.json')
                            with open(undo_path,'w',encoding='utf-8') as f:
                                json.dump({'pairs': self._phase6_runtime_context['pairs'], 'undo': True}, f, ensure_ascii=False, indent=2)
                            for idx,(src,tgt) in enumerate(self._phase6_runtime_context['pairs']):
                                try:
                                    fr = file_records[idx] if idx < len(file_records) else None
                                    trg_path = fr.get('translation') if isinstance(fr, dict) else None
                                    if trg_path and os.path.isfile(trg_path):
                                        with open(trg_path,'w',encoding='utf-8', errors='ignore') as trw:
                                            trw.write(tgt or '')
                                except Exception:
                                    continue
                        except Exception:
                            pass
                        self.show_toast(self._t("Batch zurückgesetzt"), "success", duration=2500) if hasattr(self,'show_toast') else None
                    except Exception:
                        self.show_toast(self._t("Undo Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
                undo_btn = ctk.CTkButton(action_row, text=self._t("Undo"), command=_undo_batch, fg_color=self.get_color('gray_600'), hover_color=self.get_color('gray_700'), text_color=self.get_color('white'))
                undo_btn.pack(side='left', padx=(8,0))
            except Exception:
                pass
            if phase6_report.get('skipped'):
                ctk.CTkLabel(block, text=self._t("Deaktiviert oder übersprungen"), font=ctk.CTkFont(*self.get_typography('body')), text_color=self.get_color('gray_500')).pack(padx=16, pady=(0,16), anchor="w")
                return
            total = phase6_report.get('suggestion_total', 0)
            cat = phase6_report.get('by_category', {}) or {}
            meta_frame = ctk.CTkFrame(block, fg_color=self.get_color('transparent'))
            meta_frame.pack(fill="x", padx=12, pady=(4,10))
            meta_frame.grid_columnconfigure((0,1,2,3), weight=1)
            def _kv(r,c,label,val):
                cell = ctk.CTkFrame(meta_frame, fg_color=self.get_color('gray_50'), corner_radius=6, border_width=1, border_color=self.get_color('surface_border'))
                cell.grid(row=r,column=c,sticky="nsew", padx=6)
                ctk.CTkLabel(cell, text=label, font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_500'), anchor="w").pack(fill="x", padx=8, pady=(6,0))
                ctk.CTkLabel(cell, text=val, font=ctk.CTkFont(*self.get_typography('heading_sm')), text_color=self.get_color('primary'), anchor="w").pack(fill="x", padx=8, pady=(2,6))
            _kv(0,0,self._t("Vorschläge"), str(total))
            _kv(0,1,self._t("Kategorien"), str(len(cat)))
            _kv(0,2,self._t("LLM aktiv"), self._t("Ja") if phase6_report.get('llm_enabled') else self._t("Nein"))
            _kv(0,3,self._t("Top-Kategorie"), max(cat, key=cat.get) if cat else "-")
            samples = phase6_report.get('samples', [])
            if samples:
                sep = ctk.CTkFrame(block, fg_color=self.get_color('surface_border'), height=1)
                sep.pack(fill="x", padx=12, pady=(4,6))
                ctk.CTkLabel(block, text=self._t("Beispiele"), font=ctk.CTkFont(*self.get_typography('label_bold')), text_color=self.get_color('gray_700'), anchor="w").pack(fill="x", padx=16)
                for s in samples:
                    row = ctk.CTkFrame(block, fg_color=self.get_color('gray_50'), corner_radius=6, border_width=1, border_color=self.get_color('surface_border'))
                    row.pack(fill="x", padx=16, pady=6)
                    title = f"{s.get('category','')}: {s.get('message','')}"
                    ctk.CTkLabel(row, text=title, anchor="w", font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_700')).pack(fill="x", padx=8, pady=(6,2))
                    old_text = s.get('target_before') or s.get('target_snippet') or ""
                    new_text = s.get('target_after')  or s.get('proposal_text')  or old_text
                    self._render_inline_diff(row, old_text, new_text)
                    btn_bar = ctk.CTkFrame(row, fg_color="transparent")
                    btn_bar.pack(fill="x", padx=8, pady=(2,8))
                    def _accept_one(old=old_text, new=new_text, sample=s):
                        try:
                            ctx = getattr(self, '_phase6_runtime_context', {}) or {}
                            pairs = ctx.get('pairs') or []
                            idx = sample.get('pair_index') if isinstance(sample, dict) else None
                            if idx is not None and 0 <= idx < len(pairs):
                                src, _ = pairs[idx]
                                pairs[idx] = (src, new)
                                ctx['pairs'] = pairs
                                self._phase6_runtime_context = ctx
                                fr = (ctx.get('file_records') or [None])[idx]
                                trg_path = fr.get('translation') if isinstance(fr, dict) else None
                                if trg_path:
                                    try:
                                        with open(trg_path, 'w', encoding='utf-8', errors='ignore') as f:
                                            f.write(new or '')
                                    except Exception:
                                        pass
                                self.show_toast(self._t("Änderung übernommen"), "success", 2200) if hasattr(self,'show_toast') else None
                            else:
                                self.show_toast(self._t("Kein passendes Segment gefunden"), "warning", 2200) if hasattr(self,'show_toast') else None
                        except Exception:
                            self.show_toast(self._t("Fehler beim Übernehmen"), "error", 2200) if hasattr(self,'show_toast') else None
                    def _reject_one():
                        try:
                            self.show_toast(self._t("Verworfen"), "info", 1800) if hasattr(self,'show_toast') else None
                        except Exception:
                            pass
                    accept_btn = self._create_button(btn_bar, text=self._t("Übernehmen"), command=_accept_one, kind="primary", height=28, size="sm") if hasattr(self,'_create_button') else ctk.CTkButton(btn_bar, text=self._t("Übernehmen"), command=_accept_one, fg_color=self.get_color('primary'))
                    accept_btn.pack(side="left", padx=(0,6))
                    reject_btn = self._create_button(btn_bar, text=self._t("Verwerfen"), command=_reject_one, kind="secondary", height=28, size="sm") if hasattr(self,'_create_button') else ctk.CTkButton(btn_bar, text=self._t("Verwerfen"), command=_reject_one, fg_color=self.get_color('secondary'))
                    if hasattr(reject_btn,'pack'):
                        reject_btn.pack(side="left")
            # Details Button (Dialog)
            def _open_phase6_dialog():
                try:
                    if not hasattr(self, '_phase6_suggestions_last') or not self._phase6_suggestions_last:
                        self.show_toast(self._t("Keine Vorschläge"), "warning", duration=2500) if hasattr(self,'show_toast') else None
                        return
                    dlg = ctk.CTkToplevel(self.root)
                    dlg.title(self._t("Phase 6 Vorschläge"))
                    dlg.geometry("780x560")
                    container = ctk.CTkFrame(dlg, fg_color=self.get_color('white'), corner_radius=8, border_width=1, border_color=self.get_color('surface_border'))
                    container.pack(fill='both', expand=True, padx=16, pady=16)
                    # Vereinheitlichte Typographie für Dialogüberschrift
                    header = ctk.CTkLabel(container, text=self._t("Alle Verbesserungsvorschläge"), font=ctk.CTkFont(*self.get_typography('section_label')), text_color=self.get_color('gray_700'))
                    header.pack(pady=(16,8))
                    # Filter Row
                    filter_row = ctk.CTkFrame(container, fg_color=self.get_color('transparent'))
                    filter_row.pack(fill='x', padx=10, pady=(0,8))
                    categories = sorted({ (s.get('category') if isinstance(s, dict) else getattr(s,'category','')) for s in self._phase6_suggestions_last })
                    categories_display = [self._t("Alle")] + categories
                    selected_cat = ctk.StringVar(value=self._t("Alle"))
                    selected_prio = ctk.StringVar(value=self._t("Alle"))
                    prios_display = [self._t("Alle"), '1','2','3','4','5']
                    try:
                        cat_cb = ctk.CTkComboBox(filter_row, values=categories_display, variable=selected_cat, width=160)
                        cat_cb.pack(side='left', padx=(0,8))
                        prio_cb = ctk.CTkComboBox(filter_row, values=prios_display, variable=selected_prio, width=100)
                        prio_cb.pack(side='left', padx=(0,8))
                    except Exception:
                        pass
                    quick_only = ctk.BooleanVar(value=False)
                    try:
                        quick_chk = ctk.CTkCheckBox(filter_row, text=self._t("Nur Quick Fix"), variable=quick_only)
                        quick_chk.pack(side='left', padx=(0,8))
                    except Exception:
                        pass
                    def _passes_filters(s):
                        cat = s.get('category') if isinstance(s, dict) else getattr(s,'category','')
                        prio = str(s.get('priority') if isinstance(s, dict) else getattr(s,'priority',''))
                        if quick_only.get() and cat != 'quick_fix':
                            return False
                        sc = selected_cat.get()
                        if sc != self._t("Alle") and cat != sc:
                            return False
                        sp = selected_prio.get()
                        if sp != self._t("Alle") and prio != sp:
                            return False
                        return True
                    scroll = ctk.CTkScrollableFrame(container, fg_color=self.get_color('transparent'))
                    scroll.pack(fill='both', expand=True, padx=12, pady=(0,12))
                    def _render_list():
                        try:
                            for w in scroll.winfo_children():
                                w.destroy()
                        except Exception:
                            pass
                        for s in self._phase6_suggestions_last:
                            if not _passes_filters(s):
                                continue
                            row = ctk.CTkFrame(scroll, fg_color=self.get_color('gray_50'), corner_radius=6, border_width=1, border_color=self.get_color('surface_border'))
                            row.pack(fill='x', pady=5)
                            try:
                                cat = s.get('category') if isinstance(s, dict) else getattr(s,'category','')
                                msg = s.get('message') if isinstance(s, dict) else getattr(s,'message','')
                                pri = s.get('priority') if isinstance(s, dict) else getattr(s,'priority','-')
                                rationale = s.get('rationale') if isinstance(s, dict) else getattr(s,'rationale','')
                                ctk.CTkLabel(row, text=f"[{pri}] {cat}: {msg}", font=ctk.CTkFont(*self.get_typography('body')), text_color=self.get_color('gray_700'), anchor='w', justify='left').pack(fill='x', padx=10, pady=(8,2))
                                if rationale:
                                    ctk.CTkLabel(row, text=rationale, font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_500'), anchor='w', justify='left', wraplength=700).pack(fill='x', padx=10, pady=(0,8))
                            except Exception:
                                pass
                    _render_list()
                    def _apply_filters(*_a):
                        _render_list()
                    try:
                        cat_cb.configure(command=lambda *_: _apply_filters())
                        prio_cb.configure(command=lambda *_: _apply_filters())
                        quick_chk.configure(command=lambda *_: _apply_filters())
                    except Exception:
                        pass
                    # Export mit Filterzustand
                    def _export_filtered():
                        try:
                            import json, os, datetime
                            if not hasattr(self,'_phase6_suggestions_last'):
                                return
                            # Gefilterte Liste sammeln
                            filtered = []
                            for s in self._phase6_suggestions_last:
                                if _passes_filters(s):
                                    filtered.append(s)
                            base_dir = getattr(self,'projects_base_path','.')
                            out_dir = os.path.join(base_dir,'_analysis_exports')
                            os.makedirs(out_dir, exist_ok=True)
                            ts = datetime.datetime.now().strftime('%Y%m%d_%H%M%S')
                            path = os.path.join(out_dir, f'phase6_filtered_{ts}.json')
                            with open(path,'w',encoding='utf-8') as f:
                                json.dump({
                                    'filters': {
                                        'category': selected_cat.get(),
                                        'priority': selected_prio.get(),
                                        'quick_only': bool(quick_only.get())
                                    },
                                    'suggestions': filtered
                                }, f, ensure_ascii=False, indent=2)
                            self.show_toast(self._t("Gefilterter Export erstellt"), "success", duration=2400) if hasattr(self,'show_toast') else None
                        except Exception:
                            self.show_toast(self._t("Filter Export Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
                    try:
                        export_f_btn = ctk.CTkButton(filter_row, text=self._t("Export (Filter)"), command=_export_filtered, fg_color=self.get_color('surface'), hover_color=self.get_color('surface_hover'), text_color=self.get_color('primary'), border_width=1, border_color=self.get_color('surface_border'))
                        export_f_btn.pack(side='right')
                    except Exception:
                        pass
                    close_btn = ctk.CTkButton(container, text=self._t("Schließen"), command=dlg.destroy, fg_color=self.get_color('secondary'), hover_color=self.get_color('secondary_hover'), text_color=self.get_color('white'))
                    close_btn.pack(pady=(0,12))
                except Exception:
                    self.show_toast(self._t("Dialog Fehler"), "error", duration=2500) if hasattr(self,'show_toast') else None
            try:
                more_btn = ctk.CTkButton(block, text=self._t("Details anzeigen"), command=_open_phase6_dialog, fg_color=self.get_color('surface'), hover_color=self.get_color('surface_hover'), text_color=self.get_color('primary'), border_width=1, border_color=self.get_color('surface_border'))
                more_btn.pack(padx=16, pady=(8,12), anchor='w')
            except Exception:
                pass
            # Inline Diff Viewer (Snapshot vs aktueller Zustand) – optional
            try:
                def _open_diff_dialog():
                    try:
                        if not hasattr(self,'_phase6_runtime_context'):
                            self.show_toast(self._t('Keine Laufzeitdaten'), 'warning', duration=2200) if hasattr(self,'show_toast') else None
                            return
                        ctx = self._phase6_runtime_context
                        pairs = ctx.get('pairs') or []
                        snapshots = getattr(self,'_phase6_batch_snapshots', [])
                        base_pairs = snapshots[-1] if snapshots else None
                        if not base_pairs:
                            self.show_toast(self._t('Kein Snapshot verfügbar'), 'info', duration=2200) if hasattr(self,'show_toast') else None
                            return
                        import difflib
                        dlg = ctk.CTkToplevel(self.root)
                        dlg.title(self._t('Diff Vorschau'))
                        dlg.geometry('860x600')
                        wrapper = ctk.CTkFrame(dlg, fg_color=self.get_color('white'), corner_radius=8, border_width=1, border_color=self.get_color('surface_border'))
                        wrapper.pack(fill='both', expand=True, padx=14, pady=14)
                        ctk.CTkLabel(wrapper, text=self._t('Änderungen gegenüber letztem Snapshot'), font=ctk.CTkFont(*self.get_typography('section_label')), text_color=self.get_color('gray_700')).pack(fill='x', padx=12, pady=(16,6))
                        scroll = ctk.CTkScrollableFrame(wrapper, fg_color='transparent')
                        scroll.pack(fill='both', expand=True, padx=12, pady=(4,12))
                        changed = 0
                        for idx,(src,tgt) in enumerate(pairs):
                            old_tgt = base_pairs[idx][1] if idx < len(base_pairs) else None
                            if old_tgt is None or old_tgt == tgt:
                                continue
                            changed += 1
                            row = ctk.CTkFrame(scroll, fg_color=self.get_color('gray_50'), corner_radius=6, border_width=1, border_color=self.get_color('surface_border'))
                            row.pack(fill='x', pady=6)
                            ctk.CTkLabel(row, text=f'Segment {idx+1}', font=ctk.CTkFont(*self.get_typography('section_label')), text_color=self.get_color('primary')).pack(anchor='w', padx=10, pady=(8,2))
                            try:
                                diff_lines = list(difflib.unified_diff((old_tgt or '').splitlines(), (tgt or '').splitlines(), fromfile='alt', tofile='neu', lineterm=''))
                            except Exception:
                                diff_lines = []
                            tb = ctk.CTkTextbox(row, height=min(240, max(60, len(diff_lines)*14)), fg_color=self.get_color('white'), text_color=self.get_color('gray_700'))
                            tb.pack(fill='x', padx=10, pady=(0,10))
                            try:
                                for ln in diff_lines:
                                    tb.insert('end', ln + '\n')
                                tb.configure(state='disabled')
                            except Exception:
                                pass
                        if changed == 0:
                            ctk.CTkLabel(scroll, text=self._t('Keine Änderungen'), font=ctk.CTkFont(*self.get_typography('body')), text_color=self.get_color('gray_600')).pack(pady=10)
                        ctk.CTkButton(wrapper, text=self._t('Schließen'), command=dlg.destroy, fg_color=self.get_color('secondary'), hover_color=self.get_color('secondary_hover'), text_color=self.get_color('white')).pack(pady=(0,10))
                    except Exception:
                        self.show_toast(self._t('Diff Fehler'), 'error', duration=2400) if hasattr(self,'show_toast') else None
                diff_btn = ctk.CTkButton(block, text=self._t('Diff Vorschau'), command=_open_diff_dialog, fg_color=self.get_color('surface'), hover_color=self.get_color('surface_hover'), text_color=self.get_color('primary'), border_width=1, border_color=self.get_color('surface_border'))
                diff_btn.pack(padx=16, pady=(0,12), anchor='w')
            except Exception:
                pass
        except Exception:
            pass
    
    def _show_settings_dashboard(self):
        """PROFESSIONAL: Refined settings dashboard with professional styling"""
        try:
            # Clear output for settings
            for widget in self.output_frame.winfo_children():
                widget.destroy()
            
            # Professional settings header
            settings_header = ctk.CTkFrame(
                self.output_frame,
                fg_color=self.get_color('gray_700'),
                corner_radius=8
            )
            settings_header.pack(fill="x", padx=30, pady=(30, self.get_spacing('md')))
            
            header_content = ctk.CTkFrame(settings_header, fg_color=self.get_color('transparent'))
            header_content.pack(fill="x", padx=25, pady=20)
            
            settings_title = ctk.CTkLabel(
                header_content,
                text=self._t("Application Settings & Preferences"),
                font=ctk.CTkFont(*self.get_typography('subtitle_unified')),
                text_color=self.get_color('white')
            )
            settings_title.pack()
            
            # Professional settings content
            settings_content = ctk.CTkScrollableFrame(
                self.output_frame,
                fg_color="transparent"
            )
            settings_content.pack(fill="both", expand=True, padx=30, pady=(0, self.get_spacing('md')))
            
            # ---------- Font Cache (einmalig) ----------
            if not hasattr(self, '_settings_font_cache'):
                self._settings_font_cache = {}
            # Font Getter Helper
            def _get_pref_font(name: str):
                try:
                    if name not in self._settings_font_cache:
                        self._settings_font_cache[name] = ctk.CTkFont(*self.get_typography(name))
                    return self._settings_font_cache[name]
                except Exception:
                    return ctk.CTkFont("Segoe UI", 12)

            # Kurzalias für Fonts (wie vorher genutzt: F('body'))
            def F(token: str):  # noqa: N802 - bewusst kurz
                try:
                    return _get_pref_font(token)
                except Exception:
                    return ctk.CTkFont("Segoe UI", 12)

            # Settings Row Factory (wurde durch vorherigen Patch entfernt)
            def _make_setting_row(parent, label: str, widget_type: str, config):
                try:
                    row = ctk.CTkFrame(parent, fg_color="transparent")
                    row.pack(fill="x", pady=6)
                    ctk.CTkLabel(row, text=label, font=F('body'), text_color=self.get_color('gray_600'), anchor="w").pack(side="left", fill="x", expand=True)
                    widget = None
                    if widget_type == "combobox":
                        widget = ctk.CTkComboBox(
                            row,
                            values=config,
                            width=220,
                            font=F('body'),
                            fg_color=self.get_color('gray_50'),
                            dropdown_fg_color=self.get_color('surface'),
                            button_color=self.get_color('primary_hover'),
                            border_color=self.get_color('surface_border') if hasattr(self, 'get_color') else None
                        )
                        widget.pack(side="right")
                        if config:
                            widget.set(config[0])
                    elif widget_type == "switch":
                        widget = ctk.CTkSwitch(
                            row,
                            text="",
                            width=45,
                            progress_color=self.get_color('primary')
                        )
                        widget.pack(side="right")
                        if config:
                            widget.select()
                    elif widget_type == "slider":
                        min_val, max_val, default_val = config
                        steps = None
                        if label == self._t("Memory Cache"):
                            steps = int(max_val - min_val)
                        widget = ctk.CTkSlider(
                            row,
                            from_=min_val,
                            to=max_val,
                            width=220,
                            number_of_steps=steps if steps else None,
                            progress_color=self.get_color('primary'),
                            button_color=self.get_color('primary_hover')
                        )
                        widget.pack(side="right")
                        widget.set(default_val)
                    return widget
                except Exception:
                    return None

            # ---------- Sprach-Mapping sicherstellen (vereinheitlicht) ----------
            if not hasattr(self, 'LANG_DISPLAY2ISO'):
                self.LANG_DISPLAY2ISO = {"Auto-Detect":"auto","Auto-detect":"auto","English":"en","German":"de","French":"fr","Spanish":"es","Italian":"it"}
            # (Fehlerhafte vorherige Einfügung entfernt)

            # ---------- Settings Handler Binding ----------
            def _bind_settings_handlers(row_widget, widget_type: str, label: str, mapping=None):
                key = {
                    self._t("Default Source Language"): "analysis.default_src",
                    self._t("Default Target Language"): "analysis.default_tgt",
                    self._t("Quality Threshold"):       "analysis.quality_threshold",
                    self._t("Enable Advanced Analysis"):"analysis.advanced",
                    self._t("Theme Mode"):              "ui.theme",
                    self._t("Font Size"):               "ui.font_size",
                    self._t("Show Tooltips"):           "ui.tooltips",
                    self._t("Animate Transitions"):     "ui.animations",
                    self._t("Multi-threading"):         "perf.multithreading",
                    self._t("Memory Cache"):            "perf.cache_mb",
                    self._t("Auto-save Results"):       "perf.autosave",
                    self._t("Hintergrund-Verarbeitung"):"perf.background",
                }.get(label)
                if not key or not getattr(self, 'settings_service', None) or row_widget is None:
                    return
                if widget_type == "combobox":
                    def on_change(val):
                        try:
                            if mapping:  # Language mapping
                                # Lokalisierter Wert -> englisches Display -> ISO
                                en_display = next((k for k in mapping.keys() if self._t(k) == val or k == val), None) or val
                                iso = self.LANG_DISPLAY2ISO.get(en_display, en_display)
                                # Target darf kein auto sein
                                if key == "analysis.default_tgt" and iso == "auto":
                                    if hasattr(self, 'show_toast'):
                                        try:
                                            self.show_toast(self._t("Zielsprache kann nicht automatisch erkannt werden."), "warning")
                                        except Exception as ex_toast_warn:
                                            try:
                                                self._record_suppressed_error('settings.change.combobox.toast', ex_toast_warn)
                                            except Exception:
                                                pass
                                    # Rücksetzen auf Deutsch
                                    try:
                                        row_widget.set(self._t("German"))
                                    except Exception as ex_reset_lang:
                                        try:
                                            self._record_suppressed_error('settings.change.combobox.reset_lang', ex_reset_lang)
                                        except Exception:
                                            pass
                                    iso = "de"
                                self.settings_service.set(key, iso)
                            else:
                                self.settings_service.set(key, val)
                        except Exception as ex_change:
                            try:
                                self._record_suppressed_error('settings.change.combobox', ex_change)
                            except Exception:
                                pass
                    row_widget.configure(command=on_change)
                elif widget_type == "switch":
                    def on_toggle():
                        try:
                            self.settings_service.set(key, bool(row_widget.get()))
                        except Exception as ex_toggle:
                            try:
                                self._record_suppressed_error('settings.toggle.switch', ex_toggle)
                            except Exception:
                                pass
                    row_widget.configure(command=on_toggle)
                elif widget_type == "slider":
                    def on_slide(v):
                        try:
                            if key == "perf.cache_mb":
                                self.settings_service.set(key, int(float(v)))
                            else:
                                self.settings_service.set(key, float(v))
                        except Exception as ex_slide:
                            try:
                                self._record_suppressed_error('settings.slide.slider', ex_slide)
                            except Exception:
                                pass
                    row_widget.configure(command=on_slide)

            # ---------- Restore Funktion ----------
            def _restore_settings_into_widgets(widget_map: dict):
                if not getattr(self, 'settings_service', None):
                    return
                try:
                    # Sprachen
                    def set_lang(label_key: str, store_key: str, fallback: str):
                        widget = widget_map.get(label_key)
                        if not widget: return
                        iso = self.settings_service.get(store_key, fallback)
                        # Target auto verhindern
                        if store_key == "analysis.default_tgt" and iso == "auto":
                            iso = "de"
                        display = next((self._t(d) for d,k in self.LANG_DISPLAY2ISO.items() if k==iso), self._t("Auto-Detect"))
                        # Target darf kein Auto-Detect anzeigen
                        if store_key == "analysis.default_tgt" and display == self._t("Auto-Detect"):
                            display = self._t("German")
                        try:
                            widget.set(display)
                        except Exception as ex_restore_lang:
                            try:
                                self._record_suppressed_error('settings.restore.lang.set', ex_restore_lang)
                            except Exception:
                                pass
                    set_lang(self._t("Default Source Language"), "analysis.default_src", "auto")
                    set_lang(self._t("Default Target Language"), "analysis.default_tgt", "de")
                    # Quality Threshold
                    thr_widget = widget_map.get(self._t("Quality Threshold"))
                    if thr_widget:
                        try:
                            thr_widget.set(float(self.settings_service.get("analysis.quality_threshold", 0.9)))
                        except Exception as ex_thr_set:
                            try:
                                self._record_suppressed_error('settings.restore.threshold', ex_thr_set)
                            except Exception:
                                pass
                    # Memory Cache
                    mem_widget = widget_map.get(self._t("Memory Cache"))
                    if mem_widget:
                        try:
                            mem_widget.set(int(self.settings_service.get("perf.cache_mb", 1024)))
                        except Exception as ex_mem_set:
                            try:
                                self._record_suppressed_error('settings.restore.memory', ex_mem_set)
                            except Exception:
                                pass
                    # Switches & andere Comboboxen
                    def _restore_switch(label_key, store_key, fallback=True):
                        w = widget_map.get(label_key)
                        if not w: return
                        try:
                            val = bool(self.settings_service.get(store_key, fallback))
                            if val: w.select()
                            else: w.deselect()
                        except Exception as ex_switch_set:
                            try:
                                self._record_suppressed_error('settings.restore.switch', ex_switch_set)
                            except Exception:
                                pass
                    _restore_switch(self._t("Enable Advanced Analysis"), "analysis.advanced", True)
                    _restore_switch(self._t("Show Tooltips"), "ui.tooltips", True)
                    _restore_switch(self._t("Animate Transitions"), "ui.animations", True)
                    _restore_switch(self._t("Multi-threading"), "perf.multithreading", True)
                    _restore_switch(self._t("Auto-save Results"), "perf.autosave", True)
                    _restore_switch(self._t("Hintergrund-Verarbeitung"), "perf.background", False)
                    # Font Size Combobox
                    fs_widget = widget_map.get(self._t("Font Size"))
                    if fs_widget:
                        try:
                            stored = self.settings_service.get("ui.font_size", self._t("Medium"))
                            fs_widget.set(stored if stored in [self._t("Small"), self._t("Medium"), self._t("Large")] else self._t("Medium"))
                        except Exception as ex_font_restore:
                            try:
                                self._record_suppressed_error('settings.restore.font_size', ex_font_restore)
                            except Exception:
                                pass
                except Exception:
                    pass

            # ---------- Sektionen aufbauen ----------
            self._settings_widgets = {}
            def _build_section(parent, title: str, rows: list):
                section_card = ctk.CTkFrame(parent, fg_color=self.get_color('white'), corner_radius=8, border_width=1)
                section_card.pack(fill="x", pady=12)
                ctk.CTkLabel(section_card, text=title, font=F('section_label'), text_color=self.get_color('gray_700')).pack(pady=(12, 8))
                frame = ctk.CTkFrame(section_card, fg_color="transparent")
                frame.pack(fill="x", padx=20, pady=(0, 20))
                for label, wtype, cfg in rows:
                    w = _make_setting_row(frame, label, wtype, cfg)
                    self._settings_widgets[label] = w
                    mapping = self.LANG_DISPLAY2ISO if 'Language' in label or 'Sprache' in label else None
                    _bind_settings_handlers(w, wtype, label, mapping=mapping)

            # Analysis Settings
            _build_section(settings_content, self._t("Analysis Settings"), [
                (self._t("Default Source Language"), "combobox", [self._t("Auto-Detect"), self._t("English"), self._t("German"), self._t("French"), self._t("Spanish")]),
                (self._t("Default Target Language"), "combobox", [self._t("English"), self._t("German"), self._t("French"), self._t("Spanish")]),
                (self._t("Quality Threshold"), "slider", (0.7, 1.0, 0.9)),
                (self._t("Enable Advanced Analysis"), "switch", True)
            ])
            # (Konsolidiert) Ausführliche Beschreibung entfernt – kurze Zusammenfassung jetzt bei Qualitätskriterien
            # Hinweis: Funktionslogik unverändert, nur UI-Vereinfachung zur Vermeidung von Doppelung.
            # User Interface
            _build_section(settings_content, self._t("User Interface"), [
                (self._t("Theme Mode"), "combobox", [self._t("Light Mode Only")]),
                (self._t("Font Size"), "combobox", [self._t("Small"), self._t("Medium"), self._t("Large")]),
                (self._t("Show Tooltips"), "switch", True),
                (self._t("Animate Transitions"), "switch", True)
            ])
            # Performance
            _build_section(settings_content, self._t("Performance"), [
                (self._t("Multi-threading"), "switch", True),
                (self._t("Memory Cache"), "slider", (512, 2048, 1024)),
                (self._t("Auto-save Results"), "switch", True),
                (self._t("Hintergrund-Verarbeitung"), "switch", False)
            ])

            # Notification / Toast Settings (separate card - keine bestehenden Keys verändern)
            try:
                notif_card = ctk.CTkFrame(settings_content, fg_color=self.get_color('white'), corner_radius=8, border_width=1)
                notif_card.pack(fill="x", pady=12)
                ctk.CTkLabel(notif_card, text=self._t("Benachrichtigungen"), font=F('section_label'), text_color=self.get_color('gray_700')).pack(pady=(12, 8))
                notif_frame = ctk.CTkFrame(notif_card, fg_color="transparent")
                notif_frame.pack(fill="x", padx=20, pady=(0, 20))
                # Max Visible Toasts
                max_row = ctk.CTkFrame(notif_frame, fg_color="transparent")
                max_row.pack(fill="x", pady=6)
                ctk.CTkLabel(max_row, text=self._t("Max. sichtbare Toasts"), font=F('body'), text_color=self.get_color('gray_600'), anchor="w").pack(side="left", fill="x", expand=True)
                current_max = 4
                try:
                    if hasattr(self, 'toast_system') and self.toast_system:
                        current_max = self.toast_system.get_max_visible()
                except Exception:
                    current_max = 4
                max_entry = ctk.CTkEntry(max_row, width=80)
                max_entry.insert(0, str(current_max))
                max_entry.pack(side="right")
                def _save_max_toasts():
                    try:
                        val = int(max_entry.get().strip())
                        if val < 1 or val > 10:
                            self.show_toast(self._t("Wert muss zwischen 1 und 10 liegen"), "warning")
                            return
                        if hasattr(self, 'toast_system') and self.toast_system:
                            self.toast_system.set_max_visible(val)
                        if hasattr(self, 'settings_service') and self.settings_service:
                            self.settings_service.set('notifications.max_visible', val)
                        self.show_toast(self._t("Toast-Anzahl aktualisiert"), "success")
                        self._log_event('notifications.max_visible.changed', value=val)
                    except Exception:
                        self.show_toast(self._t("Fehler beim Aktualisieren"), "error")
                save_btn = self._create_button(notif_frame, text=self._t("Speichern"), command=_save_max_toasts, kind="primary", height=36)
                save_btn.pack(anchor="w", pady=(4,4))
                # Test & Clear Buttons
                btn_row = ctk.CTkFrame(notif_frame, fg_color="transparent")
                btn_row.pack(fill="x", pady=(8,0))
                def _test_toasts():
                    try:
                        if not hasattr(self, 'toast_system') or not self.toast_system:
                            return
                        self.toast_system.show_success(self._t("Test Erfolg"))
                        self.toast_system.show_info(self._t("Test Info"))
                        self.toast_system.show_warning(self._t("Test Warnung"))
                        self.toast_system.show_error(self._t("Test Fehler"))
                    except Exception:
                        pass
                def _clear_toasts():
                    try:
                        if hasattr(self, 'toast_system') and self.toast_system:
                            self.toast_system.close_all()
                            self.show_toast(self._t("Alle Toasts geschlossen"), "info")
                    except Exception:
                        pass
                test_btn = self._create_button(btn_row, text=self._t("Test"), command=_test_toasts, kind="outline-primary", width=120, height=36)
                test_btn.pack(side="left", padx=(0,10))
                clear_btn = self._create_button(btn_row, text=self._t("Leeren"), command=_clear_toasts, kind="outline-primary", width=120, height=36)
                clear_btn.pack(side="left")
                # Wiederherstellen aus Settings falls vorhanden
                try:
                    if hasattr(self, 'settings_service') and self.settings_service:
                        stored_max = int(self.settings_service.get('notifications.max_visible', current_max))
                        if stored_max != current_max and hasattr(self, 'toast_system') and self.toast_system:
                            self.toast_system.set_max_visible(stored_max)
                            try: max_entry.delete(0, 'end'); max_entry.insert(0, str(stored_max))
                            except Exception: pass
                except Exception:
                    pass
            except Exception:
                pass

            _restore_settings_into_widgets(self._settings_widgets)
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.settings.dashboard",
                user_message=self._t("Einstellungs-Dashboard Fehler") if hasattr(self, '_t') else "Settings Dashboard Fehler"
            )
    
    # Alte _create_professional_settings_section entfernt (Funktionalität in Dashboard integriert)
            
    def _create_main_interface(self):
        """MAIN INTERFACE: Create the complete modern interface"""
        try:
            # Create main container for layout
            self.main_container.grid_rowconfigure(1, weight=1)
            self.main_container.grid_columnconfigure(0, weight=1)
            
            # Create modern tab navigator first
            self._create_modern_tab_navigator()
            
            # Create main content area
            self._create_main_content_area()
            
            # Show default welcome content
            self._show_enhanced_welcome_output()
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.main_interface",
                user_message=self._t("Hauptoberfläche Fehler") if hasattr(self, '_t') else "Main Interface Fehler"
            )
            
    def _create_main_content_area(self):
        """CONTENT AREA: Create the main content display area"""
        try:
            # Main content frame with modern styling
            self.content_area = ctk.CTkFrame(
                self.main_container,
                fg_color=self.get_color('gray_50'),
                corner_radius=0
            )
            self.content_area.grid(row=1, column=0, sticky="nsew", padx=0, pady=0)
            self.content_area.grid_rowconfigure(0, weight=1)
            self.content_area.grid_columnconfigure(0, weight=1)
            
            # Output frame for dynamic content
            self.output_frame = ctk.CTkScrollableFrame(
                self.content_area,
                fg_color="transparent"
            )
            self.output_frame.grid(row=0, column=0, sticky="nsew", padx=0, pady=0)
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.content_area",
                user_message=self._t("Inhaltsbereich konnte nicht erstellt werden") if hasattr(self, '_t') else "Content Area Fehler"
            )
    
    def _create_quality_criteria_section(self, parent):
        """DEPRECATED: Qualitätskriterien sind jetzt in der Analyse-Sektion integriert (Rückwärts-Kompatibilität)."""
        try:
            info = ctk.CTkLabel(parent, text=self._t("Hinweis: Qualitätskriterien jetzt unter 'Analyse' zusammengefasst."), font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_500'))
            info.pack(fill="x", pady=4)
        except Exception:
            pass
    
    def _create_actions_section(self, parent):
        """STEP 3: Actions & Operations - unified, cleaned."""
        try:
            actions_card = self._create_card_container(parent)
            hf, header_content, _ = self._create_section_header(actions_card, self._tr("3. Aktionen & Operationen"), accent='primary', title_font_key='subtitle_unified', title_color_key='primary')
            self.readiness_indicator = ctk.CTkLabel(
                header_content,
                text=self._t("● Bereit"),
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self._accent('warning')
            )
            self.readiness_indicator.pack(side="right")
            content_frame = ctk.CTkFrame(actions_card, fg_color="transparent")
            content_frame.pack(fill="x", padx=14, pady=12)
            self.analyze_button = self._create_button(
                content_frame,
                text=self._t("Dateien hochladen, um die Analyse zu aktivieren"),
                command=self.start_analysis,
                kind="primary",
                height=44
            )
            self.analyze_button.configure(fg_color=self.get_color('gray_400'), hover_color=self.get_color('gray_500'), state="disabled")
            self.analyze_button.pack(fill="x", pady=(0, 10))
            secondary_section = ctk.CTkFrame(content_frame, fg_color=self.get_color('gray_50'))
            secondary_section.pack(fill="x")
            ctk.CTkLabel(
                secondary_section,
                text=self._t("Weitere Aktionen"),
                font=ctk.CTkFont(*self.get_typography('body_unified')),
                text_color=self.get_color('text_secondary')
            ).pack(pady=(8, 6))
            secondary_frame = ctk.CTkFrame(secondary_section, fg_color="transparent")
            secondary_frame.pack(fill="x", padx=10, pady=(0, 10))
            for i in (0,1,2):
                secondary_frame.grid_columnconfigure(i, weight=1)
            self._create_button(secondary_frame, text=self._t("Exportieren") if hasattr(self,'_t') else "Exportieren", command=self.export_results, kind="primary", height=36).grid(row=0, column=0, sticky="ew", padx=(0, 3))
            self._create_button(secondary_frame, text=self._t("Demo") if hasattr(self,'_t') else "Demo", command=self.show_demo_results, kind="primary", height=36).grid(row=0, column=1, sticky="ew", padx=3)
            self._create_button(secondary_frame, text=self._t("Leeren") if hasattr(self,'_t') else "Leeren", command=self.clear_files, kind="primary", height=36).grid(row=0, column=2, sticky="ew", padx=(3, 0))
        except Exception as e:
            # Vereinheitlichter Fallback laut Vorgabe: keine UI-Teil-Erstellung hier, direkte Rückfallebene
            self._handle_error(
                e,
                context="actions.section",
                user_message=self._t("Fehler in Aktionen – Fallback aktiviert"),
                event_name="ui.error.actions.section"
            )
            self._create_basic_actions_section(parent)
            return
    
    def _setup_right_panel(self):
        """PROFESSIONAL: Setup enhanced right panel with modern design system"""
        try:
            # Clear existing content
            for widget in self.right_panel.winfo_children():
                widget.destroy()
            
            # Professional header with enhanced visual hierarchy
            header_frame = ctk.CTkFrame(
                self.right_panel,
                fg_color=self.get_color('primary'),
                height=self.get_component_value('heights.section_header', 64),
                corner_radius=0
            )
            header_frame.pack(fill="x", padx=0, pady=0)
            header_frame.pack_propagate(False)
            
            # Professional header content with better spacing
            header_content = ctk.CTkFrame(header_frame, fg_color="transparent")
            header_content.pack(fill="both", expand=True, 
                              padx=self.get_spacing('card_padding'), 
                              pady=self.get_spacing('sm'))
            
            # Main title with professional typography
            title_label = ctk.CTkLabel(
                header_content,
                text=self._t("Analyseergebnisse & Berichte Professional") if hasattr(self,'_t') else "Analyseergebnisse & Berichte Professional",
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self.get_color('white')
            )
            title_label.pack(anchor="w", pady=(0, 2))
            
            # Professional subtitle with enhanced status
            subtitle_frame = ctk.CTkFrame(header_content, fg_color="transparent")
            subtitle_frame.pack(fill="x", anchor="w")
            
            subtitle_label = ctk.CTkLabel(
                subtitle_frame,
                text="Erweiterte Qualitätsanalyse & Berichtswesen",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('gray_200')
            )
            subtitle_label.pack(side="left")
            
            # Professional status indicator with enhanced styling
            self.output_status_label = ctk.CTkLabel(
                subtitle_frame,
                text="● System bereit",
                font=ctk.CTkFont(*self.get_typography('status')),
                text_color=self.get_color('success_light'),
                fg_color=self.get_color('success', 'transparent'),
                corner_radius=10,
                padx=8,
                pady=2
            )
            self.output_status_label.pack(side="right")
            
            # Professional content frame with enhanced design
            self.output_frame = ctk.CTkScrollableFrame(
                self.right_panel,
                fg_color=self.get_color('background'),
                scrollbar_button_color=self.get_color('primary'),
                scrollbar_button_hover_color=self.get_color('primary_hover'),
                corner_radius=0
            )
            self.output_frame.pack(fill="both", expand=True, padx=0, pady=0)
            
            # Professional welcome content with enhanced design
            self._show_professional_welcome_output()
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.right_panel.professional",
                user_message=self._t("Professional right panel creation failed") if hasattr(self, '_t') else "Professioneller rechter Bereich konnte nicht erstellt werden"
            )
            # Fallback to basic right panel
            self._setup_basic_right_panel()
    
    def _setup_basic_right_panel(self):
        """FALLBACK: Basic right panel for error scenarios"""
        try:
            # Simple header
            header_frame = ctk.CTkFrame(
                self.right_panel,
                # Vereinheitlicht: gleicher Primär-Farbton wie linkes Panel
                fg_color=self.get_color('primary'),
                height=60
            )
            header_frame.pack(fill="x", padx=0, pady=0)
            header_frame.pack_propagate(False)
            
            title_label = ctk.CTkLabel(
                header_frame,
                text=self._t("Analyseergebnisse") if hasattr(self,'_t') else "Analyseergebnisse",
                font=ctk.CTkFont(*self.get_typography('heading')),
                text_color=self.get_color('white')
            )
            title_label.pack(pady=15)
            
            # Simple output frame
            self.output_frame = ctk.CTkScrollableFrame(
                self.right_panel,
                fg_color=self.get_color('surface_light'),
                scrollbar_button_color=self.get_color('primary'),
                scrollbar_button_hover_color=self.get_color('primary_hover')
            )
            self.output_frame.pack(fill="both", expand=True, padx=10, pady=10)
            
            # Show basic welcome content
            self._show_enhanced_welcome_output()
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.right_panel.basic",
                user_message=self._t("Rechter Bereich (einfach) Fehler") if hasattr(self, '_t') else "Right Panel Basic Fehler"
            )
    
    def _show_enhanced_welcome_output(self):
        """🚀 PROFESSIONAL: Advanced welcome dashboard with refined professional colors"""
        try:
            # Clear existing content
            for widget in self.output_frame.winfo_children():
                widget.destroy()
            
            # Professional dashboard card with clean styling
            welcome_card = ctk.CTkFrame(
                self.output_frame,
                fg_color=self.get_color('white'),
                corner_radius=8,  # Consistent corner radius
                border_width=0
            )
            welcome_card.pack(fill="x", pady=25, padx=25)
            
            # Professional content layout
            content_frame = ctk.CTkFrame(welcome_card, fg_color="transparent")
            content_frame.pack(fill="both", expand=True, padx=30, pady=30)
            
            # Sektion 1: Metriken (vereinfachte rechte Spalte)
            self._create_professional_metrics_dashboard(content_frame)

            # Sektion 2: Projekte (Navigation & Aktionen)
            self._create_project_folder_navigation(content_frame)

            # Feature- & Systemstatus-Sektionen entfernt für schlankere Übersicht; können optional reaktiviert werden
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.welcome.enhanced",
                user_message=self._t("Erweiterter Willkommensbereich Fehler") if hasattr(self, '_t') else "Welcome Output Fehler"
            )
            # Fallback to basic welcome
            self._show_basic_welcome_output()

    def _show_welcome_output(self):  # ADDITIVE: Wiederhergestellte öffentliche Wrapper-Methode für Menü "Start"
        """ENTRYPOINT: Standard-Willkommensansicht für den Start-Button.

        - Nutzt bevorzugt die professionelle (_show_enhanced_welcome_output) Variante.
        - Fällt bei Fehlern oder fehlender Implementierung sicher auf die Basic-Version zurück.
        - Verändert keine bestehende Logik; reine Kompatibilitäts-Wiederherstellung.
        """
        try:
            # Guard: Falls output_frame noch nicht erstellt ist (frühe Aufrufe)
            if not getattr(self, 'output_frame', None):
                return
            if hasattr(self, '_show_enhanced_welcome_output'):
                self._show_enhanced_welcome_output()
            else:
                self._show_basic_welcome_output()
        except Exception:
            # Letzter Fallback – Basic Variante versuchen
            try:
                self._show_basic_welcome_output()
            except Exception:
                pass
    
    def _create_professional_metrics_dashboard(self, parent):
        """OPTIMIERT: Konsistentes Metriken-Dashboard mit einheitlichem Design und Live-Update.

        Additiv – keine bestehende Funktionalität wird verändert. Baut nur UI + Registrierungen.
        """
        try:
            # Header
            header_frame = ctk.CTkFrame(parent, fg_color=self.get_color('primary'), height=60, corner_radius=6)
            header_frame.pack(fill='x', pady=(0, 25))
            header_frame.pack_propagate(False)
            header_inner = ctk.CTkFrame(header_frame, fg_color='transparent')
            header_inner.pack(fill='both', expand=True, padx=25, pady=8)
            metrics_title = ctk.CTkLabel(
                header_inner,
                text=self._tr("Metriken"),
                font=ctk.CTkFont(*self.get_typography('heading')),
                text_color=self.get_color('white')
            )
            metrics_title.pack(side='left')
            status_indicator = ctk.CTkLabel(
                header_inner,
                text=self._tr("Systeme stabil"),
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self._accent('success', 'system_status')
            )
            status_indicator.pack(side='right')

            # Container (angepasste Abstände: unten 24px)
            metrics_container = ctk.CTkFrame(parent, fg_color="transparent")
            metrics_container.pack(fill="x", pady=(0, 24))

            # Daten sammeln
            m = self._collect_runtime_metrics()
            total_files = m.get('queued_files') or 0
            cpu = m.get('cpu_percent')
            cpu_txt = f"{cpu:.0f}% CPU" if isinstance(cpu, (int, float)) else self._tr("CPU n/a")
            resp = m.get('response_ms')
            if isinstance(resp, (int, float)):
                resp_txt = f"{resp} ms" if resp < 1000 else f"{resp/1000:.2f} s"
            else:
                resp_txt = self._tr("Latenz n/a")

            show_memory = False
            show_threads = False
            try:
                from config_manager import ConfigManager  # type: ignore
                cfg = ConfigManager()
                show_memory = bool(cfg.get('metrics.show_memory', False))
                show_threads = bool(cfg.get('metrics.show_threads', False))
            except Exception as cfg_err:
                self._dev_trace('metrics.config.flags', cfg_err)

            metrics = [
                (str(total_files), self._tr("Dateien bereit"), 'gray_700', 'files'),
                (str(m.get('sessions') or 1), self._tr("Aktive Sitzungen"), 'gray_700', 'sessions'),
                (cpu_txt, self._tr("Systemauslastung"), 'gray_700', 'cpu'),
                (resp_txt, self._tr("Antwortzeit"), 'success', 'latency')
            ]
            if show_memory:
                mem_val = m.get('memory_mb')
                mem_txt = f"{mem_val:.1f} MB" if isinstance(mem_val, (int, float)) else self._tr("RAM n/a")
                metrics.append((mem_txt, self._tr("Speichernutzung"), 'gray_700', 'memory'))
            if show_threads:
                th_val = m.get('threads')
                th_txt = str(th_val) if isinstance(th_val, int) else self._tr("Threads n/a")
                metrics.append((th_txt, self._tr("Threads"), 'gray_700', 'threads'))

            # Grid konfigurieren
            for col in range(len(metrics)):
                metrics_container.grid_columnconfigure(col, weight=1)

            # Karten bauen
            metric_label_mapping = {}
            for i, (value, title, color, key) in enumerate(metrics):
                try:
                    card = ctk.CTkFrame(
                        metrics_container,
                        fg_color=self.get_color('surface'),
                        corner_radius=10,
                        border_width=1,
                        border_color=self.get_color('surface_border'),
                        height=130
                    )
                    card.grid(row=0, column=i, sticky="nsew", padx=8, pady=6)
                    card.grid_propagate(False)
                    inner = ctk.CTkFrame(card, fg_color="transparent")
                    inner.pack(fill='both', expand=True, padx=16, pady=16)
                    # Wert groß (semibold ~22px) – wir nutzen heading_md (20) und erhöhen leicht
                    try:
                        val_font = ctk.CTkFont(*self.get_typography('heading_md'))
                        val_font.configure(size=22)
                    except Exception:
                        val_font = ctk.CTkFont(*self.get_typography('heading_md'))
                    value_label = ctk.CTkLabel(
                        inner,
                        text=value,
                        font=val_font,
                        text_color=self.get_color(color),
                        anchor='w'
                    )
                    value_label.pack(anchor='w')
                    # Label klein (12-13px, muted #64748B -> gray_500)
                    title_label = ctk.CTkLabel(
                        inner,
                        text=title,
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        text_color=self.get_color('gray_500'),
                        anchor='w'
                    )
                    title_label.pack(anchor='w', pady=(4,0))
                    metric_label_mapping[key] = value_label
                except Exception as build_err:
                    self._dev_trace('metrics.card_build', build_err)

            if metric_label_mapping:
                self._register_metric_labels(metric_label_mapping)
                self._start_metrics_refresh()

        except Exception as e:
            self._handle_error(
                e,
                context="ui.metrics.dashboard",
                user_message=self._t("Metriken-Dashboard Fehler") if hasattr(self, '_t') else "Metriken-Dashboard Fehler"
            )
    
