                # Kurzer Badge Text (engl. UI Basis); optional später lokalisierbar
                self.file_count_badge.configure(text=f"{count} files")
        except Exception as e:
            self._handle_error(
                e,
                context="files.counter.update",
                user_message=self._t("Dateizähler konnte nicht aktualisiert werden") if hasattr(self, '_t') else "File Counter Fehler",
                toast=False
            )
    
    def _initialize_systems(self):
        """OPTIMIZED: Initialize additional systems with performance monitoring"""
        try:
            # Performance monitoring initialization
            import time
            start_time = time.time()
            
            # Initialize toast system with smart fallback
            try:
                from quality_gui_notifications import ToastNotification
                # Toast System mit i18n Translator integrieren
                try:
                    self.toast_system = ToastNotification(self.root, translator=getattr(self, '_t', lambda s: s))
                except Exception:
                    self.toast_system = ToastNotification(self.root)
                self.logger.info("Advanced toast system loaded")
            except ImportError:
                self.logger.info("Toast system not available - using basic notifications")
                self.toast_system = None
            
            # Performance optimization: Preload common UI components
            self._preload_ui_components()
            
            # Smart system initialization
            self._smart_feature_detection()
            
            # Performance measurement
            init_time = (time.time() - start_time) * 1000
            self.logger.info(f"Systems initialized in {init_time:.1f}ms")
            
            # Show optimized startup message
            self.update_status(self._t("All systems operational - Performance optimized"))
            # Menü-Kontext periodisch aktualisieren (Projektanzahl / Upload Enable)
            try:
                def _periodic_menu_update():
                    try:
                        if hasattr(self, '_update_menu_context'):
                            self._update_menu_context()
                    except Exception as e:
                        self._record_suppressed_error('systems.menu.periodic_update', e)
                    try:
                        if self.root:
                            self.root.after(4000, _periodic_menu_update)
                    except Exception as e:
                        self._record_suppressed_error('systems.menu.periodic_reschedule', e)
                if self.root:
                    self.root.after(4000, _periodic_menu_update)
            except Exception as e:
                self._record_suppressed_error('systems.menu.periodic_wrapper', e)
            # EventBus Subscriptions für Kontext-Refresh
            try:
                if getattr(self, 'event_bus', None):
                    def _on_files_changed(evt):
                        try:
                            self._update_menu_context()
                        except Exception as e:
                            self._record_suppressed_error('systems.menu.event.files_changed', e)
                    def _on_customer_change(evt):
                        try:
                            self._update_menu_context()
                        except Exception as e:
                            self._record_suppressed_error('systems.menu.event.customer_changed', e)
                    try:
                        self.event_bus.subscribe('files.changed', _on_files_changed)
                    except Exception as e:
                        self._record_suppressed_error('systems.menu.subscribe.files', e)
                    try:
                        self.event_bus.subscribe('customer.changed', _on_customer_change)
                    except Exception as e:
                        self._record_suppressed_error('systems.menu.subscribe.customer', e)
            except Exception as e:
                self._record_suppressed_error('systems.menu.subscribe.wrapper', e)
            
        except Exception as e:
            self._handle_error(
                e,
                context="systems.init",
                user_message=self._t("Systeme konnten nicht initialisiert werden") if hasattr(self, '_t') else "System Initialisierung Fehler"
            )
    
    def _preload_ui_components(self):
        """PERFORMANCE: Preload commonly used UI components for faster rendering"""
        try:
            # Preload common colors for instant access
            common_colors = ['primary', 'surface', 'text_primary', 'success', 'warning', 'error']
            for color in common_colors:
                self.get_color(color)  # This caches them
            
            # Preload common typography for instant access
            common_fonts = ['body', 'heading', 'subheading', 'button', 'caption']
            for font in common_fonts:
                self.get_typography(font)  # This caches them
                
            # Preload common spacing values
            common_spacing = ['sm', 'md', 'lg', 'card_padding', 'element_gap']
            for spacing in common_spacing:
                self.get_spacing(spacing)  # This caches them
                
            self.logger.info("UI components preloaded for optimal performance")
            
        except Exception as e:
            self.logger.warning(f"UI preloading warning: {e}")
    
    def _smart_feature_detection(self):
        """SMART: Automatic feature detection and optimization"""
        try:
            # Detect available features and optimize accordingly
            features = {
                'advanced_toast': hasattr(self, 'toast_system') and self.toast_system is not None,
                'performance_monitoring': True,  # Always available
                'smart_caching': len(self._color_cache) > 0,
                'enhanced_typography': True,
                'optimized_spacing': True
            }
            
            # Log detected features
            active_features = [name for name, status in features.items() if status]
            self.logger.info(f"Active features: {', '.join(active_features)}")
            
            # Store feature status for conditional functionality
            self._active_features = features
            
        except Exception as e:
            self.logger.warning(f"Feature detection warning: {e}")
            self._active_features = {}
    
    def _clear_cache_smart(self):
        """OPTIMIZATION: Smart cache clearing to prevent memory leaks"""
        try:
            # Clear caches but keep frequently used items
            if len(self._color_cache) > 50:  # Clear color cache if too large
                # Keep only most common colors
                essential_colors = {k: v for k, v in self._color_cache.items() 
                                  if k in ['primary', 'surface', 'text_primary', 'success', 'warning', 'error']}
                self._color_cache = essential_colors
                
            if len(self._font_cache) > 20:  # Clear font cache if too large
                essential_fonts = {k: v for k, v in self._font_cache.items() 
                                 if any(font in k for font in ['body', 'heading', 'button'])}
                self._font_cache = essential_fonts
                
            if len(self._ui_cache) > 30:  # Clear UI cache if too large
                essential_ui = {k: v for k, v in self._ui_cache.items() 
                               if k in ['md', 'lg', 'card_padding', 'element_gap']}
                self._ui_cache = essential_ui
                
            self.logger.info("Smart cache cleanup completed")
            
        except Exception as e:
            self.logger.warning(f"Cache cleanup warning: {e}")
    
    # Removed duplicate basic update_status to prevent signature conflicts
    
    def show_toast(self, message: str, type: str = "info", duration: int = 3000):
        """ENHANCED: Advanced toast notification system with animations"""
        try:
            # Accent-Reduktion (Option B): Vereinheitliche Farbtypen.
            # Erfolg & Warnung visuell wie Info (Primary), nur Systemstatus bleibt wirklich grün.
            original_type = type
            if type in ("success", "warning"):
                type = "info"
            if hasattr(self, 'toast_system') and self.toast_system:
                # Enhanced toast with auto-dismiss and animations
                self.toast_system.show_toast(message, type, duration)
            else:
                # Improved fallback toast using status bar and temporary window
                self._show_enhanced_fallback_toast(message, type, duration)
        except Exception as e:
            self._handle_error(e, context="toast.show", toast=False)

    # Unified alias (do not remove original show_toast usage) for new components expecting _show_toast
    def _show_toast(self, message: str, type: str = "info", duration: int = 3000):  # noqa: D401
        """Alias Wrapper für show_toast (Namensvereinheitlichung, keine Icons)."""
        try:
            return self.show_toast(message, type, duration)
        except Exception:
            try:
                self.logger.info(f"TOAST {type}: {message}")
            except Exception:
                pass
    
    def _show_enhanced_fallback_toast(self, message: str, type: str, duration: int):
        """ENHANCED: Improved fallback toast mit sicheren Farb-Fallbacks."""
        try:
            def _safe(col, fb):
                try:
                    if hasattr(self, 'get_color'):
                        return self.get_color(col)
                except Exception:
                    pass
                return fb
            color_map = {
                # Reduzierte Akzente: success/warning -> primary/text_secondary
                'success': _safe('primary', '#1F4E79'),
                'warning': _safe('text_secondary', '#6B7280'),
                'error': _safe('error', '#DC2626'),
                'info': _safe('primary', '#64748B'),
                'text_primary': _safe('text_primary', '#374151'),
                'text_secondary': _safe('text_secondary', '#6B7280')
            }
            if hasattr(self, 'status_label'):
                try:
                    self.status_label.configure(
                        text=f"● {message}",
                        text_color=color_map.get(type, color_map['text_primary'])
                    )
                    self.root.after(duration, lambda: self.status_label.configure(
                        text="Ready",
                        text_color=color_map['text_secondary']
                    ))
                except Exception:
                    pass
            self.logger.info(f"{type.upper()}: {message}")
        except Exception as e:
            self._handle_error(e, context="toast.fallback", toast=False, level="warning")
            try:
                self.logger.info(f"{type.upper()}: {message}")
            except Exception:
                pass

    # -------------------------------------------------------------
    # 🎯 AKZENT-REDUKTION HELPER (Option B)
    # Nur System-Gesamtstatus darf weiterhin grün sein. Alles andere:
    #  - Erfolg -> primary
    #  - Warnung -> primary oder text_secondary (je nach Domain)
    #  - Info -> primary
    #  - Zerstörerisch / Danger bleibt error (rot)
    # -------------------------------------------------------------
    def _accent(self, semantic: str, domain: str = "generic"):
        try:
            if semantic == 'success':
                if domain == 'system_status':  # einzig erlaubtes persistent Grün
                    return self.get_color('success')
                return self.get_color('primary')
            if semantic == 'warning':
                if domain in ('destructive', 'error_prone'):
                    return self.get_color('error')
                if domain in ('attention', 'upload_needed'):
                    return self.get_color('primary')
                return self.get_color('text_secondary')
            if semantic == 'info':
                return self.get_color('primary')
            return self.get_color(semantic)
        except Exception:
            # Fallback sicher
            return '#1F4E79' if semantic in ('success', 'info', 'warning') else '#DC2626' if semantic == 'error' else '#374151'
    
    # 📂 QUALITY GUI FOLDER STRUCTURE MANAGEMENT - Verbindliche Ordnerstruktur
    
    def create_project_structure(self, customer_name, project_date=None):
        """📂 Erstellt vollständige Projektstruktur nach bestehender Checker-Ordnerstruktur"""
        try:
            import datetime
            if not project_date:
                project_date = datetime.datetime.now().strftime("%Y-%m-%d")
            
            base_path = os.path.join("Checker_Projekte", customer_name, project_date)
            
            # Alle Standardordner erstellen
            for folder in self.STANDARD_PROJECT_STRUCTURE:
                full_path = os.path.join(base_path, folder)
                os.makedirs(full_path, exist_ok=True)
                
            self.logger.info(f"✅ Projektstruktur erstellt: {base_path}")

            # 🔄 Automatisch neuen Kunden registrieren falls noch nicht vorhanden
            try:
                customers_file = "customers.json"
                customers_data = None
                if os.path.exists(customers_file):
                    with open(customers_file, 'r', encoding='utf-8') as f:
                        try:
                            customers_data = json.load(f)
                        except Exception:
                            customers_data = None
                # Normalisiere in neues Format: {"customers": [{"name": ...}, ...]}
                updated = False
                if not customers_data:
                    customers_data = {"customers": []}
                if isinstance(customers_data, dict):
                    # Extrahiere bestehende Namen
                    existing_names = set()
                    if 'customers' in customers_data and isinstance(customers_data['customers'], list):
                        for c in customers_data['customers']:
                            if isinstance(c, dict):
                                n = c.get('name')
                                if n:
                                    existing_names.add(n)
                    else:
                        # Altes Format (Keys als Kunden)
                        for k,v in list(customers_data.items()):
                            if k in ('favorites','last_updated','_meta','customers'): continue
                            existing_names.add(k)
                            # migriere in neues Schema
                            if 'customers' not in customers_data:
                                customers_data['customers'] = []
                            customers_data['customers'].append({"name": k})
                            updated = True
                        # Entferne alte Top-Level Keys (optional nicht-kritisch)
                    if customer_name not in existing_names:
                        customers_data.setdefault('customers', []).append({"name": customer_name})
                        customers_data['last_updated'] = project_date
                        updated = True
                elif isinstance(customers_data, list):
                    # Liste -> konvertieren
                    names = {c.get('name') for c in customers_data if isinstance(c, dict)}
                    if customer_name not in names:
                        customers_data.append({"name": customer_name})
                        updated = True
                    customers_data = {"customers": customers_data, "last_updated": project_date}
                if updated:
                    with open(customers_file, 'w', encoding='utf-8') as f:
                        json.dump(customers_data, f, indent=2, ensure_ascii=False)
                    try:
                        self.show_toast(f"Neuer Kunde registriert: {customer_name}", "success")
                    except Exception:
                        pass
            except Exception as ce:
                self.logger.warning(f"Kunde konnte nicht automatisch registriert werden: {ce}")
            return base_path
            
        except Exception as e:
            self._handle_error(e, context="project.structure.create", user_message=self._t("Neues Projekt konnte nicht erstellt werden"))
            return None
    
    def validate_project_structure(self, project_path):
        """📂 Validiert und repariert Projektstruktur"""
        try:
            missing_folders = []
            for folder in self.STANDARD_PROJECT_STRUCTURE:
                full_path = os.path.join(project_path, folder)
                if not os.path.exists(full_path):
                    missing_folders.append(folder)
                    os.makedirs(full_path, exist_ok=True)
            
            if missing_folders:
                self.logger.info(f"🔧 Reparierte Ordnerstruktur: {len(missing_folders)} Ordner hinzugefügt")
            
            return len(missing_folders) == 0
            
        except Exception as e:
            self._handle_error(e, context="project.structure.validate", user_message=self._t("Projektstruktur ungültig"), toast=False)
            return False
    
    def get_project_paths(self, customer_name, project_date=None):
        """📂 Gibt alle wichtigen Projektpfade nach bestehender Struktur zurück"""
        try:
            import datetime
            if not project_date:
                project_date = datetime.datetime.now().strftime("%Y-%m-%d")
                
            base_path = os.path.join("Checker_Projekte", customer_name, project_date)
            
            return {
                'base': base_path,
                'ausgangstext': os.path.join(base_path, "01_Ausgangstext"),
                'angebot': os.path.join(base_path, "02_Angebot"),
                'prüfung': os.path.join(base_path, "03_Prüfung"),
                'finalisierung': os.path.join(base_path, "04_Finalisierung")
            }
        except Exception as e:
            self._handle_error(e, context="project.paths.get", user_message=self._t("Projekte konnten nicht ermittelt werden"), toast=False)
            return {}
    
    def _get_or_select_customer_for_upload(self):
        """📂 Professionelle Kundenauswahl mit Design-System"""
        try:
            # NEU: Falls bereits ein aktiver Kunde gesetzt ist, direkt verwenden (kein Dialog mehr nötig)
            active = getattr(self, 'current_customer', None)
            if active:
                try:
                    import re
                    clean_active = re.sub(r'[<>:"/\\|?*]', '_', active.strip())
                    return clean_active or active  # Fallback wenn Strip leer
                except Exception:
                    return active
            # Bestehende Kunden laden
            existing_customers = []
            try:
                if os.path.exists("customers.json"):
                    with open("customers.json", "r", encoding="utf-8") as f:
                        customers_data = json.load(f)
                        # Unterstützt beide Formate:
                        # Alt: {"KundeA": {...}, "KundeB": {...}}
                        # Neu: {"customers": [{"name": "KundeA"}, {"name": "KundeB"}], ...}
                        if isinstance(customers_data, dict):
                            if "customers" in customers_data and isinstance(customers_data["customers"], list):
                                for entry in customers_data["customers"]:
                                    name = entry.get("name") if isinstance(entry, dict) else None
                                    if name:
                                        existing_customers.append(name)
                            else:
                                # Alte Struktur: Keys sind Kundennamen (filtern Metafelder aus)
                                for k in customers_data.keys():
                                    if k not in ("favorites", "last_updated", "_meta"):
                                        existing_customers.append(k)
                        elif isinstance(customers_data, list):
                            # Falls direkt eine Liste gespeichert wurde
                            for entry in customers_data:
                                if isinstance(entry, dict):
                                    name = entry.get("name")
                                    if name:
                                        existing_customers.append(name)
                        # Duplikate entfernen & sortieren
                        existing_customers = sorted(dict.fromkeys(existing_customers), key=str.lower)
            except Exception:
                pass
            
            # Professioneller Kundenauswahl-Dialog
            customer_name = self._show_professional_customer_dialog(existing_customers)
            
            if customer_name:
                # Kundennamen bereinigen für Ordnernamen
                import re
                clean_name = re.sub(r'[<>:"/\\|?*]', '_', customer_name.strip())
                return clean_name
            
            return None
            
        except Exception as e:
            self._handle_error(e, context="customer.select", user_message=self._t("Kundenauswahl fehlgeschlagen") if hasattr(self, '_t') else None)
    
    def _offer_open_project_folder(self, customer_name):
        """📂 Bietet an, das Projekt-Verzeichnis zu öffnen"""
        try:
            import datetime
            project_date = datetime.datetime.now().strftime("%Y-%m-%d")
            
            # Toast mit Projekt-Ordner öffnen Option
            message = f"Projekt '{customer_name}' aktualisiert. Ordner öffnen?"
            
            # Erweiterte Toast-Nachricht mit Action
            if hasattr(self, 'extended_toast_system') and self.extended_toast_system:
                # Falls erweiterte Toast verfügbar, nutze diese für interaktive Nachrichten
                self.root.after(1000, lambda: self.extended_toast_system.show_toast(
                    message, 
                    "success", 
                    4000,
                    action_text="Ordner öffnen",
                    action_callback=lambda: self._open_specific_project(customer_name, project_date)
                ))
            else:
                # Standard Toast verwenden
                self.show_toast(message, "success")
                
        except Exception as e:
            self._handle_error(e, context="project.folder.offer", toast=False)
    
    def _open_specific_project(self, customer_name, project_date):
        """📂 Öffnet spezifisches Projekt im Datei-Explorer"""
        try:
            import subprocess, sys, os
            project_path = os.path.join("Checker_Projekte", customer_name, project_date)
            if not os.path.exists(project_path):
                self.show_toast("Projekt-Ordner nicht gefunden", "warning")
                return

            # Plattform-spezifische Logik
            cmd = None
            if sys.platform.startswith('win'):
                project_path = os.path.normpath(project_path)  # ✅ Normalisiert für Explorer
                cmd = ['explorer', project_path]
            elif sys.platform == 'darwin':
                cmd = ['open', project_path]
            else:  # Linux / andere Unix
                cmd = ['xdg-open', project_path]

            try:
                subprocess.run(cmd, check=False)
                self.logger.info(f"Projekt-Ordner geöffnet: {project_path}")
            except FileNotFoundError as fe:
                self._handle_error(fe, context="project.folder.open.cmd", user_message=self._t("Öffnen-Kommando nicht gefunden") if hasattr(self, '_t') else None)
                self.show_toast("Öffnen-Kommando fehlt", "error")
        except Exception as e:
            self._handle_error(e, context="project.folder.open", user_message=self._t("Projekt-Ordner konnte nicht geöffnet werden") if hasattr(self, '_t') else None)
            try:
                self.show_toast("Fehler beim Öffnen des Ordners", "error")
            except Exception:
                pass
    
    def _show_professional_customer_dialog(self, existing_customers):
        """🎨 Professioneller Kundenauswahl-Dialog mit Design-System

        Optimierungen (additiv, kompatibel):
        - Entprellte Live-Suche (vermeidet unnötige UI-Updates)
        - Tastaturnavigation (Pfeil ↑/↓ durch sichtbare Kunden, ENTER Auswahl)
        - Doppel-Klick Auswahl auf Kunden
        - Auto-Select wenn Filter genau einen Treffer liefert (ENTER im Suchfeld)
        - Validierung neuer Kundennamen (leer, Duplikat, ungültige Zeichen)
        - Rückgabeverhalten unverändert (String / None / "CANCELLED")
        """
        try:
            # ---------------------------------------------
            # 🔧 INTERNER STATE / VORBEREITUNG
            # ---------------------------------------------
            IGNORE_SYSTEM = {"customers", "favorites", "last_updated", "_meta", "__pycache__"}
            cleaned_customers = []
            seen = set()
            for c in existing_customers or []:
                if not c or c in IGNORE_SYSTEM or c.startswith('.'):
                    continue
                if c not in seen:
                    seen.add(c)
                    cleaned_customers.append(c)
            cleaned_customers.sort(key=str.lower)

            # Für Validierung (schneller Zugriff in Lower)
            existing_lower = {c.lower() for c in cleaned_customers}

            # ---------------------------------------------
            # 🪟 DIALOG BASIS
            # ---------------------------------------------
            dialog = ctk.CTkToplevel(self.root)
            dialog.title("Kunde auswählen")
            dialog.geometry("640x540")  # noch größer für mehr Platz (Liste + Eingabe)
            dialog.resizable(False, False)
            dialog.transient(self.root)
            dialog.grab_set()
            dialog.configure(fg_color=self.get_color('surface'))
            self._center_window(dialog, 520, 460, anchor_root=True)

            # ESC → Abbrechen
            # Platzhalter für nachträgliche Definition von _on_cancel
            # (wird später gebunden sobald Funktion existiert)

            result_container = {"value": None}
            customer_buttons = []  # (name, button)
            filter_var = ctk.StringVar(value="")
            debounce_after_id = {"id": None}
            current_index = {"i": -1}  # Tastaturnavigation
            active_customer = getattr(self, 'current_customer', None)
            # Runtime Recent-List (nur Session) – additive, keine Persistenz um Risiko zu vermeiden
            if not hasattr(self, '_recent_customers'):
                self._recent_customers = []

            # ---------------------------------------------
            # 🧩 HEADER
            # ---------------------------------------------
            def _build_header(parent):
                frame = ctk.CTkFrame(parent, fg_color="transparent")
                frame.pack(fill="x", padx=24, pady=(22, 8))
                title_lbl = ctk.CTkLabel(
                    frame,
                    text="Kunde für Projekt auswählen",
                    font=ctk.CTkFont(*self.get_typography("heading")),
                    text_color=self.get_color('gray_700')
                )
                title_lbl.pack(anchor="w")
                sub_lbl = ctk.CTkLabel(
                    frame,
                    text="Wähle einen Kunden oder erstelle einen neuen. 'Überspringen' = Upload ohne Projektordner.",
                    font=ctk.CTkFont(*self.get_typography("body")),
                    text_color=self.get_color('gray_500'),
                    wraplength=500,
                    justify="left"
                )
                sub_lbl.pack(anchor="w", pady=(4, 0))
                return frame

            # ---------------------------------------------
            # 🔍 FILTER & LISTE
            # ---------------------------------------------
            def _visible_buttons():
                return [btn for name, btn in customer_buttons if btn.winfo_manager()]

            def _reset_navigation():
                current_index["i"] = -1

            def _apply_filter_now():
                term = filter_var.get().strip().lower()
                any_visible = 0
                for name, btn in customer_buttons:
                    if not term or term in name.lower():
                        if not btn.winfo_manager():
                            btn.pack(fill="x", pady=2)
                        any_visible += 1
                    else:
                        if btn.winfo_manager():
                            btn.pack_forget()
                _reset_navigation()
                return any_visible

            def _schedule_filter(*_):
                # Entprellung 120ms
                if debounce_after_id["id"]:
                    try:
                        dialog.after_cancel(debounce_after_id["id"])
                    except Exception:
                        pass
                debounce_after_id["id"] = dialog.after(120, _apply_filter_now)

            def _select_customer(name):
                # Recent-Handling: an den Anfang setzen (ohne Duplikate)
                try:
                    if name and name != 'CANCELLED':
                        if name in self._recent_customers:
                            self._recent_customers.remove(name)
                        self._recent_customers.insert(0, name)
                        # Begrenzen
                            
                        if len(self._recent_customers) > 10:
                            self._recent_customers = self._recent_customers[:10]
                except Exception:
                    pass
                result_container["value"] = name
                dialog.destroy()

            def _build_customer_section(parent):
                nonlocal _apply_filter_now  # muss vor erster Verwendung für Rebinding deklariert werden
                if not cleaned_customers:
                    return None, None
                outer = ctk.CTkFrame(
                    parent,
                    fg_color=self.get_color('surface'),
                    border_width=1,
                    border_color=self.get_color('surface_border')
                )
                outer.pack(fill="x", padx=24, pady=10)
                header_row = ctk.CTkFrame(outer, fg_color="transparent")
                header_row.pack(fill="x", padx=16, pady=(14, 4))
                ctk.CTkLabel(
                    header_row,
                    text="Bestehende Kunden",
                    font=ctk.CTkFont(*self.get_typography("section_label")),
                    text_color=self.get_color('gray_700')
                ).pack(side="left")
                count_label = ctk.CTkLabel(
                    header_row,
                    text=f"{len(cleaned_customers)}",
                    font=ctk.CTkFont(*self.get_typography("caption")),
                    text_color=self.get_color('gray_500')
                )
                count_label.pack(side="right")
                filter_entry = ctk.CTkEntry(
                    outer,
                    height=32,
                    textvariable=filter_var,
                    placeholder_text="Suchen...",
                    font=ctk.CTkFont(*self.get_typography("body")),
                    fg_color=self.get_color('white'),
                    border_color=self.get_color('surface_border'),
                    text_color=self.get_color('gray_700')
                )
                filter_entry.pack(fill="x", padx=16, pady=(0, 8))
                filter_entry.bind("<KeyRelease>", _schedule_filter)
                scroll = ctk.CTkScrollableFrame(outer, height=150, fg_color="transparent")
                scroll.pack(fill="x", padx=16, pady=(0, 14))
                for customer in cleaned_customers:
                    btn = self._create_button(
                        scroll,
                        text=customer,
                        command=lambda c=customer: _select_customer(c),
                        kind="outline-primary",
                        height=32
                    )
                    btn.pack(fill="x", pady=2)
                    btn.bind("<Double-Button-1>", lambda e, c=customer: _select_customer(c))
                    customer_buttons.append((customer, btn))
                # Dynamische Aktualisierung der Anzahl nach Filter
                def _update_count():
                    visible = sum(1 for _n, b in customer_buttons if b.winfo_manager())
                    try:
                        count_label.configure(text=str(visible))
                    except Exception:
                        pass
                original_apply = _apply_filter_now
                def _wrapped_apply():
                    visible = original_apply()
                    _update_count()
                    return visible
                _apply_filter_now = _wrapped_apply
                return outer, filter_entry

            # ---------------------------------------------
            # ➕ NEUER KUNDE
            # ---------------------------------------------
            def _build_new_customer(parent):
                frame = ctk.CTkFrame(
                    parent,
                    fg_color=self.get_color('surface'),
                    border_width=1,
                    border_color=self.get_color('surface_border')
                )
                frame.pack(fill="x", padx=24, pady=6)
                ctk.CTkLabel(
                    frame,
                    text="Neuen Kunden erstellen:",
                    font=ctk.CTkFont(*self.get_typography("section_label")),
                    text_color=self.get_color('gray_700')
                ).pack(anchor="w", padx=16, pady=(14, 4))
                entry = ctk.CTkEntry(
                    frame,
                    placeholder_text="Kundenname eingeben...",
                    height=40,
                    font=ctk.CTkFont(*self.get_typography("body")),
                    fg_color=self.get_color('white'),
                    border_color=self.get_color('surface_border'),
                    text_color=self.get_color('gray_700')
                )
                entry.pack(fill="x", padx=16, pady=(0, 6))
                hint = ctk.CTkLabel(
                    frame,
                    text="Verbotene Zeichen: < > : \" / \\ | ? *",
                    font=ctk.CTkFont(*self.get_typography("caption")),
                    text_color=self.get_color('gray_500')
                )
                hint.pack(anchor="w", padx=16, pady=(0, 2))
                validation_label = ctk.CTkLabel(
                    frame,
                    text="",
                    font=ctk.CTkFont(*self.get_typography("caption")),
                    text_color=self.get_color('warning')
                )
                validation_label.pack(anchor="w", padx=16, pady=(0, 10))
                return frame, entry, validation_label

            # ---------------------------------------------
            # 🧭 BUTTONS & VALIDIERUNG
            # ---------------------------------------------
            import re
            INVALID_RE = re.compile(r'[<>:"/\\|?*]')

            def _validate_new_name(name: str):
                if not name:
                    self.show_toast("Bitte Kundennamen eingeben", "warning")
                    return False
                if len(name.strip()) == 0:
                    self.show_toast("Mindestens ein Buchstabe erforderlich", "warning")
                    return False
                if INVALID_RE.search(name):
                    self.show_toast("Ungültiger Name (verbotene Zeichen)", "warning")
                    return False
                if name.lower() in existing_lower:
                    self.show_toast("Name bereits vorhanden", "warning")
                    return False
                return True

            def _on_create(entry_widget):
                name = entry_widget.get().strip()
                if _validate_new_name(name):
                    try:
                        validation_label.configure(text="")
                    except Exception:
                        pass
                    result_container["value"] = name
                    dialog.destroy()
                else:
                    try:
                        validation_label.configure(text="Ungültiger oder verwendeter Name")
                    except Exception:
                        pass

            def _on_skip():
                result_container["value"] = None
                dialog.destroy()

            def _on_cancel(event=None):  # event optional für Bindings
                result_container["value"] = "CANCELLED"
                dialog.destroy()

            dialog.bind("<Escape>", _on_cancel)

            def _build_buttons(parent, entry_widget):
                frame = ctk.CTkFrame(parent, fg_color="transparent")
                frame.pack(fill="x", padx=24, pady=(12, 22))
                self._create_button(
                    frame, text="Überspringen", command=_on_skip,
                    kind="outline-primary", height=36, width=140
                ).pack(side="left")
                self._create_button(
                    frame, text="Abbrechen", command=_on_cancel,
                    kind="outline-primary", height=36, width=140
                ).pack(side="right", padx=(10, 0))
                self._create_button(
                    frame, text="Kunden erstellen", command=lambda: _on_create(entry_widget),
                    kind="primary", height=36, width=160
                ).pack(side="right")
                return frame

            # ---------------------------------------------
            # 🏗️ ORCHESTRATION
            # ---------------------------------------------
            _build_header(dialog)
            # ---------------------------------------------
            # ⚡ SCHNELLAUSWAHL (Aktueller & Zuletzt verwendet)
            # ---------------------------------------------
            def _build_quick_section(parent):
                quick_items = []
                if active_customer:
                    quick_items.append(('Aktueller Kunde', active_customer))
                for rc in self._recent_customers:
                    if rc != active_customer and rc in cleaned_customers:
                        quick_items.append(('Zuletzt verwendet', rc))
                if not quick_items:
                    return None
                frame = ctk.CTkFrame(
                    parent,
                    fg_color=self.get_color('surface'),
                    border_width=1,
                    border_color=self.get_color('surface_border')
                )
                frame.pack(fill="x", padx=24, pady=(4, 6))
                inner = ctk.CTkFrame(frame, fg_color="transparent")
                inner.pack(fill="x", padx=16, pady=10)
                # Layout: zwei Spalten dynamisch
                row = 0
                for label_text, cust in quick_items[:6]:  # max 6 anzeigen
                    btn = self._create_button(
                        inner,
                        text=f"{cust}",
                        command=lambda c=cust: _select_customer(c),
                        kind="primary",
                        height=30
                    )
                    btn.grid(row=row, column=1, sticky='ew', padx=(8,0))
                    lbl = ctk.CTkLabel(
                        inner,
                        text=label_text,
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        text_color=self.get_color('gray_500')
                    )
                    lbl.grid(row=row, column=0, sticky='w')
                    row += 1
                for c in range(2):
                    inner.grid_columnconfigure(c, weight=1 if c==1 else 0)
                return frame

            _build_quick_section(dialog)
            customer_section, filter_entry = _build_customer_section(dialog)
            _, entry, validation_label = _build_new_customer(dialog)
            _build_buttons(dialog, entry)

            # --- Tastaturnavigation & Enter-Verhalten ---
            def _move_focus(delta):
                vis = _visible_buttons()
                if not vis:
                    return
                i = current_index["i"] + delta
                if i < 0:
                    i = len(vis) - 1
                elif i >= len(vis):
                    i = 0
                current_index["i"] = i
                try:
                    vis[i].focus_set()
                except Exception:
                    pass

            def _enter_in_filter(event=None):
                vis = _visible_buttons()
                if len(vis) == 1:
                    # Nur ein Treffer → direkt auswählen
                    for name, btn in customer_buttons:
                        if btn is vis[0]:
                            _select_customer(name)
                            return
                # Sonst Fokus auf Liste beginnen
                if vis:
                    current_index["i"] = 0
                    try:
                        vis[0].focus_set()
                    except Exception:
                        pass

            def _enter_on_button(event=None):
                # ENTER auf Kundenbutton → auswählen
                widget = event.widget
                for name, btn in customer_buttons:
                    if btn is widget:
                        _select_customer(name)
                        return

            if filter_entry:
                filter_entry.bind("<Return>", _enter_in_filter)
                filter_entry.bind("<Down>", lambda e: (_move_focus(1), "break"))
                filter_entry.bind("<Up>", lambda e: (_move_focus(-1), "break"))

            # Binde ENTER auf Buttons (für Tastatur Auswahl)
            for name, btn in customer_buttons:
                btn.bind("<Return>", _enter_on_button)
                btn.bind("<Up>", lambda e: (_move_focus(-1), "break"))
                btn.bind("<Down>", lambda e: (_move_focus(1), "break"))

            # ENTER im neuen Kundenfeld → erstellen
            entry.bind("<Return>", lambda e: _on_create(entry))
            entry.bind("<Escape>", _on_cancel)

            # Start-Fokus: Suchfeld falls vorhanden sonst Eingabe
            if filter_entry:
                filter_entry.focus()
            else:
                entry.focus()

            # Initiale Filteranzeige (keine Verzögerung)
            _apply_filter_now()

            dialog.wait_window()
            val = result_container["value"]
            if val == "CANCELLED":
                return "CANCELLED"
            return val

        except Exception as e:
            self._handle_error(e, context="customer.dialog", user_message=self._t("Kundenauswahl fehlgeschlagen"))
            return None
    
    def _is_source_text(self, file_path):
        """📂 Klassifiziert ob Datei ein Ausgangstext ist (für 01_Ausgangstext)"""
        # Alle hochgeladenen Dateien gehen standardmäßig in 01_Ausgangstext
        return True
    
    def _is_translation(self, file_path):
        """📂 Klassifiziert ob Datei eine Übersetzung ist (nicht relevant für diese Struktur)"""
        # In der neuen Struktur sind Übersetzungen Teil des Workflows, nicht separate Uploads
        return False
    
    def copy_files_to_project_structure(self, files, customer_name, project_date=None):
        """📂 Kopiert Dateien in Projektordner (vereinheitlicht: key 'source')"""
        try:
            import shutil
            import datetime

            if not project_date:
                project_date = datetime.datetime.now().strftime("%Y-%m-%d")

            base_path = self.create_project_structure(customer_name, project_date)
            if not base_path:
                return False

            project_paths = self.get_project_paths(customer_name, project_date)
            copied_files = {'source': [], 'translation': [], 'other': []}

            for file_path in files:
                try:
                    filename = os.path.basename(file_path)
                    target_folder = project_paths['ausgangstext']  # physischer Zielordner bleibt
                    target_path = os.path.join(target_folder, filename)
                    shutil.copy2(file_path, target_path)
                    # Einheitlicher key 'source'
                    copied_files['source'].append(target_path)
                except Exception as e:
                    self._handle_error(e, context="project.copy.file", toast=False)

            total_copied = sum(len(v) for v in copied_files.values())
            if total_copied > 0:
                self.logger.info(f"{total_copied} Dateien in Projektstruktur kopiert")
                self.show_toast(
                    f"{total_copied} Datei(en) in Projekt '{customer_name}' ({project_date}) gespeichert",
                    "success"
                )
                self.logger.info(f"Projekt erstellt/erweitert: {base_path}")
            return copied_files
        except Exception as e:
            self._handle_error(e, context="project.copy", user_message=self._t("Projekt-Ordner konnte nicht geöffnet werden") if hasattr(self, '_t') else "Projekt-Ordner Fehler", toast=False)
            return {}

    def copy_translation_files_to_project_structure(self, files, customer_name, project_date=None):
        """📂 Kopiert Übersetzungs-Dateien in eigenen Unterordner 'Übersetzungen'.

        Additiv: Verändert bestehende Struktur nicht (kein Update von STANDARD_PROJECT_STRUCTURE),
        legt bei Bedarf nur den Unterordner an. Rückgabeformat analog zur Source-Variante
        (keys: 'source','translation','other') damit bestehende Aufrufer nicht brechen.
        """
        try:
            import shutil
            import datetime

            if not project_date:
                project_date = datetime.datetime.now().strftime("%Y-%m-%d")

            base_path = self.create_project_structure(customer_name, project_date)
            if not base_path:
                return False

            translation_dir = os.path.join(base_path, "Übersetzungen")
            os.makedirs(translation_dir, exist_ok=True)

            copied_files = {'source': [], 'translation': [], 'other': []}
            for file_path in files:
                try:
                    filename = os.path.basename(file_path)
                    target_path = os.path.join(translation_dir, filename)
                    shutil.copy2(file_path, target_path)
                    copied_files['translation'].append(target_path)
                except Exception as e:
                    self._handle_error(e, context="project.copy.translation.file", toast=False)

            if copied_files['translation']:
                self.logger.info(f"{len(copied_files['translation'])} Übersetzungsdatei(en) in '{translation_dir}' gespeichert")
                try:
                    self.show_toast(
                        f"{len(copied_files['translation'])} Übersetzungsdatei(en) gespeichert",
                        "success"
                    )
                except Exception:
                    pass
            return copied_files
        except Exception as e:
            self._handle_error(e, context="project.copy.translation", user_message=self._t("Übersetzungs-Ordner Fehler") if hasattr(self, '_t') else "Übersetzungs-Ordner Fehler", toast=False)
            return {}
    
    def _upload_source_files(self):
        """Quelldatei-Upload: Kunde zuerst (optional) auswählen, dann Dateien im Kunden-Ordner wählen."""
        try:
            # 1. Kunde vorab wählen (oder Überspringen)
            customer_name = self._get_or_select_customer_for_upload()
            if customer_name == "CANCELLED":
                return  # Abbruch

            project_base = None
            initial_dir = None
            if customer_name:  # Kunde gewählt → Projektordner vorbereiten / öffnen
                try:
                    import datetime, os, subprocess, sys
                    project_date = datetime.datetime.now().strftime("%Y-%m-%d")
                    project_base = os.path.join("Checker_Projekte", customer_name, project_date)
                    ausgang_dir = os.path.join(project_base, "01_Ausgangstext")
                    os.makedirs(ausgang_dir, exist_ok=True)
                    initial_dir = ausgang_dir
                    # Optional Explorer öffnen (nur einmal pro Session & konfigurierbar)
                    # User-Wunsch: Kein doppeltes Fenster (Explorer + Dateiauswahl) – daher Guard
                    try:
                        if (getattr(self, 'auto_open_explorer', True)
                            and sys.platform.startswith('win')
                            and not getattr(self, '_opened_explorer_source_once', False)):
                            subprocess.Popen(['explorer', os.path.normpath(ausgang_dir)])
                            self._opened_explorer_source_once = True  # Merken: bereits geöffnet
                    except Exception:
                        pass
                except Exception:
                    initial_dir = None

            # 2. Dateidialog (initial_dir wenn vorhanden)
            file_types = [
                ("All Supported", "*.pdf;*.docx;*.txt;*.doc;*.rtf;*.odt"),
                ("PDF files", "*.pdf"),
                ("Word files", "*.docx;*.doc"),
                ("Text files", "*.txt"),
                ("Rich Text", "*.rtf"),
                ("OpenDocument", "*.odt")
            ]
            dialog_kwargs = {
                'title': "Ausgangstexte für Qualitätsanalyse auswählen",
                'filetypes': file_types
            }
            if initial_dir and os.path.isdir(initial_dir):
                dialog_kwargs['initialdir'] = initial_dir
            files = filedialog.askopenfilenames(**dialog_kwargs)
            if not files:
                return  # Nutzer hat keine Dateien gewählt / abgebrochen

            self._log_event("upload.source.start", count=len(files), customer=customer_name)
            from upload_service import get_upload_service
            service = get_upload_service(event_bus=getattr(self, 'event_bus', None), logger=self.logger)
            result = service.process_simple_upload(
                kind='source',
                selected_files=list(files),
                existing_files=self.uploaded_files['source'],
                customer_name=customer_name,
                copy_callback=self.copy_files_to_project_structure if customer_name else None,
            )
            added = result['added_files']
            duplicates = result['duplicate_files']
            if added:
                # Telemetrie: before_total berechnen bevor wir erweitern
                try:
                    before_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                except Exception:
                    before_total = None
                self.uploaded_files['source'].extend(added)
                if customer_name and result['meta'].get('project_copied'):
                    self._offer_open_project_folder(customer_name)
                self._schedule_update_file_counter()
                self._refresh_file_list_display()
                self._show_enhanced_upload_results("source", added)
                self._smart_file_pairing()
                self._check_and_show_manual_pairing_option()
                status_msg = f"{len(added)} Ausgangstexte organisiert"
                if duplicates:
                    status_msg += f" ({len(duplicates)} Duplikate ignoriert)"
                self.update_status(status_msg)
                self.show_toast(f"{len(added)} Ausgangstexte erfolgreich hochgeladen", "success")
                # Telemetrie: files.changed (aggregiert) – action added
                try:
                    if getattr(self, 'event_bus', None):
                        after_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                        self.event_bus.publish('files.changed', {
                            'action': 'added',
                            'file_type': 'source',
                            'count': len(added),
                            'filenames': [os.path.basename(a) for a in added],
                            'before_total': before_total,
                            'after_total': after_total
                        })
                except Exception:
                    pass
            else:
                self.show_toast("Alle ausgewählten Dateien waren bereits hochgeladen", "info")
            self._record_upload_telemetry(len(added), len(duplicates))
            self._log_event("upload.source.result", added=len(added), duplicates=len(duplicates), customer=customer_name)
        except Exception as e:
            msg = f"Fehler beim Hochladen der Ausgangstexte: {e}"
            self.update_status(msg)
            self.show_toast("Fehler beim Hochladen der Ausgangstexte", "error")
            self._handle_error(e, context="upload.source", toast=False)
    
    def _upload_batch_files(self):
        """Delegierter Batch Upload über UploadService mit echtem Fortschritt & Cancel."""
        try:
            file_types = [
                ("All Supported Files", "*.pdf;*.docx;*.txt;*.doc;*.rtf;*.odt;*.xlsx;*.pptx"),
                ("Document files", "*.pdf;*.docx;*.doc;*.rtf;*.odt"),
                ("Text files", "*.txt"),
                ("Spreadsheets", "*.xlsx;*.xls"),
                ("Presentations", "*.pptx;*.ppt"),
                ("All files", "*.*")
            ]
            files = filedialog.askopenfilenames(title="Dateien für Stapel-Upload und Analyse auswählen", filetypes=file_types)
            if not files:
                return
            self._log_event("upload.batch.start", count=len(files))

            # Overlay (zentral im Root, reuse Design Tokens)
            overlay = ctk.CTkToplevel(self.root)
            overlay.title("Batch Upload")
            overlay.transient(self.root)
            overlay.grab_set()
            self._center_window(overlay, 420, 200, anchor_root=False)
            wrapper = ctk.CTkFrame(overlay, fg_color=self.get_color('surface'), border_width=1, border_color=self.get_color('surface_border'))
            wrapper.pack(fill='both', expand=True, padx=16, pady=16)
            title_lbl = ctk.CTkLabel(wrapper, text='Batch Upload läuft...', font=ctk.CTkFont(*self.get_typography('subheading')))
            title_lbl.pack(anchor='w')
            info_lbl = ctk.CTkLabel(wrapper, text='Vorbereitung', font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('gray_600'))
            info_lbl.pack(anchor='w', pady=(4,8))
            pbar = ctk.CTkProgressBar(wrapper)
            pbar.set(0)
            pbar.pack(fill='x', pady=(0,10))
            cancel_flag = {'v': False}
            def _cancel():
                cancel_flag['v'] = True
                try: info_lbl.configure(text='Abbruch...')
                except Exception: pass
            cancel_btn = self._create_button(wrapper, text='Abbrechen', command=_cancel, kind='outline-primary', height=34)
            cancel_btn.pack(fill='x')
            error_lbl = ctk.CTkLabel(wrapper, text='', font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('error'))
            error_lbl.pack(fill='x', pady=(8,0))

            # Größenbasierten Fortschritt vorbereiten
            total_size = self._calculate_total_size(files)
            file_sizes = {}
            for f in files:
                try: file_sizes[f] = os.path.getsize(f)
                except Exception: file_sizes[f] = 0
            processed_size = {'v': 0}

            def _progress(idx, total, path):
                processed_size['v'] += file_sizes.get(path, 0)
                ratio = (processed_size['v'] / total_size) if total_size > 0 else (idx / max(1,total))
                def _ui():
                    try:
                        pbar.set(ratio)
                        info_lbl.configure(text=f"{idx}/{total} • {os.path.basename(path)}")
                    except Exception:
                        pass
                self.after(15, _ui)

            def _cancel_check():
                return cancel_flag['v']

            result_holder = {}
            def _worker():
                try:
                    from upload_service import get_upload_service
                    service = get_upload_service(event_bus=getattr(self,'event_bus',None), logger=self.logger)
                    result = service.process_batch_upload(list(files), self.uploaded_files['source'], self.uploaded_files['translation'], progress_callback=_progress, cancel_check=_cancel_check)
                    result_holder['result'] = result
                except Exception as ie:
                    result_holder['error'] = ie
                finally:
                    try: self.after(30, _finalize)
                    except Exception: _finalize()

            def _finalize():
                try:
                    result = result_holder.get('result')
                    err = result_holder.get('error')
                    if err:
                        try: error_lbl.configure(text='Fehler beim Batch Upload')
                        except Exception: pass
                        self._handle_error(err, context='upload.batch.worker')
                    elif result:
                        if not result.get('cancelled'):
                            try:
                                batch_before_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                            except Exception:
                                batch_before_total = None
                            if result['source_added']:
                                self.uploaded_files['source'].extend(result['source_added'])
                            if result['translation_added']:
                                self.uploaded_files['translation'].extend(result['translation_added'])
                            self._schedule_update_file_counter()
                            # Telemetrie
                            try:
                                if getattr(self, 'event_bus', None):
                                    after_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                                    if result['source_added']:
                                        self.event_bus.publish('files.changed', {
                                            'action': 'added','file_type':'source','count':len(result['source_added']),
                                            'filenames':[os.path.basename(a) for a in result['source_added']],
                                            'before_total': batch_before_total,'after_total': after_total
                                        })
                                    if result['translation_added']:
                                        self.event_bus.publish('files.changed', {
                                            'action': 'added','file_type':'translation','count':len(result['translation_added']),
                                            'filenames':[os.path.basename(a) for a in result['translation_added']],
                                            'before_total': batch_before_total,'after_total': after_total
                                        })
                            except Exception:
                                pass
                            if (result['source_added'] or result['translation_added']):
                                try: self._smart_file_pairing(); self._check_and_show_manual_pairing_option()
                                except Exception: pass
                            processed_files = [f"{name} → {role}" for name, role in result['processed_details']]
                            skipped_files = [os.path.basename(p) for p in result['duplicates']]
                            try:
                                self._show_batch_upload_results(len(result['source_added']), len(result['translation_added']), processed_files, skipped_files)
                            except Exception: pass
                            total_added = len(result['source_added']) + len(result['translation_added'])
                            if total_added > 0:
                                self.update_status(f"Batch Upload abgeschlossen: {total_added} Dateien hinzugefügt", 'success')
                                self.show_toast(f"Batch Upload erfolgreich: {total_added} Dateien verarbeitet", 'success')
                            else:
                                self.update_status('Keine neuen Dateien hinzugefügt', 'warning')
                                self.show_toast('Keine neuen Dateien hinzugefügt', 'warning')
                            self._record_upload_telemetry(total_added, len(skipped_files))
                            self._log_event('upload.batch.result', added=total_added, duplicates=len(skipped_files))
                        else:
                            self.show_toast('Batch Upload abgebrochen', 'warning')
                    try: overlay.destroy()
                    except Exception: pass
                except Exception as e:
                    try: self._handle_error(e, context='upload.batch.finalize')
                    except Exception: pass

            import threading
            threading.Thread(target=_worker, daemon=True).start()
        except Exception as e:
            msg = f"Error in batch upload: {e}"
            self.update_status(msg, "error")
            self.show_toast("Batch Upload fehlgeschlagen", "error")
            self._handle_error(e, context="upload.batch", toast=False)
    
    def _show_batch_upload_results(self, source_count, translation_count, processed_files, skipped_files):
        """SHOW BATCH UPLOAD RESULTS - Zusammenfassung (Farbtokens normalisiert)"""
        try:
            results_window = ctk.CTkToplevel(self.root)
            if hasattr(self, '_t'):
                results_window.title(self._t("Batch Upload Ergebnisse"))
            else:
                results_window.title("Batch Upload Ergebnisse")
            # Adaptive Höhe basierend auf Anzahl-Einträge
            base_w, base_h = 600, 500
            total_entries = len(processed_files) + len(skipped_files)
            if total_entries < 8:
                base_h = 420
            results_window.transient(self.root)
            results_window.grab_set()
            self._center_window(results_window, base_w, base_h, anchor_root=False)

            content_frame = ctk.CTkFrame(results_window, fg_color="transparent")
            content_frame.pack(fill="both", expand=True, padx=20, pady=20)

            header = ctk.CTkLabel(
                content_frame,
                text=self._t("Batch Upload abgeschlossen") if hasattr(self, '_t') else "Batch Upload abgeschlossen",
                font=ctk.CTkFont(*self.get_typography('heading')),
                text_color=self.get_color('primary')
            )
            header.pack(pady=(0, 20))

            # ✅ Fallback falls surface_elevated nicht definiert
            elevated_color = None
            try:
                elevated_color = self.get_color('surface_elevated')
            except Exception:
                elevated_color = None
            if not elevated_color or elevated_color in (None, '', 'transparent'):
                elevated_color = self.get_color('surface')
            stats_frame = ctk.CTkFrame(content_frame, fg_color=elevated_color)
            stats_frame.pack(fill="x", pady=(0, 15))
            stats_content = ctk.CTkFrame(stats_frame, fg_color="transparent")
            stats_content.pack(fill="x", padx=20, pady=15)

            stats_grid = ctk.CTkFrame(stats_content, fg_color="transparent")
            stats_grid.pack(fill="x")
            stats_grid.grid_columnconfigure((0, 1, 2), weight=1)

            # Source Stat
            source_stat = ctk.CTkFrame(stats_grid, fg_color=self.get_color('gray_100'))
            source_stat.grid(row=0, column=0, padx=(0, 5), pady=2, sticky="ew")
            ctk.CTkLabel(
                source_stat,
                text=str(source_count),
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self.get_color('primary')
            ).pack(pady=(10, 2))
            ctk.CTkLabel(
                source_stat,
                text=self._t("Ausgangstexte") if hasattr(self, '_t') else "Ausgangstexte",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('primary')
            ).pack(pady=(0, 10))

            # Translation Stat (verwende info Palette statt secondary*)
            translation_stat = ctk.CTkFrame(stats_grid, fg_color=self.get_color('info_light'))
            translation_stat.grid(row=0, column=1, padx=(5, 5), pady=2, sticky="ew")
            ctk.CTkLabel(
                translation_stat,
                text=str(translation_count),
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self.get_color('info')
            ).pack(pady=(10, 2))
            ctk.CTkLabel(
                translation_stat,
                text=self._t("Übersetzungen") if hasattr(self, '_t') else "Übersetzungen",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('info')
            ).pack(pady=(0, 10))

            # Skipped Stat
            skipped_stat = ctk.CTkFrame(stats_grid, fg_color=self.get_color('gray_100'))
            skipped_stat.grid(row=0, column=2, padx=(5, 0), pady=2, sticky="ew")
            ctk.CTkLabel(
                skipped_stat,
                text=str(len(skipped_files)),
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self._accent('warning')
            ).pack(pady=(10, 2))
            ctk.CTkLabel(
                skipped_stat,
                text=self._t("Übersprungen") if hasattr(self, '_t') else "Übersprungen",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self._accent('warning')
            ).pack(pady=(0, 10))

            if processed_files or skipped_files:
                details_frame = ctk.CTkScrollableFrame(
                    content_frame,
                    height=200,
                    fg_color=self.get_color('surface')
                )
                details_frame.pack(fill="both", expand=True, pady=(15, 15))

                if processed_files:
                    ctk.CTkLabel(
                        details_frame,
                        text=self._t("Verarbeitete Dateien:") if hasattr(self, '_t') else "Verarbeitete Dateien:",
                        font=ctk.CTkFont(*self.get_typography('subheading')),
                        # Accent Reduction: keine direkte success-Farbe hier (nur System-Status darf grün sein)
                        text_color=self._accent('success'),
                        anchor="w"
                    ).pack(fill="x", pady=(5, 5))
                    for file_info in processed_files:
                        ctk.CTkLabel(
                            details_frame,
                            text=file_info,
                            font=ctk.CTkFont(*self.get_typography('caption')),
                            text_color=self.get_color('text_secondary'),
                            anchor="w"
                        ).pack(fill="x", pady=1)

                if skipped_files:
                    ctk.CTkLabel(
                        details_frame,
                        text=self._t("Übersprungene Dateien:") if hasattr(self, '_t') else "Übersprungene Dateien:",
                        font=ctk.CTkFont(*self.get_typography('subheading')),
                        text_color=self._accent('warning'),
                        anchor="w"
                    ).pack(fill="x", pady=(15, 5))
                    for file_info in skipped_files:
                        ctk.CTkLabel(
                            details_frame,
                            text=file_info,
                            font=ctk.CTkFont(*self.get_typography('caption')),
                            text_color=self.get_color('text_secondary'),
                            anchor="w"
                        ).pack(fill="x", pady=1)

            close_btn = self._create_button(
                content_frame,
                text=self._t("Schließen") if hasattr(self, '_t') else "Schließen",
                command=results_window.destroy,
                kind="primary",
                height=40
            )
            close_btn.configure(width=140)
            close_btn.pack(pady=(15, 0))
            try:
                close_btn.focus_set()
            except Exception:
                pass

            # Shortcuts (Esc/Enter)
            results_window.bind("<Escape>", lambda e: results_window.destroy())
            results_window.bind("<Return>", lambda e: results_window.destroy())
        except Exception as e:
            self._handle_error(e, context="upload.batch.results", toast=False)
            try:
                self.show_toast(f"{source_count + translation_count} Dateien verarbeitet", "success")
            except Exception:
                pass
    
    def _setup_modern_file_management(self, parent):
        """📁 SETUP MODERN FILE MANAGEMENT - Enhanced file overview with drag-and-drop support"""
        try:
            # Eingebetteter Modus: keine zweite Karte / kein doppelter Header – direkt Listen + kompakte Aktionsleiste.
            embedded_actions = ctk.CTkFrame(parent, fg_color="transparent")
            embedded_actions.pack(fill="x", padx=10, pady=(8,4))
            embedded_actions.grid_columnconfigure(0, weight=1)
            # Aktionsbuttons rechts ausrichten (kleiner)
            actions_inner = ctk.CTkFrame(embedded_actions, fg_color="transparent")
            actions_inner.grid(row=0, column=1, sticky="e")
            self.refresh_files_btn = self._create_button(
                actions_inner,
                text=(self._t("Aktualisieren") if hasattr(self,'_t') else "Aktualisieren"),
                command=self._refresh_file_list,
                kind="primary",
                height=28
            )
            self.refresh_files_btn.configure(width=96)
            self.refresh_files_btn.pack(side="right", padx=(6,0))
            self.clear_files_btn = self._create_button(
                actions_inner,
                text=(self._t("Alles löschen") if hasattr(self,'_t') else "Alles löschen"),
                command=self._clear_all_files,
                kind="danger",
                height=28
            )
            self.clear_files_btn.configure(width=96)
            self.clear_files_btn.pack(side="right", padx=(0,6))
            try:
                self.clear_files_btn.configure(state="disabled")
            except Exception:
                pass

            # File lists container – direkt eingebettet
            lists_container = ctk.CTkFrame(parent, fg_color="transparent")
            lists_container.pack(fill="both", expand=True, padx=25, pady=(0, 20))
            lists_container.grid_columnconfigure((0, 1), weight=1)
            
            # Source files list
            self._create_file_list_section(lists_container, (self._t("Ausgangstexte") if hasattr(self,'_t') else "Ausgangstexte"), "source", 0)
            
            # Translation files list  
            self._create_file_list_section(
                lists_container,
                self._t("Übersetzungen") if hasattr(self, '_t') else "Übersetzungen",
                "translation",
                1
            )
            
            # File Pairing Section
            pairing_frame = ctk.CTkFrame(
                lists_container,
                fg_color=self.get_color('gray_50'),  # Neutral statt Info-Hintergrund für ruhigere Optik
                border_width=1,
                corner_radius=10
            )
            pairing_frame.grid(row=1, column=0, columnspan=2, sticky="ew", pady=(10, 0), padx=5)
            
            # Pairing header (blaues Band)
            pairing_header_bar = ctk.CTkFrame(pairing_frame, fg_color=self.get_color('primary'), height=38)
            pairing_header_bar.pack(fill='x', padx=0, pady=(0,4))
            pairing_header_bar.pack_propagate(False)
            pairing_header = ctk.CTkLabel(
                pairing_header_bar,
                text=(self._t("Dateipaarung") if hasattr(self,'_t') else "Dateipaarung"),
                font=ctk.CTkFont(*self.get_typography('section_label')),
                text_color=self.get_color('white')
            )
            pairing_header.pack(anchor='w', padx=12)

            # Innerer Content mit vereinheitlichten Abständen (16 / 12)
            pairing_inner = ctk.CTkFrame(pairing_frame, fg_color='transparent')
            pairing_inner.pack(fill='x', padx=16, pady=(0,12))

            self.pairing_status_label = ctk.CTkLabel(
                pairing_inner,
                text=(self._t("Keine Paare konfiguriert") if hasattr(self,'_t') else "Keine Paare konfiguriert"),
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_secondary')
            )
            self.pairing_status_label.pack(pady=(0,8), anchor='w')

            self.manual_pairing_button = self._create_button(
                pairing_inner,
                text=(self._t("Dateipaarung anpassen") if hasattr(self,'_t') else "Dateipaarung anpassen"),
                command=self._show_manual_pairing_dialog,
                kind="info",
                height=32
            )
            self.manual_pairing_button.pack(pady=(0,0), anchor='w')
            
        except Exception as e:
            try:
                self._handle_error(e, context="files.modern.setup", user_message=self._t("Modernes Dateimanagement Fehler"), toast=False)
            except Exception:
                pass
    
    def _create_file_list_section(self, parent, title, file_type, column):
        """📋 CREATE FILE LIST SECTION - Modern file list with interactive features"""
        try:
            # Section container
            section_frame = ctk.CTkFrame(
                parent,
                fg_color=self.get_color('gray_50'),
                border_width=1,
                corner_radius=10
            )
            # Mehr horizontaler Abstand zwischen den Karten
            section_frame.grid(row=0, column=column, sticky="nsew", padx=(0 if column == 0 else 24, 0), pady=0)
            
            # Blaues Header-Band (Primary)
            header = ctk.CTkFrame(section_frame, fg_color=self.get_color('primary'), height=40)
            header.pack(fill="x", padx=16, pady=(12, 0))
            header.pack_propagate(False)

            header_content = ctk.CTkFrame(header, fg_color="transparent")
            header_content.pack(fill="x", padx=8, pady=4)
            
            # Title with count
            title_label = ctk.CTkLabel(
                header_content,
                text=title,
                font=ctk.CTkFont(*self.get_typography('section_label')),
                text_color=self.get_color('white'),
                anchor="w"
            )
            title_label.pack(side="left")
            
            # File count for this type
            count_label = ctk.CTkLabel(
                header_content,
                text="0",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('white'),
                fg_color=self.get_color('primary_hover'),
                corner_radius=10,
                width=30,
                height=20
            )
            count_label.pack(side="right")
            
            # Store references for updating
            if file_type == "source":
                self.source_count_label = count_label
            else:
                self.translation_count_label = count_label
            
            # Scrollable file list
            file_list = ctk.CTkScrollableFrame(
                section_frame,
                height=220,
                fg_color=self.get_color('white'),
                border_width=0
            )
            # Mehr Innen-Abstand zwischen Rahmen und Scrollfläche
            file_list.pack(fill="both", expand=True, padx=16, pady=(12, 16))
            
            # Store reference for updating
            if file_type == "source":
                self.source_file_list = file_list
            else:
                self.translation_file_list = file_list
            
            # Empty state message
            # Vereinfachter Empty-State (eine Zeile) – deutsche Microcopy
            if file_type == "source":
                empty_txt = "Noch keine Quelltexte. Ziehen & ablegen oder klicken."
            else:
                empty_txt = "Noch keine Übersetzungen. Ziehen & ablegen oder klicken."
            empty_message = ctk.CTkLabel(
                file_list,
                text=empty_txt,
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('text_secondary'),
                justify="center"
            )
            empty_message.pack(expand=True, pady=40)
            
            # Store empty message reference
            if file_type == "source":
                self.source_empty_msg = empty_message
            else:
                self.translation_empty_msg = empty_message
                
        except Exception as e:
            try:
                self._handle_error(e, context="files.list.section", user_message=self._t("Dateiliste Abschnitt Fehler"), toast=False, file_type=file_type)
            except Exception:
                pass
    
    def _update_file_counter(self):
        """📊 KONSOLIDIERT: Aktualisiert ALLE Dateizähler - Header und Card"""
        try:
            start_ts = time.time()
            source_count = len(self.uploaded_files.get('source', []))
            translation_count = len(self.uploaded_files.get('translation', []))
            total_count = source_count + translation_count

            # Status/Readiness
            if source_count > 0 and translation_count > 0:
                pairs = min(source_count, translation_count)
                status_text = f" • {pairs} Paar(e) bereit für Analyse"
                status_color = self._accent('success', 'system_status')
                if hasattr(self, 'readiness_indicator'):
                    self.readiness_indicator.configure(text="● Bereit für Analyse", text_color=self._accent('success', 'system_status'))
            elif source_count > 0 or translation_count > 0:
                if source_count > translation_count:
                    missing = source_count - translation_count
                    status_text = f" • {missing} weitere Übersetzungsdatei(en) hochladen"
                else:
                    missing = translation_count - source_count
                    status_text = f" • {missing} weitere Ausgangstexte hochladen"
                status_color = self._accent('warning', 'upload_needed')
                if hasattr(self, 'readiness_indicator'):
                    self.readiness_indicator.configure(text="● Weitere Dateien hochladen", text_color=self._accent('warning', 'upload_needed'))
            else:
                status_text = " • Dateien hochladen um Analyse zu beginnen"
                status_color = self.get_color('text_secondary')
                if hasattr(self, 'readiness_indicator'):
                    self.readiness_indicator.configure(text="● Warten auf Dateien", text_color=self.get_color('text_secondary'))

            # Terminologie-Anpassung: "Quelltexte" statt "Ausgangstexte" in neuen UI-Elementen
            counter_text = f"Dateien: {source_count} Quelltexte, {translation_count} Übersetzungen{status_text}"
            simple_counter_text = f"Dateien: {source_count} Quelltexte, {translation_count} Übersetzungen"

            # Neue Badges aktualisieren
            # Neuer kombinierter Badge
            if hasattr(self, 'upload_combined_badge'):
                try:
                    self.upload_combined_badge.configure(text=f"Quelltexte: {source_count} | Übersetzungen: {translation_count}")
                except Exception:
                    pass
            # Legacy Label weiterhin unterstützen falls noch vorhanden
            if hasattr(self, 'header_file_counter_label'):
                self.header_file_counter_label.configure(text=simple_counter_text, text_color=status_color)
            if hasattr(self, 'card_file_counter_label'):
                self.card_file_counter_label.configure(text=counter_text, text_color=status_color)
            if hasattr(self, 'file_counter_label'):
                self.file_counter_label.configure(text=counter_text, text_color=status_color)

            # Neues subtiles Status-Label (nur falls vorhanden)
            if hasattr(self, 'upload_status_label'):
                try:
                    # Zeige nur den dynamischen Teil ohne komplette Wiederholung
                    if 'bereit' in status_text.lower():
                        self.upload_status_label.configure(text=self._t('Bereit für Analyse'), text_color=self._accent('success','upload_ready'))
                    elif 'weitere' in status_text.lower():
                        self.upload_status_label.configure(text=self._t('Weitere Dateien erforderlich'), text_color=self._accent('warning','upload_needed'))
                    else:
                        self.upload_status_label.configure(text=self._t('Warten auf Dateien'), text_color=self.get_color('gray_500'))
                except Exception:
                    pass

            if hasattr(self, 'file_count_badge'):
                self.file_count_badge.configure(text=f"{total_count} files")
                if total_count == 0:
                    self.file_count_badge.configure(fg_color=self.get_color('gray_400'))
                elif total_count < 5:
                    self.file_count_badge.configure(fg_color=self.get_color('primary'))
                else:
                    self.file_count_badge.configure(fg_color=self.get_color('gray_600'))

            if hasattr(self, 'source_count_label'):
                self.source_count_label.configure(text=f"{source_count} Ausgangstexte")
            if hasattr(self, 'translation_count_label'):
                self.translation_count_label.configure(text=f"{translation_count} Übersetzungen")

            if hasattr(self, 'analyze_button'):
                if source_count > 0 and translation_count > 0:
                    self.analyze_button.configure(
                        state="normal",
                        fg_color=self.get_color('primary'),
                        text=(self._t("Qualitätsanalyse starten") if hasattr(self, '_t') else "Qualitätsanalyse starten")
                    )
                else:
                    self.analyze_button.configure(
                        state="disabled",
                        fg_color=self.get_color('gray_400'),
                        text=(self._t("Weitere Dateien hochladen") if hasattr(self, '_t') else "Weitere Dateien hochladen")
                    )

            # Clear-All Button toggeln
            if hasattr(self, 'clear_files_btn'):
                try:
                    if total_count == 0:
                        self.clear_files_btn.configure(state="disabled")
                    else:
                        self.clear_files_btn.configure(state="normal")
                except Exception:
                    pass

            if hasattr(self, 'logger'):
                self.logger.info(f"✅ File counter update: {source_count} source, {translation_count} translation files")
            # Performance & State Telemetrie
            try:
                duration_ms = int((time.time() - start_ts) * 1000)
                self._publish_files_state(
                    source_count=source_count,
                    translation_count=translation_count,
                    total_count=total_count,
                    duration_ms=duration_ms,
                    ts=start_ts
                )
            except Exception:
                pass

            # Folgeaktionen
            self._refresh_file_list_display()
            self._smart_file_pairing()
            self._check_and_show_manual_pairing_option()

        except Exception as e:
            # Fallbacks ohne UnboundLocalError
            try:
                if hasattr(self, 'header_file_counter_label'):
                    self.header_file_counter_label.configure(text="Dateien: Fehler beim Zählen")
                if hasattr(self, 'card_file_counter_label'):
                    self.card_file_counter_label.configure(text="Dateien: Fehler beim Zählen")
            except Exception:
                pass
            try:
                if hasattr(self, 'update_file_count'):
                    self.update_file_count(0)
            except Exception:
                pass
            self._handle_error(
                e,
                context="files.counter.update",
                user_message=(self._t("Dateizähler konnte nicht aktualisiert werden") if hasattr(self,'_t') else "Dateizähler konnte nicht aktualisiert werden"),
                toast=False
            )
    
    # --------------------------------------------------------------
    # Debounce Helper: Verhindert mehrfachen UI-Refresh bei Massenupload
    # --------------------------------------------------------------
    def _schedule_update_file_counter(self, delay_ms: int = 80):
        """Planung eines debounced Updates.

        Mehrere schnelle Änderungen (Uploads/Removals) lösen nur einen
        tatsächlichen Zähler-/Pairing-Update nach Ablauf von delay_ms aus.
        Fällt auf direkten Aufruf zurück falls root fehlt.
        """
        try:
            if not hasattr(self, '_pending_file_counter_job'):
                self._pending_file_counter_job = None
            # Vorherigen Job abbrechen
            if self._pending_file_counter_job and self.root:
                try:
                    self.root.after_cancel(self._pending_file_counter_job)
                except Exception:
                    pass
            if self.root:
                scheduled_at = time.time()
                def _run():
                    try:
                        self._pending_file_counter_job = None
                        self._update_file_counter()
                        if getattr(self, 'event_bus', None):
                            self.event_bus.publish('files.counter.debounced', {
                                'delay_ms': delay_ms,
                                'scheduled_at': scheduled_at,
                                'executed_at': time.time(),
                                'queue_latency_ms': int((time.time() - scheduled_at) * 1000)
                            })
                    except Exception:
                        pass
                self._pending_file_counter_job = self.root.after(delay_ms, _run)
            else:
                self._update_file_counter()
        except Exception:
            try:
                self._update_file_counter()
            except Exception:
                pass

    # --------------------------------------------------------------
    # Files State Telemetrie Helper (Rate-Limit + Diff)
    # --------------------------------------------------------------
    def _publish_files_state(self, source_count: int, translation_count: int, total_count: int, duration_ms: int, ts: float):
        """Publiziert files.state Event mit Deltas & Rate-Limit.

        Rate-Limit: max 1 Event / 120ms
        Liefert zusätzlich diff zu vorherigem Snapshot.
        """
        try:
            if not getattr(self, 'event_bus', None):
                return
            now = time.time()
            if not hasattr(self, '_last_files_state_ts'):
                self._last_files_state_ts = 0.0
            if not hasattr(self, '_last_files_state_snapshot'):
                self._last_files_state_snapshot = {
                    'source': None,
                    'translation': None,
                    'total': None,
                    'pairs_ready': None
                }
            # Rate Limit
            if (now - self._last_files_state_ts) < 0.12:
                return
            pairs_ready = min(source_count, translation_count)
            prev = self._last_files_state_snapshot
            diff = {
                'source': (None if prev['source'] is None else source_count - prev['source']),
                'translation': (None if prev['translation'] is None else translation_count - prev['translation']),
                'total': (None if prev['total'] is None else total_count - prev['total']),
                'pairs_ready': (None if prev['pairs_ready'] is None else pairs_ready - prev['pairs_ready'])
            }
            payload = {
                'source': source_count,
                'translation': translation_count,
                'total': total_count,
                'pairs_ready': pairs_ready,
                'duration_ms': duration_ms,
                'ts': ts,
                'diff': diff
            }
            self.event_bus.publish('files.state', payload)
            # Snapshot aktualisieren
            self._last_files_state_snapshot = {
                'source': source_count,
                'translation': translation_count,
                'total': total_count,
                'pairs_ready': pairs_ready
            }
            self._last_files_state_ts = now
        except Exception:
            pass
    
    def _refresh_file_list_display(self):
        """🔄 REFRESH FILE LIST DISPLAY - Update visual file list with current files"""
        try:
            try:
                self.logger.debug("🔄 Refreshing file lists…")
            except Exception:
                pass
            
            # Update source files display
            if hasattr(self, 'source_file_list'):
                try:
                    self.logger.debug(f"Updating source files: {len(self.uploaded_files.get('source', []))} files")
                except Exception as e:
                    self._record_suppressed_error('files.list.refresh.source.debug', e)
                self._update_file_list_content('source', self.source_file_list, self.source_empty_msg)
            else:
                try:
                    self.logger.warning("source_file_list not found")
                except Exception as e:
                    self._record_suppressed_error('files.list.refresh.source.missing_warn', e)
            
            # Update translation files display
            if hasattr(self, 'translation_file_list'):
                try:
                    self.logger.debug(f"Updating translation files: {len(self.uploaded_files.get('translation', []))} files")
                except Exception as e:
                    self._record_suppressed_error('files.list.refresh.translation.debug', e)
                self._update_file_list_content('translation', self.translation_file_list, self.translation_empty_msg)
            else:
                try:
                    self.logger.warning("translation_file_list not found")
                except Exception as e:
                    self._record_suppressed_error('files.list.refresh.translation.missing_warn', e)
                
        except Exception as e:
            try:
                self._handle_error(e, context="files.list.refresh", user_message=self._t("Dateiliste Refresh Fehler"), toast=False)
            except Exception as e2:
                self._record_suppressed_error('files.list.refresh.handle_error', e2)
            try:
                import traceback
                traceback.print_exc()
            except Exception as e3:
                self._record_suppressed_error('files.list.refresh.traceback', e3)
    
    def _update_file_list_content(self, file_type, list_frame, empty_msg):
        """📝 UPDATE FILE LIST CONTENT - Populate file list with current files"""
        try:
            files = self.uploaded_files.get(file_type, [])
            
            # Clear current content (but preserve empty_msg)
            for widget in list_frame.winfo_children():
                if widget != empty_msg:  # ✅ Empty-Message nicht zerstören
                    widget.destroy()
            
            if files:
                empty_msg.pack_forget()
                for i, file_path in enumerate(files):
                    self._create_file_item(list_frame, file_path, file_type, i)
                self._auto_hide_scrollbar(list_frame, hide=False)
            else:
                empty_msg.pack(expand=True, pady=40)
                self._auto_hide_scrollbar(list_frame, hide=True)
                
        except Exception as e:
            try:
                self._handle_error(e, context="files.list.content", user_message=self._t("Dateiliste Inhalt konnte nicht aktualisiert werden"), toast=False, file_type=file_type)
            except Exception as e2:
                self._record_suppressed_error('files.list.content.handle_error', e2)
            # Fallback: Show empty message
            try:
                empty_msg.pack(expand=True, pady=40)
            except Exception as e3:
                self._record_suppressed_error('files.list.content.fallback_empty', e3)
    
    def _create_file_item(self, parent, file_path, file_type, index):
        """📄 CREATE FILE ITEM - Individual file item with actions"""
        try:
            # File item container
            item_frame = self._create_card_frame(
                parent,
                border_width=1,
                corner_radius=8
            )
            item_frame.configure(height=60)
            item_frame.pack(fill="x", padx=5, pady=3)
            item_frame.pack_propagate(False)
            
            # File info section
            info_frame = ctk.CTkFrame(item_frame, fg_color="transparent")
            info_frame.pack(side="left", fill="both", expand=True, padx=10, pady=8)
            
            # File name
            filename = os.path.basename(file_path)
            name_label = ctk.CTkLabel(
                info_frame,
                text=filename,
                font=ctk.CTkFont(*self.get_typography('section_label')),
                text_color=self.get_color('text_primary'),
                anchor="w"
            )
            name_label.pack(fill="x", pady=(0, 2))
            
            # File path and size
            try:
                file_size = os.path.getsize(file_path)
                size_str = self._format_file_size(file_size)
                path_text = f"{file_path} • {size_str}"
            except Exception as e:
                self._record_suppressed_error('files.item.filesize', e)
                path_text = file_path
            
            path_label = ctk.CTkLabel(
                info_frame,
                text=path_text,
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('text_secondary'),
                anchor="w"
            )
            path_label.pack(fill="x")
            
            # Actions section
            actions_frame = ctk.CTkFrame(item_frame, fg_color="transparent")
            actions_frame.pack(side="right", padx=8, pady=8)
            
            # Remove button
            remove_btn = self._create_button(
                actions_frame,
                text="Remove",
                command=lambda: self._remove_file(file_type, index),
                kind="danger",
                height=26
            )
            remove_btn.configure(width=70, corner_radius=6)
            remove_btn.pack()
            # Scrollbar sicherstellen
            self._auto_hide_scrollbar(parent, hide=False)

            # OPTIONAL: Vergleichs-Button wenn Pair vorhanden (nur einmal anzeigen – bevorzugt in Quelltext-Liste)
            try:
                paired = self._get_paired_file(file_path)
                show_compare = False
                source_path = None
                translation_path = None
                if paired:
                    if file_type == 'source':
                        source_path = file_path
                        translation_path = paired
                        show_compare = True
                    elif file_type == 'translation':
                        # Zeige Button nur falls kein Pendant bereits in Source-Liste sichtbar wäre
                        # (Vermeidet doppelte Buttons für dasselbe Paar)
                        if not hasattr(self, '_pair_button_created') or not self._pair_button_created.get(paired):
                            translation_path = file_path
                            source_path = paired
                            show_compare = True
                if show_compare and source_path and translation_path:
                    # Tracking um Doppelung zu vermeiden
                    if not hasattr(self, '_pair_button_created'):
                        self._pair_button_created = {}
                    self._pair_button_created[source_path] = True
                    compare_btn = self._create_button(
                        actions_frame,
                        text=(self._t("Vergleichen") if hasattr(self,'_t') else "Vergleichen"),
                        command=lambda sp=source_path, tp=translation_path: self._open_file_comparison(sp, tp),
                        kind="secondary",
                        height=26
                    )
                    compare_btn.configure(width=90, corner_radius=6)
                    compare_btn.pack(pady=(4,0))
                    # Doppelklick auf gesamten Frame öffnet ebenfalls Vergleich
                    item_frame.bind("<Double-Button-1>", lambda e, sp=source_path, tp=translation_path: self._open_file_comparison(sp, tp))
                else:
                    # Fallback: Doppel-Klick öffnet einzelne Datei systemweit
                    item_frame.bind("<Double-Button-1>", lambda e, p=file_path: self._open_single_file(p))
            except Exception as e:
                try:
                    self._record_suppressed_error('files.item.compare_button', e)
                except Exception:
                    pass
            
        except Exception as e:
            try:
                self._handle_error(e, context="files.item.create", user_message=self._t("Dateielement konnte nicht erstellt werden"), toast=False)
            except Exception as e2:
                self._record_suppressed_error('files.item.create.handle_error', e2)
    
    def _format_file_size(self, size_bytes):
        """DATEIGRÖSSE FORMATIEREN (Delegation) - Single Source of Truth.

        Diese frühere lokale Implementierung delegiert jetzt an die zentrale
        Utility-Funktion `format_file_size` um Duplikate zu eliminieren.
        (Duplicate-Prevention Policy)
        """
        try:
            from quality_gui_utilities import format_file_size
            return format_file_size(int(size_bytes) if size_bytes is not None else 0)
        except Exception:
            # Minimaler Fallback falls Import fehlschlägt
            try:
                b = int(size_bytes)
                if b < 1024:
                    return f"{b} B"
                if b < 1024**2:
                    return f"{b/1024:.1f} KB"
                if b < 1024**3:
                    return f"{b/(1024**2):.1f} MB"
                return f"{b/(1024**3):.1f} GB"
            except Exception:
                return "Unknown"
    
    def _remove_file(self, file_type, index):
        """🗑️ REMOVE FILE - Remove specific file from list"""
        try:
            files = self.uploaded_files.get(file_type, [])
            if 0 <= index < len(files):
                removed_file = files.pop(index)
                filename = os.path.basename(removed_file)
                before_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation')) + 1  # +1 weil bereits entfernt
                self._update_file_counter()
                after_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                self.show_toast((self._t("Datei entfernt") + f": {filename}") if hasattr(self,'_t') else f"Datei entfernt: {filename}", "success")
                # Telemetrie files.changed publizieren
                try:
                    if getattr(self, 'event_bus', None):
                        self.event_bus.publish('files.changed', {
                            'action': 'removed',
                            'file_type': file_type,
                            'filename': filename,
                            'after_total': after_total,
                            'before_total': before_total
                        })
                except Exception:
                    pass
                
        except Exception as e:
            try:
                self._handle_error(e, context="files.item.remove", user_message=self._t("Dateielement konnte nicht entfernt werden"), toast=True)
            except Exception:
                pass

    def _smart_file_pairing(self):
        """SMART FILE PAIRING - nutzt pairing_utils.smart_pair_files (testbar)."""
        try:
            from pairing_utils import smart_pair_files
            from pairing_service import get_pairing_service  # Lazy Import
            source_files = self.uploaded_files.get('source', [])
            translation_files = self.uploaded_files.get('translation', [])
            # Telemetrie
            if not hasattr(self, '_telemetry_counters'):
                self._telemetry_counters = {}
            self._telemetry_counters.setdefault('pairing_invocations', 0)
            self._telemetry_counters['pairing_invocations'] += 1
            pairs, unmatched_source, unmatched_translation = smart_pair_files(
                source_files, translation_files,
                lambda: get_pairing_service(event_bus=getattr(self, 'event_bus', None))
            )
            # Normierung für alte Struktur
            self.file_pairs = [
                {
                    'source': p.source,
                    'translation': p.translation,
                    'similarity': getattr(p, 'similarity', 0.0),
                    'source_name': getattr(p, 'source_name', ''),
                    'translation_name': getattr(p, 'translation_name', '')
                } for p in pairs
            ]
            self.unmatched_files = {'source': unmatched_source, 'translation': unmatched_translation}
            # Mapping für schnellen Lookup (beide Richtungen)
            try:
                self._pair_lookup = {}
                for p in self.file_pairs:
                    src = p.get('source')
                    trg = p.get('translation')
                    if src and trg:
                        self._pair_lookup[src] = trg
                        self._pair_lookup[trg] = src
            except Exception as map_e:
                self._record_suppressed_error('pairing.lookup.build', map_e)
            self._display_file_pairing_results(self.file_pairs, unmatched_source, unmatched_translation)
            self._update_pairing_status_display()
        except Exception as e:
            try:
                self.logger.exception("Error in smart file pairing")
            except Exception:
                pass

    # =============================
    #   DATEI-VERGLEICH (Side-by-Side)
    # =============================
    def _get_paired_file(self, path):
        try:
            return getattr(self, '_pair_lookup', {}).get(path)
        except Exception:
            return None

    def _open_single_file(self, file_path):
        """Öffnet Datei mit Standard-Anwendung (Fallback bei Doppelklick ohne Paar)"""
        try:
            import os
            os.startfile(file_path)
            try:
                self.show_toast((self._t("Datei geöffnet") if hasattr(self,'_t') else "Datei geöffnet"), 'success')
            except Exception:
                pass
        except Exception as e:
            try:
                self._handle_error(e, context='file.open.single', user_message=self._t('Datei konnte nicht geöffnet werden') if hasattr(self,'_t') else 'Datei konnte nicht geöffnet werden', toast=True)
            except Exception:
                pass

    def _open_file_comparison(self, source_path, translation_path):
        """Öffnet ein Fenster mit Quelltext & Übersetzung nebeneinander."""
        try:
            import os
            if not (source_path and translation_path and os.path.exists(source_path) and os.path.exists(translation_path)):
                self.show_toast(self._t('Vergleich nicht möglich') if hasattr(self,'_t') else 'Vergleich nicht möglich', 'warning')
                return

            # Fenster erstellen
            win = ctk.CTkToplevel(self)
            win.title(self._t('Dateivergleich') if hasattr(self,'_t') else 'Dateivergleich')
            try:
                win.geometry('1400x800')
            except Exception:
                pass

            bg = self.get_color('surface') if hasattr(self, 'get_color') else '#FFFFFF'
            win.configure(fg_color=bg)

            # Header
            header = ctk.CTkFrame(win, fg_color=self.get_color('surface'), height=54)
            header.pack(fill='x')
            header.pack_propagate(False)

            title_lbl = ctk.CTkLabel(header,
                                     text=(self._t('Vergleich') if hasattr(self,'_t') else 'Vergleich'),
                                     font=ctk.CTkFont(*self.get_typography('heading_sm')),
                                     text_color=self.get_color('text_primary'))
            title_lbl.pack(side='left', padx=16)

            close_btn = self._create_button(header,
                                            text=(self._t('Schließen') if hasattr(self,'_t') else 'Schließen'),
                                            command=win.destroy,
                                            kind='secondary',
                                            height=30)
            close_btn.pack(side='right', padx=16, pady=12)

            # Main Container
            container = ctk.CTkFrame(win, fg_color='transparent')
            container.pack(fill='both', expand=True, padx=16, pady=12)
            container.grid_columnconfigure((0,1), weight=1)
            container.grid_rowconfigure(1, weight=1)

            # Helper zum Laden
            def _read_text(path):
                try:
                    # Große Dateien begrenzen
                    MAX_BYTES = 800_000  # ~0.8MB
                    with open(path, 'rb') as f:
                        data = f.read(MAX_BYTES)
                        truncated = f.read(1)
                    # Encoding heuristisch
                    import chardet  # falls installiert; ansonsten fallback
                    try:
                        enc = chardet.detect(data)['encoding'] or 'utf-8'
                    except Exception:
                        enc = 'utf-8'
                    text = data.decode(enc, errors='replace')
                    if truncated:
                        text += "\n… (Datei gekürzt für Vorschau)"
                    return text
                except Exception:
                    try:
                        with open(path, 'r', encoding='utf-8', errors='replace') as f:
                            return f.read()
                    except Exception:
                        return '(Inhalt konnte nicht geladen werden)'

            src_text = _read_text(source_path)
            trg_text = _read_text(translation_path)

            # Labels
            src_label = ctk.CTkLabel(container,
                                     text=(self._t('Quelltext') if hasattr(self,'_t') else 'Quelltext'),
                                     font=ctk.CTkFont(*self.get_typography('section_label')),
                                     anchor='w')
            src_label.grid(row=0, column=0, sticky='ew', padx=(0,8), pady=(0,4))
            trg_label = ctk.CTkLabel(container,
                                     text=(self._t('Übersetzung') if hasattr(self,'_t') else 'Übersetzung'),
                                     font=ctk.CTkFont(*self.get_typography('section_label')),
                                     anchor='w')
            trg_label.grid(row=0, column=1, sticky='ew', padx=(8,0), pady=(0,4))

            # Textboxen
            txt_fg = self.get_color('white')
            txt_color = self.get_color('gray_700')
            border_col = self.get_color('surface_border') if hasattr(self,'get_color') else '#CCCCCC'
            src_box = ctk.CTkTextbox(container, fg_color=txt_fg, text_color=txt_color, wrap='word')
            trg_box = ctk.CTkTextbox(container, fg_color=txt_fg, text_color=txt_color, wrap='word')
            src_box.grid(row=1, column=0, sticky='nsew', padx=(0,8))
            trg_box.grid(row=1, column=1, sticky='nsew', padx=(8,0))

            try:
                src_box.insert('1.0', src_text)
                trg_box.insert('1.0', trg_text)
                src_box.configure(state='disabled')
                trg_box.configure(state='disabled')
            except Exception:
                pass

            # Synchronisiertes Scrollen
            def _sync_scroll(widget, other, *args):
                try:
                    other.yview_moveto(widget.yview()[0])
                except Exception:
                    pass
            def _on_src_scroll(event):
                try:
                    trg_box.yview('scroll', int(-1*(event.delta/120)), 'units')
                    return 'break'
                except Exception:
                    return None
            def _on_trg_scroll(event):
                try:
                    src_box.yview('scroll', int(-1*(event.delta/120)), 'units')
                    return 'break'
                except Exception:
                    return None
            src_box.bind('<MouseWheel>', _on_src_scroll)
            trg_box.bind('<MouseWheel>', _on_trg_scroll)

            # Tastatur Navigation (PageUp/Down synchron)
            for key in ('<Next>', '<Prior>'):
                src_box.bind(key, lambda e, k=key: (trg_box.event_generate(k), None)[1])
                trg_box.bind(key, lambda e, k=key: (src_box.event_generate(k), None)[1])

            # Info Toast
            try:
                self.show_toast(self._t('Vergleich geöffnet') if hasattr(self,'_t') else 'Vergleich geöffnet', 'info')
            except Exception:
                pass

        except Exception as e:
            try:
                self._handle_error(e, context='file.compare.open', user_message=self._t('Vergleich konnte nicht geöffnet werden') if hasattr(self,'_t') else 'Vergleich konnte nicht geöffnet werden', toast=True)
            except Exception:
                pass

    def _update_pairing_status_display(self):
        """UPDATE PAIRING STATUS DISPLAY - Aktualisiere Pairing Status in UI"""
        try:
            if hasattr(self, 'pairing_status_label'):
                pairs_count = len(getattr(self, 'file_pairs', []))
                unmatched_count = 0
                
                if hasattr(self, 'unmatched_files'):
                    unmatched_count = len(self.unmatched_files.get('source', [])) + len(self.unmatched_files.get('translation', []))
                
                if pairs_count > 0:
                    status_text = f"{pairs_count} Dateipaar(e) konfiguriert"
                    if unmatched_count > 0:
                        status_text += f" • {unmatched_count} ungepaarte Datei(en)"
                    
                    self.pairing_status_label.configure(
                        text=status_text,
                        # Accent Reduction: Paarungs-Status nutzt jetzt Primary statt success (Grün reserviert für system_status)
                        text_color=self._accent('success')
                    )
                else:
                    self.pairing_status_label.configure(
                        text="Keine Paare konfiguriert",
                        text_color=self.get_color('text_secondary')
                    )
                    
        except Exception as e:
            self._handle_error(e, context="pairing_status", user_message=None, toast=False, event_name="error.pairing.status")
    
    def _normalize_filename(self, filepath):
        """Delegiert an PairingService für Normalisierung (Backward Compatibility Stub)."""
        try:
            from pairing_service import get_pairing_service
            svc = get_pairing_service()
            return svc._normalize(filepath)  # bewusst interne Nutzung, um Duplikate zu vermeiden
        except Exception:
            try:
                return os.path.basename(filepath).lower()
            except Exception:
                return filepath
    
    def _calculate_filename_similarity(self, name1, name2):
        """Delegiert Similarity-Berechnung an PairingService (Backward Compatibility Stub)."""
        try:
            from pairing_service import get_pairing_service
            svc = get_pairing_service()
            return svc._similarity(name1, name2)
        except Exception:
            return 0.0
    
    def _display_file_pairing_results(self, pairs, unmatched_source, unmatched_translation):
        """📋 DISPLAY FILE PAIRING RESULTS - Zeige Paarung in der UI"""
        try:
            if not pairs and not unmatched_source and not unmatched_translation:
                return
                
            # Toast mit Paarung-Zusammenfassung
            if pairs:
                count_pairs = len(pairs)
                label_pairs = self._n(self._t('file pair') if hasattr(self,'_t') else 'Dateipaar', self._t('file pairs') if hasattr(self,'_t') else 'Dateipaare', count_pairs)
                message = f"📌 {count_pairs} {label_pairs} {self._t('automatically detected') if hasattr(self,'_t') else 'automatisch erkannt'}"
                if unmatched_source or unmatched_translation:
                    unmatched_total = len(unmatched_source) + len(unmatched_translation)
                    message += f" • {unmatched_total} {self._t('unpaired file(s)')}"
                self.show_toast(message, "success", duration=4000)
                
                # Detaillierte Info ins Log
                for pair in pairs:
                    self.logger.info(f"📌 Pair: {pair['source_name']} ↔ {pair['translation_name']} (Ähnlichkeit: {pair['similarity']:.1%})")
            else:
                self.show_toast(self._t("Automatic file pairing not possible - names too different"), "warning", duration=3000)
                
            # Status-Update
            status_parts = []
            if pairs:
                count_pairs = len(pairs)
                label_pairs = self._n(self._t('file pair') if hasattr(self,'_t') else 'Dateipaar', self._t('file pairs') if hasattr(self,'_t') else 'Dateipaare', count_pairs)
                status_parts.append(f"{count_pairs} {label_pairs}")
            if unmatched_source:
                status_parts.append(f"{len(unmatched_source)} {self._t('unpaired source file(s)')}")
            if unmatched_translation:
                status_parts.append(f"{len(unmatched_translation)} {self._t('unpaired translation(s)')}")
                
            if status_parts:
                self.update_status(f"Dateipaarung: {' | '.join(status_parts)}")
                
        except Exception as e:
            self._handle_error(e, context="pairing.results.display", user_message=self._t("Pairing Ergebnisse Anzeige Fehler"), toast=False)
    
    def get_file_pairs(self):
        """📋 GET FILE PAIRS - Hole aktuelle Dateipaarung für Qualitätsanalyse"""
        if hasattr(self, 'file_pairs'):
            return self.file_pairs
        else:
            # Fallback: Einfache Index-basierte Paarung
            source_files = self.uploaded_files.get('source', [])
            translation_files = self.uploaded_files.get('translation', [])
            
            simple_pairs = []
            max_pairs = min(len(source_files), len(translation_files))
            
            for i in range(max_pairs):
                simple_pairs.append({
                    'source': source_files[i],
                    'translation': translation_files[i],
                    'similarity': 0.5,  # Unbekannt
                    'source_name': os.path.basename(source_files[i]),
                    'translation_name': os.path.basename(translation_files[i])
                })
            
            return simple_pairs

    def _check_and_show_manual_pairing_option(self):
        """🎯 CHECK MANUAL PAIRING OPTION - Prüfe ob manuelles Pairing angeboten werden soll"""
        try:
            source_count = len(self.uploaded_files.get('source', []))
            translation_count = len(self.uploaded_files.get('translation', []))
            
            # Zeige Manual Pairing Option wenn:
            # 1. Beide Dateitypen vorhanden sind
            # 2. UND (ungepaarte Dateien existieren ODER Benutzer möchte manuell konfigurieren)
            if source_count > 0 and translation_count > 0:
                unmatched_total = 0
                if hasattr(self, 'unmatched_files'):
                    unmatched_total = len(self.unmatched_files.get('source', [])) + len(self.unmatched_files.get('translation', []))
                
                # Zeige Manual Pairing Button wenn ungepaarte Dateien existieren
                if unmatched_total > 0 or source_count != translation_count:
                    self.root.after(2000, lambda: self.show_toast(
                        self._t("Manual pairing available - Click 'Adjust file pairing'"),
                        "info",
                        duration=5000
                    ))
                    
        except Exception as e:
            self._handle_error(e, context="pairing.manual.option", user_message=self._t("Manuelles Pairing Option Fehler"), toast=False)

    def _show_manual_pairing_dialog(self):
        """🔧 SHOW MANUAL PAIRING DIALOG - Zeige manuelles Pairing Interface"""
        try:
            # Erstelle Manual Pairing Window
            pairing_window = ctk.CTkToplevel(self.root)
            pairing_window.title("Manuelle Dateipaarung")
            pairing_window.geometry("800x600")
            pairing_window.transient(self.root)
            pairing_window.grab_set()
            # Cleanup Handler für Scroll-Bindings
            def _cleanup_bindings():
                try:
                    # Entfernt globale Bindings nur wenn existierend
                    pairing_window.unbind_all('<MouseWheel>')
                    pairing_window.unbind_all('<Button-4>')
                    pairing_window.unbind_all('<Button-5>')
                except Exception:
                    pass
            try:
                def _confirm_close_pairing_window():
                    dirty = getattr(self, '_pair_dirty', False)
                    if dirty:
                        try:
                            self._confirm(
                                title=self._t('Discard changes?') if hasattr(self,'_t') else 'Änderungen verwerfen?',
                                message=self._t('You have unsaved pairing changes.') if hasattr(self,'_t') else 'Es gibt ungespeicherte Paarungen.',
                                on_confirm=lambda: (_cleanup_bindings(), pairing_window.destroy())
                            )
                        except Exception:
                            pairing_window.destroy()
                    else:
                        _cleanup_bindings(); pairing_window.destroy()
                pairing_window.protocol("WM_DELETE_WINDOW", _confirm_close_pairing_window)
            except Exception:
                pass
            # ESC beendet aktiven Drag
            try:
                pairing_window.bind('<Escape>', lambda e: self._cancel_pair_drag())
            except Exception:
                pass
            
            # Header
            header_frame = ctk.CTkFrame(pairing_window, fg_color=self.get_color('primary'), height=60)
            header_frame.pack(fill="x", padx=0, pady=0)
            header_frame.pack_propagate(False)
            
            header_label = ctk.CTkLabel(
                header_frame,
                text="Manuelle Dateipaarung",
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self.get_color('white')
            )
            header_label.pack(pady=15)
            
            # Main content
            content_frame = ctk.CTkFrame(pairing_window, fg_color="transparent")
            content_frame.pack(fill="both", expand=True, padx=20, pady=20)
            
            # Instructions
            instructions = ctk.CTkLabel(
                content_frame,
                text="Verbinde Ausgangstexte mit ihren Übersetzungen durch Ziehen oder Dropdown-Auswahl:",
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_primary')
            )
            instructions.pack(pady=(0, 20))

            # Live Drag Status
            try:
                self._drag_status_var = tk.StringVar(value="")
                drag_status = ctk.CTkLabel(
                    content_frame,
                    textvariable=self._drag_status_var,
                    font=ctk.CTkFont(*self.get_typography('caption')),
                    text_color=self.get_color('text_secondary')
                )
                drag_status.pack(pady=(0,10))
            except Exception:
                pass
            
            # Pairing area
            pairing_area = ctk.CTkFrame(content_frame)
            pairing_area.pack(fill="both", expand=True)
            
            # Setup pairing interface
            self._setup_manual_pairing_interface(pairing_area, pairing_window)
            
        except Exception as e:
            self._handle_error(e, context="pairing.manual.dialog", user_message=self._t("Manueller Pairing Dialog Fehler"))
            self.show_toast("Fehler beim Öffnen der manuellen Paarung", "error")

    def _setup_manual_pairing_interface(self, parent, window):
        """🎨 SETUP MANUAL PAIRING INTERFACE - Erstelle interaktives Pairing Interface"""
        try:
            # Scrollable content
            scroll_frame = ctk.CTkScrollableFrame(parent, height=400)
            scroll_frame.pack(fill="both", expand=True, padx=10, pady=10)
            
            # Current pairs section
            current_section = ctk.CTkLabel(
                scroll_frame,
                text="Aktuelle Dateipaarungen:",
                font=ctk.CTkFont(*self.get_typography('subheading')),
                text_color=self.get_color('primary')
            )
            current_section.pack(anchor="w", pady=(0, 10))
            
            # Zeige aktuelle Paare
            self.pairing_pairs_frame = ctk.CTkFrame(scroll_frame, fg_color=self.get_color('gray_50'))
            self.pairing_pairs_frame.pack(fill="x", pady=(0, 20))
            
            # Unmatched files section
            unmatched_section = ctk.CTkLabel(
                scroll_frame,
                text="Ungepaarte Dateien:",
                font=ctk.CTkFont(*self.get_typography('subheading')),
                text_color=self._accent('warning')
            )
            unmatched_section.pack(anchor="w", pady=(0, 10))
            
            # Two columns for unmatched files
            unmatched_container = ctk.CTkFrame(scroll_frame, fg_color="transparent")
            unmatched_container.pack(fill="x", pady=(0, 20))
            unmatched_container.grid_columnconfigure((0, 1), weight=1)
            
            # Unmatched source files
            self.unmatched_source_frame = ctk.CTkFrame(unmatched_container, fg_color=self.get_color('gray_50'))
            self.unmatched_source_frame.grid(row=0, column=0, sticky="nsew", padx=(0, 5))
            
            source_label = ctk.CTkLabel(
                self.unmatched_source_frame,
                text=self._t("Unpaired source files") if hasattr(self,'_t') else "Ungepaarte Quelldateien",
                font=ctk.CTkFont(*self.get_typography('section_label')),
                text_color=self.get_color('text_primary')
            )
            source_label.pack(pady=10)
            
            # Unmatched translation files
            self.unmatched_translation_frame = ctk.CTkFrame(unmatched_container, fg_color=self.get_color('gray_50'))
            self.unmatched_translation_frame.grid(row=0, column=1, sticky="nsew", padx=(5, 0))
            
            translation_label = ctk.CTkLabel(
                self.unmatched_translation_frame,
                text=self._t("Unpaired translations") if hasattr(self,'_t') else "Ungepaarte Übersetzungen",
                font=ctk.CTkFont(*self.get_typography('section_label')),
                text_color=self.get_color('text_primary')
            )
            translation_label.pack(pady=10)
            
            # Populate interface
            self._populate_manual_pairing_interface()
            
            # Ermittele Toplevel für sichere Save/Cancel Aktionen
            try:
                win = parent.winfo_toplevel()
            except Exception:
                win = parent

            # Button area
            button_frame = ctk.CTkFrame(parent, fg_color="transparent")
            button_frame.pack(fill="x", pady=(10, 0))
            
            # Undo Button
            undo_btn = self._create_button(
                button_frame,
                text=self._t("Undo") if hasattr(self, '_t') else "Undo",
                command=self._undo,  # nutzt neues Snapshot-System
                kind="primary"
            )
            undo_btn.pack(side="left", padx=(0, 10))
            self._legacy_undo_btn = undo_btn

            # Redo Button
            redo_btn = self._create_button(
                button_frame,
                text=self._t("Redo") if hasattr(self, '_t') else "Redo",
                command=self._redo,  # nutzt neues Snapshot-System
                kind="primary"
            )
            redo_btn.pack(side="left", padx=(0, 20))
            self._legacy_redo_btn = redo_btn

            # Reset button
            reset_btn = self._create_button(
                button_frame,
                text=self._t("Repeat automatic pairing") if hasattr(self,'_t') else "Automatische Paarung wiederholen",
                command=self._reset_to_automatic_pairing,
                kind="primary"
            )
            reset_btn.pack(side="left", padx=(0, 10))
            
            # Save button
            save_btn = self._create_button(
                button_frame,
                text=self._t("Save pairing") if hasattr(self,'_t') else "Paarung speichern",
                command=lambda: self._save_manual_pairing(win),
                kind="primary"
            )
            save_btn.pack(side="right")
            
            # Cancel button
            cancel_btn = self._create_button(
                button_frame,
                text=self._t("Cancel") if hasattr(self,'_t') else "Abbrechen",
                command=win.destroy,
                kind="primary"
            )
            cancel_btn.pack(side="right", padx=(0, 10))

            # Cleanup MouseWheel Bindings beim Schließen (falls bind_all genutzt wurde)
            try:
                def _cleanup_bindings():
                    try:
                        win.unbind_all('<MouseWheel>')
                        win.unbind_all('<Button-4>')
                        win.unbind_all('<Button-5>')
                    except Exception:
                        pass
                def _confirm_close_pairing():
                    if getattr(self, '_pair_dirty', False):
                        try:
                            self._confirm(
                                title=self._t('Discard changes?') if hasattr(self,'_t') else 'Änderungen verwerfen?',
                                message=self._t('You have unsaved pairing changes.') if hasattr(self,'_t') else 'Es gibt ungespeicherte Paarungen.',
                                on_confirm=lambda: (_cleanup_bindings(), win.destroy())
                            )
                        except Exception:
                            win.destroy()
                    else:
                        _cleanup_bindings(); win.destroy()
                win.protocol("WM_DELETE_WINDOW", _confirm_close_pairing)
            except Exception:
                pass
            
        except Exception as e:
            self._handle_error(e, context="pairing.manual.interface", user_message=self._t("Manuelle Pairing Oberfläche Fehler"))

    def _populate_manual_pairing_interface(self):
        """POPULATE MANUAL PAIRING INTERFACE - Fülle Interface mit aktuellen Daten"""
        try:
            self.logger.debug("🔧 Populating manual pairing interface…")
            start_time = time.perf_counter()
            created_items = {'source': 0, 'translation': 0}
            # Telemetrie-Zähler initialisieren (lazy)
            if not hasattr(self, '_telemetry_counters'):
                self._telemetry_counters = {}
            self._telemetry_counters.setdefault('pairing_paging_used', 0)
            if not hasattr(self, '_virtual_metrics'):
                self._virtual_metrics = {}
            
            # Clear existing content
            for widget in self.pairing_pairs_frame.winfo_children():
                widget.destroy()
            for widget in self.unmatched_source_frame.winfo_children()[1:]:  # Skip label
                widget.destroy()
            for widget in self.unmatched_translation_frame.winfo_children()[1:]:  # Skip label
                widget.destroy()
            
            # Wenn keine Daten vorhanden sind, führe Smart Pairing aus
            if not hasattr(self, 'file_pairs') or not hasattr(self, 'unmatched_files'):
                self.logger.debug("No pairing data found, executing smart pairing…")
                self._smart_file_pairing()
            
            # Show current pairs
            current_pairs = getattr(self, 'file_pairs', [])
            try:
                if getattr(self, '_pair_sort_similarity', False):
                    current_pairs = sorted(current_pairs, key=lambda p: p.get('similarity',0.0), reverse=True)
            except Exception:
                pass
            self.logger.debug("Current pairs: %d", len(current_pairs))
            
            # Toolbar (Undo/Redo) – nur einmal anlegen
            if not hasattr(self, '_pairing_toolbar'):
                toolbar = ctk.CTkFrame(self.pairing_pairs_frame, fg_color=self.get_color('transparent'))
                toolbar.pack(fill='x', pady=(0,4))
                self._pairing_toolbar = toolbar
                undo_btn = self._create_button(
                    toolbar,
                    text=self._t("Undo") if hasattr(self,'_t') else "Undo",
                    command=self._undo,
                    kind='secondary',
                    height=26
                )
                undo_btn.pack(side='left', padx=(0,4))
                redo_btn = self._create_button(
                    toolbar,
                    text=self._t("Redo") if hasattr(self,'_t') else "Redo",
                    command=self._redo,
                    kind='secondary',
                    height=26
                )
                redo_btn.pack(side='left', padx=(0,8))
                self._undo_btn_toolbar = undo_btn
                self._redo_btn_toolbar = redo_btn
                # Sort by similarity Toggle
                try:
                    self._pair_sort_var = tk.BooleanVar(value=getattr(self, '_pair_sort_similarity', False))
                    sort_cb = ctk.CTkCheckBox(
                        toolbar,
                        text=self._t("Sort by similarity") if hasattr(self,'_t') else "Nach Ähnlichkeit sortieren",
                        command=lambda: self._toggle_pair_sort(),
                        variable=self._pair_sort_var
                    )
                    sort_cb.pack(side='left', padx=(4,4))
                except Exception:
                    pass

            if current_pairs:
                for i, pair in enumerate(current_pairs):
                    self._create_pair_display_item(self.pairing_pairs_frame, pair, i)
            else:
                no_pairs_label = ctk.CTkLabel(
                    self.pairing_pairs_frame,
                    text=self._t("No pairs found") if hasattr(self,'_t') else "Keine Paare gefunden",
                    font=ctk.CTkFont(*self.get_typography('body')),
                    text_color=self.get_color('text_secondary')
                )
                no_pairs_label.pack(pady=20)
            
            # Show unmatched files
            unmatched = getattr(self, 'unmatched_files', {'source': [], 'translation': []})
            self.logger.debug("Unmatched files: source=%d, translation=%d", len(unmatched.get('source', [])), len(unmatched.get('translation', [])))
            # Live Filter Queries
            q_src = (self._src_filter.get().strip().lower() if hasattr(self, '_src_filter') else "")
            q_trg = (self._trg_filter.get().strip().lower() if hasattr(self, '_trg_filter') else "")
            def _apply_q(fs, q):
                try:
                    if not q:
                        return fs
                    return [f for f in fs if q in os.path.basename(f).lower()]
                except Exception:
                    return fs
            
            # Wenn keine unmatched Files aber uploaded Files vorhanden sind, verwende uploaded Files
            if not unmatched.get('source') and not unmatched.get('translation'):
                source_files = self.uploaded_files.get('source', [])
                translation_files = self.uploaded_files.get('translation', [])
                
                if source_files or translation_files:
                    self.logger.debug("Using uploaded files as unmatched (no pairing data found)")
                    unmatched = {
                        'source': [f for f in source_files if not any(p['source'] == f for p in current_pairs)],
                        'translation': [f for f in translation_files if not any(p['translation'] == f for p in current_pairs)]
                    }
                    self.logger.debug("Calculated unmatched: source=%d, translation=%d", len(unmatched['source']), len(unmatched['translation']))
            # Optional Paging for large datasets
            SOURCE_THRESHOLD = 150
            PAGE_SIZE = 60
            total_sources = len(unmatched.get('source', []))
            total_trans = len(unmatched.get('translation', []))
            if not hasattr(self, '_pairing_page_loaded'):
                self._pairing_page_loaded = False
            paged = (total_sources > SOURCE_THRESHOLD or total_trans > SOURCE_THRESHOLD) and not self._pairing_page_loaded
            filtered_sources = _apply_q(unmatched.get('source', []), q_src)
            filtered_trans = _apply_q(unmatched.get('translation', []), q_trg)
            total_sources = len(filtered_sources)
            total_trans = len(filtered_trans)
            src_slice = filtered_sources[:PAGE_SIZE] if paged else filtered_sources
            trans_slice = filtered_trans[:PAGE_SIZE] if paged else filtered_trans
            # Virtuelle Fenstergrößen Parameter (dynamisch versuchen abzuleiten)
            # Heuristik: Schätze wie viele Items vertikal passen anhand verfügbarer Höhe der Source-Frame
            try:
                available_height = self.unmatched_source_frame.winfo_height()
            except Exception:
                available_height = 0
            # Wenn Frame noch nicht gerendert ist (Höhe=0) fallback auf vorher gespeicherten Wert oder Default
            if available_height <= 0:
                # Versuch alten Wert zu nutzen
                available_height = getattr(self, '_last_pairing_source_height', 0)
            else:
                self._last_pairing_source_height = available_height
            # Typische Item-Höhe inkl. Padding geschätzt: 34px (Label/Frame + Spacing). Sicherheitskorridor 36.
            est_item_height = 36
            dyn_window = max(40, min(300, int(available_height / est_item_height))) if available_height > 0 else 120
            VWINDOW = dyn_window  # Dynamisches Fenster
            if not hasattr(self, '_virtual_pairing'):  # State Initialisierung
                self._virtual_pairing = {
                    'source_offset': 0,
                    'translation_offset': 0,
                    'window': VWINDOW,  # dynamisch anpassbar
                    'total_source': total_sources,
                    'total_translation': total_trans
                }
            vp = self._virtual_pairing
            # Falls Fenstergroesse sich geändert hat, aktualisieren
            if vp.get('window') != VWINDOW:
                vp['window'] = VWINDOW
            # Korrigiere Offsets falls sich Gesamtzahl geändert hat
            vp['total_source'] = total_sources
            vp['total_translation'] = total_trans
            vp['source_offset'] = min(vp.get('source_offset',0), max(0, total_sources - 1)) if total_sources else 0
            vp['translation_offset'] = min(vp.get('translation_offset',0), max(0, total_trans - 1)) if total_trans else 0

            def render_window(frame, files, ftype, offset_key):
                """Render ein virtuelles Fenster für einen Dateityp."""
                try:
                    offset = vp[offset_key]
                    win = vp['window']
                    window_files = files[offset:offset+win]
                    for f in window_files:
                        self._create_unmatched_file_item(frame, f, ftype)
                    # Anzahl erstellter Items protokollieren
                    created_items[ftype] += len(window_files)
                    # Navigation Buttons (oben/unten)
                    if offset > 0:
                        up_btn = self._create_button(
                            frame,
                            text=f"▲ {max(0, offset - win)}",
                            command=lambda: self._shift_virtual_window(offset_key, -win),
                            kind="primary",
                            height=24
                        )
                        up_btn.pack(fill="x", padx=5, pady=4)
                    if offset + win < len(files):
                        down_btn = self._create_button(
                            frame,
                            text=f"▼ {min(len(files)-1, offset+win)}",
                            command=lambda: self._shift_virtual_window(offset_key, win),
                            kind="primary",
                            height=24
                        )
                        down_btn.pack(fill="x", padx=5, pady=4)
                except Exception:
                    pass

            # Mousewheel Scroll Binding für dynamische Offsets
            def _bind_mousewheel(frame, offset_key):
                def _on_mousewheel(event):
                    try:
                        delta = 0
                        # Windows liefert event.delta in 120er Schritten
                        if hasattr(event, 'delta') and event.delta:
                            delta = -1 if event.delta > 0 else 1
                        elif hasattr(event, 'num') and event.num in (4,5):  # Linux
                            delta = -1 if event.num == 4 else 1
                        if delta != 0:
                            step = max(1, int(vp.get('window', 50) * 0.25))  # 25% Fenster pro Scroll
                            self._shift_virtual_window(offset_key, delta * step)
                    except Exception:
                        pass
                try:
                    frame.bind_all('<MouseWheel>', _on_mousewheel)  # Windows / Mac (Mac nutzt auch MouseWheel, delta anders ggf.)
                    frame.bind_all('<Button-4>', _on_mousewheel)     # Linux up
                    frame.bind_all('<Button-5>', _on_mousewheel)     # Linux down
                except Exception:
                    pass

            _bind_mousewheel(self.unmatched_source_frame, 'source_offset')
            _bind_mousewheel(self.unmatched_translation_frame, 'translation_offset')

            render_window(self.unmatched_source_frame, src_slice, 'source', 'source_offset')
            render_window(self.unmatched_translation_frame, trans_slice, 'translation', 'translation_offset')
            if paged:
                # Telemetrie: Nutzung Paging registrieren
                self._telemetry_counters['pairing_paging_used'] += 1
                def _load_all():
                    try:
                        self._pairing_page_loaded = True
                        self._populate_manual_pairing_interface()
                    except Exception:
                        self.logger.exception("Error loading full pairing lists")
                # 🧠 Komponiere Text ohne Annahme über Platzhalter im Übersetzungs-String
                if hasattr(self, '_t'):
                    sources_label = self._t('sources') if hasattr(self,'_t') else 'Quellen'
                    translations_label = self._t('translations') if hasattr(self,'_t') else 'Übersetzungen'
                    btn_text = (self._t("Show all") + f" ({total_sources} {sources_label} / {total_trans} {translations_label})")
                else:
                    btn_text = f"Alle anzeigen ({total_sources} Quellen / {total_trans} Übersetzungen)"
                more_btn = self._create_button(
                    self.unmatched_source_frame,
                    text=btn_text,
                    command=_load_all,
                    kind="primary"
                )
                more_btn.pack(fill="x", padx=8, pady=8)
            # Performance / Metrics erfassen
            try:
                elapsed = (time.perf_counter() - start_time) * 1000.0
                self._virtual_metrics['last_render_ms'] = round(elapsed, 2)
                self._virtual_metrics['window'] = self._virtual_pairing.get('window')
                self._virtual_metrics['created_source'] = created_items['source']
                self._virtual_metrics['created_translation'] = created_items['translation']
                self._virtual_metrics['total_source'] = total_sources
                self._virtual_metrics['total_translation'] = total_trans
                self.logger.debug("🪟 Virtual render: win=%s src_created=%s trans_created=%s elapsed=%.2fms src_total=%d trans_total=%d", self._virtual_metrics['window'], created_items['source'], created_items['translation'], elapsed, total_sources, total_trans)
            except Exception:
                pass
            # Nach initialem Render dynamische Justierung (nur wenn Frame-Höhen vorher 0 waren)
            try:
                if getattr(self, '_virtual_adjust_scheduled', False) is False:
                    self._virtual_adjust_scheduled = True
                    self.root.after(80, self._adjust_virtual_window_size_safe)
            except Exception:
                pass
                
        except Exception as e:
            self._handle_error(e, context="pairing.manual.populate", user_message=self._t("Manuelle Pairing Befüllung Fehler"), toast=False)
        finally:
            try:
                if hasattr(self, '_update_undo_redo_buttons'):
                    self._update_undo_redo_buttons()
            except Exception:
                pass

    def _adjust_virtual_window_size_safe(self):
        """Passe die virtuelle Fenstergröße adaptiv an reale Item-Höhen an (Heuristik)."""
        try:
            if not hasattr(self, '_virtual_pairing'):
                return
            frame = getattr(self, 'unmatched_source_frame', None)
            if not frame:
                return
            children = frame.winfo_children()
            if len(children) <= 1:  # nur Label vorhanden
                # Erneut versuchen
                self.root.after(120, self._adjust_virtual_window_size_safe)
                return
            # Label-Höhe abziehen
            header_h = children[0].winfo_height() if children else 0
            usable_h = max(0, frame.winfo_height() - header_h)
            # Durchschnittliche Höhe der ersten bis zu 10 Items (exkl. Label & Navigationsbuttons erkennbar an führenden Symbolen)
            item_heights = []
            for w in children[1:11]:
                try:
                    txt = getattr(w, 'cget', lambda *_: '')('text') if hasattr(w, 'cget') else ''
                    if isinstance(txt, str) and (txt.startswith('▲') or txt.startswith('▼')):
                        continue
                    item_heights.append(w.winfo_height())
                except Exception:
                    pass
            if not item_heights:
                return
            avg_h = sum(item_heights) / len(item_heights)
            if avg_h <= 0:
                return
            target_window = int(usable_h / avg_h) if avg_h > 0 else self._virtual_pairing.get('window', 120)
            target_window = max(20, min(300, target_window))
            current_window = self._virtual_pairing.get('window', target_window)
            # Nur aktualisieren wenn signifikant anders (>5 Unterschied)
            if abs(target_window - current_window) > 5:
                self._virtual_pairing['window'] = target_window
                self.logger.debug("🔄 Adjust virtual window size: %d -> %d (avg_h=%.1f usable_h=%d)", current_window, target_window, avg_h, usable_h)
                # Neu rendern ohne erneute Scheduling-Flut
                self._populate_manual_pairing_interface()
        except Exception:
            pass

    def _create_pair_display_item(self, parent, pair, index):
        """📄 CREATE PAIR DISPLAY ITEM - Erstelle anzeigbares Dateipaar"""
        try:
            pair_frame = ctk.CTkFrame(parent, fg_color=self.get_color('surface'), border_width=1, border_color=self.get_color('surface_border'))
            pair_frame.pack(fill="x", padx=10, pady=5)
            
            # Pair content
            content_frame = ctk.CTkFrame(pair_frame, fg_color="transparent")
            content_frame.pack(fill="x", padx=15, pady=10)
            
            # Source file
            source_label = ctk.CTkLabel(
                content_frame,
                text=f"{self._t('Source') if hasattr(self,'_t') else 'Source'}: {pair['source_name']}",
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_primary'),
                anchor="w"
            )
            source_label.pack(fill="x")
            
            # Arrow and similarity
            arrow_frame = ctk.CTkFrame(content_frame, fg_color="transparent")
            arrow_frame.pack(fill="x", pady=5)
            
            # Dynamische Farbgebung nach Ähnlichkeitswert
            sim = pair.get('similarity', 0.0)
            if sim >= 0.8:
                sim_color = self.get_color('success')
            elif sim < 0.5:
                sim_color = self.get_color('warning')
            else:
                sim_color = self.get_color('text_secondary')
            arrow_label = ctk.CTkLabel(
                arrow_frame,
                text=f"↓ Ähnlichkeit: {sim:.1%}",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=sim_color
            )
            arrow_label.pack(side="left")
            try:
                badge = ctk.CTkLabel(
                    arrow_frame,
                    text=f"{sim*100:.0f}%",
                    font=ctk.CTkFont(*self.get_typography('caption')),
                    text_color=sim_color,
                    fg_color=self.get_color('white'),
                    corner_radius=8,
                    width=42
                )
                badge.pack(padx=8, side="right")
            except Exception:
                pass
            # Kontextmenü
            try:
                self._attach_ctx(pair_frame, pair.get('source'))
            except Exception:
                pass
            
            # Translation file
            trans_label = ctk.CTkLabel(
                content_frame,
                text=f"{self._t('Translation') if hasattr(self,'_t') else 'Translation'}: {pair['translation_name']}",
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_primary'),
                anchor="w"
            )
            trans_label.pack(fill="x")
            
            # Actions
            actions_frame = ctk.CTkFrame(content_frame, fg_color="transparent")
            actions_frame.pack(fill="x", pady=(10, 0))
            
            # Unpair button
            unpair_btn = self._create_button(
                actions_frame,
                text=self._t("Unpair") if hasattr(self,'_t') else "Trennen",
                command=lambda: self._unpair_files(index),
                kind="warning",
                height=26
            )
            unpair_btn.configure(width=80)
            unpair_btn.pack(side="right")
            
        except Exception as e:
            self._handle_error(e, context="pairing.manual.pair_display_item", user_message=self._t("Pair Anzeige Element Fehler"), toast=False)

    def _create_unmatched_file_item(self, parent, file_path, file_type):
        """📄 CREATE UNMATCHED FILE ITEM - Erstelle ungepaarte Datei mit Pairing-Option"""
        try:
            self.logger.debug("Creating unmatched file item: %s (type: %s)", os.path.basename(file_path), file_type)
            
            item_frame = ctk.CTkFrame(parent, fg_color=self.get_color('surface'), border_width=1, border_color=self.get_color('surface_border'))
            item_frame.pack(fill="x", padx=5, pady=2)
            
            content_frame = ctk.CTkFrame(item_frame, fg_color="transparent")
            content_frame.pack(fill="x", padx=10, pady=8)
            
            # File name
            # _t nur aufrufen wenn vorhanden
            if hasattr(self, '_t'):
                file_prefix = self._t("Source") if file_type == "source" else self._t("Translation")
            else:
                file_prefix = "Source" if file_type == "source" else "Translation"
            file_label = ctk.CTkLabel(
                content_frame,
                text=f"{file_prefix}: {os.path.basename(file_path)}",
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_primary'),
                anchor="w"
            )
            file_label.pack(fill="x")
            try:
                self._attach_ctx(item_frame, file_path)
            except Exception:
                pass

            # Drag & Drop: Start Drag bei Linksklick halten
            try:
                item_frame.bind('<ButtonPress-1>', lambda e, fp=file_path, ft=file_type, w=item_frame: self._begin_pair_drag(fp, ft, w))
                item_frame.bind('<ButtonRelease-1>', lambda e, fp=file_path, ft=file_type: self._complete_pair_drag(fp, ft))
                item_frame.bind('<Leave>', lambda e: self._drag_leave_item(item_frame))
                item_frame.bind('<Enter>', lambda e, fp=file_path, ft=file_type, w=item_frame: self._drag_enter_item(fp, ft, w))
            except Exception:
                pass
            
            # Dropdown für manuelle Paarung
            if file_type == "source":
                # Zeige verfügbare Translation-Dateien
                if hasattr(self, 'unmatched_files') and self.unmatched_files.get('translation'):
                    available_translations = self.unmatched_files.get('translation', [])
                else:
                    # Fallback: Verwende alle translation files die nicht gepaart sind
                    all_translations = self.uploaded_files.get('translation', [])
                    paired_translations = [p['translation'] for p in getattr(self, 'file_pairs', [])]
                    available_translations = [f for f in all_translations if f not in paired_translations]
                
                self.logger.debug("Available translations for %s: %d", os.path.basename(file_path), len(available_translations))
                
                if available_translations:
                    dropdown_values = [self._prompt_translation()] + [os.path.basename(f) for f in available_translations]
                    
                    pair_dropdown = ctk.CTkComboBox(
                        content_frame,
                        values=dropdown_values,
                        command=lambda value, sf=file_path: self._manual_pair_files(sf, value, file_type),
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        height=24
                    )
                    pair_dropdown.pack(fill="x", pady=(5, 0))
                    pair_dropdown.set(self._prompt_translation())
                else:
                    # Keine verfügbaren Übersetzungen
                    no_trans_label = ctk.CTkLabel(
                        content_frame,
                        text=self._t("No unmatched translations available") if hasattr(self,'_t') else "Keine ungepaarten Übersetzungen verfügbar",
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        text_color=self.get_color('text_secondary')
                    )
                    no_trans_label.pack(fill="x", pady=(5, 0))
                    
            elif file_type == "translation":
                # Zeige verfügbare Source-Dateien
                if hasattr(self, 'unmatched_files') and self.unmatched_files.get('source'):
                    available_sources = self.unmatched_files.get('source', [])
                else:
                    # Fallback: Verwende alle source files die nicht gepaart sind
                    all_sources = self.uploaded_files.get('source', [])
                    paired_sources = [p['source'] for p in getattr(self, 'file_pairs', [])]
                    available_sources = [f for f in all_sources if f not in paired_sources]
                
                self.logger.debug("Available sources for %s: %d", os.path.basename(file_path), len(available_sources))
                
                if available_sources:
                    dropdown_values = [self._prompt_source()] + [os.path.basename(f) for f in available_sources]
                    
                    pair_dropdown = ctk.CTkComboBox(
                        content_frame,
                        values=dropdown_values,
                        command=lambda value, tf=file_path: self._manual_pair_files_translation(tf, value, file_type),
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        height=24
                    )
                    pair_dropdown.pack(fill="x", pady=(5, 0))
                    pair_dropdown.set(self._prompt_source())
                else:
                    # Keine verfügbaren Quellen
                    no_source_label = ctk.CTkLabel(
                        content_frame,
                        text=self._t("No unmatched sources available") if hasattr(self,'_t') else "Keine ungepaarten Ausgangstexte verfügbar",
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        text_color=self.get_color('text_secondary')
                    )
                    no_source_label.pack(fill="x", pady=(5, 0))
                    
        except Exception as e:
            self._handle_error(e, context="pairing.manual.unmatched.item", user_message=self._t("Ungepaartes Datei Element Fehler"), toast=False)

    def _manual_pair_files(self, source_file, selected_translation, file_type):
        """🔗 MANUAL PAIR FILES - Erstelle manuelle Dateipaarung (Source -> Translation)"""
        try:
            if selected_translation == self._prompt_translation():
                return
                
            # Finde vollständigen Pfad der ausgewählten Translation
            if hasattr(self, 'unmatched_files') and self.unmatched_files.get('translation'):
                available_translations = self.unmatched_files.get('translation', [])
            else:
                # Fallback
                all_translations = self.uploaded_files.get('translation', [])
                paired_translations = [p['translation'] for p in getattr(self, 'file_pairs', [])]
                available_translations = [f for f in all_translations if f not in paired_translations]
                
            translation_file = None
            
            for trans_file in available_translations:
                if os.path.basename(trans_file) == selected_translation:
                    translation_file = trans_file
                    break
                    
            if not translation_file:
                self.show_toast(self._t("Translation file not found"), "error")
                return
            
            # Erstelle neues Paar (Konflikt-Guard)
            new_pair = {
                'source': source_file,
                'translation': translation_file,
                'similarity': 1.0,  # Manuell = 100% Vertrauen
                'source_name': os.path.basename(source_file),
                'translation_name': os.path.basename(translation_file)
            }
            if self._is_file_already_paired(source_file, 'source') or self._is_file_already_paired(translation_file, 'translation'):
                self.show_toast(self._t("File already paired") if hasattr(self,'_t') else "Datei bereits gepaart", "warning")
                return
            
            # History Snapshot vor Mutation
            self._push_history()
            # Füge zu Paaren hinzu
            if not hasattr(self, 'file_pairs'):
                self.file_pairs = []
            self.file_pairs.append(new_pair)
            # History aufzeichnen (Undo: Pair entfernen)
            try:
                self._record_pair_action('create_pair', {'pair': new_pair})
            except Exception:
                pass
            
            # Entferne aus unmatched
            if not hasattr(self, 'unmatched_files'):
                self.unmatched_files = {'source': [], 'translation': []}
                
            if source_file in self.unmatched_files.get('source', []):
                self.unmatched_files['source'].remove(source_file)
            if translation_file in self.unmatched_files.get('translation', []):
                self.unmatched_files['translation'].remove(translation_file)
            
            # Interface aktualisieren
            self._populate_manual_pairing_interface()
            
            # WICHTIG: Aktualisiere auch Haupt-GUI Status
            self._update_pairing_status_display()
            
            self._pair_dirty = True
            self.show_toast(f"{self._t('Pair created')}: {os.path.basename(source_file)} ↔ {selected_translation}", "success")
            self.logger.info(f"✅ Manual pair created: {new_pair['source_name']} ↔ {new_pair['translation_name']}")
            
        except Exception as e:
            self._handle_error(e, context="pairing.manual.pair_files", user_message=self._t("Manuelle Paarung Fehler"))
            self.show_toast("Fehler beim Erstellen der Paarung", "error")

    def _manual_pair_files_translation(self, translation_file, selected_source, file_type):
        """MANUAL PAIR FILES TRANSLATION - Erstelle manuelle Dateipaarung (Translation -> Source)"""
        try:
            if selected_source == self._prompt_source():
                return
                
            # Finde vollständigen Pfad der ausgewählten Source
            if hasattr(self, 'unmatched_files') and self.unmatched_files.get('source'):
                available_sources = self.unmatched_files.get('source', [])
            else:
                # Fallback
                all_sources = self.uploaded_files.get('source', [])
                paired_sources = [p['source'] for p in getattr(self, 'file_pairs', [])]
                available_sources = [f for f in all_sources if f not in paired_sources]
                
            source_file = None
            
            for src_file in available_sources:
                if os.path.basename(src_file) == selected_source:
                    source_file = src_file
                    break
                    
            if not source_file:
                self.show_toast(self._t("Source file not found"), "error")
                return
            
            # Erstelle neues Paar (Konflikt-Guard)
            new_pair = {
                'source': source_file,
                'translation': translation_file,
                'similarity': 1.0,  # Manuell = 100% Vertrauen
                'source_name': os.path.basename(source_file),
                'translation_name': os.path.basename(translation_file)
            }
            if self._is_file_already_paired(source_file, 'source') or self._is_file_already_paired(translation_file, 'translation'):
                self.show_toast(self._t("File already paired") if hasattr(self,'_t') else "Datei bereits gepaart", "warning")
                return
            
            # History Snapshot vor Mutation
            self._push_history()
            # Füge zu Paaren hinzu
            if not hasattr(self, 'file_pairs'):
                self.file_pairs = []
            self.file_pairs.append(new_pair)
            # History aufzeichnen
            try:
                self._record_pair_action('create_pair', {'pair': new_pair})
            except Exception:
                pass
            
            # Entferne aus unmatched
            if not hasattr(self, 'unmatched_files'):
                self.unmatched_files = {'source': [], 'translation': []}
                
            if source_file in self.unmatched_files.get('source', []):
                self.unmatched_files['source'].remove(source_file)
            if translation_file in self.unmatched_files.get('translation', []):
                self.unmatched_files['translation'].remove(translation_file)
            
            # Interface aktualisieren
            self._populate_manual_pairing_interface()
            
            # WICHTIG: Aktualisiere auch Haupt-GUI Status
            self._update_pairing_status_display()
            
            self._pair_dirty = True
            self.show_toast(f"{self._t('Pair created')}: {selected_source} ↔ {os.path.basename(translation_file)}", "success")
            self.logger.info(f"✅ Manual pair created: {new_pair['source_name']} ↔ {new_pair['translation_name']}")
            
        except Exception as e:
            self._handle_error(e, context="pairing.manual.pair_files.translation", user_message=self._t("Manuelle Paarung (Translation) Fehler"))
            self.show_toast("Fehler beim Erstellen der Paarung", "error")

    def _unpair_files(self, pair_index):
        """UNPAIR FILES - Löse Dateipaarung auf"""
        try:
            if not hasattr(self, 'file_pairs') or pair_index >= len(self.file_pairs):
                return
                
            # Hole Paar
            pair = self.file_pairs[pair_index]
            
            # History Snapshot vor Mutation
            self._push_history()
            # Entferne aus Paaren
            removed_pair = self.file_pairs.pop(pair_index)
            
            # Füge zu unmatched hinzu
            if not hasattr(self, 'unmatched_files'):
                self.unmatched_files = {'source': [], 'translation': []}
                
            self.unmatched_files['source'].append(pair['source'])
            self.unmatched_files['translation'].append(pair['translation'])
            # History (Undo: Pair wieder einsetzen an Position)
            try:
                self._record_pair_action('remove_pair', {'pair': removed_pair, 'index': pair_index})
            except Exception:
                pass
            
            # Interface aktualisieren
            self._populate_manual_pairing_interface()
            
            # WICHTIG: Aktualisiere auch Haupt-GUI Status
            self._update_pairing_status_display()
            
            self._pair_dirty = True
            self.show_toast(f"{self._t('Pair removed')}: {pair['source_name']} ↔ {pair['translation_name']}", "info")
            self.logger.info(f"Pair unpaired: {pair['source_name']} ↔ {pair['translation_name']}")
            
        except Exception as e:
            self._handle_error(e, context="pairing.unpair")

    def _reset_to_automatic_pairing(self):
        """↻ RESET TO AUTOMATIC PAIRING - Setze auf automatische Paarung zurück"""
        try:
            # History Snapshot (einfacher) – vollständige Zustände bereits im History Stack
            self._push_history()
            # Führe automatische Paarung erneut aus
            self._smart_file_pairing()
            
            # Interface aktualisieren
            self._populate_manual_pairing_interface()
            
            # WICHTIG: Aktualisiere auch Haupt-GUI Status
            self._update_pairing_status_display()
            
            self._pair_dirty = True
            self.show_toast(self._t("Automatic pairing restored"), "info")
            
        except Exception as e:
            self._handle_error(e, context="pairing.reset_auto")

    def _save_manual_pairing(self, window):
        """✅ SAVE MANUAL PAIRING - Speichere manuelle Paarung"""
        try:
            # DEFENSIVER HOT-FIX: Falls Instanz vor Hinzufügen von _n erzeugt wurde
            if not hasattr(self, '_n'):
                try:
                    self._n = lambda singular, plural, count: singular if (isinstance(count, (int, float)) and int(count) == 1) else plural  # type: ignore
                    if hasattr(self, '_record_suppressed_error'):
                        try:
                            self._record_suppressed_error('i18n.plural.fallback_injected', RuntimeError('legacy instance without _n'))
                        except Exception:
                            pass
                except Exception:
                    pass
            # Aktualisiere Status
            pairs_count = len(getattr(self, 'file_pairs', []))
            unmatched_count = len(self.unmatched_files.get('source', [])) + len(self.unmatched_files.get('translation', []))
            
            # Zeige Ergebnis
            if pairs_count > 0:
                label_pairs = self._n(self._t('file pair') if hasattr(self,'_t') else 'Dateipaar', self._t('file pairs') if hasattr(self,'_t') else 'Dateipaare', pairs_count)
                message = f"{self._t('Pairing saved')}: {pairs_count} {label_pairs}"
                if unmatched_count > 0:
                    label_unmatched = self._n(self._t('unpaired file') if hasattr(self,'_t') else 'ungepaarte Datei', self._t('unpaired files') if hasattr(self,'_t') else 'ungepaarte Dateien', unmatched_count)
                    message += f" • {unmatched_count} {label_unmatched}"
                    
                self.show_toast(message, "success", duration=4000)
                status_label_pairs = self._n(self._t('file pair') if hasattr(self,'_t') else 'Dateipaar', self._t('file pairs') if hasattr(self,'_t') else 'Dateipaare', pairs_count)
                self.update_status(f"{self._t('Manual file pairing')}: {pairs_count} {status_label_pairs} {self._t('configured') if hasattr(self,'_t') else 'konfiguriert'}")
            else:
                self.show_toast(self._t("No pairs configured"), "warning")
            
            # WICHTIG: Aktualisiere Pairing Status Display in der Haupt-GUI
            self._update_pairing_status_display()
            
            # Schließe Dialog
            window.destroy()
            
            try:
                self.save_pairings()
            except Exception:
                pass
            self._pair_dirty = False
            self.logger.info(f"✅ Manual pairing saved: {pairs_count} pairs, {unmatched_count} unmatched files")
            
        except Exception as e:
            self._handle_error(e, context="pairing.save", user_message=self._t("Fehler beim Speichern der Paarung"))
    # ------------------------------------------------------------------
    # UNDO / REDO PAIRING SYSTEM (additiv, keine bestehende Signatur geändert)
    # ------------------------------------------------------------------
    def _record_pair_action(self, action_type: str, data: Dict[str, Any]):
        """Interne History-Aufzeichnung für Pairing Aktionen.
        action_type: create_pair | remove_pair | reset_auto_pairing
        data: kontextabhängige Daten (siehe Aufrufer)
        """
        if not hasattr(self, '_pair_history'):
            self._pair_history = []  # type: ignore
        if not hasattr(self, '_pair_redo'):
            self._pair_redo = []  # type: ignore
        self._pair_history.append({'action': action_type, 'data': data})
        # Redo-Stack leeren bei neuer Aktion
        self._pair_redo.clear()

    def _undo_pair_action(self):
        """DEPRECATED: Weiterleitung auf neues _undo System (Kompatibilität)."""
        return self._undo()

    def _redo_pair_action(self):
        """DEPRECATED: Weiterleitung auf neues _redo System (Kompatibilität)."""
        return self._redo()

    # ------------------------------------------------------------------
    # DRAG & DROP PAIRING (grundlegend)
    # ------------------------------------------------------------------
    def _shift_virtual_window(self, offset_key: str, delta: int):
        """Verschiebe das virtuelle Fenster für Unmatched-Listen."""
        try:
            if not hasattr(self, '_virtual_pairing'):
                return
            vp = self._virtual_pairing
            new_offset = max(0, vp[offset_key] + delta)
            total_key = 'total_source' if 'source' in offset_key else 'total_translation'
            limit = max(0, vp.get(total_key, 0) - 1)
            new_offset = min(new_offset, limit)
            if new_offset != vp[offset_key]:
                vp[offset_key] = new_offset
                self._populate_manual_pairing_interface()
        except Exception as e:
            # Navigation-Fehler sind nicht kritisch → Debug
            self._debug_silent(e, 'pairing.virtual_window')

    def _begin_pair_drag(self, file_path: str, file_type: str, widget):
        """Starte Drag für eine ungepaarte Datei."""
        try:
            self._pairing_drag = {'file': file_path, 'type': file_type, 'widget': widget}
            # Visuelles Feedback
            try:
                widget.configure(border_color=self.get_color('primary'))
            except Exception:
                pass
            try:
                if hasattr(self, '_drag_status_var') and self._drag_status_var:
                    self._drag_status_var.set(self._t('Drag to pair'))
            except Exception:
                pass
        except Exception as e:
            self._handle_error(e, context="pairing.drag.start", user_message=self._t("Drag Start Fehler"), toast=False)

    def _drag_enter_item(self, target_file: str, target_type: str, widget):
        """Hover über potentielles Drop-Ziel."""
        try:
            if not self._pairing_drag:
                return
            drag_type = self._pairing_drag.get('type')
            # Nur unterschiedlicher Typ erlaubt
            if drag_type == target_type:
                return
            try:
                widget.configure(border_color=self.get_color('success'))
            except Exception:
                self._debug_silent(Exception('border_color failed'), 'drag.enter.border')
            # Hintergrund leicht hervorheben
            try:
                widget.configure(fg_color=self.get_color('surface_hover'))
            except Exception:
                self._debug_silent(Exception('fg_color failed'), 'drag.enter.fg')
            try:
                if hasattr(self, '_drag_status_var') and self._drag_status_var:
                    self._drag_status_var.set(self._t('Drop to pair'))
            except Exception:
                self._debug_silent(Exception('status var failed'), 'drag.enter.status')
        except Exception as e:
            self._debug_silent(e, 'drag.enter')

    def _drag_leave_item(self, widget):
        try:
            if widget and self._pairing_drag and widget is not self._pairing_drag.get('widget'):
                try:
                    widget.configure(border_color=self.get_color('surface_border'))
                except Exception:
                    self._debug_silent(Exception('border reset failed'), 'drag.leave.border')
                # Hintergrund zurücksetzen
                try:
                    widget.configure(fg_color=self.get_color('gray_50'))
                except Exception:
                    self._debug_silent(Exception('fg reset failed'), 'drag.leave.fg')
        except Exception as e:
            self._debug_silent(e, 'drag.leave')

    def _complete_pair_drag(self, release_file: str, release_type: str):
        """Abschluss eines Drag & Drop Pairings, falls möglich."""
        try:
            if not self._pairing_drag:
                return
            drag_file = self._pairing_drag.get('file')
            drag_type = self._pairing_drag.get('type')
            if drag_file == release_file:
                # Gleiches Element – abbrechen
                self._cancel_pair_drag()
                return
            if drag_type == release_type:
                self.show_toast(self._t("Cannot pair identical type"), "warning")
                self._cancel_pair_drag()
                return
            # Bestimme Source/Translation Reihenfolge
            if drag_type == 'source' and release_type == 'translation':
                source_file, translation_file = drag_file, release_file
            elif drag_type == 'translation' and release_type == 'source':
                source_file, translation_file = release_file, drag_file
            else:
                self._cancel_pair_drag()
                return
            # Duplicate Pair Guard
            try:
                for existing in getattr(self, 'file_pairs', []):
                    if existing.get('source') == source_file and existing.get('translation') == translation_file:
                        self.show_toast(self._t('Pair already exists') if hasattr(self,'_t') else 'Pair existiert bereits', 'info')
                        self._cancel_pair_drag()
                        return
            except Exception:
                self._debug_silent(Exception('duplicate guard failed'), 'drag.complete.dupcheck')
            # Konflikt-Guard (einseitige Doppelbelegung)
            try:
                if self._is_file_already_paired(source_file, 'source') or self._is_file_already_paired(translation_file, 'translation'):
                    self.show_toast(self._t('File already paired') if hasattr(self,'_t') else 'Datei bereits gepaart', 'warning')
                    self._cancel_pair_drag()
                    return
            except Exception:
                pass
            # Snapshot vor Änderung für Undo/Redo System
            try:
                if hasattr(self, '_push_history'):
                    self._push_history()
            except Exception:
                pass
            # Führe Pairing durch (nutzt bestehende Logik für Konsistenz)
            new_pair = {
                'source': source_file,
                'translation': translation_file,
                'similarity': 1.0,
                'source_name': os.path.basename(source_file),
                'translation_name': os.path.basename(translation_file)
            }
            if not hasattr(self, 'file_pairs'):
                self.file_pairs = []
            self.file_pairs.append(new_pair)
            # Entferne aus unmatched
            try:
                if source_file in self.unmatched_files.get('source', []):
                    self.unmatched_files['source'].remove(source_file)
                if translation_file in self.unmatched_files.get('translation', []):
                    self.unmatched_files['translation'].remove(translation_file)
            except Exception:
                self._debug_silent(Exception('unmatched remove failed'), 'drag.complete.unmatched')
            # History
            try:
                self._record_pair_action('create_pair', {'pair': new_pair})
            except Exception:
                self._debug_silent(Exception('legacy record failed'), 'drag.complete.legacy_record')
            self._populate_manual_pairing_interface()
            self._update_pairing_status_display()
            self._pair_dirty = True
            self.show_toast(f"{self._t('Pair created (drag & drop)')}: {new_pair['source_name']} ↔ {new_pair['translation_name']}", "success")
        except Exception as e:
            self._handle_error(e, context="pairing.drag.complete", user_message=self._t("Drag Abschluss Fehler"), toast=False)
        finally:
            self._cancel_pair_drag()

    def _cancel_pair_drag(self):
        try:
            if self._pairing_drag:
                w = self._pairing_drag.get('widget')
                try:
                    if w:
                        w.configure(border_color=self.get_color('surface_border'))
                except Exception:
                    pass
            try:
                if hasattr(self, '_drag_status_var') and self._drag_status_var:
                    self._drag_status_var.set("")
            except Exception:
                pass
            self._pairing_drag = None
        except Exception:
            pass

    # ---------------------------------------------------------------
    # Pairing Persistenz & Utilities (additiv)
    # ---------------------------------------------------------------
    def _pairings_path(self):
        try:
            base = getattr(self, 'current_project_base', None)
            if not base:
                base = os.path.join('Checker_Projekte', '_default')
            return os.path.join(base, 'pairings.json')
        except Exception:
            return os.path.join('Checker_Projekte', '_default', 'pairings.json')

    def load_pairings(self):
        try:
            import json
            p = self._pairings_path()
            if os.path.exists(p):
                with open(p, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                self.file_pairs = data.get('pairs', [])
                self.unmatched_files = data.get('unmatched', {'source': [], 'translation': []})
                self._update_pairing_status_display()
        except Exception:
            pass

    def save_pairings(self):
        try:
            import json
            p = self._pairings_path()
            os.makedirs(os.path.dirname(p), exist_ok=True)
            with open(p, 'w', encoding='utf-8') as f:
                json.dump({
                    'pairs': getattr(self, 'file_pairs', []),
                    'unmatched': getattr(self, 'unmatched_files', {'source': [], 'translation': []})
                }, f, ensure_ascii=False, indent=2)
        except Exception as e:
            try:
                self._handle_error(e, context='pairings.persist', toast=False)
            except Exception:
                pass

    def _autosave_tick(self):
        try:
            if getattr(self, '_pair_dirty', False):
                self.save_pairings()
                self._pair_dirty = False
        finally:
            try:
                if hasattr(self, 'root') and self.root:
                    self.root.after(8000, self._autosave_tick)
            except Exception:
                pass

    def _is_file_already_paired(self, fpath, ftype):
        try:
            for p in getattr(self, 'file_pairs', []):
                if ftype == 'source' and p.get('source') == fpath:
                    return True
                if ftype == 'translation' and p.get('translation') == fpath:
                    return True
        except Exception:
            return False
        return False

    def _bulk_pair_visible_in_order(self):
        try:
            if not hasattr(self, 'unmatched_files'):
                return
            q_src = (self._src_filter.get().strip().lower() if hasattr(self, '_src_filter') else "")
            q_trg = (self._trg_filter.get().strip().lower() if hasattr(self, '_trg_filter') else "")
            def _apply_q(fs, q):
                try:
                    if not q:
                        return fs
                    return [f for f in fs if q in os.path.basename(f).lower()]
                except Exception:
                    return fs
            sources = _apply_q(self.unmatched_files.get('source', []), q_src)
            translations = _apply_q(self.unmatched_files.get('translation', []), q_trg)
            if hasattr(self, '_virtual_pairing'):
                vp = self._virtual_pairing
                win = vp.get('window', len(sources))
                so = vp.get('source_offset', 0)
                to = vp.get('translation_offset', 0)
                sources = sources[so:so+win]
                translations = translations[to:to+win]
            sources.sort(key=lambda p: os.path.basename(p).lower())
            translations.sort(key=lambda p: os.path.basename(p).lower())
            count = min(len(sources), len(translations))
            if count == 0:
                self.show_toast(self._t('No files to bulk pair') if hasattr(self,'_t') else 'Keine passenden Listen', 'info')
                return
            self._push_history()
            for i in range(count):
                s = sources[i]; t = translations[i]
                if self._is_file_already_paired(s, 'source') or self._is_file_already_paired(t, 'translation'):
                    continue
                try:
                    self.file_pairs.append({
                        'source': s,
                        'translation': t,
                        'similarity': 1.0,
                        'source_name': os.path.basename(s),
                        'translation_name': os.path.basename(t)
                    })
                    self.unmatched_files['source'].remove(s)
                    self.unmatched_files['translation'].remove(t)
                except Exception:
                    pass
            self._pair_dirty = True
            self._populate_manual_pairing_interface()
            self._update_pairing_status_display()
            self.show_toast(self._t('Bulk pairing done') if hasattr(self,'_t') else 'Bulk-Pairing abgeschlossen', 'success')
        except Exception as e:
            self._handle_error(e, context='pairing.bulk_pair', toast=False)

    def _toggle_pair_sort(self):
        try:
            self._pair_sort_similarity = not getattr(self, '_pair_sort_similarity', False)
            self._populate_manual_pairing_interface()
        except Exception:
            pass

    def _ctx_menu_for(self, fpath):
        try:
            import tkinter as tk
            menu = tk.Menu(self.root, tearoff=0)
            menu.add_command(label=self._t('Open') if hasattr(self,'_t') else 'Öffnen', command=lambda: os.startfile(fpath) if os.name=='nt' else None)
            menu.add_command(label=self._t('Reveal in folder') if hasattr(self,'_t') else 'Im Ordner zeigen', command=lambda: self._reveal_in_fs(fpath) if hasattr(self,'_reveal_in_fs') else None)
            menu.add_command(label=self._t('Copy name') if hasattr(self,'_t') else 'Namen kopieren', command=lambda: self.root.clipboard_append(os.path.basename(fpath)))
            # Diagnostics Menüpunkt hinzufügen
            try:
                menu.add_separator()
                menu.add_command(label=self._t('Diagnostik') if hasattr(self,'_t') else 'Diagnostik', command=self._open_diagnostics_window)
            except Exception as ex_sep:
                try:
                    self._record_suppressed_error('ctx.menu.diagnostics_add', ex_sep)
                except Exception:
                    pass
            return menu
        except Exception as ex:
            try:
                self._record_suppressed_error('ctx.menu.build', ex)
            except Exception:
                pass
            return None

    def _attach_ctx(self, widget, fpath):
        try:
            if not fpath:
                return
            def _popup(e):
                m = self._ctx_menu_for(fpath)
                try:
                    if m:
                        m.tk_popup(e.x_root, e.y_root)
                finally:
                    try:
                        if m:
                            m.grab_release()
                    except Exception as ex_rel:
                        try:
                            self._record_suppressed_error('ctx.menu.popup.release', ex_rel)
                        except Exception:
                            pass
            widget.bind('<Button-3>', _popup)
            widget.bind('<Control-1>', _popup)
        except Exception as ex:
            try:
                self._record_suppressed_error('ctx.menu.attach', ex)
            except Exception:
                pass
    
    def _clear_all_files(self):
        """CLEAR ALL FILES - Alle hochgeladenen Dateien löschen"""
        try:
            total_files = len(self.uploaded_files.get('source', [])) + len(self.uploaded_files.get('translation', []))
            
            if total_files == 0:
                self.show_toast("Keine Dateien zum Löschen vorhanden", "info")
                return
            
            # Alle Dateien löschen
            self.uploaded_files = {'source': [], 'translation': []}
            
            # File pairs und unmatched files auch löschen
            if hasattr(self, 'file_pairs'):
                self.file_pairs = []
            if hasattr(self, 'unmatched_files'):
                self.unmatched_files = {'source': [], 'translation': []}
            
            # UI aktualisieren
            self._schedule_update_file_counter()
            # Beide Scrollbars ausblenden (Listen jetzt leer)
            try:
                if hasattr(self, 'source_file_list'):
                    self._auto_hide_scrollbar(self.source_file_list, hide=True)
                if hasattr(self, 'translation_file_list'):
                    self._auto_hide_scrollbar(self.translation_file_list, hide=True)
            except Exception as ex_hide:
                try:
                    self._record_suppressed_error('files.clear.scrollbar_hide', ex_hide)
                except Exception:
                    pass
            self._refresh_file_list_display()
            self._update_pairing_status_display()
            
            self.update_status("Alle Dateien wurden gelöscht")
            self.show_toast(f"{total_files} Dateien erfolgreich gelöscht", "success")
            # Event publizieren
            try:
                if getattr(self, 'event_bus', None):
                    self.event_bus.publish('files.cleared', {'total': total_files})
            except Exception as ex_evt:
                try:
                    self._record_suppressed_error('files.clear.event_publish', ex_evt)
                except Exception:
                    pass
            
        except Exception as e:
            try:
                self._handle_error(e, context="files.clear_all", user_message=self._t("Dateien Löschen Fehler"))
            except Exception as ex_handle_fail:
                try:
                    self._record_suppressed_error('files.clear.error_handle_fail', ex_handle_fail)
                except Exception:
                    pass
            self.show_toast("Fehler beim Löschen der Dateien", "error")
    
    def _refresh_file_list(self):
        """REFRESH FILE LIST - Dateiliste aktualisieren"""
        try:
            self._update_file_counter()
            self._refresh_file_list_display()
            self._update_pairing_status_display()
            
            total_files = len(self.uploaded_files.get('source', [])) + len(self.uploaded_files.get('translation', []))
            self.update_status(f"Dateiliste aktualisiert - {total_files} Dateien verfügbar")
            self.show_toast("Dateiliste erfolgreich aktualisiert", "success")
            
        except Exception as e:
            try:
                self._handle_error(e, context="files.refresh", user_message=self._t("Dateiliste Aktualisierung fehlgeschlagen"))
            except Exception as ex_handle_fail2:
                try:
                    self._record_suppressed_error('files.refresh.error_handle_fail', ex_handle_fail2)
                except Exception:
                    pass
            self.show_toast("Fehler beim Aktualisieren der Dateiliste", "error")
            try:
                self._handle_error(e, context="files.refresh_list", user_message=self._t("Dateiliste Refresh Fehler"), toast=False)
            except Exception:
                pass
    
    # --- Dropzone Helper: nicht-interaktiver Bulk-Upload (Quelle) ---
    def _upload_source_files_from_list(self, files):
        try:
            if not files:
                return
            customer_name = self._get_or_select_customer_for_upload()
            if customer_name == 'CANCELLED':
                return
            self._log_event('upload.source.drop', count=len(files), customer=customer_name)
            from upload_service import get_upload_service
            service = get_upload_service(event_bus=getattr(self, 'event_bus', None), logger=self.logger)
            result = service.process_simple_upload(
                kind='source',
                selected_files=list(files),
                existing_files=self.uploaded_files['source'],
                customer_name=customer_name,
                copy_callback=self.copy_files_to_project_structure if customer_name else None,
            )
            added = result['added_files']
            if added:
                self.uploaded_files['source'].extend(added)
                if customer_name and result['meta'].get('project_copied'):
                    self._offer_open_project_folder(customer_name)
                self._schedule_update_file_counter(); self._refresh_file_list_display()
                self._show_enhanced_upload_results('source', added); self._smart_file_pairing(); self._check_and_show_manual_pairing_option()
                self.show_toast(f"{len(added)} Ausgangstexte (Drop) hochgeladen", 'success')
        except Exception as e:
            try: self._handle_error(e, context='upload.source.drop')
            except Exception: pass

    # --- Dropzone Helper: nicht-interaktiver Bulk-Upload (Übersetzungen) ---
    def _upload_translation_files_from_list(self, files):
        try:
            if not files:
                return
            customer_name = self._get_or_select_customer_for_upload()
            if customer_name == 'CANCELLED':
                return
            self._log_event('upload.translation.drop', count=len(files), customer=customer_name)
            from upload_service import get_upload_service
            service = get_upload_service(event_bus=getattr(self, 'event_bus', None), logger=self.logger)
            result = service.process_simple_upload(
                kind='translation',
                selected_files=list(files),
                existing_files=self.uploaded_files['translation'],
                customer_name=customer_name,
                copy_callback=self.copy_translation_files_to_project_structure if customer_name else None,
            )
            added = result['added_files']
            if added:
                self.uploaded_files['translation'].extend(added)
                if customer_name and result['meta'].get('project_copied'):
                    self._offer_open_project_folder(customer_name)
                self._schedule_update_file_counter(); self._refresh_file_list_display()
                self._show_enhanced_upload_results('translation', added); self._smart_file_pairing(); self._check_and_show_manual_pairing_option()
                self.show_toast(f"{len(added)} Übersetzungsdateien (Drop) hochgeladen", 'success')
        except Exception as e:
            try: self._handle_error(e, context='upload.translation.drop')
            except Exception: pass

    def _upload_translation_files(self):
        """Delegierter Übersetzungsdatei-Upload via UploadService."""
        try:
            # NEU (Anforderung): Beim Klick zuerst Kunden-Übersetzungsordner anzeigen / öffnen
            customer_name = self._get_or_select_customer_for_upload()
            if customer_name == "CANCELLED":
                return  # Abbruch wie gehabt

            initial_dir = None
            if customer_name:
                try:
                    import datetime, os, subprocess, sys
                    project_date = datetime.datetime.now().strftime("%Y-%m-%d")
                    # Neuer dedizierter Unterordner für Übersetzungen (additiv, nicht Teil der Standardliste)
                    project_base = os.path.join("Checker_Projekte", customer_name, project_date)
                    translation_dir = os.path.join(project_base, "Übersetzungen")
                    os.makedirs(translation_dir, exist_ok=True)
                    initial_dir = translation_dir
                    # Explorer optional & nur einmal pro Session öffnen (siehe Source-Upload)
                    if (getattr(self, 'auto_open_explorer', True)
                        and sys.platform.startswith('win')
                        and not getattr(self, '_opened_explorer_translation_once', False)):
                        try:
                            subprocess.Popen(['explorer', os.path.normpath(translation_dir)])
                            self._opened_explorer_translation_once = True
                        except Exception:
                            pass
                except Exception as _prep_exc:
                    try:
                        self.logger.debug(f"Vorbereitung Übersetzungsordner fehlgeschlagen: {_prep_exc}")
                    except Exception:
                        pass

            file_types = [
                ("All Supported", "*.pdf;*.docx;*.txt;*.doc;*.rtf;*.odt"),
                ("PDF files", "*.pdf"),
                ("Word files", "*.docx;*.doc"),
                ("Text files", "*.txt"),
                ("Rich Text", "*.rtf"),
                ("OpenDocument", "*.odt")
            ]
            dialog_kwargs = {
                'title': "Übersetzungsdateien für Qualitätsanalyse auswählen",
                'filetypes': file_types
            }
            if initial_dir and os.path.isdir(initial_dir):
                dialog_kwargs['initialdir'] = initial_dir
            files = filedialog.askopenfilenames(**dialog_kwargs)
            if not files:
                return  # Nutzer hat Dialog abgebrochen
            from upload_service import get_upload_service
            service = get_upload_service(event_bus=getattr(self, 'event_bus', None), logger=self.logger)
            result = service.process_simple_upload(
                kind='translation',
                selected_files=list(files),
                existing_files=self.uploaded_files['translation'],
                customer_name=customer_name,
                # Neues Copy-Target für Übersetzungen
                copy_callback=self.copy_translation_files_to_project_structure if customer_name else None,
            )
            added = result['added_files']
            duplicates = result['duplicate_files']
            if added:
                try:
                    before_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                except Exception:
                    before_total = None
                self.uploaded_files['translation'].extend(added)
                if customer_name and result['meta'].get('project_copied'):
                    self._offer_open_project_folder(customer_name)
                self._update_file_counter()
                self._refresh_file_list_display()
                self._show_enhanced_upload_results("translation", added)
                source_count = len(self.uploaded_files['source'])
                trans_count = len(self.uploaded_files['translation'])
                status_msg = f"{len(added)} Übersetzungsdateien hinzugefügt"
                if duplicates:
                    status_msg += f" ({len(duplicates)} Duplikate ignoriert)"
                if source_count > 0 and trans_count > 0:
                    status_msg += f" | Bereit für Analyse ({min(source_count, trans_count)} Paare)"
                self.update_status(status_msg)
                self.show_toast(f"{len(added)} Übersetzungsdateien erfolgreich hochgeladen", "success")
                if source_count > 0 and trans_count > 0:
                    self.root.after(1000, lambda: self.show_toast("Bereit für Qualitätsanalyse!", "info"))
                # Telemetrie: files.changed (added translation)
                try:
                    if getattr(self, 'event_bus', None):
                        after_total = sum(len(self.uploaded_files.get(k, [])) for k in ('source','translation'))
                        self.event_bus.publish('files.changed', {
                            'action': 'added',
                            'file_type': 'translation',
                            'count': len(added),
                            'filenames': [os.path.basename(a) for a in added],
                            'before_total': before_total,
                            'after_total': after_total
                        })
                except Exception:
                    pass
            else:
                self.show_toast("Alle ausgewählten Dateien waren bereits hochgeladen", "info")
            if not hasattr(self, '_telemetry_counters'):
                self._telemetry_counters = {}
            self._telemetry_counters.setdefault('upload_count', 0)
            self._telemetry_counters.setdefault('upload_files_added', 0)
            self._telemetry_counters.setdefault('upload_duplicates_ignored', 0)
            self._telemetry_counters['upload_count'] += 1
            self._telemetry_counters['upload_files_added'] += len(added)
            self._telemetry_counters['upload_duplicates_ignored'] += len(duplicates)
        except Exception as e:
            msg = f"Fehler beim Hochladen der Übersetzungsdateien: {e}"
            self.update_status(msg)
            self.show_toast("Fehler beim Hochladen der Übersetzungsdateien", "error")
            try:
                self._handle_error(e, context="upload.translation", user_message=self._t("Übersetzungsdateien Upload fehlgeschlagen"))
            except Exception:
                pass

    # =====================================================================
    # Upload Telemetrie Helper
    # =====================================================================
    def _record_upload_telemetry(self, added: int, duplicates: int):
        """Reduzierte Duplikation: Einheitliche Erfassung von Upload-Telemetrie."""
        try:
            if not hasattr(self, '_telemetry_counters'):
                self._telemetry_counters = {}
            self._telemetry_counters.setdefault('upload_count', 0)
            self._telemetry_counters.setdefault('upload_files_added', 0)
            self._telemetry_counters.setdefault('upload_duplicates_ignored', 0)
            self._telemetry_counters['upload_count'] += 1
            self._telemetry_counters['upload_files_added'] += added
            self._telemetry_counters['upload_duplicates_ignored'] += duplicates
        except Exception:
            pass
    
    # DUPLIKAT METHODE ENTFERNT - _update_file_counter() ist bereits oben konsolidiert implementiert
    
    def _show_enhanced_upload_results(self, file_type, files):
        """OPTIMIERT: Verbesserte Upload-Ergebnisse mit intelligenter Dateianalyse und Vorschau"""
        try:
            # Clear output and show enhanced upload results
            for widget in self.output_frame.winfo_children():
                widget.destroy()
            
            # Enhanced upload results card
            results_card = ctk.CTkFrame(
                self.output_frame,
                fg_color=self.get_color('surface'),
                corner_radius=self.get_spacing('large_border_radius'),
                border_width=0,
                            )
            results_card.pack(fill="x", pady=self.get_spacing('lg'), padx=self.get_spacing('lg'))
            
            # Animated header with gradient effect simulation
            header_frame = ctk.CTkFrame(results_card, fg_color=self.get_color('gray_600'))
            header_frame.pack(fill="x", padx=0, pady=0)
            
            # Header with file type icon
            file_prefix = "Source" if file_type == "source" else "Translation"
            file_type_german = "Ausgangstexte" if file_type == "source" else "Übersetzungen"
            header_label = ctk.CTkLabel(
                header_frame,
                text=f"{file_type_german} erfolgreich hochgeladen",
                font=ctk.CTkFont(*self.get_typography('subheading')),
                text_color=self.get_color('white')
            )
            header_label.pack(pady=self.get_spacing('header_padding'))
            
            # Enhanced file list with metadata
            content_frame = ctk.CTkFrame(results_card, fg_color="transparent")
            content_frame.pack(fill="x", padx=self.get_spacing('content_padding'), pady=self.get_spacing('content_padding'))
            
            # File analysis summary
            total_size = 0
            file_types_detected = set()
            
            for i, file_path in enumerate(files, 1):
                file_name = os.path.basename(file_path)
                file_ext = os.path.splitext(file_name)[1].lower()
                file_types_detected.add(file_ext)
                
                try:
                    file_size = os.path.getsize(file_path)
                    total_size += file_size
                    size_str = self._format_file_size(file_size)
                except Exception as e:
                    self._record_suppressed_error('upload.results.file_size', e)
                    size_str = "Unbekannte Größe"
                
                # Enhanced file entry with icon and metadata
                file_frame = ctk.CTkFrame(content_frame, fg_color=self.get_color('surface_light'))
                file_frame.pack(fill="x", pady=2)
                
                file_label = ctk.CTkLabel(
                    file_frame,
                    text=f"{i}. {file_name} ({size_str})",
                    font=ctk.CTkFont(*self.get_typography('body')),
                    text_color=self.get_color('text_primary'),
                    anchor="w"
                )
                file_label.pack(side="left", padx=self.get_spacing('sm'), pady=self.get_spacing('xs'))
                
                # File type indicator
                type_indicator = ctk.CTkLabel(
                    file_frame,
                    text=file_ext.upper(),
                    font=ctk.CTkFont(*self.get_typography('caption')),
                    text_color=self.get_color('primary'),
                    width=40
                )
                type_indicator.pack(side="right", padx=self.get_spacing('sm'), pady=self.get_spacing('xs'))
            
            # Smart summary with analytics
            summary_frame = ctk.CTkFrame(content_frame, fg_color=self.get_color('gray_100'))
            summary_frame.pack(fill="x", pady=(self.get_spacing('md'), 0))
            
            summary_text = f"""
Upload-Zusammenfassung:
• Dateien gesamt: {len(files)}
• Gesamtgröße: {self._format_file_size(total_size)}
• Dateitypen: {', '.join(sorted(file_types_detected))}
• Aktuelle {file_type_german}-Anzahl: {len(self.uploaded_files[file_type])}

{self._get_smart_upload_advice(file_type)}
"""
            
            summary_label = ctk.CTkLabel(
                summary_frame,
                text=summary_text,
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_primary'),
                justify="left",
                anchor="w"
            )
            summary_label.pack(padx=self.get_spacing('md'), pady=self.get_spacing('md'))
            
        except Exception as e:
            try:
                self._handle_error(e, context="upload.results.enhanced", user_message=self._t("Erweiterte Upload Ergebnisse Fehler"), toast=False)
            except Exception:
                pass
            # Fallback to simple display
            self._show_upload_results(file_type, files)
    
    def _format_file_size(self, size_bytes):
        # Diese zweite frühere Doppel-Definition wurde entfernt (Consolidation).
        # Beibehalten für Rückwärtskompatibilität falls Referenzen bestehen.
        try:
            from quality_gui_utilities import format_file_size
            return format_file_size(int(size_bytes) if size_bytes is not None else 0)
        except Exception:
            return "Unknown"

    def _auto_hide_scrollbar(self, list_frame, hide: bool):
        """Versteckt oder zeigt Scrollbar eines scrollbaren Frames.

        Defensive Implementation – ignoriert Fehler still (kein funktionaler Impact).
        """
        try:
            scrollbar = getattr(list_frame, '_scrollbar', None)
            if not scrollbar:
                for child in list_frame.winfo_children():
                    try:
                        if child.__class__.__name__.lower().endswith('scrollbar'):
                            scrollbar = child
                            break
                    except Exception:
                        pass
            if not scrollbar:
                return
            if hide:
                try:
                    scrollbar.pack_forget()
                except Exception:
                    pass
            else:
                if not scrollbar.winfo_ismapped():
                    try:
                        scrollbar.pack(side="right", fill="y")
                    except Exception:
                        pass
        except Exception:
            pass
    
    def _get_smart_upload_advice(self, file_type):
        """INTELLIGENT: Kontextuelle Ratschläge basierend auf Upload-Status"""
        try:
            files = getattr(self, 'uploaded_files', {}) or {}
            source_count = len(files.get('source', []) or [])
            trans_count = len(files.get('translation', []) or [])
            if file_type == "source":
                if trans_count == 0:
                    return "Nächster Schritt: Entsprechende Übersetzungsdateien hochladen"
                if trans_count < source_count:
                    return f"Ausgleich: Erwägen Sie das Hochladen von {source_count - trans_count} weiteren Übersetzungsdatei(en)"
                return "Bereit: Alle Dateien hochgeladen - Qualitätsanalyse starten!"
            else:  # translation
                if source_count == 0:
                    return "Nächster Schritt: Entsprechende Ausgangstexte hochladen"
                if source_count < trans_count:
                    return f"Ausgleich: Erwägen Sie das Hochladen von {trans_count - source_count} weiteren Ausgangstexten"
                return "Bereit: Alle Dateien hochgeladen - Qualitätsanalyse starten!"
        except Exception:
            return "Dateien erfolgreich hochgeladen"
    
    def start_analysis(self, rule_profile: str = "default"):
        """Startet Analyse mit Cache-Prüfung und Event-Publishing.

        Erweiterung: Setzt _last_response_ms für Metrics-Dashboard (auch bei Cache-Treffer)
        und nutzt _dev_trace statt stiller pass-Blöcke für Diagnose im Entwicklungsmodus.
        """
        try:
            import uuid, time as _tmod
            from itertools import zip_longest

            if not hasattr(self, 'uploaded_files') or not isinstance(self.uploaded_files, dict):
                self.uploaded_files = {'source': [], 'translation': []}

            analysis_id = getattr(self, '_current_analysis_id', None)
            if not analysis_id:
                analysis_id = str(uuid.uuid4())
                self._current_analysis_id = analysis_id

            start_ts = _tmod.time()
            try:
                self._analysis_start_monotonic = start_ts
            except Exception as e:
                self._dev_trace('analysis.start.set_start', e)

            files = self.uploaded_files
            if not files.get('source') and not files.get('translation'):
                self.show_toast("Keine Dateien geladen.", "warning")
                return

            source_count = len(files.get('source', []))
            translation_count = len(files.get('translation', []))

            analysis_input = [
                {'source': s, 'translation': t}
                for s, t in zip_longest(files.get('source', []), files.get('translation', []))
            ]

            cache_key = None
            try:
                if getattr(self, '_cache', None):
                    cache_key = self._cache.make_key(analysis_input, rule_profile)  # type: ignore
                    cached = self._cache.get(cache_key)  # type: ignore
                    if cached:
                        self.analysis_results = cached
                        try:
                            if hasattr(self, '_show_analysis_results'):
                                self.current_analysis = cached
                                if hasattr(self, 'ui'):
                                    try:
                                        self.ui(self._show_analysis_results)
                                    except Exception:
                                        self._show_analysis_results()
                                else:
                                    self._show_analysis_results()
                        except Exception as ie:
                            self._dev_trace('analysis.cache.show_results', ie)
                        if self.event_bus:
                            try:
                                self.event_bus.publish("cache.hit", {"key": cache_key, "analysis_id": analysis_id})
                            except Exception as e2:
                                self._debug_silent(e2, 'analysis.cache.event.cache_hit')
                            try:
                                duration_ms = int((_tmod.time() - start_ts) * 1000)
                                try:
                                    self._last_response_ms = duration_ms
                                except Exception as le:
                                    self._dev_trace('analysis.cache.set_latency', le)
                                meta = {
                                    "analysis_id": analysis_id,
                                    "_cache_key": cache_key,
                                    "cache": True,
                                    "duration_ms": duration_ms,
                                    "rule_profile": rule_profile,
                                    "source_count": source_count,
                                    "translation_count": translation_count
                                }
                                self.event_bus.publish("analysis.done", {**cached, **meta})
                                try:
                                    self.event_bus.publish("analysis.completed", {**meta, "summary_keys": list(cached.keys())[:10]})
                                except Exception as ie2:
                                    self._debug_silent(ie2, 'analysis.cache.event.analysis_completed')
                            except Exception as e3:
                                self._debug_silent(e3, 'analysis.cache.event.analysis_done')
                        try:
                            self._log_event("analysis.completed", analysis_id=analysis_id, cache=True, duration_ms=getattr(self,'_last_response_ms', None))
                        except Exception as le2:
                            self._dev_trace('analysis.cache.log_event', le2)
                        return
            except Exception as e:
                self._debug_silent(e, 'analysis.cache.lookup')

            # 2) Kein Cache: Progress UI aufbauen
            for widget in self.output_frame.winfo_children():
                widget.destroy()
            # Event-basierte Progress UI
            progress_card = ctk.CTkFrame(
                self.output_frame,
                fg_color=self.get_color('surface'),
                corner_radius=self.get_component_value('borders.radius_md') if hasattr(self, 'get_component_value') else 8,
                border_width=1,
                border_color=self.get_color('surface_border')
            )
            progress_card.pack(fill="x", pady=self.get_spacing('lg'), padx=self.get_spacing('lg'))
            header_frame = ctk.CTkFrame(progress_card, fg_color=self.get_color('primary'))
            header_frame.pack(fill="x")
            header_label = ctk.CTkLabel(
                header_frame,
                text=self._t("Quality analysis in progress"),
                font=ctk.CTkFont(*self.get_typography('subheading')),
                text_color=self.get_color('text_inverse')
            )
            header_label.pack(pady=self.get_spacing('md'))
            content_frame = ctk.CTkFrame(progress_card, fg_color="transparent")
            content_frame.pack(fill="x", padx=self.get_spacing('lg'), pady=self.get_spacing('lg'))
            progress_bar = ctk.CTkProgressBar(
                content_frame,
                height=18,
                # Accent Reduction: Fortschrittsfarbe vereinheitlicht auf Primary
                progress_color=self.get_color('primary'),
                fg_color=self.get_color('surface_border')
            )
            progress_bar.pack(pady=self.get_spacing('sm'), fill='x')
            progress_bar.set(0)
            status_label = ctk.CTkLabel(
                content_frame,
                text=self._t("Initializing analysis engine"),
                font=ctk.CTkFont(*self.get_typography('body')),
                text_color=self.get_color('text_primary'),
                anchor='w', justify='left'
            )
            status_label.pack(pady=(self.get_spacing('xs'),0), fill='x')

            # Cancel Button
            cancel_btn = self._create_button(
                content_frame,
                text=self._t('Cancel analysis'),
                command=lambda: self._request_analysis_cancel(status_label, progress_bar),
                kind="warning",
                height=32
            )
            cancel_btn.pack(pady=(self.get_spacing('md'),0), anchor='e')

            # Listener für progress Events (einmalig registrieren)
            def _on_progress(payload):
                """Fein granularer Fortschritts-Mapper.

                Phasen-Gewichtung (Summe 100%):
                  start 2%, pairs 8%, phase1 10%, phase2 10%, phase3 10%, phase4 10%, phase5 10%, phase6 10%, metrics 10%, severity 10%, finalize 10%.
                Bei Unterzählungen (z.B. fehlende Phasen) bleiben Fortschrittswerte monoton.
                """
                try:
                    phase = payload.get('phase') if isinstance(payload, dict) else None
                    weights = {
                        'start': 0.02,
                        'pairs': 0.10,   # kumulativ 0.12
                        'phase1': 0.20,
                        'phase2': 0.30,
                        'phase3': 0.40,
                        'phase4': 0.50,
                        'phase5': 0.60,
                        'phase6': 0.70,
                        'metrics': 0.80,
                        'severity': 0.90,
                        'finalize': 1.00
                    }
                    if phase in weights:
                        # Sonderfall rules (dynamisch innerhalb phase1 Range 0.12-0.20)
                        if phase == 'rules':
                            cur = payload.get('current', 0)
                            total = max(1, payload.get('total', 1))
                            base_start = 0.12
                            base_span = 0.08
                            ratio = base_start + base_span * max(0.0, min(1.0, cur/total))
                            progress_bar.set(ratio)
                            status_label.configure(text=self._t('Analyzing rules') + f" ({cur}/{total})")
                        else:
                            progress_bar.set(weights[phase])
                            # Nutzerfreundliche Statusmeldung
                            phase_label_map = {
                                'start': self._t('Initialisiere Analyse'),
                                'pairs': self._t('Paar-Ermittlung'),
                                'phase1': self._t('Strukturprüfung 1'),
                                'phase2': self._t('Strukturprüfung 2'),
                                'phase3': self._t('Strukturprüfung 3'),
                                'phase4': self._t('Strukturprüfung 4'),
                                'phase5': self._t('Erweiterte Logik 5'),
                                'phase6': self._t('Erweiterte Logik 6'),
                                'metrics': self._t('Berechne Metriken'),
                                'severity': self._t('Bewerte Severity'),
                                'finalize': self._t('Finalisiere Ergebnisse')
                            }
                            base_txt = phase_label_map.get(phase, phase)
                            # Zusatzdetails falls verfügbar
                            if phase == 'severity':
                                try:
                                    base_txt += f" (C:{payload.get('critical','?')} M:{payload.get('major','?')} m:{payload.get('minor','?')})"
                                except Exception: pass
                            if phase == 'finalize':
                                try:
                                    base_txt += f" – {payload.get('duration',0):.2f}s"
                                except Exception: pass
                            status_label.configure(text=base_txt)
                    elif phase == 'rules':  # falls weights mapping geändert wurde
                        cur = payload.get('current', 0)
                        total = max(1, payload.get('total', 1))
                        progress_bar.set(max(0.0, min(1.0, cur/total*0.2)))
                        status_label.configure(text=self._t('Analyzing rules') + f" ({cur}/{total})")
                except Exception as e:
                    self._debug_silent(e, 'analysis.progress.handler')
            try:
                if getattr(self, 'event_bus', None):
                    self.event_bus.subscribe('analysis.progress', _on_progress)
            except Exception as e:
                self._debug_silent(e, 'analysis.progress.subscribe')

            # Events: analysis.started
            if self.event_bus:
                try:
                    self.event_bus.publish("analysis.started", {
                        "analysis_id": analysis_id,
                        "sources": source_count,
                        "translations": translation_count,
                        "rule_profile": rule_profile,
                        "ts": start_ts
                    })
                except Exception as e:
                    self._debug_silent(e, 'analysis.started.publish')
            self.update_status(self._t("Quality analysis started"))
            self._show_toast(self._t("Quality analysis started"), "success")
            self._log_event("analysis.started.ui", analysis_id=analysis_id, sources=source_count, translations=translation_count, rule_profile=rule_profile)

            def job():
                try:
                    results = self._run_analysis_pipeline(analysis_input, rule_profile)
                    self.analysis_results = results
                    self.current_analysis = results
                    duration_ms = int((_tmod.time() - start_ts) * 1000)
                    try:
                        self._last_response_ms = duration_ms
                    except Exception as le:
                        self._dev_trace('analysis.pipeline.set_latency', le)
                    results_meta = {
                        "analysis_id": analysis_id,
                        "duration_ms": duration_ms,
                        "rule_profile": rule_profile,
                        "source_count": source_count,
                        "translation_count": translation_count,
                        "cache": False
                    }
                    if self.event_bus:
                        try:
                            self.event_bus.publish("analysis.done", {**results, "_cache_key": cache_key, **results_meta})
                        except Exception:
                            pass
                        try:
                            self.event_bus.publish("analysis.completed", {**results_meta, "summary_keys": list(results.keys())[:10]})
                        except Exception as e:
                            self._debug_silent(e, 'analysis.completed.publish')
                    try:
                        self._log_event("analysis.completed", **results_meta)
                    except Exception as le:
                        self._dev_trace('analysis.pipeline.log_completed', le)
                    # UI close wenn Cancel
                    # NEU: Ergebnisse nach erfolgreicher Analyse anzeigen (fehlte bisher -> Benutzer sah nichts)
                    try:
                        if not getattr(self, '_analysis_cancel_requested', False):
                            if hasattr(self, '_show_analysis_results'):
                                if hasattr(self, 'ui'):
                                    try:
                                        self.ui(self._show_analysis_results)
                                    except Exception:
                                        self._show_analysis_results()
                                else:
                                    self._show_analysis_results()
                            # Optional: dynamischen HTML Bericht erzeugen & öffnen
                            if getattr(self, 'auto_open_dynamic_report', False):
                                try:
                                    def _auto_report():
                                        try:
                                            path = self._generate_dynamic_report()
                                            if path and os.path.exists(path):
                                                import webbrowser
                                                webbrowser.open_new_tab(f'file://{path}')
                                                try:
                                                    self.show_toast(self._t('Dynamischer Bericht geöffnet'), 'success')
                                                except Exception:
                                                    pass
                                        except Exception as ie:
                                            try:
                                                self._debug_silent(ie, 'analysis.auto_report')
                                            except Exception:
                                                pass
                                    self.ui(_auto_report)
                                except Exception:
                                    pass
                    except Exception as e:
                        try:
                            self._debug_silent(e, 'analysis.results.render')
                        except Exception:
                            pass
                    if getattr(self, '_analysis_cancel_requested', False):
                        try:
                            self._show_toast(self._t('Analysis cancelled'), 'warning')
                        except Exception as e:
                            self._debug_silent(e, 'analysis.done.toast_cancel')
                except Exception as e:  # Einheitliche Fehlerbehandlung über zentralen Handler
                    duration_ms = int((_tmod.time() - start_ts) * 1000)
                    try:
                        self._last_response_ms = duration_ms
                    except Exception as le:
                        self._dev_trace('analysis.failed.set_latency', le)
                    try:
                        self._log_event("analysis.failed", analysis_id=analysis_id, duration_ms=duration_ms, error=str(e.__class__.__name__), message=str(e))
                    except Exception as le:
                        self._dev_trace('analysis.failed.log_event', le)
                    if self.event_bus:
                        try:
                            self.event_bus.publish("analysis.failed", {
                                "analysis_id": analysis_id,
                                "duration_ms": duration_ms,
                                "error": str(e.__class__.__name__),
                                "message": str(e)
                            })
                        except Exception as pe:
                            self._dev_trace('analysis.failed.publish', pe)
                    self._handle_error(
                        e,
                        context="analysis.pipeline",
                        user_message=self._t("Analyse fehlgeschlagen") if hasattr(self, '_t') else "Analyse fehlgeschlagen",
                        event_name="analysis.error",
                        cache_key=cache_key
                    )
                finally:
                    try:
                        self._show_busy(False)
                    except Exception as he:
                        self._debug_silent(he, 'analysis.busy.hide')
                    self._analysis_cancel_requested = False

            try:
                self._show_busy(True)
            except Exception as e:
                self._debug_silent(e, 'analysis.busy.show')
            if getattr(self, 'worker_pool', None):
                try:
                    self.worker_pool.submit(job)
                except Exception as e:
                    self._debug_silent(e, 'analysis.worker_pool.submit')
                    job()
            else:
                job()
        except Exception as e:  # Start-Phase Fehler zentral behandeln
            self._handle_error(
                e,
                context="analysis.start",
                user_message=self._t("Analyse Start fehlgeschlagen") if hasattr(self, '_t') else "Analyse Start fehlgeschlagen",
                event_name="analysis.error.start"
            )
    
    # LEGACY: Simulation (ersetzt durch Event-basierte progress Events: analysis.progress)
    def _simulate_analysis_progress(self, progress_bar, status_label):  # pragma: no cover
        """Legacy Simulation deaktiviert – beibehalten für Rückwärtskompatibilität."""
        try:
            status_label.configure(text=self._t('Progress simulation deprecated – waiting for real events'))
        except Exception:
            pass
    
    def _update_enhanced_progress(self, *_, **__):  # pragma: no cover
        """Legacy Hook: Wird nicht mehr genutzt (Event-basierter Fortschritt aktiv)."""
        return

    # ---------------------------------------------------------------
    # 🧪 FEHLENDE ANALYSE-PIPELINE (Placeholder Implementation)
    # ---------------------------------------------------------------
    def _run_analysis_pipeline(self, files: list[dict], rule_profile: str) -> dict:
        """Lightweight Ersatz der fehlenden ursprünglichen Pipeline.

        Liefert deterministische Basis-Metriken damit Export / UI nicht fehlschlagen.
        Struktur:
          {
            'file_pairs': [...],
            'metrics': {'accuracy': float, 'fluency': float, 'style': float, 'pair_count': int},
            'summary': {...}
          }
        """
        try:
            import os, time, hashlib, re, math, json
            from pathlib import Path
            start = time.time()
            # 🆕 Progress Helper (nicht invasiv) – sendet optionale Echtzeit-Events an Dashboard / Progress-Bar
            def _progress(phase: str, **extra):  # lokale Hilfsfunktion; kein globaler Impact
                try:
                    bus = getattr(self, 'event_bus', None)
                    if bus and hasattr(bus, 'publish'):
                        payload = {'phase': phase, **extra}
                        bus.publish('analysis.progress', payload)
                except Exception:
                    pass

            _progress('start')  # Initiales Startsignal (Dashboard setzt Start-Timestamp)

            # 1. Profil → erlaubte Regeln (einfache Zuordnung; erweiterbar durch settings_service)
            profile_map = {
                'basic': ['length'],
                'extended': ['length', 'dummy_terminology', 'number_consistency'],
                'full': ['length', 'dummy_terminology', 'number_consistency', 'untranslated_segments'],
                'all': None  # None => keine Filterung (alle geladenen Regeln)
            }
            allowed_rules = profile_map.get(rule_profile) if rule_profile in profile_map else None

            def _safe_read(path: str, limit: int = 120_000) -> str:
                try:
                    if path and os.path.exists(path) and os.path.isfile(path):
                        with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                            return f.read(limit)
                except Exception:
                    return ''
                return ''

            pairs = []
            source_texts = []
            translation_texts = []
            total_source_chars = 0
            total_translation_chars = 0
            number_mismatches_total = 0
            number_total = 0
            # 🔠 Namen-Konsistenz Zähler
            names_mismatches_total = 0
            names_total = 0
            # 🧪 Einheit-Konsistenz Zähler
            unit_mismatches_total = 0
            unit_total = 0
            # 💱 Währungs-Konsistenz Zähler
            currency_mismatches_total = 0
            currency_total = 0
            # 🔎 Aggregierte Warnungen (Einheiten-Plausibilität)
            aggregated_unit_plaus_warnings = []
            untranslated_segments_total = 0
            total_segments = 0

            # 🔢 Erweiterte Nummern-Erkennung: erfasst auch Tausendertrennungen mit Punkt/Komma/Apostroph/Space
            # Beispiele: 1.234,56  |  1,234.56  |  12'345.67  |  12 345,67
            # Design-System Hinweis: rein analytische Funktion, keine UI-Farben / Fonts hier verwenden
            num_pattern = re.compile(r"(?<![\w])([-+]?\d{1,3}(?:[.,' \u00A0]\d{3})*(?:[.,]\d+)?|[-+]?\d+(?:[.,]\d+)?)(?![\w])")

            # 🆕 Eigennamen-Erkennung (heuristisch). Berücksichtigt sprachspezifische Monats-/Wochentags-Mappings.
            name_pattern = re.compile(r"\b[A-ZÄÖÜ][A-Za-zÄÖÜäöüß\-]{2,}\b")
            months_de = ['januar','februar','märz','april','mai','juni','juli','august','september','oktober','november','dezember']
            months_en = ['january','february','march','april','may','june','july','august','september','october','november','december']
            weekdays_de = ['montag','dienstag','mittwoch','donnerstag','freitag','samstag','sonntag']
            weekdays_en = ['monday','tuesday','wednesday','thursday','friday','saturday','sunday']
            common_caps = {'The','This','That','Die','Der','Das','Ein','Eine','Und','Oder','Aber','Mit','Ohne','Für','Bei','Von','Zum','Zur','Im','In'}

            try:
                from config_manager import ConfigManager as _NameCfg  # type: ignore
                _ncfg = _NameCfg()
                names_enabled = _ncfg.get('analysis.names.enabled', True)
                names_affect_score = bool(_ncfg.get('analysis.names.affect_score', False))
                lang_hint_names = _ncfg.get('analysis.tgt_lang', 'de') or 'de'
            except Exception:
                names_enabled = True
                names_affect_score = False
                lang_hint_names = 'de'

            # Fuzzy / Transliteration Konfiguration einlesen (robust, mit Defaults)
            try:
                _fuzzy_short_max = int(_ncfg.get('analysis.names.fuzzy.short_max_distance', 1) or 1)
            except Exception:
                _fuzzy_short_max = 1
            try:
                _fuzzy_long_max = int(_ncfg.get('analysis.names.fuzzy.long_max_distance', 2) or 2)
            except Exception:
                _fuzzy_long_max = 2
            try:
                _fuzzy_long_threshold = int(_ncfg.get('analysis.names.fuzzy.long_length_threshold', 8) or 8)
            except Exception:
                _fuzzy_long_threshold = 8
            try:
                _translit_extra = _ncfg.get('analysis.names.transliteration_extra', {}) or {}
            except Exception:
                _translit_extra = {}

            def _canonical_name(token: str) -> str:
                """Kanonische Normalisierung für Namen.

                Schritte:
                  1. Lowercase
                  2. Zeichenweise Transliteration (Basis + konfigurierbare Erweiterung)
                  3. Multi-Zeichen-Replacements (nur falls in transliteration_extra definiert)
                  4. Monat/Wochentag Mapping → stabile IDs (month-#, weekday-#)
                """
                low = token.lower()
                # Basis-Map (keine Hardcodes entfernen!)
                translit_map = {
                    'ä':'ae','ö':'oe','ü':'ue','ß':'ss','à':'a','á':'a','â':'a','ã':'a','å':'a','ā':'a','č':'c','ć':'c','đ':'d','é':'e','è':'e','ê':'e','ë':'e','ē':'e','ğ':'g','ï':'i','î':'i','ì':'i','í':'i','ł':'l','ñ':'n','ń':'n','ô':'o','ö':'oe','ò':'o','ó':'o','õ':'o','ř':'r','š':'s','ś':'s','ü':'ue','ù':'u','ú':'u','û':'u','ý':'y','ž':'z','ź':'z','ż':'z'
                }
                # Ein-Zeichen-Erweiterungen aus Konfiguration (überschreiben Basis)
                if _translit_extra:
                    try:
                        for k,v in _translit_extra.items():
                            if isinstance(k,str) and isinstance(v,str) and len(k)==1:
                                translit_map[k.lower()] = v.lower()
                    except Exception:
                        pass
                basic = ''.join(translit_map.get(c, c) for c in low)
                # Multi-Char-Ersatz (z.B. "œ" -> "oe") falls als Key >1 definiert
                if _translit_extra:
                    try:
                        for k,v in _translit_extra.items():
                            if isinstance(k,str) and isinstance(v,str) and len(k) > 1:
                                basic = basic.replace(k.lower(), v.lower())
                    except Exception:
                        pass
                if basic in months_de:
                    return f"month-{months_de.index(basic)+1}"
                if basic in months_en:
                    return f"month-{months_en.index(basic)+1}"
                if basic in weekdays_de:
                    return f"weekday-{weekdays_de.index(basic)+1}"
                if basic in weekdays_en:
                    return f"weekday-{weekdays_en.index(basic)+1}"
                return basic

            def _extract_names(txt: str) -> set[str]:
                if not names_enabled or not txt:
                    return set()
                found = set()
                for m in name_pattern.findall(txt):
                    if m in common_caps or m.isupper():
                        continue
                    found.add(m)
                return found

            # Fuzzy Matching Utility (konfigurierbar) – unterstützt max Distanz 1 oder 2 performant
            # Externes Utility (LRU-cached) verwenden falls verfügbar
            try:
                from analysis_utils import lev_dist_leq as _lev_ext
                def _lev_dist_leq(a: str, b: str, max_d: int) -> bool:  # type: ignore
                    try:
                        return _lev_ext(a, b, max_d)
                    except Exception:
                        # Fallback minimal: Gleichheit / Längencheck
                        if a == b:
                            return True
                        if abs(len(a)-len(b)) > max_d:
                            return False
                        return False
            except Exception:
                def _lev_dist_leq(a: str, b: str, max_d: int) -> bool:  # type: ignore
                    return a == b

            # Konfig: Whitelist / Blacklist / Produkt-Mapping / Einheiten
            try:
                whitelist = set(_ncfg.get('analysis.names.whitelist', []) or [])
                blacklist = set(_ncfg.get('analysis.names.blacklist', []) or [])
                product_map_cfg = _ncfg.get('analysis.names.product_map', {}) or {}
                # product_map: {"produkt_de": ["product_en", "alt_variante"]}
                # Kanonisch auf Basis-canonical Namen abbilden
                product_map = { _canonical_name(k): { _canonical_name(v) for v in (vals if isinstance(vals, list) else [vals]) } for k, vals in product_map_cfg.items() }
                units_required_match = bool(_ncfg.get('analysis.units.enabled', True))
                unit_patterns = _ncfg.get('analysis.units.patterns', ["km","km/h","m","cm","mm","kg","g","%","EUR","€","USD","$","h","min","s"]) or []
                unit_plaus_enabled = bool(_ncfg.get('analysis.units.plausibility.enabled', True))
                magnitude_map_cfg = _ncfg.get('analysis.units.plausibility.magnitude_map', {}) or {}
                default_magnitudes = { 'mm':0.001, 'cm':0.01, 'm':1.0, 'km':1000.0, 'g':1.0, 'kg':1000.0 }
                magnitude_map = { **default_magnitudes, **{k.lower(): float(v) for k,v in magnitude_map_cfg.items() if isinstance(v,(int,float,str)) and str(v).replace('.','',1).isdigit()} }
                currency_enabled = bool(_ncfg.get('analysis.currency.enabled', True))
                currency_map_cfg = _ncfg.get('analysis.currency.map', {}) or {}
            except Exception:
                whitelist = set()
                blacklist = set()
                product_map = {}
                units_required_match = True
                unit_patterns = ["km","km/h","m","cm","kg","%","€","h"]
                unit_plaus_enabled = True
                magnitude_map = { 'mm':0.001, 'cm':0.01, 'm':1.0, 'km':1000.0, 'g':1.0, 'kg':1000.0 }
                currency_enabled = True
                currency_map_cfg = { 'EUR':['€','eur','euro'], 'USD':['$','usd','us$'], 'GBP':['£','gbp'], 'CHF':['chf','sfr','fr'] }

            unit_regex = re.compile(r"(?<![\w])([+-]?\d+[\d.,]*)(?:\s?)(" + "|".join(map(re.escape, unit_patterns)) + r")(?![\w])") if unit_patterns else None

            # Currency Regex & Mapping vorbereiten
            currency_regex = None
            variant_to_code = {}
            if currency_enabled and currency_map_cfg:
                try:
                    variants = []
                    for code, var_list in currency_map_cfg.items():
                        code_up = str(code).upper()
                        all_vars = set([code_up])
                        if isinstance(var_list, list):
                            all_vars.update(var_list)
                        else:
                            all_vars.add(str(var_list))
                        for v in all_vars:
                            v_norm = str(v)
                            variants.append(re.escape(v_norm))
                            variant_to_code[v_norm.lower()] = code_up
                    if variants:
                        currency_regex = re.compile(r"(?<![\w])([+-]?\d+[\d.,]*)(?:\s?)(" + "|".join(variants) + r")(?![\w])", re.IGNORECASE)
                except Exception:
                    currency_regex = None

            # ⚙️ Konfigurierbare Normalisierung aktivieren (Default: True)
            try:
                from config_manager import ConfigManager as _NumCfgMgr  # type: ignore
                _num_cfg = _NumCfgMgr()
                numeric_normalize_enabled = _num_cfg.get('analysis.numeric.normalize', True)
                lang_hint = _num_cfg.get('analysis.tgt_lang', 'de') or 'de'
            except Exception:
                numeric_normalize_enabled = True
                lang_hint = 'de'

            # Externe Normalisierung verwenden (Robust+Getestet)
            try:
                from analysis_utils import normalize_number_token as _norm_num
                def _normalize_number_token(token: str, lang: str) -> str:  # type: ignore
                    try:
                        return _norm_num(token, lang)
                    except Exception:
                        return token
            except Exception:
                def _normalize_number_token(token: str, lang: str) -> str:  # type: ignore
                    return token

            def _build_normalized_sets(tokens: set[str], lang: str):
                if not numeric_normalize_enabled:
                    return tokens, {t: t for t in tokens}
                norm_map = {}
                for t in tokens:
                    try:
                        norm_map[t] = _normalize_number_token(t, lang)
                    except Exception:
                        norm_map[t] = t
                norm_set = set(norm_map.values())
                return norm_set, norm_map

            for item in files or []:
                if not isinstance(item, dict):
                    continue
                src = item.get('source')
                trg = item.get('translation')
                if not src:
                    continue
                src_path = str(src)
                trg_path = str(trg) if trg else None
                src_text = _safe_read(src_path)
                trg_text = _safe_read(trg_path) if trg_path else ''
                source_texts.append(src_text)
                translation_texts.append(trg_text)
                total_source_chars += len(src_text)
                total_translation_chars += len(trg_text)

                # Länge / basic similarity
                similarity = 0.0
                if src_text and trg_text:
                    # simple jaccard über chars (begrenzter Ausschnitt)
                    a = set(src_text[:1000])
                    b = set(trg_text[:1000])
                    denom = len(a | b) or 1
                    similarity = round(len(a & b) / denom, 4)

                # Zahlenkonsistenz
                src_raw_nums = set(num_pattern.findall(src_text))
                trg_raw_nums = set(num_pattern.findall(trg_text)) if trg_text else set()

                # Normalisierte Mengen (sprachempfindlich)
                src_norm_set, src_norm_map = _build_normalized_sets(src_raw_nums, lang_hint)
                trg_norm_set, trg_norm_map = _build_normalized_sets(trg_raw_nums, lang_hint)

                # Fehlende / Extra über normalisierte Werte bestimmen
                missing_norm = src_norm_set - trg_norm_set
                extra_norm = trg_norm_set - src_norm_set

                # Original-Repräsentationen jener Werte sammeln (für Nutzer-Transparenz)
                def _orig_for(norm_values: set[str], raw_map: dict[str,str]):
                    rev = {}
                    for orig, norm in raw_map.items():
                        rev.setdefault(norm, []).append(orig)
                    selected = []
                    for v in norm_values:
                        selected.extend(rev.get(v, []))
                    return sorted(set(selected))

                missing = _orig_for(missing_norm, src_norm_map)
                extra = _orig_for(extra_norm, trg_norm_map)

                number_mismatches_total += len(missing_norm) + len(extra_norm)
                number_total += len(src_norm_set) or 0
                # Einheiten-Konsistenz (an Zahlen gekoppelt)
                unit_missing = []
                unit_extra = []
                unit_plaus_warnings = []
                if units_required_match and unit_regex and (src_text or trg_text):
                    src_units = set(unit_regex.findall(src_text)) if src_text else set()
                    trg_units = set(unit_regex.findall(trg_text)) if trg_text else set()
                    # Normalisieren: Wert+kanonische Einheit (z.B. km/h → kmh)
                    def _norm_unit(u):
                        try:
                            val, unit = u
                        except Exception:
                            return str(u)
                        return _normalize_number_token(val, lang_hint) + '|' + unit.lower().replace('/', '')
                    src_units_norm = { _norm_unit(u) for u in src_units }
                    trg_units_norm = { _norm_unit(u) for u in trg_units }
                    u_miss = src_units_norm - trg_units_norm
                    u_extra = trg_units_norm - src_units_norm
                    # Original-Rekonstruktion (erstes Auftreten)
                    def _orig_units(norm_set, original_pairs):
                        out = []
                        for v in norm_set:
                            for pair in original_pairs:
                                val, unit = pair
                                if _normalize_number_token(val, lang_hint) + '|' + unit.lower().replace('/', '') == v:
                                    out.append(val.strip() + ' ' + unit)
                                    break
                        return out
                    unit_missing = _orig_units(u_miss, src_units)
                    unit_extra = _orig_units(u_extra, trg_units)
                    unit_mismatches_total += len(u_miss) + len(u_extra)
                    unit_total += len(src_units_norm) or 0
                    if unit_plaus_enabled and (src_units or trg_units):
                        def _group(units):
                            g = {}
                            for val, unit in units:
                                val_norm = _normalize_number_token(val, lang_hint)
                                unit_norm = unit.lower().replace('/', '')
                                g.setdefault(val_norm, set()).add(unit_norm)
                            return g
                        g_src = _group(src_units)
                        g_trg = _group(trg_units)
                        shared_vals = set(g_src.keys()) & set(g_trg.keys())
                        for val in shared_vals:
                            for us in g_src[val]:
                                for ut in g_trg[val]:
                                    if us != ut:
                                        mag_s = magnitude_map.get(us, None)
                                        mag_t = magnitude_map.get(ut, None)
                                        if mag_s is not None and mag_t is not None and mag_s != mag_t:
                                            warn = f"{val} {us} -> {val} {ut}"
                                            unit_plaus_warnings.append(warn)
                        if unit_plaus_warnings:
                            aggregated_unit_plaus_warnings.extend(unit_plaus_warnings)

                # Währungs-Konsistenz
                currencies_missing = []
                currencies_extra = []
                if currency_enabled and currency_regex and (src_text or trg_text):
                    src_curs = set(currency_regex.findall(src_text)) if src_text else set()
                    trg_curs = set(currency_regex.findall(trg_text)) if trg_text else set()
                    def _norm_currency(entry):
                        try:
                            val, cur = entry
                        except Exception:
                            return str(entry)
                        canon_val = _normalize_number_token(val, lang_hint)
                        canon_code = variant_to_code.get(str(cur).lower(), str(cur).upper())
                        return canon_val + '|' + canon_code
                    src_cur_norm = { _norm_currency(c) for c in src_curs }
                    trg_cur_norm = { _norm_currency(c) for c in trg_curs }
                    c_miss = src_cur_norm - trg_cur_norm
                    c_extra = trg_cur_norm - src_cur_norm
                    def _orig_currencies(norm_set, original_pairs):
                        out = []
                        for v in norm_set:
                            val_norm, code = v.split('|',1)
                            for pair in original_pairs:
                                val, cur = pair
                                canon_code = variant_to_code.get(str(cur).lower(), str(cur).upper())
                                if _normalize_number_token(val, lang_hint) == val_norm and canon_code == code:
                                    out.append(val.strip() + ' ' + cur)
                                    break
                        return out
                    currencies_missing = _orig_currencies(c_miss, src_curs)
                    currencies_extra = _orig_currencies(c_extra, trg_curs)
                    currency_mismatches_total += len(c_miss) + len(c_extra)
                    currency_total += len(src_cur_norm) or 0

                # Namen-Konsistenz
                names_missing = []
                names_extra = []
                names_fuzzy_mapped = []  # Treffer über Levenshtein <=1 oder Produkt-Mapping
                if names_enabled:
                    src_names = _extract_names(src_text)
                    trg_names = _extract_names(trg_text) if trg_text else set()
                    if src_names or trg_names:
                        src_can = { _canonical_name(n) for n in src_names }
                        trg_can = { _canonical_name(n) for n in trg_names }
                        # Produkt-Mapping: erweitere Ziel-Kanonische Menge um erlaubte Varianten
                        augmented_trg_can = set(trg_can)
                        for canonical_src in list(src_can):
                            mapped = product_map.get(canonical_src)
                            if mapped:
                                augmented_trg_can.update(mapped)
                        trg_can = augmented_trg_can
                        miss_can = src_can - trg_can
                        extra_can = trg_can - src_can
                        # Fuzzy Matching: dynamisch (kurze Namen max Distanz kurz, lange Namen max Distanz lang)
                        still_missing = set(miss_can)
                        for m_can in list(still_missing):
                            max_d = _fuzzy_long_max if len(m_can) >= _fuzzy_long_threshold else _fuzzy_short_max
                            for t_can in trg_can:
                                if _lev_dist_leq(m_can, t_can, max_d):
                                    names_fuzzy_mapped.append(m_can)
                                    still_missing.discard(m_can)
                                    break
                        miss_can = still_missing
                        # Mapping zurück zu Original
                        names_missing = sorted({ n for n in src_names if _canonical_name(n) in miss_can })
                        names_extra = sorted({ n for n in trg_names if _canonical_name(n) in extra_can })
                        # Whitelist / Blacklist filtern
                        if whitelist:
                            names_missing = [n for n in names_missing if _canonical_name(n) not in whitelist]
                        if blacklist:
                            # Blacklist-Verletzungen als extra kennzeichnen (werden nicht entfernt sondern ergänzt)
                            blk_hits = [n for n in trg_names if _canonical_name(n) in blacklist]
                            if blk_hits:
                                names_extra = sorted(set(names_extra) | set(blk_hits))
                        names_mismatches_total += len(miss_can) + len(extra_can)
                        names_total += len(src_can) or 0

                # Unübersetzte Segmente (identische Zeilen) – nur grob
                untranslated_local = 0
                segs = 0
                if src_text and trg_text:
                    src_lines = [l.strip() for l in src_text.splitlines() if l.strip()]
                    trg_lines = set(l.strip() for l in trg_text.splitlines() if l.strip())
                    for l in src_lines:
                        if len(l) > 25:  # heuristik: nur längere Zeilen zählen
                            segs += 1
                            if l in trg_lines:
                                untranslated_local += 1
                untranslated_segments_total += untranslated_local
                total_segments += segs

                length_ratio = round((len(trg_text) / (len(src_text) or 1)), 4) if src_text else 0.0

                pairs.append({
                    'id': hashlib.md5(f"{src_path}|{trg_path}".encode('utf-8', 'ignore')).hexdigest()[:12],
                    'source': src_path,
                    'translation': trg_path,
                    'source_size': len(src_text),
                    'translation_size': len(trg_text),
                    'length_ratio': length_ratio,
                    'char_similarity': similarity,
                    'numbers_missing': missing if missing else [],  # Original-Formate der fehlenden Zahlen
                    'numbers_extra': extra if extra else [],        # Original-Formate der zusätzlichen Zahlen
                    'numbers_normalized_total': len(src_norm_set),  # Transparenz: Basis für Konsistenzmetrik
                    'numbers_mismatch_normalized': len(missing_norm) + len(extra_norm),
                    'names_missing': names_missing if names_missing else [],
                    'names_extra': names_extra if names_extra else [],
                    'names_fuzzy_mapped': names_fuzzy_mapped if names_fuzzy_mapped else [],
                    'units_missing': unit_missing if unit_missing else [],
                    'units_extra': unit_extra if unit_extra else [],
                    'unit_plausibility_warnings': unit_plaus_warnings if unit_plaus_warnings else [],
                    'currencies_missing': currencies_missing if currencies_missing else [],
                    'currencies_extra': currencies_extra if currencies_extra else [],
                    'untranslated_segments': untranslated_local,
                    'segments_considered': segs
                })

            # Fortschritt nach Pair-Build Phase
            _progress('pairs', files=len(pairs))

            # Aggregierte Kennzahlen
            avg_ratio = round(sum(p['length_ratio'] for p in pairs) / (len(pairs) or 1), 4) if pairs else 0.0
            ratio_dev = 0.0
            if pairs:
                ratio_dev = round(math.sqrt(sum((p['length_ratio'] - avg_ratio) ** 2 for p in pairs) / len(pairs)), 4)
            untranslated_ratio = round(untranslated_segments_total / (total_segments or 1), 4)
            numeric_consistency = 1.0
            if number_total:
                numeric_consistency = max(0.0, 1 - (number_mismatches_total / (number_total * 2)))
            name_consistency = 1.0
            if names_total:
                name_consistency = max(0.0, 1 - (names_mismatches_total / (names_total * 2)))
            unit_consistency = 1.0
            if unit_total:
                unit_consistency = max(0.0, 1 - (unit_mismatches_total / (unit_total * 2)))
            currency_consistency = 1.0
            if currency_total:
                currency_consistency = max(0.0, 1 - (currency_mismatches_total / (currency_total * 2)))

            completeness = 0.0
            if total_source_chars:
                completeness = min(1.0, total_translation_chars / (total_source_chars * 1.05))  # kleiner Puffer

            # Teil-Scores (explizit für Breakdown)
            length_balance_score = max(0.0, 1 - min(ratio_dev, 1))           # 1 bei perfekter Balance, fällt mit Streuung
            untranslated_completeness_score = max(0.0, 1 - untranslated_ratio) # 1 wenn keine unübersetzten Segmente
            numeric_consistency_score = numeric_consistency
            name_consistency_score = name_consistency
            unit_consistency_score = unit_consistency
            translation_completeness_score = completeness

            # 🆕 Phase 1 Struktur-/Platzhalter-/Whitespace-/Bracket-Checks
            structural_phase1_score = 1.0
            phase1_report = {}
            try:
                # Konfigurationsschalter einlesen (analysis.phase1.enabled, default True)
                _phase1_enabled_cfg = True
                try:
                    from config_manager import ConfigManager as _p1_cfg_cls  # type: ignore
                    _p1cfg = _p1_cfg_cls()
                    _phase1_enabled_cfg = _p1cfg.get('analysis.phase1.enabled', True)
                    # Optionaler Override für Gewicht (analysis.phase1.weight)
                    _phase1_weight_override = _p1cfg.get('analysis.phase1.weight', None)
                except Exception:
                    _phase1_weight_override = None
                from quality_gui_phase1_checkers import run_phase1_checks as _phase1_run  # type: ignore
                _phase1_issues = []
                if _phase1_enabled_cfg:
                    # Quelle/Ziel Texte paarweise (gleiche Reihenfolge wie file_pairs Aufbau)
                    _phase1_pairs = zip(source_texts, translation_texts)
                    _phase1_issues = _phase1_run(_phase1_pairs) or []
                if _phase1_issues:
                    _sev_counts_p1 = {}
                    _code_counts = {}
                    _cat_counts = {}
                    _samples = {}
                    for _iss in _phase1_issues:
                        _sev_counts_p1[_iss.severity] = _sev_counts_p1.get(_iss.severity, 0) + 1
                        _code_counts[_iss.code] = _code_counts.get(_iss.code, 0) + 1
                        _cat_counts[_iss.category] = _cat_counts.get(_iss.category, 0) + 1
                        # Kurze Beispielsammlung (eine Message pro Code, max 12 Codes)
                        if _iss.code not in _samples and len(_samples) < 12:
                            _samples[_iss.code] = _iss.message[:180]
                    # 🔧 Raw Issues für spätere Detailanzeige zwischenspeichern (additiv, kein Export-Zwang)
                    try:
                        self._phase1_issues_last = _phase1_issues  # additive state variable
                    except Exception:
                        pass
                    _crit = _sev_counts_p1.get('critical', 0)
                    _maj = _sev_counts_p1.get('major', 0)
                    _min = _sev_counts_p1.get('minor', 0)
                    _den = max(1, len(pairs))
                    _penalty = min(1.0, (_crit * 1.0 + _maj * 0.5 + _min * 0.2) / _den)
                    structural_phase1_score = max(0.0, 1 - _penalty)
                    phase1_report = {
                        'issue_total': len(_phase1_issues),
                        'by_severity': _sev_counts_p1,
                        'by_code': _code_counts,
                        'by_category': _cat_counts,
                        'samples': _samples,
                        'structural_score': round(structural_phase1_score, 4)
                    }
                else:
                    phase1_report = {'issue_total': 0, 'structural_score': 1.0}
            except Exception as _p1_err:  # robust: Fehler dürfen Analyse nicht brechen
                phase1_report = {'skipped': True, 'error': str(_p1_err)[:200]}
                structural_phase1_score = 1.0
            _progress('phase1', structural_phase1_score=structural_phase1_score)

            # 🆕 Phase 2 Erweiterte Checks (HTML, Anrede, Terminologie, Duplikat, Zeichensetzung, Security)
            structural_phase2_score = 1.0
            phase2_report = {}
            try:
                _phase2_enabled_cfg = True
                _phase2_weight_override = None
                _glossary_path = 'glossary_terms.json'
                try:
                    from config_manager import ConfigManager as _p2_cfg_cls  # type: ignore
                    _p2cfg = _p2_cfg_cls()
                    _phase2_enabled_cfg = _p2cfg.get('analysis.phase2.enabled', True)
                    _phase2_weight_override = _p2cfg.get('analysis.phase2.weight', None)
                    _glossary_path = _p2cfg.get('analysis.phase2.glossary_path', _glossary_path)
                except Exception:
                    pass
                phase2_issues = []
                if _phase2_enabled_cfg:
                    try:
                        from quality_gui_phase2_checkers import run_phase2_checks as _phase2_run  # type: ignore
                        phase2_pairs = zip(source_texts, translation_texts)
                        phase2_issues = _phase2_run(phase2_pairs, glossary_path=_glossary_path) or []
                    except Exception as _p2_imp_err:  # Import/Runtime Fehler kapseln
                        phase2_report = {'skipped': True, 'error': str(_p2_imp_err)[:180]}
                        phase2_issues = []
                if phase2_issues:
                    sev2 = {}
                    code_counts2 = {}
                    cat_counts2 = {}
                    samples2 = {}
                    for iss in phase2_issues:
                        sev2[iss.severity] = sev2.get(iss.severity, 0) + 1
                        code_counts2[iss.code] = code_counts2.get(iss.code, 0) + 1
                        cat_counts2[iss.category] = cat_counts2.get(iss.category, 0) + 1
                        if iss.code not in samples2 and len(samples2) < 12:
                            samples2[iss.code] = iss.message[:180]
                    try:
                        self._phase2_issues_last = phase2_issues
                    except Exception:
                        pass
                    crit = sev2.get('critical', 0)
                    maj = sev2.get('major', 0)
                    minu = sev2.get('minor', 0)
                    den = max(1, len(source_texts))
                    penalty2 = min(1.0, (crit * 1.0 + maj * 0.5 + minu * 0.2) / den)
                    structural_phase2_score = max(0.0, 1 - penalty2)
                    phase2_report = {
                        'issue_total': len(phase2_issues),
                        'by_severity': sev2,
                        'by_code': code_counts2,
                        'by_category': cat_counts2,
                        'samples': samples2,
                        'advanced_score': round(structural_phase2_score, 4)
                    }
                else:
                    if not phase2_report:  # nicht überschreiben falls skipped gesetzt wurde
                        phase2_report = {'issue_total': 0, 'advanced_score': 1.0}
            except Exception as _p2_err:
                phase2_report = {'skipped': True, 'error': str(_p2_err)[:200]}
                structural_phase2_score = 1.0
            _progress('phase2', structural_phase2_score=structural_phase2_score)

            # 🆕 Phase 3 (Semantik / Stil vertieft / Risiko erweitert / Lesbarkeit)
            structural_phase3_score = 1.0
            phase3_report = {}
            try:
                _phase3_enabled_cfg = True
                _phase3_weight_override = None
                _phase3_semantic = True
                _phase3_semantic_ollama = False
                _phase3_semantic_ollama_model = 'nomic-embed-text'
                try:
                    from config_manager import ConfigManager as _p3_cfg_cls  # type: ignore
                    _p3cfg = _p3_cfg_cls()
                    _phase3_enabled_cfg = _p3cfg.get('analysis.phase3.enabled', False)  # Default AUS (schwerer)
                    _phase3_weight_override = _p3cfg.get('analysis.phase3.weight', None)
                    _phase3_semantic = _p3cfg.get('analysis.phase3.semantic', True)
                    _phase3_semantic_ollama = _p3cfg.get('analysis.phase3.semantic.use_ollama', False)
                    _phase3_semantic_ollama_model = _p3cfg.get('analysis.phase3.semantic.ollama_model', 'nomic-embed-text') or 'nomic-embed-text'
                except Exception:
                    pass
                p3_issues = []
                if _phase3_enabled_cfg:
                    try:
                        from quality_gui_phase3_checkers import run_phase3_checks as _phase3_run  # type: ignore
                        p3_pairs = zip(source_texts, translation_texts)
                        p3_issues = _phase3_run(
                            p3_pairs,
                            enable_semantic=_phase3_semantic,
                            semantic_use_ollama=(_phase3_semantic and _phase3_semantic_ollama),
                            semantic_ollama_model=_phase3_semantic_ollama_model
                        ) or []
                    except Exception as _p3_imp_err:
                        phase3_report = {'skipped': True, 'error': str(_p3_imp_err)[:160]}
                        p3_issues = []
                if p3_issues:
                    sev3 = {}; code3 = {}; cat3 = {}; samples3 = {}
                    for iss in p3_issues:
                        sev3[iss.severity] = sev3.get(iss.severity, 0) + 1
                        code3[iss.code] = code3.get(iss.code, 0) + 1
                        cat3[iss.category] = cat3.get(iss.category, 0) + 1
                        if iss.code not in samples3 and len(samples3) < 12:
                            samples3[iss.code] = iss.message[:180]
                    try: self._phase3_issues_last = p3_issues
                    except Exception as ex_p3_assign:
                        try:
                            self._record_suppressed_error('analysis.phase3.assign', ex_p3_assign)
                        except Exception:
                            pass
                    crit3 = sev3.get('critical',0); maj3 = sev3.get('major',0); min3 = sev3.get('minor',0)
                    den3 = max(1, len(source_texts))
                    penalty3 = min(1.0, (crit3 * 1.0 + maj3 * 0.5 + min3 * 0.2) / den3)
                    structural_phase3_score = max(0.0, 1 - penalty3)
                    phase3_report = {
                        'issue_total': len(p3_issues),
                        'by_severity': sev3,
                        'by_code': code3,
                        'by_category': cat3,
                        'samples': samples3,
                        'semantic_enabled': bool(_phase3_semantic),
                        'semantic_ollama': bool(_phase3_semantic and _phase3_semantic_ollama),
                        'semantic_ollama_model': _phase3_semantic_ollama_model if (_phase3_semantic and _phase3_semantic_ollama) else None,
                        'advanced2_score': round(structural_phase3_score, 4)
                    }
                else:
                    if not phase3_report:
                        phase3_report = {'issue_total': 0, 'advanced2_score': 1.0}
            except Exception as _p3_err:
                phase3_report = {'skipped': True, 'error': str(_p3_err)[:200]}
                structural_phase3_score = 1.0
            _progress('phase3', structural_phase3_score=structural_phase3_score)

            # 🆕 Phase 4 Konsolidierung (Aggregation Risiko + Empfehlungen)
            structural_phase4_score = 1.0
            phase4_report = {}
            try:
                _phase4_enabled_cfg = True
                _phase4_weight_override = None
                try:
                    from config_manager import ConfigManager as _p4_cfg_cls  # type: ignore
                    _p4cfg = _p4_cfg_cls()
                    _phase4_enabled_cfg = _p4cfg.get('analysis.phase4.enabled', False)  # Default AUS
                    _phase4_weight_override = _p4cfg.get('analysis.phase4.weight', None)
                except Exception:
                    pass
                if _phase4_enabled_cfg:
                    try:
                        from quality_gui_phase4_checkers import consolidate_issues as _p4_cons  # type: ignore
                        _p1_list = locals().get('_phase1_issues', []) or []
                        _p2_list = locals().get('phase2_issues', []) or []
                        _p3_list = locals().get('p3_issues', []) or []
                        _p4_res = _p4_cons(_p1_list, _p2_list, _p3_list) or {}
                        phase4_report = _p4_res
                        rs = float(_p4_res.get('risk_score', 0.0) or 0.0)
                        # Risiko invertieren -> hoher Score bleibt gut
                        structural_phase4_score = max(0.0, min(1.0, 1.0 - rs))
                    except Exception as _p4_imp_err:
                        phase4_report = {'skipped': True, 'error': str(_p4_imp_err)[:160]}
                        structural_phase4_score = 1.0
                else:
                    phase4_report = {'skipped': True, 'disabled': True}
            except Exception as _p4_err:
                phase4_report = {'skipped': True, 'error': str(_p4_err)[:200]}
                structural_phase4_score = 1.0
            _progress('phase4', structural_phase4_score=structural_phase4_score)

            # 🆕 Phase 5 Enforcer (Safe Auto-Fix + CI-Gate) – optional & additiv
            phase5_report = {}
            try:
                _phase5_enabled_cfg = False
                _phase5_llm_enabled = False
                try:
                    from config_manager import ConfigManager as _p5_cfg_cls  # type: ignore
                    _p5cfg = _p5_cfg_cls()
                    _phase5_enabled_cfg = _p5cfg.get('analysis.phase5.enabled', False)
                    _phase5_llm_enabled = _p5cfg.get('analysis.phase5.llm_enabled', False)
                except Exception:
                    pass
                if _phase5_enabled_cfg and getattr(self, 'phase5_enabled', True):
                    try:
                        from quality_gui_phase5_enforcer import enforce_phase5  # type: ignore
                        # Ursprüngliche Paare (source_texts, translation_texts) liegen vor
                        _orig_pairs = list(zip(source_texts, translation_texts))
                        # Phase1 Issues Liste (für Guard) + andere
                        _p1_list = locals().get('_phase1_issues', []) or []
                        _p2_list = locals().get('phase2_issues', []) or []
                        _p3_list = locals().get('p3_issues', []) or []
                        _enf_res = enforce_phase5(
                            _orig_pairs,
                            _p1_list,
                            _p2_list,
                            _p3_list,
                            phase4_report or {},
                            baseline_path='qa_baseline.json',
                            recheck_phase1_fn=None,  # GUI: kein automatischer Re-Run hier (Performance)
                            out_dir='qa_artifacts',
                            write_artifacts=True,
                            export_sarif_flag=True
                        )
                        phase5_report = {
                            'pass': _enf_res.get('pass'),
                            'reasons': _enf_res.get('reasons'),
                            'applied_fix_count': len(_enf_res.get('applied_fixes', [])),
                            'artifact_paths': _enf_res.get('artifacts', {})
                        }
                        # (Optional) Übersetzungen im Speicher aktualisieren, falls pass
                        if _enf_res.get('pass') and _enf_res.get('pairs_changed'):
                            try:
                                new_pairs = _enf_res['pairs_changed']
                                # Nur Zieltexte ersetzen
                                for i, (_s, _t) in enumerate(new_pairs):
                                    if i < len(translation_texts):
                                        translation_texts[i] = _t
                            except Exception:
                                pass
                    except Exception as _p5_err:
                        phase5_report = {'skipped': True, 'error': str(_p5_err)[:160]}
                else:
                    phase5_report = {'skipped': True, 'disabled': True}
            except Exception as _p5_top_err:
                phase5_report = {'skipped': True, 'error': str(_p5_top_err)[:160]}
            try:
                # Nur Score falls pass/fail Informationen später relevant – hier einfacher Status
                _progress('phase5', phase5_pass=phase5_report.get('pass') if isinstance(phase5_report, dict) else None)
            except Exception:
                pass

            # 🆕 Phase 6 (Intelligente Verbesserungsvorschläge) – optional & additiv
            phase6_report = {}
            try:
                _phase6_enabled_cfg = False
                _phase6_max = 40
                _phase6_llm = False
                try:
                    from config_manager import ConfigManager as _p6_cfg_cls  # type: ignore
                    _p6cfg = _p6_cfg_cls()
                    _phase6_enabled_cfg = _p6cfg.get('analysis.phase6.enabled', False)
                    _phase6_max = int(_p6cfg.get('analysis.phase6.max_suggestions', 40) or 40)
                    _phase6_llm = _p6cfg.get('analysis.phase6.enable_llm', False)
                except Exception:
                    pass
                if _phase6_enabled_cfg and getattr(self, 'phase6_enabled', True):
                    try:
                        from quality_gui_phase6_suggestions import run_phase6_suggestions, QASuggestion  # type: ignore
                        # Kombiniere Issues aus vorangegangenen Phasen (falls vorhanden)
                        _acc_issues = []
                        for _lst_name in ('_phase1_issues', 'phase2_issues', 'p3_issues'):
                            _lst = locals().get(_lst_name)
                            if _lst:
                                _acc_issues.extend(_lst)
                        # Konsolidierte Issues aus Phase 4 optional (enthält evtl. Kopien → tolerant)
                        try:
                            if isinstance(phase4_report, dict) and phase4_report.get('total'):
                                # Phase4 hat keine Original-QAIssue Objekte, daher nicht zwingend hinzufügen
                                pass
                        except Exception:
                            pass
                        _p6_pairs = list(zip(source_texts, translation_texts))
                        _sugs = run_phase6_suggestions(_p6_pairs, _acc_issues, max_suggestions=_phase6_max, enable_llm=_phase6_llm)
                        # Aggregation
                        _by_cat = {}
                        for s in _sugs:
                            _by_cat[s.category] = _by_cat.get(s.category, 0) + 1
                        _samples = []
                        for s in _sugs[: min(6, len(_sugs))]:
                            _samples.append({'message': s.message, 'category': s.category, 'priority': s.priority})
                        phase6_report = {
                            'suggestion_total': len(_sugs),
                            'by_category': _by_cat,
                            'samples': _samples,
                            'llm_enabled': bool(_phase6_llm),
                        }
                        try:
                            self._phase6_suggestions_last = [s.__dict__ for s in _sugs]
                            # Runtime Kontext für schnelles Re-Generate (Refresh Button)
                            try:
                                self._phase6_runtime_context = {
                                    'pairs': _p6_pairs,
                                    # Original Dateireferenzen für Persistenz (source/translation Pfade)
                                    'file_records': files,
                                    # Speichere Issues minimal (nur essentielle Felder) um UI leicht zu halten
                                    'issues': [
                                        {
                                            'code': getattr(i, 'code', ''),
                                            'severity': getattr(i, 'severity', ''),
                                            'category': getattr(i, 'category', ''),
                                            'message': getattr(i, 'message', ''),
                                            'source_text': getattr(i, 'source_text', getattr(i, 'source', '')),
                                            'target_text': getattr(i, 'target_text', getattr(i, 'target', '')),
                                        }
                                        for i in _acc_issues
                                    ],
                                    'cfg': {
                                        'max': _phase6_max,
                                        'llm': _phase6_llm
                                    }
                                }
                            except Exception:
                                pass
                        except Exception:
                            pass
                    except Exception as _p6_err:
                        phase6_report = {'skipped': True, 'error': str(_p6_err)[:160]}
                else:
                    phase6_report = {'skipped': True, 'disabled': True}
            except Exception as _p6_top_err:
                phase6_report = {'skipped': True, 'error': str(_p6_top_err)[:160]}
            try:
                _progress('phase6', suggestions=phase6_report.get('suggestion_total') if isinstance(phase6_report, dict) else None)
            except Exception:
                pass

            # Gewichte zentral definieren (leichter später justierbar)
            # Dynamische Gewichtung via availability-aware Utility
            base_weights = {
                'numeric_consistency': 0.30,
                'length_balance': 0.16,
                'translation_completeness': 0.22,
                'untranslated': 0.16,
                'unit_consistency': 0.09,
                'currency_consistency': 0.07 if currency_total else 0.0,
                'name_consistency': 0.05 if names_affect_score and names_total else 0.0,
                # 🔧 Neuer optionaler Anteil für strukturelle Phase-1 Checks (wird dynamisch normalisiert)
                'structural_phase1': 0.08,
                # 🆕 Anteil für Phase 2 Erweiterte Checks
                'structural_phase2': 0.06,
                # 🆕 Anteil für Phase 3 (standardmäßig kleiner – optional)
                'structural_phase3': 0.05,
                # 🆕 Anteil Phase 4 Konsolidierung (Meta-Aggregation)
                'structural_phase4': 0.04
            }
            # Optionales Override aus Config anwenden
            try:
                if '_phase1_weight_override' in locals() and _phase1_weight_override is not None:
                    val = float(_phase1_weight_override)
                    if 0 <= val <= 0.5:
                        base_weights['structural_phase1'] = val
                if '_phase2_weight_override' in locals() and _phase2_weight_override is not None:
                    val2 = float(_phase2_weight_override)
                    if 0 <= val2 <= 0.5:
                        base_weights['structural_phase2'] = val2
                if '_phase3_weight_override' in locals() and _phase3_weight_override is not None:
                    val3 = float(_phase3_weight_override)
                    if 0 <= val3 <= 0.5:
                        base_weights['structural_phase3'] = val3
                if '_phase4_weight_override' in locals() and _phase4_weight_override is not None:
                    val4 = float(_phase4_weight_override)
                    if 0 <= val4 <= 0.5:
                        base_weights['structural_phase4'] = val4
            except Exception:
                pass
            availability = {
                'numeric_consistency': number_total > 0,
                'length_balance': True,
                'translation_completeness': total_source_chars > 0,
                'untranslated': total_segments > 0,
                'unit_consistency': unit_total > 0,
                'currency_consistency': currency_total > 0,
                'name_consistency': names_affect_score and names_total > 0,
                'structural_phase1': (len(pairs) > 0) and ('skipped' not in phase1_report) and (phase1_report.get('issue_total',0) or 0) >= 0,
                'structural_phase2': (len(pairs) > 0) and ('skipped' not in phase2_report) and (phase2_report.get('issue_total',0) or 0) >= 0,
                'structural_phase3': (len(pairs) > 0) and ('skipped' not in phase3_report) and (phase3_report.get('issue_total',0) or 0) >= 0,
                'structural_phase4': (len(pairs) > 0) and ('skipped' not in phase4_report)
            }
            try:
                from analysis_utils import compute_dynamic_weights as _cdw
                weights = _cdw(base_weights, availability)
            except Exception:
                weights = base_weights
            overall_score = round(
                numeric_consistency_score * weights.get('numeric_consistency', 0) +
                length_balance_score * weights.get('length_balance', 0) +
                translation_completeness_score * weights.get('translation_completeness', 0) +
                untranslated_completeness_score * weights.get('untranslated', 0) +
                unit_consistency_score * weights.get('unit_consistency', 0) +
                currency_consistency * weights.get('currency_consistency', 0) +
                name_consistency_score * weights.get('name_consistency', 0) +
                structural_phase1_score * weights.get('structural_phase1', 0) +
                structural_phase2_score * weights.get('structural_phase2', 0) +
                structural_phase3_score * weights.get('structural_phase3', 0) +
                structural_phase4_score * weights.get('structural_phase4', 0)
            , 4)
            _progress('metrics', quality_score=overall_score, critical=0, major=0, minor=0)  # Severity folgt später

            # 2. Plugins ausführen
            plugin_context = {
                'source_texts': source_texts,
                'translation_texts': translation_texts,
                'source_files': [p['source'] for p in pairs],
                'translation_files': [p['translation'] for p in pairs],
                'pairs': pairs,
                '__allowed_rules__': allowed_rules,
            }
            plugin_results = []
            try:
                plugin_results = self._analyze_with_plugins(plugin_context) or []
            except Exception:
                plugin_results = []
            # Plugin Result Normalisierung (dataclass → dict)
            norm_plugin_results = []
            for r in plugin_results:
                try:
                    if hasattr(r, '__dict__'):
                        norm_plugin_results.append({
                            'rule': getattr(r, 'rule', 'unknown'),
                            'passed': getattr(r, 'passed', None),
                            'details': getattr(r, 'details', {})
                        })
                    elif isinstance(r, dict):
                        norm_plugin_results.append(r)
                except Exception:
                    continue

            per_rule_summary = {rp['rule']: rp.get('details', {}) for rp in norm_plugin_results if isinstance(rp, dict)}

            duration = time.time() - start
            metrics = {
                'pair_count': len(pairs),
                'total_source_chars': total_source_chars,
                'avg_length_ratio': avg_ratio,
                'length_ratio_deviation': ratio_dev,
                'numeric_consistency': round(numeric_consistency, 4),
                'name_consistency': round(name_consistency, 4),
                'unit_consistency': round(unit_consistency, 4),
                'currency_consistency': round(currency_consistency, 4),
                'untranslated_ratio': untranslated_ratio,
                'completeness': round(completeness, 4),
                'overall_score': overall_score,
                'length_balance_score': round(length_balance_score, 4),
                'numeric_consistency_score': round(numeric_consistency_score, 4),
                'name_consistency_score': round(name_consistency_score, 4),
                'unit_consistency_score': round(unit_consistency_score, 4),
                'currency_consistency_score': round(currency_consistency, 4),
                'translation_completeness_score': round(translation_completeness_score, 4),
                'untranslated_completeness_score': round(untranslated_completeness_score, 4),
                'structural_phase1_score': round(structural_phase1_score, 4),
                'structural_phase2_score': round(structural_phase2_score, 4),
                'structural_phase3_score': round(structural_phase3_score, 4),
                'structural_phase4_score': round(structural_phase4_score, 4),
                'score_breakdown_weights': weights,
            }

            # Heuristische Severity-Klassifikation (ohne externe Regeln) – liefert konsistente Anzeige
            critical_pairs = [p for p in pairs if (p.get('char_similarity', 0) < 0.15 and p.get('untranslated_segments', 0) > 0) or numeric_consistency_score < 0.75]
            major_pairs = [p for p in pairs if p not in critical_pairs and (p.get('length_ratio', 0) < 0.6 or p.get('length_ratio', 1) > 1.4 or len(p.get('numbers_missing') or []) + len(p.get('numbers_extra') or []) >= 2)]
            minor_pairs = [p for p in pairs if p not in critical_pairs and p not in major_pairs and (p.get('untranslated_segments', 0) > 0 or (len(p.get('numbers_missing') or []) + len(p.get('numbers_extra') or [])) == 1 or abs(p.get('length_ratio', 1) - 1) > 0.15)]

            sev_counts = {
                'critical': len(critical_pairs),
                'major': len(major_pairs),
                'minor': len(minor_pairs)
            }
            # Jetzt wo Severities bestimmt sind Progress updaten
            try:
                _progress('severity', critical=sev_counts['critical'], major=sev_counts['major'], minor=sev_counts['minor'])
            except Exception:
                pass

            # Qualität-Grade (A..D) für schnelle Einordnung
            def _grade(score: float) -> str:
                if score >= 0.90: return 'A'
                if score >= 0.80: return 'B'
                if score >= 0.65: return 'C'
                return 'D'
            quality_grade = _grade(overall_score)
            # Konsolidierter Konsistenz-Report (Beispiele)
            def _sample(field_missing: str, field_extra: str, limit: int = 8):
                miss_samples = []
                extra_samples = []
                for p in pairs:
                    if len(miss_samples) < limit and p.get(field_missing):
                        miss_samples.extend(p[field_missing])
                    if len(extra_samples) < limit and p.get(field_extra):
                        extra_samples.extend(p[field_extra])
                    if len(miss_samples) >= limit and len(extra_samples) >= limit:
                        break
                return sorted(set(miss_samples))[:limit], sorted(set(extra_samples))[:limit]
            nums_miss_s, nums_extra_s = _sample('numbers_missing','numbers_extra')
            units_miss_s, units_extra_s = _sample('units_missing','units_extra')
            names_miss_s, names_extra_s = _sample('names_missing','names_extra')
            cur_miss_s, cur_extra_s = _sample('currencies_missing','currencies_extra')
            consistency_report = {
                'numbers': {
                    'total_source_numbers': number_total,
                    'mismatches': number_mismatches_total,
                    'missing_sample': nums_miss_s,
                    'extra_sample': nums_extra_s
                },
                'units': {
                    'total_source_units': unit_total,
                    'mismatches': unit_mismatches_total,
                    'missing_sample': units_miss_s,
                    'extra_sample': units_extra_s,
                    'plausibility_warnings': sorted(set(aggregated_unit_plaus_warnings))[:12]
                },
                'names': {
                    'total_source_names': names_total,
                    'mismatches': names_mismatches_total,
                    'missing_sample': names_miss_s,
                    'extra_sample': names_extra_s
                },
                'currencies': {
                    'total_source_currencies': currency_total,
                    'mismatches': currency_mismatches_total,
                    'missing_sample': cur_miss_s,
                    'extra_sample': cur_extra_s
                }
            }
            summary = {
                'rule_profile': rule_profile,
                'duration_s': round(duration, 3),
                'sources': len(source_texts),
                'translations': sum(1 for t in translation_texts if t),
                'plugins_executed': len(norm_plugin_results),
                'allowed_rules': allowed_rules if allowed_rules is not None else 'all',
                'consistency_report': consistency_report
            }
            # Phase 1 Report einfügen (additiv, rückwärtskompatibel)
            try:
                summary['phase1_report'] = phase1_report
            except Exception:
                pass
            # Phase 2 Report einfügen
            try:
                summary['phase2_report'] = phase2_report
            except Exception:
                pass
            try:
                summary['phase3_report'] = phase3_report
            except Exception:
                pass
            try:
                summary['phase4_report'] = phase4_report
            except Exception:
                pass
            # Severity + Gesamtsichtung einfügen (additiv; überschreibt nichts vorhandenes)
            try:
                summary.update(sev_counts)
                summary['count'] = sum(sev_counts.values())
                summary['quality_grade'] = quality_grade
            except Exception:
                pass
            # 🔁 Rückwärtskompatibilität: quality_score (0..100) & Normalisierte Variante
            try:
                summary['quality_score'] = round(overall_score * 100, 2)
                summary['overall_score_norm'] = overall_score
                summary['analysis_export_version'] = 6  # Version erhöht wegen Phase4 Integration
            except Exception:
                pass
            # JSONL History Log (append best-effort, capped fields)
            try:
                hist_path = os.path.join(os.path.dirname(__file__), 'analysis_history.jsonl')
                with open(hist_path, 'a', encoding='utf-8') as _hf:
                    _hf.write(json.dumps({
                        'ts': time.strftime('%Y-%m-%dT%H:%M:%S'),
                        'overall': overall_score,
                        'numeric': numeric_consistency_score,
                        'unit': unit_consistency_score,
                        'currency': currency_consistency,
                        'names': name_consistency_score,
                        'untranslated': untranslated_completeness_score,
                        'pairs': len(pairs)
                    }, ensure_ascii=False) + '\n')
            except Exception:
                pass

            # 📦 Export-Zeilen vorbereiten (aggregierte erste Zeile + Paar-Details + Plugin Ergebnisse)
            export_rows = []
            try:
                # Ergänze Phase 2/3 Kennzahlen explizit (Scores + Issue Counts) für bessere Auswertbarkeit
                phase2_score = metrics.get('structural_phase2_score')
                phase3_score = metrics.get('structural_phase3_score')
                phase4_score = metrics.get('structural_phase4_score')
                phase2_issue_count = 0
                phase3_issue_count = 0
                phase4_issue_count = 0
                try:
                    if isinstance(summary.get('phase2_report'), dict):
                        # Summe aller gefundenen Issues in Phase2 Sub-Abschnitten
                        for v in summary['phase2_report'].values():
                            try:
                                if isinstance(v, dict) and 'issues' in v:
                                    phase2_issue_count += len(v.get('issues') or [])
                                elif isinstance(v, list):
                                    phase2_issue_count += len(v)
                            except Exception:
                                pass
                    if isinstance(summary.get('phase3_report'), dict):
                        for v in summary['phase3_report'].values():
                            try:
                                if isinstance(v, dict) and 'issues' in v:
                                    phase3_issue_count += len(v.get('issues') or [])
                                elif isinstance(v, list):
                                    phase3_issue_count += len(v)
                            except Exception:
                                pass
                    if isinstance(summary.get('phase4_report'), dict):
                        try:
                            phase4_issue_count = int(summary['phase4_report'].get('total', 0) or 0)
                        except Exception:
                            phase4_issue_count = 0
                except Exception:
                    pass
                aggregate_row = {**metrics,
                                  'phase2_score': phase2_score,
                                  'phase3_score': phase3_score,
                                  'phase4_score': phase4_score,
                                  'phase2_issue_count': phase2_issue_count,
                                  'phase3_issue_count': phase3_issue_count,
                                  'phase4_issue_count': phase4_issue_count,
                                  **{f'summary_{k}': v for k, v in summary.items() if k not in metrics}}
                aggregate_row['row_type'] = 'aggregate'
                export_rows.append(aggregate_row)
                for p in pairs:
                    r = dict(p)
                    r['row_type'] = 'pair'
                    r['numbers_missing_count'] = len(r.get('numbers_missing') or [])
                    r['numbers_extra_count'] = len(r.get('numbers_extra') or [])
                    export_rows.append(r)
                for pr in norm_plugin_results:
                    try:
                        pr_row = {'row_type': 'plugin', 'rule': pr.get('rule'), 'passed': pr.get('passed'), **{f'detail_{k}': v for k, v in (pr.get('details') or {}).items()}}
                        export_rows.append(pr_row)
                    except Exception:
                        continue
            except Exception:
                pass
            try:
                self.file_pairs = pairs  # UI Kompatibilität
            except Exception:
                pass
            # 🔤 Grammatik / Rechtschreibung (hybrid) – optional
            grammar_findings = []
            try:
                # Konfigurationsgesteuerte Aktivierung
                cfg = None
                try:
                    from config_manager import ConfigManager
                    cfg = getattr(self, '_config_manager', None) or ConfigManager()
                    if not hasattr(self, '_config_manager'):
                        self._config_manager = cfg
                except Exception:
                    cfg = None
                grammar_enabled = True
                grammar_deep = False
                grammar_use_lt = True
                grammar_use_hunspell = True
                grammar_use_ollama = False
                grammar_max = 250
                if cfg:
                    grammar_enabled = cfg.get('analysis.grammar.enabled', True)
                    grammar_deep = cfg.get('analysis.grammar.deep', False)
                    grammar_use_lt = cfg.get('analysis.grammar.use_languagetool', True)
                    grammar_use_hunspell = cfg.get('analysis.grammar.use_hunspell', True)
                    grammar_use_ollama = cfg.get('analysis.grammar.use_ollama', False)
                    grammar_max = cfg.get('analysis.grammar.max_findings', 250) or 250
                grammar_used = []
                grammar_disabled = []
                if grammar_enabled:
                    import re as _re_grammar
                    # Neuer bevorzugter Import (umbenanntes Modul):
                    try:
                        from quality_gui_grammar import GrammarChecker, _language_tool as _lt_mod, _hunspell as _hs_mod  # type: ignore
                    except Exception:
                        # Fallback auf Legacy-Kompatibilitäts-Wrapper
                        from grammar_quality import GrammarChecker, _language_tool as _lt_mod, _hunspell as _hs_mod  # type: ignore
                    # Segmente extrahieren
                    segs = []
                    for t in translation_texts:
                        if not t:
                            continue
                        for s in _re_grammar.split(r'[.!?]\s+', t):
                            s = s.strip()
                            if len(s) >= 6:
                                segs.append(s)
                    if segs:
                        # Verfügbarkeit bestimmen
                        if grammar_use_lt:
                            if _lt_mod is not None:
                                grammar_used.append('languagetool')
                            else:
                                grammar_disabled.append('languagetool')
                        if grammar_use_hunspell:
                            if _hs_mod is not None:
                                grammar_used.append('hunspell')
                            else:
                                grammar_disabled.append('hunspell')
                        if grammar_use_ollama and grammar_deep:
                            # Ollama Prüfung erfolgt beim Aufruf; hier nur gewünschter Status
                            grammar_used.append('ollama')
                        # Cache Key (Inhalt + Flags + Sprache) & Disk-Layer
                        grammar_cache_hit = False
                        try:
                            import hashlib as _ghash, json, time as _gtime
                            lang_cfg = 'de'
                            try:
                                lang_cfg = cfg.get('analysis.tgt_lang', 'de') if cfg else 'de'
                            except Exception:
                                pass
                            # Hash über gesamten Text-Inhalt (gekürzt) für Robustheit
                            joined_content = '\n'.join(translation_texts)
                            if len(joined_content) > 2_000_000:  # Cap auf ~2MB
                                joined_content = joined_content[:2_000_000]
                            content_hash = _ghash.md5(joined_content.encode('utf-8','ignore')).hexdigest()
                            flags_sig = f"{grammar_use_lt}-{grammar_use_hunspell}-{grammar_use_ollama and grammar_deep}-{grammar_deep}-{grammar_max}-{lang_cfg}"
                            cache_key = _ghash.md5((flags_sig + '|' + content_hash).encode('utf-8','ignore')).hexdigest()
                        except Exception:
                            cache_key = None
                        # Memory Cache init
                        cache_store = getattr(self, '_grammar_cache', None)
                        if cache_store is None:
                            try:
                                self._grammar_cache = {}
                                cache_store = self._grammar_cache
                            except Exception:
                                cache_store = None
                        # Disk Cache Laden
                        disk_cache_path = Path('grammar_cache.json')
                        disk_cache = {}
                        try:
                            if disk_cache_path.exists():
                                disk_cache = json.loads(disk_cache_path.read_text(encoding='utf-8'))
                        except Exception:
                            disk_cache = {}
                        # Merge disk->memory (lazy)
                        try:
                            if cache_store is not None and disk_cache:
                                for k,v in list(disk_cache.items())[:50]:
                                    if k not in cache_store:
                                        cache_store[k] = v.get('findings', [])
                        except Exception:
                            try:
                                self._record_suppressed_error('grammar.cache.merge', Exception('merge.failed'))
                            except Exception:
                                pass
                        # Lookup
                        if cache_key and cache_store and cache_key in cache_store:
                            grammar_findings = cache_store.get(cache_key, [])[:int(grammar_max)]
                            grammar_cache_hit = True
                        elif cache_key and cache_key in disk_cache:
                            try:
                                grammar_findings = (disk_cache[cache_key] or {}).get('findings', [])[:int(grammar_max)]
                                grammar_cache_hit = True
                                if cache_store is not None:
                                    cache_store[cache_key] = grammar_findings
                            except Exception:
                                grammar_findings = []
                        else:
                            # Deep Ollama Progress Events
                            if grammar_use_ollama and grammar_deep and getattr(self, 'event_bus', None):
                                try:
                                    self.event_bus.publish('grammar.deep.start', {'ts': time.time()})
                                except Exception as ex_gstart:
                                    try:
                                        self._record_suppressed_error('grammar.deep.start.publish', ex_gstart)
                                    except Exception:
                                        pass
                                    try:
                                        self._record_suppressed_error('grammar.deep.start.publish', _)
                                    except Exception:
                                        pass
                            checker = GrammarChecker(
                                enable_languagetool=grammar_use_lt,
                                enable_hunspell=grammar_use_hunspell,
                                enable_ollama=(grammar_use_ollama and grammar_deep)
                            )
                            grammar_findings = checker.analyze_segments(segs, lang_cfg)[:int(grammar_max)]
                            if grammar_use_ollama and grammar_deep and getattr(self, 'event_bus', None):
                                try:
                                    self.event_bus.publish('grammar.deep.end', {'ts': time.time()})
                                except Exception as ex_gend:
                                    try:
                                        self._record_suppressed_error('grammar.deep.end.publish', ex_gend)
                                    except Exception:
                                        pass
                                    try:
                                        self._record_suppressed_error('grammar.deep.end.publish', _)
                                    except Exception:
                                        pass
                            # Memory store + Disk LRU (max 30)
                            if cache_key:
                                try:
                                    if cache_store is not None:
                                        if len(cache_store) > 30:
                                            # Entferne ältesten Key
                                            oldest_key = next(iter(cache_store.keys()))
                                            cache_store.pop(oldest_key, None)
                                        cache_store[cache_key] = grammar_findings
                                except Exception:
                                    pass
                                try:
                                    disk_cache[cache_key] = {
                                        'ts': _gtime.time(),
                                        'flags': flags_sig,
                                        'findings': grammar_findings[:int(grammar_max)]
                                    }
                                    if len(disk_cache) > 50:
                                        try:
                                            items = sorted(disk_cache.items(), key=lambda x: x[1].get('ts', 0), reverse=True)[:50]
                                            disk_cache = {k: v for k, v in items}
                                        except Exception as ex_disk_shrink:
                                            try:
                                                self._record_suppressed_error('grammar.cache.disk.shrink', ex_disk_shrink)
                                            except Exception:
                                                pass
                                    try:
                                        with disk_cache_path.open('w', encoding='utf-8') as fh:
                                            json.dump(disk_cache, fh, ensure_ascii=False, indent=2)
                                    except Exception as ex_disk_write:
                                        try:
                                            self._record_suppressed_error('grammar.cache.disk.write', ex_disk_write)
                                        except Exception:
                                            pass
                                except Exception:
                                    pass
                # Grammar Checker Info in Summary integrieren
                try:
                    summary['grammar_enabled'] = bool(grammar_enabled)
                    if grammar_enabled:
                        summary['grammar_checkers_used'] = grammar_used
                        if grammar_disabled:
                            summary['grammar_checkers_disabled'] = grammar_disabled
                        summary['grammar_cache_hit'] = grammar_cache_hit
                        # Per-Checker Statistik
                        try:
                            stats = {}
                            for f in grammar_findings:
                                c = f.get('checker','?')
                                stats[c] = stats.get(c,0)+1
                            summary['grammar_checker_stats'] = stats
                        except Exception:
                            pass
                        # Warnungen für angeforderte aber fehlende
                        try:
                            missing = []
                            if grammar_use_lt and 'languagetool' in grammar_disabled:
                                missing.append('LanguageTool')
                            if grammar_use_hunspell and 'hunspell' in grammar_disabled:
                                missing.append('Hunspell')
                            if grammar_use_ollama and grammar_deep and 'ollama' not in grammar_used:
                                missing.append('Ollama')
                            if missing:
                                summary['grammar_missing_requested'] = missing
                        except Exception:
                            pass
                except Exception:
                    pass
            except Exception:
                grammar_findings = []
            try:
                # Finalize Progress (Dauer + Score) – tolerant
                _progress('finalize', duration=time.time()-start, quality_score=metrics.get('overall_score'))
            except Exception:
                pass
            return {
                'file_pairs': pairs,
                'metrics': metrics,
                'summary': summary,
                'plugins': norm_plugin_results,
                'findings': grammar_findings,
                'rules_summary': per_rule_summary,
                'export_rows': export_rows
            }
            # (Nicht erreicht)
        except Exception as e:
            try:
                if hasattr(self, '_debug_silent'):
                    self._debug_silent(e, 'analysis.pipeline.enhanced')
            except Exception:
                pass
            try:
                _progress('finalize', error=str(e)[:120])
            except Exception:
                pass
            return {'file_pairs': [], 'metrics': {}, 'summary': {'error': str(e), 'rule_profile': rule_profile}}
    
    def _show_analysis_results(self):
        """Show comprehensive analysis results"""
        # Non-destruktive Anreicherung: Score-Breakdown in self._last_score_breakdown cachen
        try:
            if getattr(self, 'current_analysis', None):
                metrics = self.current_analysis.get('metrics', {})
                summary = self.current_analysis.get('summary', {})
                self._last_score_breakdown = {
                    'overall': metrics.get('overall_score'),
                    'grade': summary.get('quality_grade'),
                    'scores': {
                        'numeric_consistency': metrics.get('numeric_consistency_score'),
                        'length_balance': metrics.get('length_balance_score'),
                        'translation_completeness': metrics.get('translation_completeness_score'),
                        'untranslated': metrics.get('untranslated_completeness_score')
                    },
                    'weights': metrics.get('score_breakdown_weights'),
                    'severity_counts': {k: summary.get(k) for k in ('critical','major','minor')},
                }
        except Exception:
            pass
        # Delegation an bestehenden Renderer unverändert lassen
        try:
            from quality_gui_components_analysis_results import show_analysis_results
            show_analysis_results(self)
        except Exception as e:
            try:
                self._handle_error(e, context="analysis.results.delegate", user_message=self._t("Analyse Ergebnisse Anzeige Fehler"))
            except Exception:
                pass
            # 🆕 Minimaler Fallback falls externer Renderer fehlt – verhindert "keine Ausgabe" Eindruck
            try:
                if getattr(self, 'output_frame', None):
                    # Nur falls noch nichts gerendert wurde
                    if not self.output_frame.winfo_children():
                        import customtkinter as ctk
                        card = ctk.CTkFrame(self.output_frame, fg_color=self.get_color('surface'), corner_radius=8, border_width=1, border_color=self.get_color('surface_border'))
                        card.pack(fill='both', expand=True, padx=24, pady=24)
                        title = ctk.CTkLabel(card, text=self._t('Analyse Zusammenfassung (Fallback)'), font=ctk.CTkFont(*self.get_typography('heading')),
                                             text_color=self.get_color('primary'))
                        title.pack(pady=(16,8))
                        summary = getattr(self, 'analysis_results', {}).get('summary', {}) if isinstance(getattr(self, 'analysis_results', {}), dict) else {}
                        metrics = getattr(self, 'analysis_results', {}).get('metrics', {}) if isinstance(getattr(self, 'analysis_results', {}), dict) else {}
                        lines = []
                        try:
                            sc = metrics.get('overall_score')
                            if isinstance(sc, (int,float)):
                                lines.append(self._t('Gesamtqualität') + f": {int(sc*100)} / 100")
                        except Exception:
                            pass
                        for k in ('pair_count','numeric_consistency','untranslated_ratio','completeness'):
                            v = metrics.get(k)
                            if isinstance(v,(int,float)):
                                lines.append(f"{k}: {v}")
                        txt = "\n".join(lines) if lines else self._t('Keine Metriken verfügbar')
                        ctk.CTkLabel(card, text=txt, font=ctk.CTkFont(*self.get_typography('body')), text_color=self.get_color('text_primary'), justify='left').pack(padx=20, pady=12, anchor='w')
            except Exception:
                pass

        # 🆕 Grammar Deep Progress Listener UI Setup (einmalig)
        try:
            if getattr(self, 'event_bus', None) and not hasattr(self, '_grammar_progress_bound'):
                self._grammar_progress_bound = True
                # Container Lazy
                if not hasattr(self, '_grammar_progress_label'):
                    try:
                        self._grammar_progress_label = ctk.CTkLabel(self.output_frame, text='', font=ctk.CTkFont(*self.get_typography('caption')), text_color=self.get_color('info'))
                    except Exception:
                        self._grammar_progress_label = None
                def _on_deep_start(evt):
                    try:
                        if self._grammar_progress_label and self._grammar_progress_label.winfo_exists():
                            self._grammar_progress_label.configure(text=self._t('Tiefe Grammatikprüfung läuft...'))
                            self._grammar_progress_label.pack(fill='x', padx=20, pady=(4,0))
                    except Exception:
                        pass
                def _on_deep_end(evt):
                    try:
                        if self._grammar_progress_label and self._grammar_progress_label.winfo_exists():
                            self._grammar_progress_label.configure(text=self._t('Tiefe Grammatikprüfung abgeschlossen'))
                            # Automatisches Ausblenden nach 3s
                            self.after(3000, lambda: (self._grammar_progress_label.configure(text='') if self._grammar_progress_label and self._grammar_progress_label.winfo_exists() else None))
                    except Exception:
                        pass
                try:
                    self.event_bus.subscribe('grammar.deep.start', _on_deep_start)
                    self.event_bus.subscribe('grammar.deep.end', _on_deep_end)
                except Exception:
                    pass
        except Exception:
            pass

    def _request_analysis_cancel(self, status_label=None, progress_bar=None):
        """Markiert laufende Analyse als abgebrochen (kooperativer Abbruch)."""
        try:
            if getattr(self, '_analysis_cancel_requested', False):
                return
            self._analysis_cancel_requested = True
            if status_label:
                try:
                    status_label.configure(text=self._t('Cancellation requested – finishing current rule'))
                except Exception:
                    pass
            if progress_bar:
                try:
                    progress_bar.configure(progress_color=self.get_color('warning'))
                except Exception:
                    pass
            if getattr(self, 'event_bus', None):
                try:
                    self.event_bus.publish('analysis.cancelled', {'ts': time.time()})
                except Exception:
                    pass
            self._show_toast(self._t('Cancel requested'), 'warning')
        except Exception:
            pass
    
