def _safe_color_override(name, fallback=None):
    """Lokaler Anti-Dark-Mode Override ohne Import-Schatten."""
    if name in ('black', '#000000', '#1C1C1C'):
        return '#F8FAFC'
    return name or fallback


class ProfessionelleUebersetzungsqualitaetsApp:
    PROJECTS_ROOT = "Checker_Projekte"  # zentrale Ordnerkonstante
    # ---------- GENERISCHE UI-BAU-HELFER (Redundanz-Reduktion) ----------
    def _create_section_header(self, parent, title: str, accent: str = 'primary', height: int = 50,
                               title_font_key: str = 'heading_sm', title_color_key: str | None = None,
                               padding: tuple = (14,6), add_accent: bool = True):
        """Erstellt einen einheitlichen Abschnitts-Header Frame.

        Parameter:
            parent: Container Frame
            title: Überschrift (bereits i18n vorbereitet vor Aufruf)
            accent: Farb-Key für Akzent-Bar
            height: Höhe des Header-Balkens
            title_font_key: Typografie-Key für Überschrift
            title_color_key: Farb-Key (Default: accent / gray_700 fallback)
            padding: Innen-Padding (x,y)
            add_accent: Ob eine vertikale Akzent-Leiste links eingefügt wird
        Rückgabe:
            (header_frame, header_content)
        """
        try:
            hf = ctk.CTkFrame(parent, fg_color=self.get_color('gray_100'), height=height)
            hf.pack(fill='x', padx=0, pady=0)
            hf.pack_propagate(False)
            content = ctk.CTkFrame(hf, fg_color='transparent')
            content.pack(fill='x', padx=padding[0], pady=padding[1])
            if add_accent:
                try:
                    self._add_header_accent(content, accent)
                except Exception as ex_accent:
                    # vorher: pass – jetzt diagnostizierbar
                    try:
                        self._record_suppressed_error('ui.header.accent', ex_accent)
                    except Exception:
                        pass
            color_key = title_color_key or accent or 'gray_700'
            lbl = ctk.CTkLabel(content,
                               text=title,
                               font=ctk.CTkFont(*self.get_typography(title_font_key)),
                               text_color=self.get_color(color_key))
            lbl.pack(side='left', padx=(10 if add_accent else 0, 0))
            return hf, content, lbl
        except Exception as ex_build_header:
            # vorher: stiller Fallback – jetzt erfassbar
            try:
                self._record_suppressed_error('ui.header.build', ex_build_header)
            except Exception:
                pass
            return None, None, None

    def _create_card_container(self, parent, *, corner_radius: int = 8, border: bool = True,
                               fg: str = 'surface', pad_y: tuple = (0,6), pad_x: int = 4):
        """Einheitliche Card-Erstellung (reduziert mehrfachen Boilerplate)."""
        try:
            card = ctk.CTkFrame(parent,
                                fg_color=self.get_color(fg),
                                corner_radius=corner_radius,
                                border_width=(1 if border else 0),
                                border_color=self.get_color('surface_border'))
            card.pack(fill='x', pady=pad_y, padx=pad_x)
            return card
        except Exception as ex_card:
            try:
                self._record_suppressed_error('ui.card.build', ex_card)
            except Exception:
                pass
            return None

    # ---------- I18N HELPER ----------
    def _tr(self, text: str) -> str:
        """Wrapper für _t falls vorhanden; ermöglicht spätere Erweiterung (Plural, Kontext)."""
        try:
            return self._t(text) if hasattr(self, '_t') else text
        except Exception:
            return text

    def _n(self, singular: str, plural: str, count: int | float | None) -> str:
        """Einfaches Pluralisierungs-Utility.

        Parameters:
            singular: Singular-Form (bereits lokalisiert)
            plural:   Plural-Form (bereits lokalisiert)
            count:    Zahl zur Entscheidung
        Returns:
            passende Form als String (Fallback: plural bei Unsicherheit)
        """
        try:
            c = int(count if count is not None else 0)
            # Deutsch/Englisch einfache Regel: 1 -> Singular, sonst Plural
            return singular if c == 1 else plural
        except Exception as e:
            try:
                # Diagnose statt stillem pass – verhindert erneut AttributeError-Kaskaden
                self._record_suppressed_error('i18n.plural', e)
            except Exception:
                pass
            return plural

    # ---------- PROFESSIONAL DESIGN SYSTEM HELPERS ----------
    def get_spacing(self, spacing_name: str) -> int:
        """Get spacing value from design system with fallback."""
        try:
            from design_system import DesignSystem
            return DesignSystem.get_spacing_value(spacing_name)
        except Exception:
            # Fallback spacing values
            spacing_map = {
                'xs': 4, 'sm': 8, 'md': 16, 'lg': 24, 'xl': 32,
                'card_padding': 20, 'card_margin': 12, 'section_spacing': 28,
                'element_spacing': 12, 'tight_spacing': 6, 'loose_spacing': 32
            }
            return spacing_map.get(spacing_name, 16)

    def get_component_value(self, component_path: str, fallback_value: Any = None) -> Any:
        """Get component property value using dot notation (e.g., 'heights.button_md')."""
        try:
            from design_system import DesignSystem
            path_parts = component_path.split('.')
            if len(path_parts) == 2:
                category, property_name = path_parts
                return DesignSystem.get_component_property(category, property_name)
            return fallback_value
        except Exception:
            return fallback_value

    def create_professional_card(self, parent, title: str = "", content_padding: int = None) -> ctk.CTkFrame:
        """Create a professional card using design system."""
        try:
            from design_system import DesignSystem
            return DesignSystem.create_professional_card(
                parent, 
                title=title, 
                content_padding=content_padding or self.get_spacing('card_padding')
            )
        except Exception:
            # Fallback card creation
            card = ctk.CTkFrame(
                parent,
                fg_color=self.get_color('surface'),
                corner_radius=8,
                border_width=1,
                border_color=self.get_color('surface_border')
            )
            if title:
                header = ctk.CTkFrame(card, fg_color=self.get_color('gray_50'), height=48)
                header.pack(fill="x", padx=0, pady=0)
                header.pack_propagate(False)
                ctk.CTkLabel(
                    header, 
                    text=title, 
                    font=ctk.CTkFont(*self.get_typography('title')),
                    text_color=self.get_color('text_primary')
                ).pack(padx=20, pady=12, anchor="w")
            return card

    def create_professional_button(self, parent, text: str, style: str = 'primary', 
                                 size: str = 'md', command=None) -> ctk.CTkButton:
        """Create a professional button using design system."""
        try:
            from design_system import DesignSystem
            return DesignSystem.create_professional_button(
                parent, text=text, style=style, size=size, command=command
            )
        except Exception:
            # Fallback button creation with improved styling
            height_map = {'sm': 34, 'md': 40, 'lg': 46}
            font_map = {
                'sm': ('Segoe UI', 11, 'bold'),
                'md': ('Segoe UI', 13, 'bold'), 
                'lg': ('Segoe UI', 15, 'bold')
            }
            color_map = {
                'primary': {'fg': self.get_color('button_primary'), 'hover': self.get_color('button_primary_hover')},
                'secondary': {'fg': self.get_color('button_secondary'), 'hover': self.get_color('button_secondary_hover')},
                'warning': {'fg': self.get_color('button_warning'), 'hover': self.get_color('button_warning_hover')},
                'danger': {'fg': self.get_color('button_danger'), 'hover': self.get_color('button_danger_hover')}
            }
            colors = color_map.get(style, color_map['primary'])
            return ctk.CTkButton(
                parent,
                text=text,
                font=ctk.CTkFont(*font_map.get(size, font_map['md'])),
                height=height_map.get(size, height_map['md']),
                corner_radius=8,
                fg_color=colors['fg'],
                hover_color=colors['hover'],
                text_color=self.get_color('white'),
                command=command
            )

    def create_section_header(self, parent, title: str, subtitle: str = "", color_accent: str = 'primary') -> ctk.CTkFrame:
        """Create a professional section header."""
        try:
            from design_system import DesignSystem
            return DesignSystem.create_professional_section_header(
                parent, title=title, subtitle=subtitle, color_accent=color_accent
            )
