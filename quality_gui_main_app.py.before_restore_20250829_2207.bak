            )
            header_frame.pack(fill='x', pady=(0, self.get_spacing('element_spacing')))

            # Actions card with professional styling
            actions_card = self.create_professional_card(
                section_container,
                title="",
                content_padding=self.get_spacing('card_padding')
            )
            actions_card.pack(fill='x')

            # Actions grid with professional buttons
            actions_content = ctk.CTkFrame(actions_card, fg_color='transparent')
            actions_content.pack(fill='x', padx=self.get_spacing('card_padding'), 
                               pady=self.get_spacing('card_padding'))

            for i in range(2):
                actions_content.grid_columnconfigure(i, weight=1, uniform='export_actions')

            # Export buttons
            report_btn = self.create_professional_button(
                actions_content,
                text=self._t("📊 Bericht generieren") if hasattr(self, '_t') else "📊 Bericht generieren",
                style='primary',
                size='md',
                command=self._generate_quality_report
            )
            report_btn.grid(row=0, column=0, sticky='ew', 
                          padx=(0, self.get_spacing('tight_spacing')), 
                          pady=(0, self.get_spacing('tight_spacing')))

            export_btn = self.create_professional_button(
                actions_content,
                text=self._t("💾 Daten exportieren") if hasattr(self, '_t') else "💾 Daten exportieren",
                style='secondary',
                size='md',
                command=self._export_data
            )
            export_btn.grid(row=0, column=1, sticky='ew', 
                          padx=(self.get_spacing('tight_spacing'), 0),
                          pady=(0, self.get_spacing('tight_spacing')))

            # Additional action row
            settings_btn = self.create_professional_button(
                actions_content,
                text=self._t("⚙️ Einstellungen") if hasattr(self, '_t') else "⚙️ Einstellungen",
                style='secondary',
                size='sm',
                command=self._show_settings
            )
            settings_btn.grid(row=1, column=0, sticky='ew', 
                            padx=(0, self.get_spacing('tight_spacing')), 
                            pady=self.get_spacing('tight_spacing'))

            help_btn = self.create_professional_button(
                actions_content,
                text=self._t("❓ Hilfe") if hasattr(self, '_t') else "❓ Hilfe",
                style='secondary',
                size='sm',
                command=self._show_help
            )
            help_btn.grid(row=1, column=1, sticky='ew', 
                        padx=(self.get_spacing('tight_spacing'), 0),
                        pady=self.get_spacing('tight_spacing'))

        except Exception as e:
            self._handle_error(
                e,
                context="ui.actions_section.professional", 
                user_message=self._t("Professional actions section creation failed") if hasattr(self, '_t') else "Professioneller Aktions-Bereich konnte nicht erstellt werden"
            )

