    def _t(self, text: str) -> str:
        """Translate a text if a German mapping exists and language is 'de'."""
        try:
            if getattr(self, 'current_language', 'en') == 'de':
                return self._i18n_map.get(text, text)
            return text
        except Exception:
            return text

    # (duplicate _apply_localization_safe removed – canonical version defined earlier)
    
    def _basic_get_color(self, color_name: str, fallback: str = '#FFFFFF'):
        """Sicherer Farbzugriff – ausschliesslich über DesignSystem + Mini-Fallback.

        Entfernt lokale harte Palette (Single Source of Truth: design_system).
        Loggt einmalig fehlende Tokens (pro Name), erzwingt Light Mode Safe Color.
        """
        try:
            if color_name in self._color_cache:
                return self._color_cache[color_name]
            ds_colors = {}
            try:
                if hasattr(self, 'design_system'):
                    ds_colors = self.design_system.get('colors', {}) or {}
            except Exception:
                ds_colors = {}
            color = ds_colors.get(color_name)
            if not color:  # token missing
                # einmaliges Logging
                if not hasattr(self, '_missing_color_tokens'):
                    self._missing_color_tokens = set()
                if color_name not in self._missing_color_tokens:
                    try:
                        self.logger.warning(f"DesignSystem Farb-Token fehlt: {color_name} – verwende Fallback")
                    except Exception:
                        pass
                    self._missing_color_tokens.add(color_name)
                # Minimal definierte Light-Mode Standard-Fallbacks (nur 100% notwendige)
                minimal = {
                    'white': '#FFFFFF', 'surface': '#FFFFFF', 'surface_border': '#E5E7EB',
                    'text_primary': '#374151', 'text_secondary': '#6B7280',
                    'primary': '#1F4E79', 'primary_hover': '#1A3F65',
                    'warning': '#F59E0B', 'warning_hover': '#E08B3E',
                    'success': '#16A34A', 'error': '#DC2626', 'info': '#1F4E79',  # vereinheitlichtes Brand-Blau
                    'transparent': 'transparent'
                }
                color = minimal.get(color_name, fallback)
            # Anti-Dark-Mode Schutz anwenden falls verfügbar
            try:
                fn = globals().get('amd_safe_color')
                if callable(fn):
                    color = fn(color)
            except Exception:
                pass
            self._color_cache[color_name] = color
            return color
        except Exception:
            return fallback
    
    # ========================= UI DISPATCH HELPER (THREAD-SAFE) =========================
    def ui(self, fn, *a, **k):
        """Thread-sicheres Dispatch von UI-Operationen über root.after."""
        try:
            if getattr(self, 'root', None) is None:
                return
            self.root.after(0, lambda: fn(*a, **k))
        except Exception as e:
            try:
                self.logger.debug(f"UI dispatch failed: {e}")
            except Exception:
                pass

    # ========================= INTERN: SILENT DEBUG HELPER =========================
    def _debug_silent(self, e: Exception, context: str):
        """Nicht-kritische Fehler zentral debug-loggen (kein Toast)."""
        try:
            if hasattr(self, 'logger'):
                self.logger.debug(f"[silent:{context}] {e}")
        except Exception as ex:
            try:
                self._record_suppressed_error('pairing.toggle_sort', ex)
            except Exception:
                pass

    # ========================= PAIRING UNDO/REDO SYSTEM =========================
    def _snapshot_pairs(self):
        try:
            return copy.deepcopy({
                'pairs': getattr(self, 'file_pairs', []),
                'unmatched': getattr(self, 'unmatched_files', {'source': [], 'translation': []})
            })
        except Exception as e:
            self._handle_error(e, context="pairing.snapshot", toast=False)
            return {'pairs': [], 'unmatched': {'source': [], 'translation': []}}

    def _push_history(self):
        try:
            if not hasattr(self, '_pair_history'):
                self._pair_history = []
            self._pair_history.append(self._snapshot_pairs())
            if hasattr(self, '_pair_redo'):
                self._pair_redo.clear()
            # Update Undo/Redo Buttons wenn vorhanden
            if hasattr(self, '_update_undo_redo_buttons'):
                try:
                    self._update_undo_redo_buttons()
                except Exception:
                    pass
        except Exception as e:
            self._handle_error(e, context="pairing.history.push", toast=False)

    def _undo(self):
        try:
            if not getattr(self, '_pair_history', None):
                self.show_toast(self._t("Nothing to undo"), "info")
                return
            current = self._snapshot_pairs()
            prev = self._pair_history.pop()
            if not hasattr(self, '_pair_redo'):
                self._pair_redo = []
            self._pair_redo.append(current)
            self.file_pairs = prev['pairs']
            self.unmatched_files = prev['unmatched']
            self._populate_manual_pairing_interface()
            self._update_pairing_status_display()
            self.show_toast(self._t("Undo pairing action"), "success")
            if hasattr(self, '_update_undo_redo_buttons'):
                try:
                    self._update_undo_redo_buttons()
                except Exception:
                    pass
        except Exception as e:
            self._handle_error(e, context="pairing.undo")

    def _redo(self):
        try:
            if not getattr(self, '_pair_redo', None):
                self.show_toast(self._t("Nothing to redo"), "info")
                return
            next_state = self._pair_redo.pop()
            if not hasattr(self, '_pair_history'):
                self._pair_history = []
            self._pair_history.append(self._snapshot_pairs())
            self.file_pairs = next_state['pairs']
            self.unmatched_files = next_state['unmatched']
            self._populate_manual_pairing_interface()
            self._update_pairing_status_display()
            self.show_toast(self._t("Redo pairing action"), "success")
            if hasattr(self, '_update_undo_redo_buttons'):
                try:
                    self._update_undo_redo_buttons()
                except Exception:
                    pass
        except Exception as e:
            self._handle_error(e, context="pairing.redo")

    def _update_undo_redo_buttons(self):
        """Aktualisiert aktiv/deaktiviert Status der Undo/Redo Buttons (Legacy + Toolbar)."""
        try:
            history_len = len(getattr(self, '_pair_history', []) or [])
            redo_len = len(getattr(self, '_pair_redo', []) or [])
            undo_state = 'normal' if history_len > 0 else 'disabled'
            redo_state = 'normal' if redo_len > 0 else 'disabled'
            # Legacy Buttons speichern unter _legacy_*
            for name in ('_legacy_undo_btn','_legacy_redo_btn'):
                btn = getattr(self, name, None)
                if btn:
                    try:
                        btn.configure(state=undo_state if 'undo' in name else redo_state)
                    except Exception:
                        pass
            # Toolbar Buttons
            for name in ('_undo_btn_toolbar','_redo_btn_toolbar'):
                btn = getattr(self, name, None)
                if btn:
                    try:
                        btn.configure(state=undo_state if 'undo' in name else redo_state)
                    except Exception:
                        pass
        except Exception as e:
            self._handle_error(e, context="pairing.undo_redo_buttons", toast=False)

    def get_spacing(self, spacing_name):
        """OPTIMIZED: Enhanced spacing system with intelligent defaults and caching"""
        try:
            # Smart spacing caching for layout performance
            if spacing_name in self._ui_cache:
                return self._ui_cache[spacing_name]
            
            # Enhanced spacing system with semantic names
            optimized_spacing = {
                # Basic spacing scale
                'xs': 4, 'sm': 8, 'md': 16, 'lg': 24, 'xl': 32,
                '2xl': 48, '3xl': 64, '4xl': 80, '5xl': 96, '6xl': 128,
                
                # Component-specific spacing
                'card_padding': 20, 'button_gap': 10, 'element_gap': 12,
                'component_margin': 16, 'section_gap': 24,
                
                # UI element spacing
                'header_padding': 15, 'content_padding': 20, 'border_radius': 8,
                'large_border_radius': 12, 'small_border_radius': 6,
                
                # Layout spacing
                'panel_gap': 5, 'widget_spacing': 8, 'container_padding': 10,
                'scroll_padding': 10, 'status_padding': 5
            }
            
            # Get spacing with fallback to design system
            spacing = optimized_spacing.get(spacing_name)
            if spacing is None and hasattr(self, 'design_system') and 'spacing' in self.design_system:
                spacing = self.design_system['spacing'].get(spacing_name, 16)
            
            # Final fallback
            if spacing is None:
                spacing = 16
            
            # Cache for performance
            self._ui_cache[spacing_name] = spacing
            return spacing
            
        except Exception:
            return 16
    
    def get_typography(self, typography_name):
        """OPTIMIZED: Smart typography system with font caching for ~50% performance boost"""
        try:
            # Performance-optimized font caching - prevents redundant CTkFont object creation
            cache_key = f"font_{typography_name}"
            if cache_key in self._font_cache:
                return self._font_cache[cache_key]
            # GOVERNANCE LOCK: Eingeschränkte Legacy Tokens (bereinigt – keine aktiv genutzten Tokens blockieren)
            legacy_block = {
                'metric_value','input','heading_lg','heading_xl','title_lg','title_xl'
            }
            if typography_name in legacy_block:
                # Zentralisierte Behandlung blockierter Legacy Tokens (kein Toast, nur Log & Exception)
                try:
                    self._handle_error(
                        ValueError(f"Legacy typography token blocked: {typography_name}"),
                        context="typography.legacy.block",
                        toast=False,
                        level="warning"
                    )
                except Exception:
                    pass
                raise ValueError(f"Legacy typography token blocked: {typography_name}")

            # Public → unified remapping (allowed names mapped to the 6-Level system)
            # Only map if caller uses one of the classic semantic names.
            public_to_unified = {
                'caption': 'caption_unified',
                'label': 'label_unified',
                'body': 'body_unified',
                'body_bold': 'body_strong_unified',
                'subheading': 'subtitle_unified',
                'title': 'title_unified',
            }
            mapped_name = public_to_unified.get(typography_name, typography_name)
            if mapped_name != typography_name:
                typography_name = mapped_name
                cache_key = f"font_{typography_name}"  # update cache key after mapping
                if cache_key in self._font_cache:
                    return self._font_cache[cache_key]
            
            # Enhanced typography system with semantic naming
            optimized_typography = {
                # Micro text (10px) - Minimal labels
                'micro': ('Segoe UI', 10, 'normal'),
                'micro_bold': ('Segoe UI', 10, 'bold'),
                
                # Small text (12px) - Captions, buttons, menu
                'caption': ('Segoe UI', 12, 'normal'),
                'small': ('Segoe UI', 12, 'bold'),
                'menu': ('Segoe UI', 12, 'normal'),
                'small_normal': ('Segoe UI', 12, 'normal'),
                
                # Body text (14px) - Standard content, inputs
                'body': ('Segoe UI', 14, 'normal'),
                'body_bold': ('Segoe UI', 14, 'bold'),
                'input': ('Segoe UI', 14, 'normal'),
                'button': ('Segoe UI', 14, 'bold'),
                'body_sm': ('Segoe UI', 13, 'normal'),
                'body_lg': ('Segoe UI', 15, 'normal'),
                
                # Labels (16px) - Important labels
                'label': ('Segoe UI', 16, 'normal'),
                'label_bold': ('Segoe UI', 16, 'bold'),
                'button_md': ('Segoe UI', 16, 'bold'),
                
                # Subheadings (18px) - Card headers, sections
                'subheading': ('Segoe UI', 18, 'bold'),
                'card_header': ('Segoe UI', 18, 'bold'),
                'heading_sm': ('Segoe UI', 18, 'normal'),
                
                # Headings (22px) - Main headings
                'heading': ('Segoe UI', 22, 'bold'),
                'section': ('Segoe UI', 22, 'bold'),
                'heading_md': ('Segoe UI', 20, 'bold'),
                'heading_lg': ('Segoe UI', 24, 'bold'),
                
                # Titles (26px) - Page titles
                'title': ('Segoe UI', 26, 'bold'),
                'page_title': ('Segoe UI', 26, 'bold'),
                
                # Display (32px) - Hero text
                'display': ('Segoe UI', 32, 'bold'),
                'hero': ('Segoe UI', 32, 'normal'),
                'display_lg': ('Segoe UI', 36, 'bold'),

                # 🔐 Unified Ziel-Tokens (nur interne Nutzung – bevorzugt externe Aufrufe über caption/label/body/... Mapping)
                'caption_unified': ('Segoe UI', 12, 'normal'),
                'label_unified': ('Segoe UI', 13, 'bold'),
                'body_unified': ('Segoe UI', 14, 'normal'),
                'body_strong_unified': ('Segoe UI', 14, 'bold'),
                'subtitle_unified': ('Segoe UI', 16, 'bold'),
                'title_unified': ('Segoe UI', 26, 'bold'),
            }
            
            # Get font data with fallback to design system
            font_data = optimized_typography.get(typography_name)
            if not font_data and hasattr(self, 'design_system') and 'typography' in self.design_system:
                font_data = self.design_system['typography'].get(typography_name)
            
            # Final fallback
            if not font_data:
                font_data = ('Segoe UI', 14, 'normal')
            
            # Cache the result for performance
            self._font_cache[cache_key] = font_data
            return font_data
            
        except Exception:
            return ('Segoe UI', 14, 'normal')
    
    def _setup_application(self):
        """Setup main application window and structure (idempotent)."""
        if getattr(self, '_app_initialized', False):
            return
        try:
            self.root = ctk.CTk()
            self.root.title("Quality Framework Professional - Übersetzungsqualitäts-Analyse")
            self.root.geometry("1680x1000")  # Größeres Fenster für professionellere Anmutung
            self.root.minsize(1500, 900)     # Erhöhte Mindestgröße
            self.root.configure(fg_color=self.get_color('background'))
            
            # Professional window icon (if available)
            try:
                icon_path = "Checker Logo Transparent.png"
                if os.path.exists(icon_path):
                    self.root.iconbitmap(icon_path)
            except:
                pass
            
            self._create_header()
            # Professional menu bar
            try:
                self._create_menu_bar()
            except Exception:
                pass
            self._create_main_layout()
            self._create_status_bar()
            self._initialize_systems()
            try:
                def _on_close():
                    try:
                        if self.event_bus:
                            try:
                                self.event_bus.publish("app.closing", {"ts": time.time()})
                            except Exception:
                                pass
                        # Persistente Speicherung der Menü-Nutzung (falls Settings verfügbar)
                        try:
                            if hasattr(self,'settings_service') and self.settings_service and hasattr(self,'_menu_usage'):
                                self.settings_service.set('menu.usage', getattr(self,'_menu_usage',{}))
                        except Exception:
                            pass
                        if self.worker_pool:
                            try:
                                self.worker_pool.shutdown(timeout=2.0)
                            except Exception:
                                pass
                        # Ressourcen Cleanup
                        try:
                            import gc
                            # Große Sammlungen freigeben
                            for attr in [
                                'uploaded_files','analysis_results','current_analysis','current_file',
                                '_ui_cache','_color_cache','_font_cache','_pair_history','_pair_redo'
                            ]:
                                try:
                                    if hasattr(self, attr):
                                        setattr(self, attr, None)
                                except Exception as ex_suffix:
                                    try:
                                        self._record_suppressed_error('ui.palette.usage.suffix', ex_suffix)
                                    except Exception:
                                        pass
                            # DesignSystem Caches leeren falls verfügbar
                            try:
                                from design_system import DesignSystem
                                DesignSystem.clear_caches()
                            except Exception:
                                pass
                            gc.collect()
                        except Exception:
                            pass
                    finally:
                        try:
                            self.root.destroy()
                        except Exception:
                            pass
                if self.root and not hasattr(self.root, '_quality_close_bound'):
                    self.root.protocol("WM_DELETE_WINDOW", _on_close)
                    setattr(self.root, '_quality_close_bound', True)
            except Exception:
                pass
            self.logger.info("Application setup completed successfully")
            setattr(self, '_app_initialized', True)
        except Exception as e:
            self._handle_error(
                e,
                context="app.setup",
                user_message=self._t("Application initialization failed") if hasattr(self, '_t') else "Anwendung konnte nicht initialisiert werden"
            )

    # ------------------------------------------------------------------
    # ADDITIVE INFRASTRUKTUR (EventBus, WorkerPool, Plugins) – NON-BREAKING
    # ------------------------------------------------------------------
    def _generate_dynamic_report(self):
        """Erzeugt einen dynamischen HTML-Bericht aus aktuellen self.analysis_results.

        - Nicht destruktiv: Legt/überschreibt nur 'Bericht_Dynamisch.html' im Modulverzeichnis
        - Minimaler Template-Aufbau (leichtgewichtig, kein externes CSS)
        - Nutzt vorhandene Analyse-Daten roh als JSON (reportData Variable)
        - Fallback bei Fehlern: None
        """
        try:
            if not self.analysis_results:
                return None
            import json, os, datetime, html
            # Schreibbaren Zielordner wählen (Projektbasis > CWD > Temp)
            import tempfile, pathlib, sys as _sys
            _this_file = getattr(sys.modules[__name__], "__file__", os.getcwd()) if 'sys' in globals() else os.getcwd()
            base_dir = pathlib.Path(_this_file).resolve().parent
            try:
                proj_base = getattr(self, 'projects_base_path', None)
                if proj_base and os.path.isdir(proj_base) and os.access(proj_base, os.W_OK):
                    base_dir = pathlib.Path(proj_base)
            except Exception:
                pass
            if not os.access(str(base_dir), os.W_OK):  # Fallback CWD
                base_dir = pathlib.Path.cwd()
            if not os.access(str(base_dir), os.W_OK):  # Letzte Rettung Temp
                base_dir = pathlib.Path(tempfile.gettempdir())
            target_path = str(base_dir / 'Bericht_Dynamisch.html')

            # Metadata
            now = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            meta = {'generated_at': now, 'source': 'quality_gui_main_app', 'item_counts': {}}
            try:
                if isinstance(self.analysis_results, dict):
                    for k, v in self.analysis_results.items():
                        try:
                            if isinstance(v, (list, tuple)):
                                meta['item_counts'][k] = len(v)
                            elif isinstance(v, dict):
                                meta['item_counts'][k] = len(v)
                        except Exception:
                            pass
            except Exception:
                pass

            payload = {'meta': meta, 'reportData': self.analysis_results}
            try:
                json_blob = json.dumps(payload, ensure_ascii=False, indent=2)
            except Exception:
                json_blob = '{}'

            counts_html = ' '.join(f"<span>{html.escape(k)}: {v}</span>" for k, v in meta['item_counts'].items()) or '<em>Keine Strukturmetriken</em>'

            # Farb-Tokens
            def _c(token: str, fallback_token: str = 'white'):
                try:
                    return self.get_color(token)
                except Exception:
                    try:
                        return self.get_color(fallback_token)
                    except Exception:
                        return '#FFFFFF'

            color_surface = _c('surface'); color_text = _c('gray_700'); color_panel = _c('gray_50'); color_border = _c('surface_border')
            color_badge_border = color_border; color_badge_bg = _c('white'); color_footer = _c('gray_500')
            color_button = _c('primary'); color_button_hover = _c('primary_hover'); color_filter_border = _c('input_border')
            color_table_header = _c('gray_100'); color_white = _c('white')

            # Ergebnis-Injektion
            try:
                ar = self.analysis_results if isinstance(self.analysis_results, dict) else {}
                metrics = ar.get('metrics', {}) if isinstance(ar.get('metrics', {}), dict) else {}
                plugins = ar.get('plugins', []) if isinstance(ar.get('plugins', []), (list, tuple)) else []
                file_pairs = ar.get('file_pairs', []) if isinstance(ar.get('file_pairs', []), (list, tuple)) else []

                if metrics:
                    metrics_rows = ''.join(f"<tr><th style=\"width:220px\">{html.escape(str(k))}</th><td>{html.escape(str(v))}</td></tr>" for k, v in metrics.items())
                    metrics_html = f"<div class='results-block'><h2>Metriken</h2><table class='kv-table'><tbody>{metrics_rows}</tbody></table></div>"
                else:
                    metrics_html = "<div class='results-block'><h2>Metriken</h2><em>Keine Metriken vorhanden</em></div>"

                plugin_rows_list = []
                for p in plugins:
                    if not isinstance(p, dict):
                        continue
                    pname = html.escape(str(p.get('name') or p.get('rule') or 'Unbenannt'))
                    issues = p.get('issues') or p.get('results') or []
                    issue_count = len(issues) if isinstance(issues, (list, tuple)) else 0
                    preview_items = []
                    if isinstance(issues, (list, tuple)):
                        for issue in issues[:3]:
                            try:
                                if isinstance(issue, dict):
                                    msg = issue.get('message') or issue.get('detail') or issue.get('text') or json.dumps(issue, ensure_ascii=False)
                                else:
                                    msg = str(issue)
                                preview_items.append(html.escape(str(msg))[:160])
                            except Exception:
                                pass
                    preview_html = '<br/>'.join(preview_items) if preview_items else '<em>Keine Vorschau</em>'
                    plugin_rows_list.append(f"<tr><td>{pname}</td><td style=\"text-align:right\">{issue_count}</td><td>{preview_html}</td></tr>")
                if plugin_rows_list:
                    plugins_html = ("<div class='results-block'><h2>Regel- / Plugin-Ergebnisse</h2>" "<table><thead><tr><th>Plugin</th><th>Anz. Issues</th><th>Beispiele</th></tr></thead><tbody>" + ''.join(plugin_rows_list) + "</tbody></table></div>")
                else:
                    plugins_html = "<div class='results-block'><h2>Regel- / Plugin-Ergebnisse</h2><em>Keine Plugin-Daten</em></div>"

                file_pair_rows = []
                if file_pairs and isinstance(file_pairs, (list, tuple)):
                    for fp in file_pairs[:50]:
                        try:
                            if isinstance(fp, dict):
                                src = html.escape(str(fp.get('source') or fp.get('src') or ''))
                                tgt = html.escape(str(fp.get('target') or fp.get('tgt') or ''))
                            elif isinstance(fp, (list, tuple)) and len(fp) >= 2:
                                src = html.escape(str(fp[0])); tgt = html.escape(str(fp[1]))
                            else:
                                src = html.escape(str(fp)); tgt = ''
                            file_pair_rows.append(f"<tr><td>{src}</td><td>{tgt}</td></tr>")
                        except Exception:
                            pass
                if file_pair_rows:
                    file_pairs_html = ("<div class='results-block'><h2>Dateipaare (Auszug)</h2><table><thead><tr><th>Quelle</th><th>Ziel</th></tr></thead><tbody>" + ''.join(file_pair_rows) + "</tbody></table></div>")
                else:
                    file_pairs_html = "<div class='results-block'><h2>Dateipaare</h2><em>Keine Dateipaare</em></div>"

                injection_html = metrics_html + plugins_html + file_pairs_html
                # --- Automatischer PDF-Export & Download-Link (additiv, optional) ---
                try:
                    from src.export.pdf_system import PDFExportSystem  # type: ignore
                    pdf_sys = PDFExportSystem(self)
                    issues_for_pdf = []
                    try:
                        for _p in (plugins or []):
                            if not isinstance(_p, dict):
                                continue
                            for _iss in (_p.get('issues') or _p.get('results') or []):  # type: ignore
                                if isinstance(_iss, dict):
                                    issues_for_pdf.append(_iss)
                                else:
                                    issues_for_pdf.append({'description': str(_iss)})
                    except Exception:
                        pass
                    import datetime as _dt, os as _os, html as _html
                    ts_pdf = _dt.datetime.now().strftime('%Y%m%d_%H%M%S')
                    pdf_payload = {
                        'customer': ar.get('customer'),
                        'project': ar.get('project'),
                        'date': ar.get('date') or ts_pdf,
                        'metrics': metrics,
                        'issues': issues_for_pdf,
                        'recommendations': ar.get('recommendations', []),
                    }
                    export_dir = pdf_sys._get_default_export_path()
                    _os.makedirs(export_dir, exist_ok=True)
                    pdf_full = _os.path.join(export_dir, f"quality_report_{ts_pdf}.pdf")
                    ok_pdf, pdf_result = pdf_sys.export_quality_report(pdf_payload, pdf_full)
                    if ok_pdf:
                        rel = _os.path.relpath(pdf_result, base_dir).replace('\\', '/')
                        pdf_link_html = f"<div class='actions'><a href='{rel}' download target='_blank' style='display:inline-block;background:{color_button};color:{color_white};padding:8px 14px;border-radius:6px;text-decoration:none;font-size:14px;font-weight:600;'>PDF herunterladen</a></div>"
                    else:
                        pdf_link_html = f"<div class='actions'><span style='color:{color_footer};font-size:12px;'>PDF nicht verfügbar: {_html.escape(str(pdf_result))}</span></div>"
                    injection_html = pdf_link_html + injection_html
                except Exception:
                    # Fallback: still show HTML without PDF link
                    pass
            except Exception:
                injection_html = "<div class='results-block'><em>Fehler bei Ergebnis-Aufbereitung</em></div>"

            # Template mit Injection
            template = """<!DOCTYPE html>
<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Dynamischer Qualitätsbericht</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n body{{font-family:Segoe UI,Arial,sans-serif;background:{color_surface};margin:24px;color:{color_text};}}\n h1{{font-size:24px;margin:0 0 8px;font-weight:600;}}\n h2{{font-size:18px;margin:32px 0 12px;font-weight:600;}}\n .meta, .summary{{background:{color_panel};border:1px solid {color_border};border-radius:8px;padding:16px;margin-bottom:20px;}}\n code,pre{{font-family:Consolas,monospace;font-size:12px;}}\n .counts span{{display:inline-block;margin:4px 8px 4px 0;padding:4px 8px;border:1px solid {color_badge_border};border-radius:6px;background:{color_badge_bg};}}\n .raw-container{{border:1px solid {color_border};border-radius:8px;padding:16px;white-space:pre;overflow:auto;max-height:480px;background:{color_surface};}}\n .footer{{margin-top:40px;font-size:12px;color:{color_footer};}}\n button{{background:{color_button};color:{color_white};border:none;padding:8px 14px;border-radius:6px;cursor:pointer;font-size:14px;font-weight:600;}}\n button:hover{{background:{color_button_hover};}}\n .filter-box{{border:1px solid {color_filter_border};border-radius:6px;padding:8px;margin:24px 0 16px;}}\n input[type=text]{{padding:6px 8px;border:1px solid {color_filter_border};border-radius:4px;width:260px;}}\n table{{border-collapse:collapse;width:100%;margin-top:12px;}}\n th,td{{border:1px solid {color_border};padding:6px 8px;font-size:12px;text-align:left;vertical-align:top;}}\n th{{background:{color_table_header};font-weight:600;}}\n .hidden{{display:none;}}\n .results-block{{background:{color_panel};border:1px solid {color_border};border-radius:8px;padding:16px;margin:32px 0;}}\n .kv-table th{{text-align:left;width:200px;}}\n</style>\n</head>\n<body>\n<h1>Qualitätsbericht (Dynamisch)</h1>\n<div class=\"meta\">\n  <strong>Erstellt:</strong> {meta_generated_at}<br/>\n  <strong>Quelle:</strong> {meta_source}<br/>\n</div>\n<div class=\"summary\">\n  <h2>Struktur Zusammenfassung</h2>\n  <div class=\"counts\">{counts_html}</div>\n  <p>Gefilterte Ansicht: Verwende Suchfeld für einfache Textfilterung (client-side). Rohdaten unten vollständig.</p>\n</div>\n{injection_html}\n<div class=\"filter-box\">\n  <input id=\"filterInput\" type=\"text\" placeholder=\"Suchen...\" oninput=\"applyFilter()\" />\n  <button onclick=\"resetFilter()\">Zurücksetzen</button>\n</div>\n<div id=\"dynamicTables\"></div>\n<h2>Rohdaten JSON</h2>\n<div class=\"raw-container\" id=\"rawJson\"></div>\n<div class=\"footer\">Automatisch generiert – temporäre Datei (Bericht_Dynamisch.html).</div>\n<script>\nconst payload = {json_blob};\nconst reportData = payload.reportData || {{}};\nfunction esc(s){{return String(s).replace(/[&<>\\\"']/g, c=>({{'&':'&amp;','<':'&lt;','>':'&gt;','\\\"':'&quot;','\'':'&#39;'}})[c]);}}\nfunction buildTables(){{\n  const container=document.getElementById('dynamicTables');\n  container.innerHTML='';\n  const keys=Object.keys(reportData);\n  if(!keys.length){{container.innerHTML='<em>Keine Daten</em>';return;}}\n  keys.forEach(k=>{{\n    const section=document.createElement('div');\n    section.className='data-section';\n    const val=reportData[k];\n    let html='';\n    if(Array.isArray(val) && val.length && typeof val[0]==='object'){{\n       const cols=Array.from(new Set(val.flatMap(o=>Object.keys(o))));\n       html += `<h2>${{esc(k)}}</h2><table><thead><tr>${{cols.map(c=>`<th>${esc(c)}</th>`).join('')}} </tr></thead><tbody>`;\n       val.forEach(row=>{{html+='<tr>'+cols.map(c=>`<td>${esc(row[c]!==undefined?row[c]:'')}</td>`).join('')+'</tr>';}});\n       html+='</tbody></table>';\n    }} else if (Array.isArray(val)) {{\n       html += `<h2>${{esc(k)}}</h2><div>${{val.map(i=>`<div>- ${esc(i)}</div>`).join('')}} </div>`;\n    }} else if (val && typeof val==='object') {{\n       html += `<h2>${{esc(k)}}</h2><pre>${{esc(JSON.stringify(val,null,2))}}</pre>`;\n    }} else {{\n       html += `<h2>${{esc(k)}}</h2><div>${{esc(val)}}</div>`;\n    }}\n    section.innerHTML=html;\n    container.appendChild(section);\n  }});\n}}\nfunction applyFilter(){{\n  const q=document.getElementById('filterInput').value.toLowerCase();\n  document.querySelectorAll('.data-section').forEach(sec=>{{\n    sec.classList.remove('hidden');\n    if(q){{ if(sec.textContent.toLowerCase().indexOf(q)===-1) sec.classList.add('hidden'); }}\n  }});\n}}\nfunction resetFilter(){{document.getElementById('filterInput').value='';applyFilter();}}\nfunction init(){{\n  buildTables();\n  document.getElementById('rawJson').textContent=JSON.stringify(payload,null,2);\n}}\ninit();\n</script>\n</body>\n</html>""".format(
                meta_generated_at=html.escape(meta['generated_at']),
                meta_source=html.escape(meta['source']),
                counts_html=counts_html,
                injection_html=injection_html,
                json_blob=json_blob,
                color_surface=color_surface,
                color_text=color_text,
                color_panel=color_panel,
                color_border=color_border,
                color_badge_border=color_badge_border,
                color_badge_bg=color_badge_bg,
                color_footer=color_footer,
                color_button=color_button,
                color_button_hover=color_button_hover,
                color_filter_border=color_filter_border,
                color_table_header=color_table_header,
                color_white=color_white
            )
            try:
                with open(target_path, 'w', encoding='utf-8') as f:
                    f.write(template)
            except Exception:
                return None
            try:
                if hasattr(self, '_log_event'):
                    self._log_event("report.dynamic.generated", {"path": target_path, "items": meta.get('item_counts', {}), "generated_at": meta.get('generated_at')})
            except Exception:
                pass
            return target_path
        except Exception:
            return None

    def _initialize_infrastructure_async(self):
        """Starte Infrastruktur Lazy im Hintergrund für minimale Startup-Latenz."""
        try:
            t = threading.Thread(target=self._initialize_infrastructure_safe, name="infra-init", daemon=True)
            t.start()
        except Exception as e:
            self.logger.warning(f"Infrastruktur Async-Init fehlgeschlagen: {e}")

    def _initialize_infrastructure_safe(self):
        """Thread-Safe Initialisierung der neuen Infrastruktur (additiv)."""
        try:
            # EventBus
            if self.event_bus is None:
                self.event_bus = get_global_event_bus()
            # ThemeGuard (High Contrast) – nur einmalig initialisieren
            try:
                if not hasattr(self, 'theme_guard'):
                    from infra.theme_guard import ThemeGuard
                    # Provider liest Setting lazy (Fallback False)
                    def _hc_enabled():
                        try:
                            if hasattr(self, 'settings_service') and self.settings_service:
                                return bool(self.settings_service.get("ui.contrast_mode", False))
                        except Exception:
                            return False
                        return False
                    self.theme_guard = ThemeGuard(_hc_enabled)
                    # Wrapper für vorhandene get_color Methode nur hinzufügen falls noch nicht dekoriert
                    if hasattr(self, 'get_color') and not hasattr(self.get_color, '_theme_guard_wrapped'):
                        original_get_color = self.get_color
                        def guarded_get_color(name, fallback=None):  # type: ignore
                            try:
                                col = original_get_color(name, fallback) if fallback is not None else original_get_color(name)
                                try:
                                    col = self.theme_guard.validate(col)
                                    col = self.theme_guard.apply_contrast(col)
                                except Exception:
                                    pass
                                return col
                            except Exception:
                                return fallback if fallback else '#FFFFFF'
                        setattr(guarded_get_color, '_theme_guard_wrapped', True)
                        self.get_color = guarded_get_color  # type: ignore
            except Exception as e:
                try:
                    self.logger.debug(f"ThemeGuard Init Fehler: {e}")
                except Exception:
                    pass
            # SettingsService
            if self.settings_service is None and SettingsService:
                try:
                    self.settings_service = SettingsService()
                except Exception:
                    self.settings_service = None
            # WorkerPool
            if self.worker_pool is None and 'WORKER_POOL_DISABLED' not in os.environ:
                try:
                    if WorkerPool:
                        pool_size = 3
                        try:
                            if self.settings_service:
                                pool_size = int(self.settings_service.get("infrastructure.worker_pool.size", 3) or 3)
                        except Exception:
                            pool_size = 3
                        self.worker_pool = WorkerPool(size=pool_size, name="quality")
                        self.worker_pool.start()
                except Exception as e:
                    self.logger.warning(f"WorkerPool Init Fehler: {e}")
            # Plugins
            try:
                rules = discover_rules() or []
                # Optional: Filter deaktivierte Regeln laut Settings
                if self.settings_service and self.settings_service.is_enabled("plugins.enabled", True):
                    disabled = set(self.settings_service.get("plugins.disabled_rules", []) or [])
                    self.loaded_rules = [r for r in rules if getattr(r, "__name__", "") not in disabled]
                else:
                    self.loaded_rules = []
            except Exception as e:
                self.logger.warning(f"Plugin Discovery Fehler: {e}")
            # Logging Hook: Infrastruktur-Zusammenfassung (einmalig)
            try:
                self.logger.info(
                    "✅ Infrastruktur bereit | WorkerPool=%s | Plugins=%s | HighContrast=%s",
                    bool(self.worker_pool),
                    len(getattr(self, 'loaded_rules', [])),
                    getattr(self, 'theme_guard', None) is not None and bool(getattr(self, 'theme_guard')._hcp())  # type: ignore
                )
            except Exception:
                pass
            # Event Ankündigung
            try:
                if self.event_bus:
                    self.event_bus.publish("infrastructure.ready", {
                        "rules": [r.__name__ for r in self.loaded_rules],
                        "worker_pool": bool(self.worker_pool)
                    })
            except Exception:
                pass
        except Exception as e:
            # Zentraler Fehlerpfad
            self._handle_error(
                e,
                context="infrastructure.init",
                user_message=self._t("Infrastructure initialization failed") if hasattr(self, '_t') else "Infrastruktur konnte nicht initialisiert werden",
                toast=False  # Infrastruktur-Fehler nicht sofort als Toast spammen
            )

    def submit_background_task(self, func: Callable, *args, **kwargs) -> bool:
        """Öffentliche Helper-API für zukünftige Features zur Nutzung des WorkerPools.
        Rückgabe: True wenn angenommen, sonst False (fällt geräuschlos zurück)."""
        try:
            if self.worker_pool:
                self.worker_pool.submit(func, *args, **kwargs)
                return True
        except Exception as e:
            self.logger.debug(f"Background Task Submit Fehler: {e}")
        return False

    def _analyze_with_plugins(self, context: dict) -> list:
        """Führe geladene Plugin-Regeln sicher aus und liefere RuleResult Objekte.

        Eigenschaften:
          - Individueller Timeout (Thread Join) konfigurierbar via settings_service (plugins.timeout_ms)
          - Fehler/Timeouts beeinflussen nicht andere Regeln
          - Detail-Statistik in self._last_plugin_stats persistiert
          - Optionales Event "plugins.analysis.completed"
        """
        import time as _t
        import concurrent.futures as _f
        import copy as _copy
        results = []  # Rohwerte (Kompatibilität beibehalten)
        stats = {
            "executed": 0,      # Versuchte Ausführungen (inkl. Fehler/Timeout)
            "timeouts": 0,
            "errors": 0,
            "total_duration_s": 0.0,
            "per_rule": []      # {rule, duration_s, timeout, error}
        }
        start_overall = _t.time()  # Mini-Patch A: sicherstellen korrekter Variablenname
        try:
            # Timeout bestimmen
            try:
                if getattr(self, 'settings_service', None):
                    try:
                        timeout_ms = int(self.settings_service.get('plugins.timeout_ms', 2000) or 2000)  # type: ignore[arg-type]
                    except (TypeError, ValueError):
                        timeout_ms = 2000
                else:
                    timeout_ms = 2000
            except Exception:
                timeout_ms = 2000
            timeout_s = max(0.05, timeout_ms / 1000.0)
            # Gesamt-Budget skaliert mit Anzahl Regeln (1.5x Reserve) – realistischer Watchdog
            loaded_peek = list(getattr(self, 'loaded_rules', []) or [])
            overall_budget = max(5.0, timeout_s * max(1, len(loaded_peek)) * 1.5)

            # Konfigurierbares Logging-Level für Timeouts
            timeout_log_level = None
            try:
                if getattr(self, 'settings_service', None):
                    lvl_name = (self.settings_service.get('plugins.timeout_log_level', 'warning') or 'warning').lower()
                    timeout_log_level = getattr(self.logger, lvl_name, self.logger.warning)
            except Exception:
                timeout_log_level = self.logger.warning if hasattr(self, 'logger') else None

            loaded = list(getattr(self, 'loaded_rules', []) or [])
            # Optional: Regel-Profil Filter (wird über Kontext gesetzt, verändert keine globale Liste)
            try:
                allowed = context.get('__allowed_rules__')  # Liste von Namen oder None
                if allowed is not None:
                    allowed_set = set(allowed)
                    loaded = [r for r in loaded if getattr(r, 'name', getattr(r, '__name__', '')) in allowed_set]
            except Exception:
                pass
            if not loaded:
                return []

            for rule_cls in loaded:
                # Gesamt-Budget prüfen
                if (_t.time() - start_overall) > overall_budget:
                    try:
                        self.logger.warning("Plugin-Analyse abgebrochen: Budget überschritten (%.2fs > %.2fs)", (_t.time() - start_overall), overall_budget)
                    except Exception:
                        pass
                    break

                rule_name = getattr(rule_cls, 'name', getattr(rule_cls, '__name__', 'rule'))
                rule_start = _t.time()
                timed_out = False
                error = False
                duration = 0.0
                try:
                    with _f.ThreadPoolExecutor(max_workers=1) as ex:
                        # Kontext-Isolation
                        future = ex.submit(lambda: rule_cls().analyze(_copy.deepcopy(context)))
                        try:
                            val = future.result(timeout=timeout_s)
                            duration = _t.time() - rule_start
                            if val is not None:
                                # Struktur beibehalten (Rohwert); optional könnte normalisiert werden
                                results.append(val)
                        except _f.TimeoutError:
                            duration = _t.time() - rule_start
                            timed_out = True
                            stats["timeouts"] += 1
                            try:
                                if timeout_log_level:
                                    timeout_log_level("Plugin Timeout (%s) nach %.2fs", rule_name, duration)
                            except Exception:
                                pass
                        except Exception:
                            duration = _t.time() - rule_start
                            error = True
                            stats["errors"] += 1
                            try:
                                self.logger.exception("Plugin Fehler (%s)", rule_name)
                            except Exception:
                                pass
                except Exception:
                    # Executor Failure – als Fehler zählen
                    duration = _t.time() - rule_start
                    error = True
                    stats["errors"] += 1
                    try:
                        self.logger.exception("Plugin Executor Fehler (%s)", rule_name)
                    except Exception:
                        pass

                stats["executed"] += 1
                stats["per_rule"].append({
                    "rule": rule_name,
                    "duration_s": round(duration, 4),
                    "timeout": timed_out,
                    "error": error
                })

            stats["total_duration_s"] = round(_t.time() - start_overall, 4)
            # Abgeleitete Kennzahl: erfolgreich
            try:
                stats["succeeded"] = sum(1 for r in stats["per_rule"] if not r["timeout"] and not r["error"])
            except Exception:
                pass
            # Persist & Event
            try:
                self._last_plugin_stats = stats
            except Exception:
                pass
            try:
                if getattr(self, 'event_bus', None):
                    self.event_bus.publish("plugins.analysis.completed", {
                        "count": len(results),
                        # Mini-Patch A: Regelnamen aus per_rule Stats (robust, unabhängig vom Resultat-Typ)
                        "rules": [r["rule"] for r in stats.get("per_rule", [])],
                        "stats": stats
                    })
            except Exception:
                pass
        except Exception as e:
            # Plugin Analyse Fehler zentral behandelt (kein Toast – bereits UI neutral)
            self._handle_error(e, context="plugins.analysis", user_message=None, toast=False)
        return results

    # ------------------------------------------------------------------
    # UI IMPROVEMENT HELPERS (NON-BREAKING – styling only)
    # ------------------------------------------------------------------
    def _create_button(self, parent, text: str, command=None, kind: str = "primary", **overrides):
        """Enhanced Button Factory (design-system aligned).
        Styles:
          Filled: primary | secondary | success | warning | danger | info
          Outline: outline-primary | outline | outline-danger | outline-warning
        Zusätzliche optionale Overrides:
          size: 'sm' | 'md' | 'lg' (mappt auf heights.button_sm/md/lg)
          width/height: explizit möglich (überschreibt size)
        Alle Farben / Maße kommen aus dem Design-System (keine Hardcodes).
        """
        try:
            size = overrides.pop('size', None)  # optionaler semantischer Größen-Parameter

            # Komponenten Token Helper (robust gegen fehlende Methode)
            def _comp(path: str, fallback=None):
                try:
                    if hasattr(self, 'get_component_value'):
                        return self.get_component_value(path)
                except Exception:
                    pass
                return fallback

            # Höhen-Tokens (Fallbacks sichern)
            h_sm = _comp('heights.button_sm', 32)
            h_md = _comp('heights.button_md', 38)
            h_lg = _comp('heights.button_lg', 44)
            size_height = {
                'sm': h_sm,
                'md': h_md,
                'lg': h_lg
            }.get(size, h_md)

            palette = {
                'primary':   (self.get_color('button_primary'), self.get_color('button_primary_hover'), self.get_color('primary_light')),
                'secondary': (self.get_color('button_secondary'), self.get_color('button_secondary_hover'), self.get_color('primary_light')),
                'success':   (self.get_color('success'), self.get_color('success_hover'), self.get_color('success_light', '#F0FDF4')),
                'warning':   (self.get_color('warning'), self.get_color('warning_hover'), self.get_color('warning_light', '#FFFBEB')),
                'danger':    (self.get_color('error'), self.get_color('error_hover'), self.get_color('error_light')),
                'info':      (self.get_color('info'), self.get_color('info_hover'), self.get_color('info_light')),
            }
            fg, hover, light_bg = palette.get(kind, palette['primary'])

            # Welcome-Screen Stil: bevorzugt semantische Button-Font falls verfügbar
            try:
                if hasattr(self, 'get_font'):
                    # get_font liefert direkt CTkFont tuple kompatibel (family,size,weight)
                    font_tuple = self.get_font('button')  # fallback intern geregelt
                else:
                    font_tuple = self.get_typography('body_bold') if hasattr(self, 'get_typography') else ('Segoe UI', 14, 'bold')
            except Exception:
                font_tuple = ('Segoe UI', 14, 'bold')
            # Basis-Höhe primär über size oder Token
            ds_height = size_height

            base_cfg = dict(
                text=text,
                command=command,
                fg_color=fg,
                hover_color=hover,
                text_color=self.get_color('white'),
                font=ctk.CTkFont(*font_tuple),
                corner_radius=_comp('borders.radius_sm', 12),
                height=int(ds_height),  # Outline justiert später ggf.
                border_width=0,
                anchor="center",
            )

            # Outline Varianten wie Welcome Screen (weißer Hintergrund, farbiger Text, feine Border)
            if kind in {"outline-primary", "outline", "outline-danger", "outline-warning"}:
                # Welcome Screen Outline Stil (weiß, feine Border, farbiger Text)
                if kind == "outline-danger":
                    txt_col = self.get_color('error')
                elif kind == "outline-warning":
                    txt_col = self.get_color('warning')
                else:
                    txt_col = self.get_color('primary')
                # Höhe konsistent zu Welcome Screen bevorzugt heights.button_md
                outline_height = h_md
                base_cfg.update(
                    fg_color=self.get_color('white'),
                    hover_color=self.get_color('surface_hover'),  # dezente Hover-Fläche
                    text_color=txt_col,
                    border_width=1,
                    border_color=self.get_color('surface_border'),
                    height=int(outline_height)
                )
                # Font ggf. auf semantische Button-Font normalisieren (nicht bold wenn System es so definiert)
                try:
                    if hasattr(self, 'get_font'):
                        base_cfg['font'] = self.get_font('button')
                except Exception:
                    pass

            # Unsupported geometry keys entfernen
            for unsupported in ('padx', 'pady', 'ipadx', 'ipady'):
                overrides.pop(unsupported, None)
            base_cfg.update({k: v for k, v in overrides.items() if v is not None})

            # Breitenberechnung
            try:
                if 'width' not in base_cfg:
                    text_px = None
                    try:
                        measure_font = ctk.CTkFont(*font_tuple)
                        if hasattr(measure_font, 'measure'):
                            text_px = measure_font.measure(text)
                    except Exception:
                        text_px = None
                    if text_px is None:
                        try:
                            import tkinter.font as tkfont  # type: ignore
                            measure_font2 = tkfont.Font(family=font_tuple[0], size=font_tuple[1], weight=font_tuple[2])
                            text_px = measure_font2.measure(text)
                        except Exception:
                            text_px = None
                    if text_px is None:
                        text_px = len(text) * 8
                    desired = max(120, min(300, text_px + 30))
                    base_cfg['width'] = int(desired)
            except Exception:
                pass

            btn = ctk.CTkButton(parent, **base_cfg)

            # Tastatur-Fokus klar sichtbar machen (2px Fokus-Ring in Akzentfarbe)
            try:
                focus_color = self.get_color('primary')
                normal_border = base_cfg.get('border_color', self.get_color('surface_border'))
                normal_bw = base_cfg.get('border_width', 0)
                def _on_focus_in(_e):
                    try:
                        btn.configure(border_width=2, border_color=focus_color)
                    except Exception:
                        pass
                def _on_focus_out(_e):
                    try:
                        btn.configure(border_width=normal_bw, border_color=normal_border)
                    except Exception:
                        pass
                btn.bind('<FocusIn>', _on_focus_in)
                btn.bind('<FocusOut>', _on_focus_out)
            except Exception:
                pass

            # Delegiere optional an UIHelpers für konsistentes Enabled/Disabled Styling
            try:
                if UIHelpers and kind in ("primary", "secondary", "warning", "danger"):
                    UIHelpers.apply_button_style(btn, style=("primary" if kind == "primary" else kind), enabled=True, ds=self)
            except Exception:
                pass

            try:
                if not hasattr(btn, '_font') or btn._font is None:  # type: ignore[attr-defined]
                    btn.configure(font=ctk.CTkFont(*font_tuple))
            except Exception:
                pass
            return btn
        except Exception as e:
            self.logger.warning(f"Button factory fallback ({text}): {e}")
            return ctk.CTkButton(parent, text=text, command=command)

    def _apply_button_style(self, btn: ctk.CTkButton, enabled: bool, style: str = "primary"):
        """Delegation analog Welcome Screen – zentraler Style Helper."""
        try:
            if not btn:
                return
            if UIHelpers:
                UIHelpers.apply_button_style(btn, style=style, enabled=enabled, ds=self)
            else:
                btn.configure(state=("normal" if enabled else "disabled"))
        except Exception:
            pass

    def _create_card_frame(self, parent, **overrides):
        """🎨 ENHANCED: Modern card frame with subtle shadow effects and premium styling
        Features: Elevated appearance, subtle borders, premium corner radius
        """
        try:
            # 🎯 Modern Card Configuration with Enhanced Visual Depth
            cfg = dict(
                fg_color=self.get_color('surface'),
                corner_radius=16,  # More rounded for modern premium look
                border_width=1,
                border_color=self.get_color('surface_border'),
                # Enhanced properties for premium card appearance
            )
            cfg.update(overrides)
            
            # Create enhanced card with modern styling
            frame = ctk.CTkFrame(parent, **cfg)
            
            # Add subtle hover enhancement (visual-only enhancement)
            self._add_card_hover_enhancement(frame)
            
            return frame
        except Exception:
            # Fallback to basic frame
            return ctk.CTkFrame(parent, fg_color=self.get_color('surface', '#FFFFFF'), corner_radius=12)

    def _add_dragdrop_visual_cues(self, frame):
        """🎨 ENHANCEMENT: Add modern drag & drop visual feedback (non-breaking)"""
        try:
            # Store original styling
            original_fg = frame.cget('fg_color')
            original_border = frame.cget('border_color')
            
            # Enhanced drag & drop colors
            drag_hover_fg = self.get_color('primary_light', '#F0F7FF')
            drag_hover_border = self.get_color('primary', '#1F4E79')
            
            def on_drag_enter(event):
                """Visual feedback when dragging files over"""
                try:
                    frame.configure(
                        fg_color=drag_hover_fg,
                        border_color=drag_hover_border,
                        border_width=3
                    )
                except Exception as e:
                    self._record_suppressed_error('ui.drag_visual.enter', e)
                    
            def on_drag_leave(event):
                """Return to normal state"""
                try:
                    frame.configure(
                        fg_color=original_fg,
                        border_color=original_border,
                        border_width=2
                    )
                except Exception as e:
                    self._record_suppressed_error('ui.drag_visual.leave', e)
            
            # Bind drag events for visual feedback
            frame.bind("<Button-1>", on_drag_enter)  # Simulate drag hover
            frame.bind("<ButtonRelease-1>", on_drag_leave)
            
        except Exception:
            # Visual enhancements are optional
            pass

    def _add_card_hover_enhancement(self, frame):
        """🎨 ENHANCEMENT: Add subtle hover effects to cards (non-breaking)"""
        try:
            # Store original colors for hover effect
            original_fg = frame.cget('fg_color')
            hover_fg = self.get_color('surface_hover', '#F8FAFC')
            
            def on_enter(event):
                """Subtle hover effect"""
                try:
                    frame.configure(fg_color=hover_fg)
                except Exception as e:
                    self._record_suppressed_error('ui.card_hover.enter', e)
                    
            def on_leave(event):
                """Return to original state"""
                try:
                    frame.configure(fg_color=original_fg)
                except Exception as e:
                    self._record_suppressed_error('ui.card_hover.leave', e)
            
            # Bind hover events (safe binding)
            frame.bind("<Enter>", on_enter)
            frame.bind("<Leave>", on_leave)
            
        except Exception:
            # Hover enhancement is optional, continue without it
            pass

    def _add_header_accent(self, parent, color_key: str = 'primary'):
        """Add a slim colored accent bar to a header container."""
        try:
            bar = ctk.CTkFrame(parent, fg_color=self.get_color(color_key), width=4)
            bar.pack(side="left", fill="y")
            return bar
        except Exception:
            return None

    def _render_inline_diff(self, parent, old_text: str, new_text: str):
        """Leichtgewichtiger Inline-Diff (Zeilen-basiert) mit farbigen Tags.

        Nutzt difflib.ndiff; Tags:
        + add (grün / success)
        - rem (orange / warning)
        ? meta (Hinweispfeile / Kontext)
          ctx (unverändert)
        """
        try:
            import difflib
            box = ctk.CTkTextbox(parent, height=120, fg_color=self.get_color('white'), text_color=self.get_color('gray_700'))
            box.pack(fill="x", padx=16, pady=(6,8))
            box.configure(state="normal")
            try:
                box.tag_config("add",  foreground=self.get_color('success'))
                box.tag_config("rem",  foreground=self.get_color('warning'))
                box.tag_config("ctx",  foreground=self.get_color('gray_600'))
                box.tag_config("meta", foreground=self.get_color('gray_500'))
            except Exception as e:
                self._record_suppressed_error('ui.inline_diff.tag_config', e)
            for line in difflib.ndiff((old_text or "").splitlines(), (new_text or "").splitlines()):
                tag = "ctx"
                if line.startswith("+ "): tag = "add"
                elif line.startswith("- "): tag = "rem"
                elif line.startswith("? "): tag = "meta"
                box.insert("end", line + "\n", (tag,))
            box.configure(state="disabled")
            return box
        except Exception:
            return None
    
    def _create_header(self):
        """Create application header"""
        try:
            # Wrapper für Accent Bar + Inhalt
            header_frame = ctk.CTkFrame(self.root, height=54, fg_color=self.get_color('surface'))
            header_frame.pack(fill="x", padx=0, pady=0)
            header_frame.pack_propagate(False)
            content_wrapper = ctk.CTkFrame(header_frame, fg_color='transparent')
            content_wrapper.pack(fill='both', expand=True)
            # Accent Bar (optional)
            try:
                self._add_header_accent(content_wrapper, 'primary')
            except Exception:
                pass
            header_text = self._t("Translation Quality Framework - Professional") if hasattr(self, '_t') else "Translation Quality Framework - Professional"
            title_label = ctk.CTkLabel(
                content_wrapper,
                text=header_text,
                font=ctk.CTkFont(*self.get_typography('heading') if hasattr(self, 'get_typography') else ('Segoe UI', 22, 'bold')),
                text_color=self.get_color('text_primary')
            )
            title_label.pack(side="left", padx=18, pady=8)
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.header",
                user_message=self._t("Header creation failed") if hasattr(self, '_t') else "Header konnte nicht erstellt werden"
            )

    # ---------------- MENU BAR (Ribbon) -----------------
    def _create_menu_bar(self):
        """Einfaches text-basiertes Menüband unterhalb des Headers.

        Design-Vorgaben:
        - Keine Icons / Emojis
        - Nutzung Design-System Farben / Typografie
        - Schlanke Höhe, horizontale Buttons
        - Fokus: Navigation + Schnellzugriffe (Einstellungen, Basisordner)
        """
        try:
            if hasattr(self, '_menu_bar_created') and self._menu_bar_created:
                return
            self._menu_buttons = {}
            self._menu_meta = {}
            # Usage-Map evtl. aus Settings laden (nur einmal)
            try:
                if not hasattr(self, '_menu_usage'):
                    loaded_usage = None
                    if hasattr(self,'settings_service') and self.settings_service:
                        loaded_usage = self.settings_service.get('menu.usage')
                        if not isinstance(loaded_usage, dict):
                            loaded_usage = None
                    self._menu_usage = loaded_usage or {}
            except Exception:
                self._menu_usage = {}
            bar = ctk.CTkFrame(self.root, fg_color=self.get_color('surface'), height=40)
            bar.pack(fill='x', padx=0, pady=(0,0))
            bar.pack_propagate(False)
            self._menu_bar_frame = bar

            inner = ctk.CTkFrame(bar, fg_color='transparent')
            inner.pack(fill='both', expand=True, padx=12, pady=2)

            # Active State Handling
            def _move_indicator(key: str):
                try:
                    if not hasattr(self, '_menu_indicator'):
                        return
                    btn = self._menu_buttons.get(key, {}).get('widget')
                    if not btn:
                        return
                    btn.update_idletasks()
                    x = btn.winfo_x()
                    w = btn.winfo_width()
                    self._menu_indicator.place(x=x, y=bar.winfo_height()-3, width=w, height=3)
                except Exception:
                    pass

            # Zentrale Style-Anwendung für konsistente Zustände
            def _apply_menu_style(k: str, info: dict):
                try:
                    btn = info.get('widget')
                    if not btn:
                        return
                    active = (k == getattr(self, '_active_menu', None))
                    style = info.get('style')
                    if active:
                        # Aktiver Button immer Primary-Farbfläche + Hover auf primary_hover
                        btn.configure(
                            fg_color=self.get_color('primary'),
                            hover_color=self.get_color('primary_hover'),
                            text_color=self.get_color('white'),
                            border_width=0
                        )
                    else:
                        if style == 'primary':
                            # Primärer (aber inaktiv) behält button_primary Tokens
                            btn.configure(
                                fg_color=self.get_color('button_primary'),
                                hover_color=self.get_color('button_primary_hover'),
                                text_color=self.get_color('white'),
                                border_width=0
                            )
                        else:  # Sekundär / Outline
                            btn.configure(
                                fg_color=self.get_color('surface'),
                                text_color=self.get_color('primary'),
                                border_color=self.get_color('primary'),
                                border_width=1,
                                hover_color=self.get_color('surface_hover')
                            )
                except Exception:
                    pass

            def _refresh_menu_styles():
                for k, info in self._menu_buttons.items():
                    _apply_menu_style(k, info)

            def _set_active(key: str):
                try:
                    self._active_menu = key
                    _refresh_menu_styles()
                    # Indikator verschieben (deferred für Geometrie)
                    self.root.after(10, lambda k=key: _move_indicator(k))
                except Exception:
                    pass
            self._set_active_menu_button = _set_active  # referenzieren
            self.mark_menu_active = _set_active  # öffentliche Alias-Methode

            def _btn(key, txt, cmd, kind='secondary', hotkey=None):
                try:
                    def _wrapped():  # Aktive Markierung + Usage-Tracking + Command
                        try:
                            _set_active(key)
                            if hasattr(self, '_record_menu_usage'):
                                try:
                                    self._record_menu_usage(key)
                                except Exception:
                                    pass
                            cmd()
                            # Nach Nutzung optional persistieren (throttled)
                            try:
                                now = time.time()
                                if getattr(self,'_last_usage_persist',0) + 5 < now:
                                    if hasattr(self,'settings_service') and self.settings_service:
                                        self.settings_service.set('menu.usage', getattr(self,'_menu_usage',{}))
                                    self._last_usage_persist = now
                            except Exception:
                                pass
                        except Exception:
                            pass
                    b = self._create_button(inner, text=txt, command=_wrapped, kind=('primary' if kind=='primary' else 'secondary'), height=30, size='sm')
                except Exception:
                    b = ctk.CTkButton(inner, text=txt, command=_wrapped, fg_color=self.get_color('primary'))
                b.pack(side='left', padx=(0,8))
                # Einheitliche Hover-Effekte (auch wenn später aktiv geändert)
                try:
                    def _on_enter(e, key=key):
                        if key != getattr(self, '_active_menu', None):
                            if kind == 'primary':
                                b.configure(fg_color=self.get_color('button_primary_hover'))
                            else:
                                b.configure(fg_color=self.get_color('surface_hover'))
                    def _on_leave(e, key=key):
                        # Refresh erzwingt Rückkehr in Grundzustand
                        _apply_menu_style(key, self._menu_buttons.get(key, {}))
                    b.bind('<Enter>', _on_enter)
                    b.bind('<Leave>', _on_leave)
                except Exception:
                    pass
                # Sekundär direkt korrekt stylen
                if kind != 'primary':
                    _apply_menu_style(key, {'widget': b, 'style': kind})
                self._menu_buttons[key] = {'widget': b, 'style': kind, 'hotkey': hotkey, 'base_text': txt}
                self._menu_meta[key] = {'label': txt, 'command': cmd, 'hotkey': hotkey, 'kind': kind}
                # Fokus Outline für Accessibility
                try:
                    def _on_focus_in(e, btn=b):
                        try:
                            btn.configure(border_color=self.get_color('primary'), border_width=2)
                        except Exception as ex_focus_style_in:
                            try:
                                self._record_suppressed_error('ui.menu.focus.in', ex_focus_style_in)
                            except Exception:
                                pass
                    def _on_focus_out(e, btn=b):
                        try:
                            # Nur bei nicht aktivem Button Outline entfernen
                            if key != getattr(self,'_active_menu', None):
                                btn.configure(border_color=self.get_color('primary') if kind!='primary' else self.get_color('primary'), border_width=(1 if kind!='primary' else 0))
                        except Exception as ex_focus_style_out:
                            try:
                                self._record_suppressed_error('ui.menu.focus.out', ex_focus_style_out)
                            except Exception:
                                pass
                    b.bind('<FocusIn>', _on_focus_in)
                    b.bind('<FocusOut>', _on_focus_out)
                except Exception as ex_focus_bind:
                    try:
                        self._record_suppressed_error('ui.menu.focus.bind', ex_focus_bind)
                    except Exception:
                        pass
                return b

            # Aktionen
            def _show_home():
                try:
                    self._show_welcome_output()
                    self.show_toast(self._t('Startseite geladen'), 'info')
                except Exception as ex_show_home:
                    try:
                        self._record_suppressed_error('ui.menu.action.home', ex_show_home)
                    except Exception:
                        pass

            def _show_upload():
                try:
                    self._create_upload_section(getattr(self, 'left_panel', self.root))
                except Exception:
                    pass

            def _open_base_folder():
                """Plattform-sicher Ordner im Dateimanager öffnen (Win/macOS/Linux)."""
                try:
                    import os, subprocess, shutil, platform
                    base = getattr(self, 'projects_base_path', 'Checker_Projekte')
                    os.makedirs(base, exist_ok=True)
                    sysname = platform.system()
                    if sysname == 'Windows':
                        subprocess.Popen(['explorer', os.path.normpath(base)])
                    elif sysname == 'Darwin':
                        subprocess.Popen(['open', base])
                    else:
                        opener = shutil.which('xdg-open') or 'xdg-open'
                        subprocess.Popen([opener, base])
                except Exception as e:
                    try:
                        self._handle_error(e, context="open.base.folder", toast=False)
                    except Exception:
                        pass

            def _show_projects():
                try:
                    self._show_project_navigation_dashboard() if hasattr(self, '_show_project_navigation_dashboard') else None
                except Exception:
                    pass

            def _show_settings():
                try:
                    self.show_settings_view()
                except Exception:
                    pass

            # Buttons definieren (mit Hotkeys Alt+1..5)
            # Zentrale Registry (Standardreihenfolge)
            # Upload wurde aus dem sichtbaren Menüband entfernt (Nutzerwunsch),
            # Hotkeys werden neu sequenziert.
            # Alle Buttons als 'primary' (gefüllt blau) konfigurieren (User-Wunsch: alle blau)
            default_actions = [
                ('home', 'Start', _show_home, 'primary', '1'),
                ('projects', 'Projekte', _show_projects, 'primary', '2'),
                ('base', 'Basisordner', _open_base_folder, 'primary', '3'),
                ('settings', 'Einstellungen', _show_settings, 'primary', '4'),
            ]
            # Persistente Reihenfolge berücksichtigen
            try:
                stored_order = None
                if hasattr(self,'settings_service') and self.settings_service:
                    so = self.settings_service.get('menu.order')
                    if isinstance(so, (list,tuple)):
                        stored_order = [x for x in so if any(a[0]==x for a in default_actions)]
                if stored_order:
                    # Sortiere actions entsprechend, fehlende hinten
                    ordered = []
                    for k in stored_order:
                        for a in default_actions:
                            if a[0]==k and a not in ordered:
                                ordered.append(a)
                    for a in default_actions:
                        if a not in ordered:
                            ordered.append(a)
                    default_actions = ordered
            except Exception:
                pass
            for key, txt, cmd, kind, hk in default_actions:
                _btn(key, self._t(txt) if hasattr(self, '_t') else txt, cmd, kind=kind, hotkey=hk)
            # Upload weiterhin über Command-Palette verfügbar (nicht im Menüband)
            try:
                if 'upload' not in self._menu_meta:
                    self._menu_meta['upload'] = {
                        'label': 'Upload',
                        'command': _show_upload,
                        'hotkey': None,
                        'kind': 'secondary'
                    }
            except Exception:
                pass

            # -------- Kunden-Badge (rechts) --------
            try:
                # Wrapper Frame rechts (Button + Badge)
                badge_frame = ctk.CTkFrame(inner, fg_color='transparent')
                badge_frame.pack(side='right', padx=(8,0))
                # Expliziter Button für Kundenauswahl (User-Wunsch)
                def _open_customer_dialog():  # noqa: D401
                    try:
                        self._open_customer_selection_dialog()
                    except Exception:
                        pass
                select_btn_cfg = self._create_button_config(kind='secondary', height=30, size='sm') if hasattr(self,'_create_button_config') else {}
                try:
                    self._customer_select_button = ctk.CTkButton(
                        badge_frame,
                        text='Kunde wählen',
                        command=_open_customer_dialog,
                        **select_btn_cfg
                    )
                    # Outline Stil
                    try:
                        self._customer_select_button.configure(fg_color=self.get_color('surface'), text_color=self.get_color('primary'), border_color=self.get_color('primary'), border_width=1, hover_color=self.get_color('surface_hover'))
                    except Exception:
                        pass
                    self._customer_select_button.pack(side='right', padx=(0,6))
                    # Shortcut Alt+K (global root bind once)
                    try:
                        if not hasattr(self,'_customer_select_shortcut_bound'):
                            self.root.bind('<Alt-k>', lambda e: _open_customer_dialog())
                            self.root.bind('<Alt-K>', lambda e: _open_customer_dialog())
                            self._customer_select_shortcut_bound = True
                    except Exception:
                        pass
                except Exception:
                    pass
                # Label Stil (Outline-Chip Stil)
                self._customer_badge = ctk.CTkLabel(
                    badge_frame,
                    text="Kunde: -",
                    fg_color=self.get_color('surface'),
                    text_color=self.get_color('primary'),
                    corner_radius= self.get_color('corner_radius') if False else 6,  # dynamischer Radius optional
                    font=ctk.CTkFont(* (self.get_typography('small') if hasattr(self,'get_typography') else ('Segoe UI',12,'bold')) ),
                    padx=10,
                    pady=4
                )
                # Border simulieren über zusätzlichen Frame (CTkLabel hat kein border_color param in allen Versionen)
                try:
                    self._customer_badge.configure(border_color=self.get_color('surface_border'), border_width=1)
                except Exception:
                    pass
                self._customer_badge.pack(side='right')
                # Klick öffnet Auswahl-Dialog
                try:
                    self._customer_badge.bind('<Button-1>', lambda e: self._open_customer_selection_dialog())
                except Exception:
                    pass

                def _update_customer_badge():  # poll-basiert, non-invasiv
                    try:
                        name = getattr(self, 'current_customer', None)
                        txt = f"Kunde: {name}" if name else "Kunde: -"
                        if self._customer_badge.cget('text') != txt:
                            self._customer_badge.configure(text=txt)
                    except Exception:
                        pass
                    # erneutes Scheduling
                    try:
                        self.root.after(1500, _update_customer_badge)
                    except Exception:
                        pass
                # initial starten
                self.root.after(800, _update_customer_badge)
            except Exception:
                pass

            # Anpassungs-Eintrag nur in Meta für Command-Palette
            def _open_customize():
                self._open_menu_customize_dialog()
            self._menu_meta['customize'] = {'label': 'Menü anpassen', 'command': _open_customize, 'hotkey': None, 'kind':'secondary'}

            # Responsive: einfacher Mehr-Dropdown bei geringer Breite
            try:
                self._menu_overflow_button = None
                def _reflow():
                    """Dynamische Overflow-Logik: reale Buttonbreiten messen statt fixer Schwelle.
                    Vorgehen: Alles sichtbar machen -> Breiten summieren -> prüfen gegen verfügbare Breite -> sekundäre Buttons in Overflow verschieben.
                    """
                    try:
                        inner.update_idletasks()
                        active_key = getattr(self,'_active_menu','home')
                        # Alle Buttons sicher sichtbar für Messung
                        for k, info in self._menu_buttons.items():
                            if not info['widget'].winfo_manager():
                                try:
                                    info['widget'].pack(side='left', padx=(0,8))
                                except Exception:
                                    pass
                        inner.update_idletasks()
                        # Verfügbarer Platz (inkl. Badge rechts berücksichtigen)
                        available = inner.winfo_width() or self.root.winfo_width()
                        # Breiten summieren
                        total = 0
                        ordered = list(self._menu_buttons.keys())
                        for k in ordered:
                            btn = self._menu_buttons[k]['widget']
                            total += btn.winfo_width() + 8
                        # Badge Frame identifizieren (rechts gepackter Frame mit Kunde Label)
                        badge_w = 0
                        try:
                            for child in inner.winfo_children():
                                for g in child.winfo_children():
                                    if isinstance(g, ctk.CTkLabel) and 'Kunde:' in str(getattr(g,'cget')('text')):
                                        badge_w = max(badge_w, child.winfo_width())
                        except Exception:
                            pass
                        total += badge_w + 24  # Innen-Padding
                        need_overflow = available > 0 and total > available
                        # Anwenden
                        if need_overflow:
                            # Liste sekundärer Kandidaten (ohne active und settings) erneut ermitteln
                            hidden = []
                            for k, info in self._menu_buttons.items():
                                if k not in ('settings', active_key) and info['style']=='secondary':
                                    try:
                                        info['widget'].pack_forget()
                                        hidden.append(k)
                                    except Exception as ex_usage_record:
                                        try:
                                            self._record_suppressed_error('ui.palette.usage.record', ex_usage_record)
                                        except Exception:
                                            pass
                            if hidden and not self._menu_overflow_button:
                                def _show_menu_popup():
                                    try:
                                        win = ctk.CTkToplevel(self.root)
                                        win.title('Menü')
                                        win.geometry('260x260')
                                        for k in hidden:
                                            meta = self._menu_meta.get(k)
                                            if not meta:
                                                continue
                                            b = self._create_button(win, text=meta['label'], command=lambda kk=k: (self._menu_buttons[kk]['widget'].invoke(), win.destroy()), kind='secondary', height=32, size='sm')
                                            b.pack(fill='x', padx=10, pady=4)
                                    except Exception:
                                        pass
                                self._menu_overflow_button = self._create_button(inner, text='Mehr', command=_show_menu_popup, kind='secondary', height=30, size='sm')
                                self._menu_overflow_button.configure(fg_color=self.get_color('surface'), text_color=self.get_color('primary'), border_color=self.get_color('primary'), border_width=1, hover_color=self.get_color('surface_hover'))
                                self._menu_overflow_button.pack(side='left', padx=(0,8))
                        else:
                            if self._menu_overflow_button:
                                try:
                                    self._menu_overflow_button.destroy()
                                except Exception:
                                    pass
                                self._menu_overflow_button = None
                            # Alles wiederherstellen
                            for k, info in self._menu_buttons.items():
                                if not info['widget'].winfo_manager():
                                    try:
                                        info['widget'].pack(side='left', padx=(0,8))
                                    except Exception:
                                        pass
                        if getattr(self,'_active_menu',None):
                            _move_indicator(self._active_menu)
                    except Exception:
                        pass
                # Nur einmal global binden (verhindert gehäufte Mehrfach-Bindings nach Rebuild)
                if not getattr(self, '_menu_reflow_bound', False):
                    self.root.bind('<Configure>', lambda e: self.root.after(50, _reflow))
                    self._menu_reflow_bound = True
            except Exception:
                pass

            # Hotkey Bindings (Alt+Ziffer)
            try:
                def _on_key(event):
                    try:
                        if not (event.state & 0x0008):  # Alt Maske plattformabhängig; heuristisch weglassen falls unzuverlässig
                            return
                        ch = event.keysym
                        for k, info in self._menu_buttons.items():
                            if info.get('hotkey') == ch:
                                info['widget'].invoke()
                    except Exception:
                        pass
                self.root.bind_all('<KeyPress>', _on_key)
            except Exception:
                pass

            # Pfeilnavigation (Links/Rechts)
            try:
                def _arrow_nav(event):
                    try:
                        order = [k for k in self._menu_buttons.keys()]
                        if not order:
                            return
                        cur = getattr(self, '_active_menu', order[0])
                        idx = order.index(cur)
                        if event.keysym == 'Right':
                            idx = (idx + 1) % len(order)
                        elif event.keysym == 'Left':
                            idx = (idx - 1) % len(order)
                        else:
                            return
                        self._menu_buttons[order[idx]]['widget'].invoke()
                    except Exception:
                        pass
                self.root.bind_all('<KeyPress-Right>', _arrow_nav)
                self.root.bind_all('<KeyPress-Left>', _arrow_nav)
            except Exception:
                pass

            # Command-Palette (Strg+K / Strg+P) – erweiterte Fuzzy-Suche + Nutzungshistorie Ranking
            try:
                def _open_palette(event=None):
                    try:
                        pal = ctk.CTkToplevel(self.root)
                        pal.title('Aktionen')
                        pal.geometry('420x360')
                        pal.transient(self.root)
                        try:
                            pal.focus_force()
                        except Exception:
                            pass
                        wrapper = ctk.CTkFrame(pal, fg_color=self.get_color('surface'))
                        wrapper.pack(fill='both', expand=True, padx=12, pady=12)
                        entry = ctk.CTkEntry(wrapper, placeholder_text='Aktion suchen...', width=320)
                        entry.pack(fill='x', pady=(0,8))
                        list_frame = ctk.CTkScrollableFrame(wrapper, fg_color=self.get_color('surface'), height=260)
                        list_frame.pack(fill='both', expand=True)
                        # Unterer Button-Bereich mit Schließen
                        footer = ctk.CTkFrame(wrapper, fg_color='transparent')
                        footer.pack(fill='x', pady=(6,0))
                        close_btn = self._create_button(footer, text='Schließen', command=lambda: pal.destroy(), kind='secondary', height=30, size='sm')
                        close_btn.pack(side='right')
                        results = []
                        usage_map = getattr(self, '_menu_usage', {}) if hasattr(self, '_menu_usage') else {}
                        def _fuzzy_score(query: str, label: str, hot: str|None, cat: str, usage: dict|None):
                            if not query:
                                u_cnt = usage.get('count', 0) if usage else 0
                                last = usage.get('last', 0) if usage else 0
                                return 1000 + u_cnt*15 + (last/100000.0)
                            q = query.lower()
                            text = label.lower()
                            score = 0
                            last_pos = -1
                            # Acronym Bonus: Anfangsbuchstaben der Worte
                            try:
                                initials = ''.join(w[0] for w in label.split() if w)
                                if len(q) > 1 and initials.lower().startswith(q):
                                    score += 40
                            except Exception:
                                pass
                            for ch in q:
                                pos = text.find(ch, last_pos+1)
                                if pos == -1:
                                    return -1
                                score += 5
                                if last_pos != -1 and pos == last_pos + 1:
                                    score += 6
                                if pos == 0 or text[pos-1] in (' ','-','_'):
                                    score += 8
                                last_pos = pos
                            span = (last_pos - text.find(q[0])) if q else 0
                            if span:
                                score -= span
                            if hot and q == hot.lower():
                                score += 30
                            if cat == 'Navigation':
                                score += 3
                            if usage:
                                score += min(usage.get('count',0), 25)
                            return score
                        def _render(q: str):
                            for w in results:
                                try:
                                    w.destroy()
                                except Exception as e:
                                    self._record_suppressed_error('ui.menu.palette.cleanup', e)
                            results.clear()
                            ql = q.lower().strip()
                            enriched = []
                            for k, meta in self._menu_meta.items():
                                label = meta.get('label', k)
                                hot = meta.get('hotkey')
                                cat = 'Navigation' if k in self._menu_buttons else 'System'
                                usage = usage_map.get(k)
                                sc = _fuzzy_score(ql, label, hot, cat, usage)
                                if sc >= 0:
                                    enriched.append((sc,k,label,hot,cat,usage))
                            enriched.sort(key=lambda x: (-x[0], x[2].lower()))
                            # Wenn keine Query: Top "Zuletzt verwendet" Abschnitt erzeugen
                            if not ql:
                                recent = [e for e in enriched if e[5] and e[5].get('count',0) > 0]
                                recent.sort(key=lambda x: (-x[5].get('count',0), -x[5].get('last',0)))
                                recent = recent[:5]
                                if recent:
                                    header = ctk.CTkLabel(list_frame, text='Zuletzt verwendet', anchor='w', text_color=self.get_color('text_secondary'), font=ctk.CTkFont(*self.get_typography('caption')))
                                    header.pack(fill='x', pady=(0,4))
                                    results.append(header)
                                    for sc,k,label,hot,cat,usage in recent:
                                        suffix = ' (häufig)' if usage and usage.get('count',0) >= 3 else ''
                                        display = f"{label}{' ['+hot+']' if hot else ''}{suffix} - {cat}"
                                        def _invoke_recent(kk=k):
                                            try:
                                                if hasattr(self, '_record_menu_usage'):
                                                    self._record_menu_usage(kk)
                                            except Exception as e:
                                                self._record_suppressed_error('ui.menu.usage.record', e)
                                            btn_ref = self._menu_buttons.get(kk,{}).get('widget')
                                            if btn_ref:
                                                try:
                                                    btn_ref.invoke()
                                                except Exception as e:
                                                    self._record_suppressed_error('ui.menu.recent.invoke', e)
                                            pal.destroy()
                                        btn_recent = self._create_button(list_frame, text=display, command=_invoke_recent, kind='secondary', height=30, size='sm')
                                        btn_recent.configure(fg_color=self.get_color('surface'), text_color=self.get_color('primary'), border_color=self.get_color('primary'), border_width=1, hover_color=self.get_color('surface_hover'))
                                        btn_recent.pack(fill='x', pady=2)
                                        results.append(btn_recent)
                                    sep = ctk.CTkFrame(list_frame, fg_color=self.get_color('surface_border'), height=1)
                                    sep.pack(fill='x', pady=(6,4))
                                    results.append(sep)
                            for sc,k,label,hot,cat,usage in enriched[:35]:
                                suffix = ''
                                try:
                                    if not ql and usage and usage.get('count',0) >= 3:
                                        suffix = ' (häufig)'
                                except Exception:
                                    pass
                                display = f"{label}{' ['+hot+']' if hot else ''}{suffix} - {cat}"
                                def _invoke(kk=k):
                                    try:
                                        if hasattr(self, '_record_menu_usage'):
                                            self._record_menu_usage(kk)
                                    except Exception:
                                        pass
                                    btn_ref = self._menu_buttons.get(kk,{}).get('widget')
                                    if btn_ref:
                                        try:
                                            btn_ref.invoke()
                                        except Exception as ex_invoke_btn:
                                            try:
                                                self._record_suppressed_error('ui.palette.invoke', ex_invoke_btn)
                                            except Exception:
                                                pass
                                    pal.destroy()
                                b = self._create_button(list_frame, text=display, command=_invoke, kind='secondary', height=30, size='sm')
                                b.configure(fg_color=self.get_color('surface'), text_color=self.get_color('primary'), border_color=self.get_color('primary'), border_width=1, hover_color=self.get_color('surface_hover'))
                                b.pack(fill='x', pady=2)
                                results.append(b)
                        def _on_change(_):
                            _render(entry.get())
                        entry.bind('<KeyRelease>', _on_change)
                        entry.bind('<Return>', lambda e: (results and results[0].invoke()))
                        entry.bind('<Escape>', lambda e: pal.destroy())
                        pal.bind('<Escape>', lambda e: pal.destroy())
                        # Auto-Schließen bei Verlust des Fokus (optional, ohne Crash bei Plattformproblemen)
                        def _maybe_close(_e):
                            try:
                                if not pal.focus_displayof():
                                    pal.destroy()
                            except Exception as ex_maybe_close:
                                try:
                                    self._record_suppressed_error('ui.palette.maybe_close', ex_maybe_close)
                                except Exception:
                                    pass
                        pal.bind('<FocusOut>', _maybe_close)
                        _render('')
                        entry.focus()
                    except Exception as ex_palette_open:
                        try:
                            self._record_suppressed_error('ui.palette.open.fail', ex_palette_open)
                        except Exception:
                            pass
                self.root.bind_all('<Control-k>', _open_palette)
                self.root.bind_all('<Control-p>', _open_palette)  # Alternativ-Shortcut (Power-User)
                self._open_command_palette = _open_palette
            except Exception as ex_palette_bind:
                try:
                    self._record_suppressed_error('ui.palette.install.bind', ex_palette_bind)
                except Exception:
                    pass
            # Shortcut für Anpassen
            try:
                self.root.bind_all('<Control-m>', lambda e: self._menu_meta.get('customize',{}).get('command')())
            except Exception:
                pass

            # Initial aktiv
            _set_active('home')
            # Nach initialem Set vollständige Styles sicherstellen
            try:
                _refresh_menu_styles()
            except Exception:
                pass
            # Indikator Frame anlegen
            try:
                self._menu_indicator = ctk.CTkFrame(bar, fg_color=self.get_color('primary'))
                self.root.after(30, lambda: _move_indicator('home'))
                # Reposition nutzt globalen Configure-Hook (_reflow ruft intern _move_indicator über _set_active)
            except Exception:
                pass
            self._menu_bar_created = True
            # Initialen Kontext aktualisieren
            try:
                self._update_menu_context()
            except Exception:
                pass
        except Exception as e:
            try:
                self.logger.debug(f"Menüband Fehler: {e}")
            except Exception:
                pass

    def _open_menu_customize_dialog(self):
        """Dialog zur Anpassung der Menü-Reihenfolge (drag-free via Up/Down)."""
        """Dialog zur Anpassung der Menü-Reihenfolge.

        Up/Down Buttons bleiben als Tastatur-/Fallback-Lösung erhalten.
        Ergänzt um einfaches Drag & Drop (vertikal) zur schnelleren Reorganisation.
        Bei Fehlern fällt das System still auf die Buttons zurück (Robustheit).
        """
        try:
            dlg = ctk.CTkToplevel(self.root)
            dlg.title('Menü anpassen')
            dlg.geometry('380x420')
            frame = ctk.CTkFrame(dlg, fg_color=self.get_color('surface'))
            frame.pack(fill='both', expand=True, padx=14, pady=14)
            order = [k for k in self._menu_buttons.keys()]
            list_container = ctk.CTkScrollableFrame(frame, fg_color=self.get_color('surface'))
            list_container.pack(fill='both', expand=True)
            row_widgets = []
            # Verlauf für Undo (nur innerhalb dieses Dialogs)
            if not hasattr(self, '_menu_order_history'):
                self._menu_order_history = []  # type: ignore[attr-defined]
            self._menu_order_history.append(list(order))  # Startzustand merken
            drag_state = {'key': None, 'last_saved_order': list(order), 'placeholder': None}
            def _rebuild_rows():
                for w in row_widgets:
                    try:
                        w.destroy()
                    except Exception as e:
                        self._record_suppressed_error('ui.menu.customize.row_cleanup', e)
                row_widgets.clear()
                for k in order:
                    meta = self._menu_meta.get(k, {})
                    row = ctk.CTkFrame(list_container, fg_color=self.get_color('surface'))
                    row.pack(fill='x', pady=2)
                    label = ctk.CTkLabel(row, text=meta.get('label', k), anchor='w')
                    label.pack(side='left', padx=6, pady=6, expand=True, fill='x')
                    def _make_move(delta, key=k):
                        def _do():
                            try:
                                idx = order.index(key)
                                new = idx+delta
                                if 0 <= new < len(order):
                                    order[idx], order[new] = order[new], order[idx]
                                    _rebuild_rows()
                            except Exception as e:
                                self._record_suppressed_error('ui.menu.customize.reorder', e)
                        return _do
                    up_btn = self._create_button(row, text='↑', command=_make_move(-1), kind='secondary', height=26, size='sm')
                    up_btn.pack(side='right', padx=(4,2))
                    down_btn = self._create_button(row, text='↓', command=_make_move(1), kind='secondary', height=26, size='sm')
                    down_btn.pack(side='right', padx=(2,6))
                    # Drag & Drop (optional)
                    try:
                        row._menu_key = k  # type: ignore[attr-defined]
                        def _on_press(e, key=k, r=row):  # noqa: ANN001
                            drag_state['key'] = key
                            try:
                                r.configure(fg_color=self.get_color('surface_hover'))
                            except Exception as ex_press_color:
                                try:
                                    self._record_suppressed_error('ui.menu.customize.drag.press', ex_press_color)
                                except Exception:
                                    pass
                        def _on_motion(e, key=k):  # noqa: ANN001
                            if drag_state.get('key') != key:
                                return
                            try:
                                mouse_y = e.y_root - list_container.winfo_rooty()
                                positions = []
                                for rw in row_widgets:
                                    try:
                                        positions.append((rw._menu_key, rw.winfo_y()+rw.winfo_height()/2))  # type: ignore[attr-defined]
                                    except Exception as ex_positions:
                                        try:
                                            self._record_suppressed_error('ui.menu.customize.drag.motion.positions', ex_positions)
                                        except Exception:
                                            pass
                                        continue
                                positions.sort(key=lambda x: x[1])
                                key_list = [p[0] for p in positions]
                                current_index = key_list.index(key)
                                target_index = current_index
                                for idx,(kk,mid) in enumerate(positions):
                                    if mouse_y < mid:
                                        target_index = idx
                                        break
                                else:
                                    target_index = len(positions)-1
                                if target_index != current_index:
                                    item = order.pop(current_index)
                                    order.insert(target_index, item)
                                    _rebuild_rows()
                                # Ziel-Reihe visuell hervorheben
                                try:
                                    for rw in row_widgets:
                                        if getattr(rw, '_menu_key', None) == order[target_index]:
                                            rw.configure(border_width=1, border_color=self.get_color('primary'))
                                        else:
                                            rw.configure(border_width=0)
                                except Exception as ex_highlight:
                                    try:
                                        self._record_suppressed_error('ui.menu.customize.drag.motion.highlight', ex_highlight)
                                    except Exception:
                                        pass
                            except Exception as ex_motion_outer:
                                try:
                                    self._record_suppressed_error('ui.menu.customize.drag.motion.outer', ex_motion_outer)
                                except Exception:
                                    pass
                        def _on_release(e, key=k, r=row):  # noqa: ANN001
                            if drag_state.get('key') == key:
                                drag_state['key'] = None
                            try:
                                r.configure(fg_color=self.get_color('surface'))
                            except Exception as ex_release_color:
                                try:
                                    self._record_suppressed_error('ui.menu.customize.drag.release.color', ex_release_color)
                                except Exception:
                                    pass
                            # Rahmen zurücksetzen
                            try:
                                for rw in row_widgets:
                                    rw.configure(border_width=0)
                            except Exception as ex_release_reset:
                                try:
                                    self._record_suppressed_error('ui.menu.customize.drag.release.reset', ex_release_reset)
                                except Exception:
                                    pass
                            # Sofort speichern & Menü neu aufbauen (Auto-Persist)
                            try:
                                if order != drag_state.get('last_saved_order') and hasattr(self,'settings_service') and self.settings_service:
                                    self.settings_service.set('menu.order', order)
                                    drag_state['last_saved_order'] = list(order)
                                    # Live-Rebuild (nicht blockierend)
                                    self.root.after(150, self._rebuild_menu_bar)
                            except Exception as ex_release_persist:
                                try:
                                    self._record_suppressed_error('ui.menu.customize.drag.release.persist', ex_release_persist)
                                except Exception:
                                    pass
                                pass
                        for _w in (row, label):
                            try:
                                _w.bind('<Button-1>', _on_press)
                                _w.bind('<B1-Motion>', _on_motion)
                                _w.bind('<ButtonRelease-1>', _on_release)
                            except Exception:
                                pass
                    except Exception:
                        pass
                    row_widgets.append(row)
            _rebuild_rows()
            def _save():
                try:
                    if hasattr(self,'settings_service') and self.settings_service:
                        self.settings_service.set('menu.order', order)
                    self.show_toast('Menü gespeichert', 'success')
                    dlg.destroy()
                    # Rebuild sofort
                    self._rebuild_menu_bar()
                except Exception:
                    dlg.destroy()
            buttons_row = ctk.CTkFrame(frame, fg_color='transparent')
            buttons_row.pack(fill='x', pady=(10,0))
            def _undo():
                try:
                    if hasattr(self, '_menu_order_history') and self._menu_order_history:
                        # Letzten gespeicherten Zustand (vor dem aktuellen) wiederherstellen
                        if len(self._menu_order_history) >= 2:
                            self._menu_order_history.pop()  # aktuellen verwerfen
                            prev = self._menu_order_history[-1]
                            order[:] = list(prev)
                            drag_state['last_saved_order'] = list(order)
                            _rebuild_rows()
                            self.show_toast('Menü-Reihenfolge zurückgesetzt', 'info')
                            # Persist & Rebuild
                            if hasattr(self,'settings_service') and self.settings_service:
                                self.settings_service.set('menu.order', order)
                            self.root.after(100, self._rebuild_menu_bar)
                except Exception:
                    pass
            undo_btn = self._create_button(buttons_row, text='Undo', command=_undo, kind='secondary', height=32, size='sm')
            undo_btn.pack(side='left')
            # Reset auf Default-Reihenfolge
            def _reset_defaults():  # noqa: D401
                try:
                    # Upload entfernt – neue Standardreihenfolge ohne Upload
                    defaults = ['home','projects','base','settings']
                    order[:] = [k for k in defaults if k in order]
                    drag_state['last_saved_order'] = list(order)
                    _rebuild_rows()
                    if hasattr(self,'settings_service') and self.settings_service:
                        self.settings_service.set('menu.order', order)
                    self.show_toast('Standardreihenfolge geladen', 'info')
                    self.root.after(120, self._rebuild_menu_bar)
                except Exception:
                    pass
            reset_btn = self._create_button(buttons_row, text='Reset', command=_reset_defaults, kind='secondary', height=32, size='sm')
            reset_btn.pack(side='left', padx=(8,0))
            save_btn = self._create_button(buttons_row, text='Speichern (manuell)', command=_save, kind='primary', height=34)
            save_btn.pack(side='right')
            # Shortcut Ctrl+Z im Dialog
            try:
                dlg.bind_all('<Control-z>', lambda e: _undo())
                dlg.bind('<Escape>', lambda e: dlg.destroy())
                # Optionaler eigener Schließen-Button oben rechts
                try:
                    top_close = self._create_button(frame, text='Schließen', command=lambda: dlg.destroy(), kind='secondary', height=30, size='sm')
                    top_close.pack(side='bottom', pady=(8,0))
                except Exception:
                    pass
            except Exception:
                pass
        except Exception:
            pass

    def _rebuild_menu_bar(self):
        """Zerstört aktuelles Menüband und erzeugt es neu (z.B. nach Anpassung)."""
        try:
            if getattr(self,'_menu_bar_frame', None):
                try:
                    self._menu_bar_frame.destroy()
                except Exception:
                    pass
            self._menu_bar_created = False
            # Reflow-Binding bleibt global bestehen (_menu_reflow_bound), kein weiteres Bind hier
            self._create_menu_bar()
        except Exception:
            pass

    # ---------------- MENU USAGE TRACKING (Additiv) -----------------
    def _record_menu_usage(self, key: str):  # noqa: D401
        """Interne Nutzungsstatistik für Ranking in Command-Palette.
        Speichert nur In-Memory (Session-basiert), beeinflusst keine bestehende Logik.
        Struktur: self._menu_usage = { key: { 'count': int, 'last': timestamp } }
        """
        try:
            if not hasattr(self, '_menu_usage'):
                self._menu_usage = {}
            entry = self._menu_usage.get(key)
            now = time.time()
            if entry:
                entry['count'] = min(entry.get('count',0)+1, 9999)
                entry['last'] = now
            else:
                self._menu_usage[key] = {'count': 1, 'last': now}
        except Exception:
            pass

    def _get_menu_usage_snapshot(self):  # noqa: D401
        """Gibt eine defensive Kopie der Usage-Daten zurück (für spätere Persist-Ideen)."""
        try:
            if hasattr(self, '_menu_usage'):
                return {k: dict(v) for k,v in self._menu_usage.items()}
        except Exception:
            pass
        return {}

    def _update_menu_context(self):
        """Aktualisiert dynamische Eigenschaften (Disable/Badges)."""
        try:
            # Upload Button disable wenn kein Kunde gewählt und keine Kunden vorhanden
            upload_btn = self._menu_buttons.get('upload', {}).get('widget')
            if upload_btn:
                customers_exist = False
                try:
                    import os
                    base = getattr(self, 'projects_base_path', 'Checker_Projekte')
                    if os.path.isdir(base):
                        for entry in os.scandir(base):
                            if entry.is_dir():
                                customers_exist = True
                                break
                except Exception:
                    pass
                state = 'normal' if (customers_exist or getattr(self, 'current_customer', None)) else 'disabled'
                try:
                    upload_btn.configure(state=state)
                except Exception:
                    pass
            # Projektanzahl Badge
            proj_btn = self._menu_buttons.get('projects', {}).get('widget')
            if proj_btn:
                try:
                    count = 0
                    base = getattr(self, 'projects_base_path', 'Checker_Projekte')
                    import os
                    if os.path.isdir(base):
                        count = sum(1 for e in os.scandir(base) if e.is_dir())
                    base_text = self._menu_buttons['projects']['base_text']
                    proj_btn.configure(text=f"{base_text} ({count})" if count else base_text)
                except Exception:
                    pass
        except Exception:
            pass
    
    def _create_main_layout(self):
        """Create professional 2-panel layout with enhanced styling."""
        try:
            self.main_container = ctk.CTkFrame(
                self.root, 
                fg_color=self.get_color('transparent')
            )
            self.main_container.pack(fill="both", expand=True, 
                                   padx=self.get_spacing('card_margin'), 
                                   pady=self.get_spacing('sm'))
            
            # Professional grid configuration with better proportions
            self.main_container.grid_columnconfigure(0, weight=2)  # Left panel slightly smaller
            self.main_container.grid_columnconfigure(1, weight=3)  # Right panel slightly larger
            self.main_container.grid_rowconfigure(0, weight=1)
            
            # Professional left panel with enhanced styling
            self.left_panel = ctk.CTkFrame(
                self.main_container, 
                fg_color=self.get_color('surface'),
                corner_radius=self.get_component_value('borders.radius_lg', 8),
                border_width=1,
                border_color=self.get_color('surface_border')
            )
            self.left_panel.grid(row=0, column=0, sticky="nsew", 
                               padx=(0, self.get_spacing('sm')), pady=0)
            
            # Professional right panel with enhanced styling
            self.right_panel = ctk.CTkFrame(
                self.main_container, 
                fg_color=self.get_color('surface'),
                corner_radius=self.get_component_value('borders.radius_lg', 8),
                border_width=1,
                border_color=self.get_color('surface_border')
            )
            self.right_panel.grid(row=0, column=1, sticky="nsew", 
                                padx=(self.get_spacing('sm'), 0), pady=0)
            
            self._setup_left_panel()
            self._setup_right_panel()
            
        except Exception as e:
            self._handle_error(e, context="layout.main.professional", 
                             user_message=self._t("Professional layout could not be created") if hasattr(self, '_t') else "Professionelles Layout konnte nicht erstellt werden")
    
    def _setup_left_panel(self):
        """ENHANCED: Setup professional left panel with modern design elements"""
        try:
            # Clear existing content
            for widget in self.left_panel.winfo_children():
                widget.destroy()
            
            # PROFESSIONAL HEADER with enhanced visual hierarchy
            header_frame = ctk.CTkFrame(
                self.left_panel,
                fg_color=self.get_color('primary'),
                height=self.get_component_value('heights.section_header', 64),
                corner_radius=0
            )
            header_frame.pack(fill='x')
            header_frame.pack_propagate(False)
            
            header_content = ctk.CTkFrame(header_frame, fg_color='transparent')
            header_content.pack(fill='both', expand=True, padx=self.get_spacing('card_padding'), pady=self.get_spacing('sm'))
            
            title_label = ctk.CTkLabel(
                header_content,
                text='Qualitäts-Framework Professional',
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self.get_color('white')
            )
            title_label.pack(anchor='w')
            
            subtitle_label = ctk.CTkLabel(
                header_content,
                text='Erweiterte Qualitätskontrolle & Analyse',
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('gray_200')
            )
            subtitle_label.pack(anchor='w', pady=(2,0))
            
            # MAIN CONTENT with professional spacing
            content_frame = ctk.CTkScrollableFrame(
                self.left_panel,
                fg_color=self.get_color('background'),
                corner_radius=0,
                scrollbar_button_color=self.get_color('primary'),
                scrollbar_button_hover_color=self.get_color('primary_hover')
            )
            content_frame.pack(fill="both", expand=True, padx=0, pady=0)
            
            # Add professional spacing at top
            top_spacer = ctk.CTkFrame(content_frame, fg_color="transparent", height=self.get_spacing('section_spacing'))
            top_spacer.pack(fill="x")
            
            # PROFESSIONAL WORKFLOW SECTIONS with enhanced spacing:
            # 1️⃣ STEP 1: File Upload & Management  
            self._create_upload_section(content_frame)
            
            # Professional section separator
            section_spacer1 = ctk.CTkFrame(content_frame, fg_color="transparent", height=self.get_spacing('section_spacing'))
            section_spacer1.pack(fill="x")
            
            # 2️⃣ STEP 2: Analysis with improved design
            self._create_analysis_section(content_frame)
            
            # Professional section separator
            section_spacer2 = ctk.CTkFrame(content_frame, fg_color="transparent", height=self.get_spacing('section_spacing'))
            section_spacer2.pack(fill="x")
            
            # 3️⃣ STEP 3: Actions & Operations with modern styling
            self._create_actions_section(content_frame)
            
            # Final professional spacing
            bottom_spacer = ctk.CTkFrame(content_frame, fg_color="transparent", height=self.get_spacing('loose_spacing'))
            bottom_spacer.pack(fill="x")
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.left_panel.professional",
                user_message=self._t("Professional left panel creation failed") if hasattr(self, '_t') else "Professionelle linke Seite konnte nicht aufgebaut werden"
            )
            # Create minimal fallback
            self._create_minimal_left_panel()
    
    def _create_minimal_left_panel(self):
        """FALLBACK: Minimal left panel when full setup fails"""
        try:
            # Simple title
            title = ctk.CTkLabel(
                self.left_panel,
                text="Quality Framework",
                font=ctk.CTkFont(*self.get_typography('subtitle_unified')),
                text_color=self.get_color('primary')
            )
            title.pack(pady=20)
            
            # Basic upload button
            # Vereinheitlicht über zentrale Button-Factory
            upload_btn = self._create_button(
                self.left_panel,
                text=self._t("Dateien hochladen") if hasattr(self,'_t') else "Dateien hochladen",
                command=self._upload_source_files,
                kind="primary",
                height=40
            )
            upload_btn.pack(pady=10, padx=20, fill="x")
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.left_panel.minimal",
                user_message=self._t("Minimal left panel creation failed") if hasattr(self, '_t') else "Linke Minimal-Leiste konnte nicht erstellt werden"
            )
    
    def _create_upload_section(self, parent):
        """STEP 1: Professional File Upload & Management Section"""
        try:
            # Professional spacing using design system
            spacing_lg = self.get_spacing('section_spacing')
            spacing_md = self.get_spacing('element_spacing') 
            spacing_sm = self.get_spacing('tight_spacing')

            # Professional container with enhanced styling
            section_container = ctk.CTkFrame(parent, fg_color='transparent')
            section_container.pack(fill='x', padx=self.get_spacing('card_margin'), pady=(0, spacing_lg))

            # Professional section header
            header_frame = self.create_section_header(
                section_container, 
                title="Datei-Upload & Management",
                subtitle="Professionelle Dateiverwaltung für Qualitätsanalysen",
                color_accent='primary'
            )
            header_frame.pack(fill='x', pady=(0, spacing_md))

            # Professional main card with enhanced design
            upload_card = self.create_professional_card(
                section_container,
                title="",  # No title needed as we have section header
                content_padding=self.get_spacing('card_padding')
            )
            upload_card.pack(fill='x')

            # Professional status bar with modern design
            status_frame = ctk.CTkFrame(
                upload_card,
                fg_color=self.get_color('gray_50'),
                corner_radius=6,
                height=40
            )
            status_frame.pack(fill='x', padx=self.get_spacing('card_padding'), 
                            pady=(self.get_spacing('card_padding'), spacing_md))
            status_frame.pack_propagate(False)
            status_frame.grid_columnconfigure(0, weight=1)

            # Status indicator with professional styling
            self.upload_status_label = ctk.CTkLabel(
                status_frame,
                text=self._t("Bereit für Datei-Upload") if hasattr(self, '_t') else "Bereit für Datei-Upload",
                font=ctk.CTkFont(*self.get_typography('label')),
                text_color=self.get_color('text_secondary'),
                anchor='w'
            )
            self.upload_status_label.grid(row=0, column=0, sticky='w', padx=16, pady=8)

            # Professional counter badge
            self.upload_combined_badge = ctk.CTkLabel(
                status_frame,
                text="● Dateien: 0",
                font=ctk.CTkFont(*self.get_typography('counter')),
                text_color=self.get_color('primary'),
                fg_color=self.get_color('primary_light'),
                corner_radius=12,
                padx=12,
                pady=4
            )
            self.upload_combined_badge.grid(row=0, column=1, sticky='e', padx=16, pady=6)

            # Professional upload actions grid
            actions_frame = ctk.CTkFrame(upload_card, fg_color='transparent')
            actions_frame.pack(fill='x', padx=self.get_spacing('card_padding'), 
                             pady=(0, self.get_spacing('card_padding')))
            
            # Configure grid for professional layout
            for i in range(2):  # 2 columns for better layout
                actions_frame.grid_columnconfigure(i, weight=1, uniform='upload_buttons')

            # Primary action buttons with professional styling
            # QUELLTEXT HOCHLADEN (ohne Emoji – Repo-Richtlinie: keine Icons im Text)
            source_btn = self.create_professional_button(
                actions_frame,
                text=self._t("Quelltexte hochladen") if hasattr(self, '_t') else "Quelltexte hochladen",
                style='primary',
                size='lg',
                command=self._upload_source_files
            )
            source_btn.grid(row=0, column=0, sticky='ew', padx=(0, spacing_sm), pady=(0, spacing_sm))

            translation_btn = self.create_professional_button(
                actions_frame,
                text=self._t("Übersetzungen hochladen") if hasattr(self, '_t') else "Übersetzungen hochladen", 
                style='primary',
                size='lg',
                command=self._upload_translation_files
            )
            translation_btn.grid(row=0, column=1, sticky='ew', padx=(spacing_sm, 0), pady=(0, spacing_sm))

            # Secondary action buttons 
            pair_btn = self.create_professional_button(
                actions_frame,
                text=self._t("Dateien verknüpfen") if hasattr(self, '_t') else "Dateien verknüpfen",
                style='secondary', 
                size='md',
                command=self._start_file_pairing_wizard
            )
            pair_btn.grid(row=1, column=0, sticky='ew', padx=(0, spacing_sm), pady=(0, spacing_sm))

            manage_btn = self.create_professional_button(
                actions_frame,
                text=self._t("Dateien verwalten") if hasattr(self, '_t') else "Dateien verwalten",
                style='secondary',
                size='md', 
                command=self._show_file_management
            )
            manage_btn.grid(row=1, column=1, sticky='ew', padx=(spacing_sm, 0), pady=(0, spacing_sm))

            # Professional file list with modern design (if files exist)
            self._create_professional_file_list(upload_card)

            # ---------------------------------------------
            # PROFESSIONELLE PAIRING-KARTE (Status & Aktionen)
            # ---------------------------------------------
            try:
                pairing_card = self.create_professional_card(
                    section_container,
                    title=self._t("Dateipaarung") if hasattr(self,'_t') else "Dateipaarung",
                    content_padding=self.get_spacing('card_padding')
                )
                pairing_card.pack(fill='x', pady=(spacing_md, 0))

                pairing_inner = ctk.CTkFrame(pairing_card, fg_color='transparent')
                pairing_inner.pack(fill='x')
                pairing_inner.grid_columnconfigure(0, weight=1)
                pairing_inner.grid_columnconfigure(1, weight=0)

                # Status Label
                self.pairing_status_label = ctk.CTkLabel(
                    pairing_inner,
                    text=self._t("Keine Paare konfiguriert") if hasattr(self,'_t') else "Keine Paare konfiguriert",
                    font=ctk.CTkFont(*self.get_typography('body')),
                    text_color=self.get_color('text_secondary'),
                    anchor='w'
                )
                self.pairing_status_label.grid(row=0, column=0, sticky='w', pady=(0, spacing_sm))

                # Button-Reihe
                btn_row = ctk.CTkFrame(pairing_inner, fg_color='transparent')
                btn_row.grid(row=1, column=0, columnspan=2, sticky='ew')
                btn_row.grid_columnconfigure(0, weight=1)
                btn_row.grid_columnconfigure(1, weight=1)

                # Automatische Aktualisierung
                auto_btn = self.create_professional_button(
                    btn_row,
                    text=self._t("Automatisch abgleichen") if hasattr(self,'_t') else "Automatisch abgleichen",
                    style='secondary',
                    size='sm',
                    command=lambda: (self._smart_file_pairing(), self._update_pairing_status_display())
                )
                auto_btn.grid(row=0, column=0, sticky='ew', padx=(0, spacing_sm), pady=(0, spacing_sm))

                # Manuelle Paarung öffnen
                manual_btn = self.create_professional_button(
                    btn_row,
                    text=self._t("Manuell anpassen") if hasattr(self,'_t') else "Manuell anpassen",
                    style='secondary',
                    size='sm',
                    command=self._show_manual_pairing_dialog
                )
                manual_btn.grid(row=0, column=1, sticky='ew', padx=(spacing_sm, 0), pady=(0, spacing_sm))

                # Initialer Status falls bereits Paare existieren
                try:
                    self._update_pairing_status_display()
                except Exception:
                    pass
            except Exception as pairing_card_ex:
                try:
                    self._record_suppressed_error('ui.pairing.card', pairing_card_ex)
                except Exception:
                    pass

        except Exception as e:
            self._handle_error(
                e,
                context="ui.upload_section.professional",
                user_message=self._t("Professional upload section creation failed") if hasattr(self, '_t') else "Professioneller Upload-Bereich konnte nicht erstellt werden"
            )

    def _create_professional_file_list(self, parent):
        """Creates a professional file list display if files exist."""
        try:
            # Only show if files exist
            total_files = len(self.uploaded_files.get('source', [])) + len(self.uploaded_files.get('translation', []))
            if total_files == 0:
                return

            # Professional file list header
            list_header = ctk.CTkFrame(
                parent,
                fg_color=self.get_color('primary'),
                height=40,
                corner_radius=6
            )
            list_header.pack(fill='x', padx=self.get_spacing('card_padding'), 
                           pady=(self.get_spacing('element_spacing'), self.get_spacing('tight_spacing')))
            list_header.pack_propagate(False)

            header_label = ctk.CTkLabel(
                list_header,
                text=f"📁 Hochgeladene Dateien ({total_files})",
                font=ctk.CTkFont(*self.get_typography('label')),
                text_color=self.get_color('white')
            )
            header_label.pack(pady=8)

            # Professional file list content
            list_frame = ctk.CTkFrame(
                parent,
                fg_color=self.get_color('gray_50'),
                corner_radius=6
            )
            list_frame.pack(fill='x', padx=self.get_spacing('card_padding'), 
                          pady=(0, self.get_spacing('card_padding')))

            # Display source files
            if self.uploaded_files.get('source'):
                source_label = ctk.CTkLabel(
                    list_frame,
                    text="📄 Quelltexte:",
                    font=ctk.CTkFont(*self.get_typography('label')),
                    text_color=self.get_color('primary')
                )
                source_label.pack(anchor='w', padx=16, pady=(12, 4))
                
                for file in self.uploaded_files['source'][:3]:  # Show max 3 files
                    file_label = ctk.CTkLabel(
                        list_frame,
                        text=f"  • {os.path.basename(file)}",
                        font=ctk.CTkFont(*self.get_typography('body_sm')),
                        text_color=self.get_color('text_secondary')
                    )
                    file_label.pack(anchor='w', padx=32, pady=1)
                
                if len(self.uploaded_files['source']) > 3:
                    more_label = ctk.CTkLabel(
                        list_frame,
                        text=f"  ... und {len(self.uploaded_files['source']) - 3} weitere",
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        text_color=self.get_color('text_secondary')
                    )
                    more_label.pack(anchor='w', padx=32, pady=2)

            # Display translation files
            if self.uploaded_files.get('translation'):
                translation_label = ctk.CTkLabel(
                    list_frame,
                    text="📝 Übersetzungen:",
                    font=ctk.CTkFont(*self.get_typography('label')),
                    text_color=self.get_color('primary')
                )
                translation_label.pack(anchor='w', padx=16, pady=(8, 4))
                
                for file in self.uploaded_files['translation'][:3]:  # Show max 3 files
                    file_label = ctk.CTkLabel(
                        list_frame,
                        text=f"  • {os.path.basename(file)}",
                        font=ctk.CTkFont(*self.get_typography('body_sm')),
                        text_color=self.get_color('text_secondary')
                    )
                    file_label.pack(anchor='w', padx=32, pady=1)
                
                if len(self.uploaded_files['translation']) > 3:
                    more_label = ctk.CTkLabel(
                        list_frame,
                        text=f"  ... und {len(self.uploaded_files['translation']) - 3} weitere",
                        font=ctk.CTkFont(*self.get_typography('caption')),
                        text_color=self.get_color('text_secondary')
                    )
                    more_label.pack(anchor='w', padx=32, pady=2)

            # Add padding at bottom
            ctk.CTkFrame(list_frame, fg_color='transparent', height=12).pack()

        except Exception as e:
            # Silent fallback - don't show file list if there's an error
            pass

    def _show_professional_welcome_output(self):
        """PROFESSIONAL: Advanced welcome dashboard with modern design system"""
        try:
            # Clear existing content
            for widget in self.output_frame.winfo_children():
                widget.destroy()
            
            # Add professional spacing at top
            top_spacer = ctk.CTkFrame(self.output_frame, fg_color="transparent", 
                                    height=self.get_spacing('section_spacing'))
            top_spacer.pack(fill="x")
            
            # Professional welcome cards with enhanced design
            self._create_professional_welcome_cards()
            
            # Professional metrics dashboard
            self._create_professional_metrics_section()
            
            # Professional quick actions
            self._create_professional_quick_actions()
            
            # Add professional spacing at bottom
            bottom_spacer = ctk.CTkFrame(self.output_frame, fg_color="transparent", 
                                       height=self.get_spacing('loose_spacing'))
            bottom_spacer.pack(fill="x")
            
        except Exception as e:
            self._handle_error(
                e,
                context="ui.welcome.professional", 
                user_message=self._t("Professional welcome display failed") if hasattr(self, '_t') else "Professioneller Willkommensbereich konnte nicht erstellt werden"
            )
            # Fallback to basic welcome
            try:
                self._show_enhanced_welcome_output()
            except:
                pass

    def _create_professional_welcome_cards(self):
        """Create professional welcome cards with modern styling."""
        try:
            # Main welcome card
            welcome_card = self.create_professional_card(
                self.output_frame,
                title="Willkommen zum Quality Framework Professional",
                content_padding=self.get_spacing('card_padding')
            )
            welcome_card.pack(fill="x", padx=self.get_spacing('card_margin'), 
                            pady=(0, self.get_spacing('element_spacing')))
            
            # Content area
            content_area = ctk.CTkFrame(welcome_card, fg_color="transparent")
            content_area.pack(fill="x", padx=self.get_spacing('card_padding'), 
                            pady=(self.get_spacing('element_spacing'), self.get_spacing('card_padding')))
            
            # Welcome message with professional typography
            welcome_text = """
Professionelles Übersetzungsqualitäts-Framework

• Erweiterte Qualitätsanalyse mit KI-gestützten Metriken
• Automatisierte Berichtsgenerierung und Exportfunktionen  
• Modernste Benutzeroberfläche mit optimiertem Workflow
• Unterstützung für umfangreiche Dateiformate und Sprachen

Beginnen Sie mit dem Upload Ihrer Dateien im linken Bereich.
            """.strip()
            
            welcome_label = ctk.CTkLabel(
                content_area,
                text=welcome_text,
                font=ctk.CTkFont(*self.get_typography('body_md')),
                text_color=self.get_color('text_primary'),
                justify="left",
                anchor="w"
            )
            welcome_label.pack(fill="x", anchor="w")
            
        except Exception:
            pass

    def _create_professional_metrics_section(self):
        """Create professional metrics section."""
        try:
            metrics_card = self.create_professional_card(
                self.output_frame,
                title="System-Status & Metriken",
                content_padding=self.get_spacing('card_padding')
            )
            metrics_card.pack(fill="x", padx=self.get_spacing('card_margin'), 
                            pady=(0, self.get_spacing('element_spacing')))
            
            # Metrics content grid
            metrics_content = ctk.CTkFrame(metrics_card, fg_color="transparent")
            metrics_content.pack(fill="x", padx=self.get_spacing('card_padding'), 
                               pady=(self.get_spacing('element_spacing'), self.get_spacing('card_padding')))
            
            # Configure grid
            for i in range(3):
                metrics_content.grid_columnconfigure(i, weight=1, uniform='metrics')
            
            # Metric items with professional styling
            self._create_metric_item(metrics_content, "Dateien geladen", "0", 0, 0)
            self._create_metric_item(metrics_content, "Analysen durchgeführt", "0", 0, 1)
            self._create_metric_item(metrics_content, "Berichte erstellt", "0", 0, 2)
            
        except Exception:
            pass

    def _create_metric_item(self, parent, label: str, value: str, row: int, col: int):
        """Create a professional metric item."""
        try:
            metric_frame = ctk.CTkFrame(
                parent,
                fg_color=self.get_color('gray_50'),
                corner_radius=8
            )
            metric_frame.grid(row=row, column=col, sticky="ew", 
                            padx=self.get_spacing('tight_spacing'), 
                            pady=self.get_spacing('tight_spacing'))
            
            # Value label
            value_label = ctk.CTkLabel(
                metric_frame,
                text=value,
                font=ctk.CTkFont(*self.get_typography('heading_md')),
                text_color=self.get_color('primary')
            )
            value_label.pack(pady=(12, 2))
            
            # Label
            label_label = ctk.CTkLabel(
                metric_frame,
                text=label,
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('text_secondary')
            )
            label_label.pack(pady=(0, 12))
            
        except Exception:
            pass

    def _create_professional_quick_actions(self):
        """Create professional quick actions section."""
        try:
            actions_card = self.create_professional_card(
                self.output_frame,
                title="Schnellzugriff",
                content_padding=self.get_spacing('card_padding')
            )
            actions_card.pack(fill="x", padx=self.get_spacing('card_margin'), 
                            pady=(0, self.get_spacing('element_spacing')))
            
            # Actions grid
            actions_content = ctk.CTkFrame(actions_card, fg_color="transparent")
            actions_content.pack(fill="x", padx=self.get_spacing('card_padding'), 
                               pady=(self.get_spacing('element_spacing'), self.get_spacing('card_padding')))
            
            for i in range(2):
                actions_content.grid_columnconfigure(i, weight=1, uniform='actions')
            
            # Quick action buttons
            demo_btn = self.create_professional_button(
                actions_content,
                text="📊 Demo-Analyse starten",
                style='primary',
                size='md',
                command=self._show_demo_analysis
            )
            demo_btn.grid(row=0, column=0, sticky="ew", 
                         padx=(0, self.get_spacing('tight_spacing')),
                         pady=self.get_spacing('tight_spacing'))
            
            help_btn = self.create_professional_button(
                actions_content,
                text="❓ Hilfe & Dokumentation",
                style='secondary',
                size='md',
                command=self._show_help
            )
            help_btn.grid(row=0, column=1, sticky="ew", 
                         padx=(self.get_spacing('tight_spacing'), 0),
                         pady=self.get_spacing('tight_spacing'))
            
        except Exception:
            pass

    def _create_analysis_section(self, parent):
        """STEP 2: Professional Analysis Section with Configuration"""
        try:
            # Professional analysis section using design system
            section_container = ctk.CTkFrame(parent, fg_color='transparent')
            section_container.pack(fill='x', padx=self.get_spacing('card_margin'), 
                                 pady=(0, self.get_spacing('section_spacing')))

            # Professional section header
            header_frame = self.create_section_header(
                section_container,
                title="Qualitätsanalyse",
                subtitle="Erweiterte Analyse-Tools und Qualitätskriterien",
                color_accent='success'
            )
            header_frame.pack(fill='x', pady=(0, self.get_spacing('element_spacing')))

            # Analysis card with professional styling
            analysis_card = self.create_professional_card(
                section_container,
                title="",
                content_padding=self.get_spacing('card_padding')
            )
            analysis_card.pack(fill='x')

            # Status indicator
            status_frame = ctk.CTkFrame(
                analysis_card,
                fg_color=self.get_color('success_light'),
                height=32,
                corner_radius=6
            )
            status_frame.pack(fill='x', padx=self.get_spacing('card_padding'), 
                            pady=(self.get_spacing('card_padding'), self.get_spacing('element_spacing')))
            status_frame.pack_propagate(False)

            status_label = ctk.CTkLabel(
                status_frame,
                text="✓ Bereit",
                font=ctk.CTkFont(*self.get_typography('label')),
                text_color=self.get_color('success')
            )
            status_label.pack(pady=6)

            # Language configuration section
            config_frame = ctk.CTkFrame(analysis_card, fg_color='transparent')
            config_frame.pack(fill='x', padx=self.get_spacing('card_padding'), 
                            pady=(0, self.get_spacing('element_spacing')))

            # Language pair configuration
            lang_label = ctk.CTkLabel(
                config_frame,
                text="Sprachpaar-Konfiguration",
                font=ctk.CTkFont(*self.get_typography('label')),
                text_color=self.get_color('text_primary')
            )
            lang_label.pack(anchor='w', pady=(0, self.get_spacing('tight_spacing')))

            lang_grid = ctk.CTkFrame(config_frame, fg_color='transparent')
            lang_grid.pack(fill='x', pady=(0, self.get_spacing('element_spacing')))
            lang_grid.grid_columnconfigure(0, weight=1)
            lang_grid.grid_columnconfigure(1, weight=1)

            # Source language dropdown
            self.source_lang_combo = ctk.CTkComboBox(
                lang_grid,
                values=["Auto-detect", "Deutsch", "Englisch", "Französisch", "Spanisch", "Italienisch"],
                font=ctk.CTkFont(*self.get_typography('body_md')),
                dropdown_font=ctk.CTkFont(*self.get_typography('body_sm')),
                height=self.get_component_value('heights.input', 42),
                corner_radius=6,
                border_color=self.get_color('input_border'),
                button_color=self.get_color('primary'),
                button_hover_color=self.get_color('primary_hover')
            )
            self.source_lang_combo.set("Auto-detect")
            self.source_lang_combo.grid(row=0, column=0, sticky='ew', 
                                      padx=(0, self.get_spacing('tight_spacing')))

            # Target language dropdown  
            self.target_lang_combo = ctk.CTkComboBox(
                lang_grid,
                values=["German", "English", "French", "Spanish", "Italian"],
                font=ctk.CTkFont(*self.get_typography('body_md')),
                dropdown_font=ctk.CTkFont(*self.get_typography('body_sm')),
                height=self.get_component_value('heights.input', 42),
                corner_radius=6,
                border_color=self.get_color('input_border'),
                button_color=self.get_color('primary'),
                button_hover_color=self.get_color('primary_hover')
            )
            self.target_lang_combo.set("German")
            self.target_lang_combo.grid(row=0, column=1, sticky='ew',
                                      padx=(self.get_spacing('tight_spacing'), 0))

            # Quality criteria section
            criteria_label = ctk.CTkLabel(
                config_frame,
                text="Erweiterte Analyse",
                font=ctk.CTkFont(*self.get_typography('label')),
                text_color=self.get_color('text_primary')
            )
            criteria_label.pack(anchor='w', pady=(self.get_spacing('element_spacing'), self.get_spacing('tight_spacing')))

            criteria_text = ctk.CTkLabel(
                config_frame,
                text="Prüft Struktur, Stil, Terminologie, Semantik (optional)",
                font=ctk.CTkFont(*self.get_typography('caption')),
                text_color=self.get_color('text_secondary')
            )
            criteria_text.pack(anchor='w', pady=(0, self.get_spacing('tight_spacing')))

            # Analysis type selector
            analysis_frame = ctk.CTkFrame(config_frame, fg_color='transparent')
            analysis_frame.pack(fill='x', pady=(0, self.get_spacing('element_spacing')))

            self.analysis_combo = ctk.CTkComboBox(
                analysis_frame,
                values=["Standard Analyse", "Erweiterte Analyse", "Vollständige Analyse", "Custom Analyse"],
                font=ctk.CTkFont(*self.get_typography('body_md')),
                height=self.get_component_value('heights.input', 42),
                corner_radius=6,
                border_color=self.get_color('input_border'),
                button_color=self.get_color('success'),
                button_hover_color=self.get_color('success_hover')
            )
            self.analysis_combo.set("Standard Analyse")
            self.analysis_combo.pack(fill='x')

            # Quality check option
            self.quality_check_var = ctk.BooleanVar(value=True)
            quality_checkbox = ctk.CTkCheckBox(
                config_frame,
                text="Struktur-, Glossar- & Sicherheitscheck",
                variable=self.quality_check_var,
                font=ctk.CTkFont(*self.get_typography('body_sm')),
                text_color=self.get_color('text_primary'),
                fg_color=self.get_color('success'),
                hover_color=self.get_color('success_hover'),
                checkmark_color=self.get_color('white')
            )
            quality_checkbox.pack(anchor='w', pady=(self.get_spacing('tight_spacing'), self.get_spacing('element_spacing')))

            # Analysis actions with professional buttons
            actions_frame = ctk.CTkFrame(analysis_card, fg_color='transparent')
            actions_frame.pack(fill='x', padx=self.get_spacing('card_padding'), 
                             pady=(0, self.get_spacing('card_padding')))

            for i in range(2):
                actions_frame.grid_columnconfigure(i, weight=1, uniform='analysis_actions')

            # Primary analysis button
            analyze_btn = self.create_professional_button(
                actions_frame,
                text="🎯 Qualitätsanalyse starten",
                style='success',
                size='lg',
                command=self._start_comprehensive_analysis
            )
            analyze_btn.grid(row=0, column=0, sticky='ew', 
                           padx=(0, self.get_spacing('tight_spacing')), 
                           pady=(0, self.get_spacing('tight_spacing')))

            # Secondary analysis options
            options_btn = self.create_professional_button(
                actions_frame,
                text="⚙️ Analyse-Optionen",
                style='secondary',
                size='lg',
                command=self._show_analysis_options
            )
            options_btn.grid(row=0, column=1, sticky='ew', 
                           padx=(self.get_spacing('tight_spacing'), 0),
                           pady=(0, self.get_spacing('tight_spacing')))

        except Exception as e:
            self._handle_error(
                e,
                context="ui.analysis_section.professional",
                user_message=self._t("Professional analysis section creation failed") if hasattr(self, '_t') else "Professioneller Analyse-Bereich konnte nicht erstellt werden"
            )

    def _create_actions_section(self, parent):
        """STEP 3: Professional Actions & Operations Section"""
