            content_frame = ctk.CTkFrame(header_frame, fg_color="transparent")
            content_frame.pack(fill="both", expand=True, padx=16, pady=8)
            
            ctk.CTkLabel(
                content_frame,
                text=title,
                font=ctk.CTkFont(*self.get_typography('title')),
                text_color=self.get_color('text_primary'),
                anchor="w"
            ).pack(fill="x")
            
            if subtitle:
                ctk.CTkLabel(
                    content_frame,
                    text=subtitle,
                    font=ctk.CTkFont(*self.get_typography('caption')),
                    text_color=self.get_color('text_secondary'),
                    anchor="w"
                ).pack(fill="x", pady=(2, 0))
            
            return header_frame

    # ---------- SYSTEM / METRICS HELFER ----------
    def _collect_runtime_metrics(self):
        """Sammelt dynamische System-Metriken (CPU %, Anzahl Dateien, Queue, Response-Zeit placeholder)."""
        data = {
            'cpu_percent': None,
            'queued_files': 0,
            'response_ms': None,
            'sessions': 1,
            'memory_mb': None,
            'threads': None
        }
        try:
            import psutil  # optional
            try:
                # Sofortige Stichprobe ohne Block
                data['cpu_percent'] = psutil.cpu_percent(interval=0.0)
                try:
                    proc = psutil.Process()
                    data['memory_mb'] = round(proc.memory_info().rss / (1024*1024), 1)
                    data['threads'] = proc.num_threads()
                except Exception as ie:
                    self._dev_trace('metrics.proc', ie)
            except Exception as e:  # pragma: no cover - defensive
                self._dev_trace('metrics.cpu', e)
        except Exception as e:  # psutil nicht vorhanden
            self._dev_trace('metrics.psutil_missing', e)
        try:
            data['queued_files'] = len(self.uploaded_files.get('source', [])) + len(self.uploaded_files.get('translation', []))
        except Exception as e:
            self._dev_trace('metrics.queued_files', e)
        # Placeholder Response-Zeit Messung (kann später durch echte Messung ersetzt werden)
        try:
            data['response_ms'] = getattr(self, '_last_response_ms', None)
        except Exception as e:
            self._dev_trace('metrics.response', e)
        return data

    # ---------- DEV / DIAGNOSTIC HELFER ----------
    def _dev_trace(self, context: str, e: Exception | str):  # leichte zentrale Debug-Ausgabe statt pass
        if not getattr(self, 'development_mode', True):
            return
        try:
            msg = e if isinstance(e, str) else f"{e.__class__.__name__}: {e}"
            if hasattr(self, 'logger'):
                self.logger.debug(f"[DEV:{context}] {msg}")
        except Exception as ex:
            try:
                self._record_suppressed_error('dev.trace.emit', ex)
            except Exception:
                pass

    def _register_metric_labels(self, mapping: dict):
        try:
            self._metrics_labels = mapping  # {'files': label, 'sessions': label, ...}
        except Exception as e:
            self._dev_trace('metrics.register', e)

    def _start_metrics_refresh(self):
        try:
            if not getattr(self, '_metrics_labels', None):
                return
            # Einzige zentrale Schleife – 5s Interval (konfigurierbar)
            interval = getattr(self, 'METRICS_REFRESH_MS', None)
            if interval is None:
                # Lazy Konfig-Ladung
                interval = 5000
                try:
                    from config_manager import ConfigManager  # type: ignore
                    cfg = ConfigManager()
                    val = cfg.get('metrics.refresh_ms', 5000)
                    if isinstance(val, int) and 500 <= val <= 60000:
                        interval = val
                    self.METRICS_REFRESH_MS = interval
                except Exception as e:
                    self._dev_trace('metrics.config.interval', e)
            else:
                try:
                    interval = int(interval)
                except Exception:
                    interval = 5000
            if getattr(self, '_metrics_refresh_active', False):
                # bereits aktiv
                return
            self._metrics_refresh_active = True
            self._schedule_metrics_update(interval)
        except Exception as e:
            self._dev_trace('metrics.start_refresh', e)

    def _schedule_metrics_update(self, interval: int):
        try:
            if not getattr(self, 'root', None):
                return
            self.root.after(interval, self._update_metrics_values)
        except Exception as e:
            self._dev_trace('metrics.schedule', e)

    def _update_metrics_values(self):
        try:
            if not getattr(self, '_metrics_labels', None):
                return
            m = self._collect_runtime_metrics()
            lbls = self._metrics_labels
            # Aktualisierung – defensive Checks
            try:
                if 'files' in lbls and lbls['files']:
                    lbls['files'].configure(text=str(m.get('queued_files') or 0))
            except Exception as e:
                self._dev_trace('metrics.update.files', e)
            try:
                if 'sessions' in lbls and lbls['sessions']:
                    lbls['sessions'].configure(text=str(m.get('sessions') or 1))
            except Exception as e:
                self._dev_trace('metrics.update.sessions', e)
            try:
                cpu = m.get('cpu_percent')
                cpu_txt = (f"{cpu:.0f}% CPU" if isinstance(cpu, (int,float)) else self._tr("CPU n/a"))
                if 'cpu' in lbls and lbls['cpu']:
                    lbls['cpu'].configure(text=cpu_txt)
            except Exception as e:
                self._dev_trace('metrics.update.cpu', e)
            try:
                resp = m.get('response_ms')
                if isinstance(resp,(int,float)):
                    resp_txt = f"{resp} ms" if resp < 1000 else f"{resp/1000:.2f} s"
                else:
                    resp_txt = self._tr("Latenz n/a")
                if 'latency' in lbls and lbls['latency']:
                    lbls['latency'].configure(text=resp_txt)
            except Exception as e:
                self._dev_trace('metrics.update.latency', e)
            try:
                mem = m.get('memory_mb')
                if 'memory' in lbls and lbls['memory']:
                    lbls['memory'].configure(text=(f"{mem:.1f} MB" if isinstance(mem,(int,float)) else self._tr("RAM n/a")))
            except Exception as e:
                self._dev_trace('metrics.update.memory', e)
            try:
                th = m.get('threads')
                if 'threads' in lbls and lbls['threads']:
                    lbls['threads'].configure(text=(str(th) if isinstance(th,int) else self._tr("Threads n/a")))
            except Exception as e:
                self._dev_trace('metrics.update.threads', e)
        finally:
            # Re-Scheduling (falls Root noch existiert)
            try:
                if getattr(self, 'root', None) and getattr(self, '_metrics_refresh_active', False):
                    interval = getattr(self, 'METRICS_REFRESH_MS', 5000)
                    self._schedule_metrics_update(interval)
            except Exception as e:
                self._dev_trace('metrics.reschedule', e)

    # ---------- PROJECT STATUS MARKER HELFER ----------
    def _format_project_status_marker(self, project: dict | None):
        """Textbasierter Marker (kein Emoji wegen Policy) für Projektstatus."""
        try:
            if not project:
                return ''
            # Heuristik: valid == True -> OK / error_count >0 -> WARN
            if project.get('errors'):
                return '[WARN]'
            if project.get('validated'):
                return '[OK]'
            return ''
        except Exception:
            return ''

    # ---------- FILE MANAGER HELFER ----------
    def _open_in_file_manager(self, path: str):
        """Öffnet Pfad im nativen Dateimanager (plattformabhängig)."""
        try:
            import subprocess, sys
            if not os.path.exists(path):
                try:
                    self.show_toast(self._t("Ordner nicht gefunden") if hasattr(self,'_t') else "Ordner nicht gefunden", "error")
                except Exception as ex:
                    try:
                        self._record_suppressed_error('pairing.bulk_pair.loop', ex)
                    except Exception:
                        pass
                return
            if sys.platform == 'win32':
                subprocess.run(['explorer', path])
            elif sys.platform == 'darwin':
                subprocess.run(['open', path])
            else:
                subprocess.run(['xdg-open', path])
        except Exception as e:
            self._handle_error(e, context='file_manager.open')
    """Professionelle Übersetzungsqualitäts-GUI mit erweiterten Funktionen"""

    def __init__(self):  # Wiederhergestellt aus Backup & an neue Struktur angepasst
        """Initialisiert Kernzustand, Logging, Caches, Design-System & Hauptfenster.

        Minimal-invasiv: Keine bestehende Logik entfernt, nur fehlende Initialisierung ergänzt.
        """
        try:  # Gesamter Initialisierungsblock robust gekapselt
            # -------------------- LOGGER --------------------
            try:
                self.logger = logging.getLogger("quality_gui")
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.logger', ex)
                except Exception as ex_warn:
                    try:
                        self._record_suppressed_error('suppressed.burst.warn', ex_warn)
                    except Exception:
                        pass
                self.logger = logging.getLogger(__name__)

            # -------------------- GRUND-STATE --------------------
            self.root: Optional[ctk.CTk] = None
            self.left_panel = None
            self.right_panel = None
            self.output_frame = None

            # -------------------- DATEN / STATUS --------------------
            self.uploaded_files: Dict[str, List[str]] = {'source': [], 'translation': []}
            self.analysis_results: Dict[str, Any] = {}
            self.current_analysis: Any = None
            self.current_file: Optional[str] = None

            # -------------------- PROJEKTSTRUKTUR --------------------
            self.STANDARD_PROJECT_STRUCTURE = [
                "01_Ausgangstext", "02_Angebot", "03_Prüfung", "04_Finalisierung"
            ]

            # -------------------- CACHES --------------------
            self._ui_cache: Dict[str, Any] = {}
            self._color_cache: Dict[str, str] = {}
            self._font_cache: Dict[str, Any] = {}
            # -------------------- DIAGNOSTICS STATE --------------------
            try:
                if not hasattr(self, '_recent_errors'):
                    self._recent_errors = deque(maxlen=300)  # type: ignore
                if not hasattr(self, '_suppressed_error_totals'):
                    self._suppressed_error_totals = {}
                if not hasattr(self, '_suppressed_error_first_sample'):
                    self._suppressed_error_first_sample = {}
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.diagnostics_state', ex)
                except Exception as ex_hover_bind:
                    try:
                        self._record_suppressed_error('ui.menu.hover.bind', ex_hover_bind)
                    except Exception:
                        pass

            # -------------------- SYSTEM-KOMPONENTEN (ursprünglich vorhanden) --------------------
            self.toast_system = getattr(self, 'toast_system', None)
            self.context_menu_manager = getattr(self, 'context_menu_manager', None)
            self.advanced_search_system = getattr(self, 'advanced_search_system', None)
            self.performance_monitor = getattr(self, 'performance_monitor', None)
            # Optionale Infrastruktur (nur falls verfügbar) – verhindert AttributeError in Callbacks
            try:
                self.event_bus = get_global_event_bus() if 'get_global_event_bus' in globals() else None  # type: ignore
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.event_bus', ex)
                except Exception:
                    try:
                        self._record_suppressed_error('customer.list.reload', Exception('reload.failed'))
                    except Exception:
                        pass
                self.event_bus = None  # type: ignore
            try:
                self.worker_pool = WorkerPool(max_workers=4) if 'WorkerPool' in globals() and WorkerPool else None  # type: ignore
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.worker_pool', ex)
                except Exception:
                    pass
                self.worker_pool = None  # type: ignore
            try:
                self.settings_service = SettingsService() if 'SettingsService' in globals() and SettingsService else None  # type: ignore
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.settings_service', ex)
                except Exception:
                    pass
                self.settings_service = None  # type: ignore

            # -------------------- FEATURE FLAGS --------------------
            self.advanced_features_enabled = True
            self.phase3_enabled = True
            self.phase4_enabled = True
            self.phase5_enabled = True
            self.phase6_enabled = True
            # Upload UX: Explorer nicht automatisch doppelt öffnen (User-Wunsch)
            self.auto_open_explorer = False  # Kann per Config / Laufzeit auf True gesetzt werden

            # -------------------- DESIGN SYSTEM --------------------
            try:
                # Original: self.design_system = self._initialize_design_system()
                if not hasattr(self, 'design_system') or not self.design_system:
                    if hasattr(self, '_initialize_design_system'):
                        self.design_system = self._initialize_design_system()  # type: ignore
                    else:
                        self.design_system = {}
            except Exception as e:
                self.logger.warning(f"Design-System Init Fallback: {e}")
                self.design_system = {}

            # Einheitliche Farb-API früh bereitstellen
            try:
                if not hasattr(self, 'get_color') or not callable(getattr(self, 'get_color')):
                    self.get_color = self._basic_get_color  # type: ignore
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.get_color_fallback', ex)
                except Exception:
                    pass
                self.get_color = self._basic_get_color  # type: ignore

            # -------------------- LOKALISIERUNG --------------------
            self.current_language = 'de'
            # Backup hatte _initialize_localization(); aktuelle Variante nutzt _initialize_localization_map()
            try:
                if hasattr(self, '_initialize_localization'):
                    self._initialize_localization()  # type: ignore
                elif hasattr(self, '_initialize_localization_map'):
                    self._initialize_localization_map()  # type: ignore
            except Exception as e:
                try:
                    self._record_suppressed_error('init.localization', e)
                except Exception:
                    pass
                self.logger.warning(f"Lokalisierungs-Init Fallback: {e}")
            try:
                self._apply_localization_safe()
            except Exception as ex:
                try:
                    self._record_suppressed_error('init.localization.apply_safe', ex)
                except Exception:
                    pass

            # -------------------- HAUPT-SETUP (Fenster/Layout) --------------------
            try:
                self._setup_application()
            except Exception as e:
                try:
                    self._record_suppressed_error('init.setup_application', e)
                except Exception:
                    pass
                self.logger.error(f"Setup Fehler: {e}")

            # -------------------- MIGRATION (falls Funktion existiert) --------------------
            try:
                if hasattr(self, '_migrate_existing_projects_on_startup'):
                    self._migrate_existing_projects_on_startup()  # type: ignore
            except Exception as e:
                try:
                    self._record_suppressed_error('init.migrate_projects', e)
                except Exception:
                    pass
                self.logger.warning(f"Projekt-Migration übersprungen: {e}")

            # -------------------- DIAGNOSTICS SHORTCUT --------------------
            try:
                if getattr(self, 'root', None):
                    # Ctrl+D => Diagnostics Window
                    self.root.bind('<Control-d>', lambda e: self._open_diagnostics_window())
            except Exception as ex:  # silent init bind failure -> diagnostics aggregation
                try:
                    self._record_suppressed_error('init.bind.ctrl_d', ex)
                except Exception:
                    pass  # final safeguard: never raise during init

        except Exception as e:  # letzter Fallback – niemals Absturz nach außen
            try:
                logging.getLogger("quality_gui").exception(f"Kritischer Initialisierungsfehler: {e}")
            except Exception:
                pass

    # Klasseweiter Default Mapping Cache (einmalig definiert statt pro Aufruf gebaut)
    _CONTEXT_DEFAULT_MAP = {
        # Files
        "files.counter.update": "Dateizähler konnte nicht aktualisiert werden",
        "files.list.refresh": "Dateiliste Refresh Fehler",
        "files.list.content": "Dateiliste Inhalt konnte nicht aktualisiert werden",
        "files.item.create": "Dateielement konnte nicht erstellt werden",
        "files.item.remove": "Dateielement konnte nicht entfernt werden",
        "files.clear": "Dateien Leeren Fehler",
        # Upload
        "upload.translation": "Übersetzungsdateien Upload fehlgeschlagen",
        "upload.source": "Upload Source Files",
        "upload.batch": "Batch Upload",
        "upload.results.enhanced": "Erweiterte Upload Ergebnisse Fehler",
        # Pairing
        "pairing.results.display": "Pairing Ergebnisse Anzeige Fehler",
        "pairing.manual.dialog": "Manueller Pairing Dialog Fehler",
        "pairing.manual.interface": "Manuelle Pairing Oberfläche Fehler",
        "pairing.manual.populate": "Manuelle Pairing Befüllung Fehler",
        # (weitere Kontext Keys folgen tiefer im File – Mapping hier sauber beendet)
    }

    # --------------------------- SAFE LOCALIZATION APPLY ---------------------------
    def _apply_localization_safe(self):
        """Wendet sichere Lokalisierung auf primäre UI-Elemente an (Fenstertitel)."""
        try:
            if getattr(self, 'root', None):
                self.root.title(self._t("Translation Quality Framework - Professional"))
        except Exception as ex:  # previously silent
            try:
                self._record_suppressed_error('localization.apply.window_title', ex)
            except Exception:
                pass

    # ========================= DESIGN SYSTEM INITIALIZER (aus Backup übernommen) =========================
