    def _show_message(self, message: str, msg_type: str = "info"):
        """Show a message to the user."""
        try:
            if hasattr(self, 'output_status_label') and self.output_status_label:
                icon_map = {"info": "ℹ️", "success": "✅", "warning": "⚠️", "error": "❌"}
                icon = icon_map.get(msg_type, "ℹ️")
                self.output_status_label.configure(text=f"{icon} {message}")
            else:
                print(f"[{msg_type.upper()}] {message}")
        except Exception:
            print(f"[{msg_type.upper()}] {message}")

    def _start_file_pairing_wizard(self):
        """Start file pairing wizard."""
        try:
