    # ========================= ZENTRALER ERROR HANDLER =========================
    def _handle_error(self, e: Exception, context: str = "", user_message: str | None = None, level: str = "error", toast: bool = True, event_name: str | None = None, **extra):
        """Zentraler Fehler-Handler: Logging, optional Toast & Event.

        Parameters:
            e: Exception Instanz
            context: semantischer Kontext ("upload", "analysis", ...)
            user_message: UI-Meldung (DE). Fallback generisch.
            level: logging Level (error|warning|info|debug)
            toast: Ob ein Toast angezeigt wird
            event_name: Optionales Event für event_bus
            extra: Zusätzliche Felder für Logging / Event
        """
        try:
            # 1) Logging (error-level mit exception() für direkten Trace)
            if level == "error":
                try:
                    self.logger.exception(f"[{context}] {e}")
                except Exception:
                    self.logger.error(f"[{context}] {e}", exc_info=True)
            else:
                logger_fn = getattr(self.logger, level, self.logger.error)
                logger_fn(f"[{context}] {e}", exc_info=True)

            # 2) Event Dispatch (optional)
            if event_name and getattr(self, 'event_bus', None):
                try:
                    payload = {"context": context, "error": str(e), **extra}
                    self.event_bus.publish(event_name, payload)
                except Exception as ex_evt:
                    try:
                        self._record_suppressed_error('error.event.publish', ex_evt)
                    except Exception:
                        pass

            # 3) Automatische Standard-Meldung falls keine user_message übergeben
            if user_message is None and context:
                try:
                    mapped = self._CONTEXT_DEFAULT_MAP.get(context)
                    if mapped:
                        if hasattr(self, '_t'):
                            user_message = self._t(mapped)
                        else:
                            user_message = mapped
                except Exception as ex_map:
                    try:
                        self._record_suppressed_error('error.context.map', ex_map)
                    except Exception:
                        pass

            # 4) UI Toast
            if toast and hasattr(self, 'show_toast'):
                try:
                    msg = user_message or (f"Fehler ({context})" if context else "Fehler")
                    self.show_toast(msg, "error")
                except Exception as ex_toast:
                    try:
                        self._record_suppressed_error('error.toast.show', ex_toast)
                    except Exception:
                        pass
        except Exception as ex_fail:
            # Letzter Fallback – kein Crash aber im Suppressed Pool sichtbar
            try:
                self._record_suppressed_error('error.handler.fail', ex_fail)
            except Exception:
                pass

    # ========================= SUPPRESSED ERROR AGGREGATOR =========================
    def _record_suppressed_error(self, context: str, e: Exception):
        """Leichte Aggregation stiller (bewusst unterdrückter) Fehler.

        Ziel:
        - Vermeidet Log-Spam bei häufigen, unkritischen UI-Operationen
        - Liefert dennoch später Diagnose (aggregiert) im Logger + Diagnostics Window
        - Keine Toasts, Level debug
        """
        try:
            if not hasattr(self, '_suppressed_error_counts'):
                self._suppressed_error_counts = {}
                self._suppressed_error_samples = {}
                self._suppressed_error_flush_scheduled = False
            ctx = context or 'unknown'
            bucket = self._suppressed_error_counts.get(ctx, 0) + 1
            self._suppressed_error_counts[ctx] = bucket
            # Persistente Total-Zählung (für Diagnostics Fenster)
            try:
                if not hasattr(self, '_suppressed_error_totals'):
                    self._suppressed_error_totals = {}
                self._suppressed_error_totals[ctx] = self._suppressed_error_totals.get(ctx, 0) + 1
            except Exception:
                pass
            # Nur erstes Sample pro Kontext merken (für spätere Analyse / Anzeige)
            if ctx not in self._suppressed_error_samples:
                self._suppressed_error_samples[ctx] = repr(e)[:180]
            if ctx not in getattr(self, '_suppressed_error_first_sample', {}):
                try:
                    self._suppressed_error_first_sample[ctx] = repr(e)[:180]
                except Exception:
                    pass
            # Optional Burst-Warnung (nur bei bestimmten Schwellen – kein Spam)
            try:
                total = getattr(self, '_suppressed_error_totals', {}).get(ctx, 0)
                if total in (25, 100, 500, 1000):  # Eskalierende Schwellenwerte
                    try:
                        self.logger.warning(f"Suppressed Fehlerhäufung: {ctx} total={total}")
                    except Exception:
                        pass
                    # Nur im Development Mode einen dezenten Toast anzeigen
                    if getattr(self, 'development_mode', True) and hasattr(self, 'show_toast'):
                        try:
                            self.show_toast(self._t("Unterdrückte Fehler häufen sich") + f" ({ctx}: {total})", "warning")
                        except Exception as ex_toast:
                            try:
                                self._record_suppressed_error('suppressed.burst.toast', ex_toast)
                            except Exception:
                                pass
            except Exception as ex_block:
                try:
                    self._record_suppressed_error('suppressed.burst.block', ex_block)
                except Exception:
                    pass
            # Optional im internen Fehlerpuffer sichtbar machen (als debug – ohne Toast)
            try:
                self._recent_errors.appendleft({
                    # Lokaler Import um globalen Namespace nicht vorauszusetzen; utcnow() deprecated → timezone-aware now()
                    'ts': (__import__('datetime').datetime.now(__import__('datetime').timezone.utc)
                           .isoformat(timespec='seconds').replace('+00:00', 'Z')),
                    'context': f"suppressed:{ctx}",
                    'error': f"{type(e).__name__}: {e}"[:220]
                })
            except Exception as ex_recent:
                try:
                    self._record_suppressed_error('suppressed.recent.append', ex_recent)
                except Exception:
                    pass
            # Flush planen (Debounce ~300ms)
            if not self._suppressed_error_flush_scheduled:
                self._suppressed_error_flush_scheduled = True
                def _flush():
                    try:
                        parts = []
                        for k, cnt in sorted(self._suppressed_error_counts.items(), key=lambda x: -x[1]):
                            sample = self._suppressed_error_samples.get(k, '')
                            parts.append(f"{k}={cnt} (sample: {sample})")
                        self.logger.debug("[suppressed.aggregate] " + "; ".join(parts))
                    except Exception as ex_build:  # pragma: no cover - safety
                        try:
                            self._record_suppressed_error('suppressed.flush.build', ex_build)
                        except Exception:
                            pass
                    finally:
                        try:
                            self._suppressed_error_counts.clear()
                            self._suppressed_error_samples.clear()
                        except Exception as ex_cleanup:
                            try:
                                self._record_suppressed_error('suppressed.flush.cleanup', ex_cleanup)
                            except Exception:
                                pass
                        self._suppressed_error_flush_scheduled = False
                try:
                    # UI-Kontext: nach Möglichkeit after nutzen
                    if hasattr(self, 'root') and getattr(self, 'root', None):
                        self.root.after(300, _flush)
                    else:
                        _flush()
                except Exception as ex_schedule:
                    try:
                        self._record_suppressed_error('suppressed.flush.schedule', ex_schedule)
                    except Exception:
                        pass
                    _flush()
        except Exception as ex_fail_agg:
            try:
                self._record_suppressed_error('suppressed.aggregate.fail', ex_fail_agg)
            except Exception:
                pass

    # ========================= DIAGNOSTICS WINDOW =========================
    def _open_diagnostics_window(self):
        """Öffnet oder fokussiert ein Diagnose-Fenster mit jüngsten & aggregierten Fehlern."""
        try:
            if hasattr(self, '_diagnostics_win') and self._diagnostics_win and self._diagnostics_win.winfo_exists():
                try:
                    self._diagnostics_win.lift()
                    self._refresh_diagnostics_window()
                except Exception as ex_focus:
                    try:
                        self._record_suppressed_error('diag.window.focus', ex_focus)
                    except Exception:
                        pass
                return
            if not getattr(self, 'root', None):
                return
            win = ctk.CTkToplevel(self.root)
            self._diagnostics_win = win
            win.title(self._t("Diagnose & Fehlerüberblick") if hasattr(self,'_t') else "Diagnostics")
            try:
                win.geometry('860x600')
            except Exception as ex_geom:
                try:
                    self._record_suppressed_error('diag.window.geometry', ex_geom)
                except Exception:
                    pass
            fg = self.get_color('surface') if hasattr(self,'get_color') else '#FFFFFF'
            border = self.get_color('surface_border') if hasattr(self,'get_color') else '#E5E7EB'
            container = ctk.CTkFrame(win, fg_color=fg, border_width=1, border_color=border)
            container.pack(fill='both', expand=True, padx=12, pady=12)

            header = ctk.CTkLabel(container, text=self._t("Diagnose & Fehlerüberblick") if hasattr(self,'_t') else "Diagnostics", font=ctk.CTkFont(*self.get_typography('heading')) if hasattr(self,'get_typography') else None, text_color=self.get_color('text_primary') if hasattr(self,'get_color') else None)
            header.pack(anchor='w', pady=(0,8))

            btn_row = ctk.CTkFrame(container, fg_color='transparent')
            btn_row.pack(fill='x', pady=(0,8))

            reload_btn = self._create_button(btn_row, text=self._t("Aktualisieren") if hasattr(self,'_t') else "Refresh", command=self._refresh_diagnostics_window, kind='outline-primary', height=32)
            reload_btn.pack(side='right')
            export_btn = self._create_button(btn_row, text=self._t("Exportieren") if hasattr(self,'_t') else "Export", command=self._export_diagnostics_json, kind='outline-primary', height=32)
            export_btn.pack(side='right', padx=(0,8))

            # Split Frames
            upper = ctk.CTkFrame(container, fg_color=self.get_color('surface_light') if hasattr(self,'get_color') else fg, border_width=1, border_color=border)
            lower = ctk.CTkFrame(container, fg_color='transparent')
            upper.pack(fill='both', expand=True, pady=(0,8))
            lower.pack(fill='both', expand=True)

            # Aggregated suppressed errors (top)
            agg_header = ctk.CTkLabel(upper, text=self._t("Unterdrückte Fehler (aggregiert)") if hasattr(self,'_t') else "Suppressed Errors (Aggregated)", font=ctk.CTkFont(*self.get_typography('subheading')) if hasattr(self,'get_typography') else None, text_color=self.get_color('text_primary') if hasattr(self,'get_color') else None)
            agg_header.pack(anchor='w', padx=8, pady=(6,4))
            agg_frame = ctk.CTkScrollableFrame(upper, fg_color='transparent', height=180)
            agg_frame.pack(fill='both', expand=True, padx=6, pady=(0,6))
            self._diag_agg_frame = agg_frame

            recent_header = ctk.CTkLabel(lower, text=self._t("Jüngste Fehler (inkl. unterdrückte Kontexte)") if hasattr(self,'_t') else "Recent Errors", font=ctk.CTkFont(*self.get_typography('subheading')) if hasattr(self,'get_typography') else None, text_color=self.get_color('text_primary') if hasattr(self,'get_color') else None)
            recent_header.pack(anchor='w', padx=8, pady=(0,4))
            recent_frame = ctk.CTkScrollableFrame(lower, fg_color='transparent')
            recent_frame.pack(fill='both', expand=True, padx=6, pady=(0,0))
            self._diag_recent_frame = recent_frame

            self._refresh_diagnostics_window()
        except Exception as e:
            try:
                self._handle_error(e, context='diagnostics.window', toast=False)
            except Exception as ex_handle_diag:
                try:
                    self._record_suppressed_error('diag.window.error_handle_fail', ex_handle_diag)
                except Exception:
                    pass

    def _refresh_diagnostics_window(self):
        """Aktualisiert Inhalte des Diagnose-Fensters (falls geöffnet)."""
        try:
            if not hasattr(self, '_diagnostics_win') or not self._diagnostics_win or not self._diagnostics_win.winfo_exists():
                return
            # Aggregated suppressed errors
            try:
                for w in list(self._diag_agg_frame.winfo_children()):
                    w.destroy()
            except Exception as ex_destroy_agg:
                try:
                    self._record_suppressed_error('diag.refresh.agg.destroy', ex_destroy_agg)
                except Exception:
                    pass
            totals = getattr(self, '_suppressed_error_totals', {}) or {}
            first_samples = getattr(self, '_suppressed_error_first_sample', {}) or {}
            if not totals:
                ctk.CTkLabel(self._diag_agg_frame, text=self._t("Keine Daten") if hasattr(self,'_t') else "No data", text_color=self.get_color('gray_600') if hasattr(self,'get_color') else None).pack(anchor='w', padx=4, pady=2)
            else:
                # Sort by count desc
                for ctx, cnt in sorted(totals.items(), key=lambda x: -x[1])[:50]:
                    sample = first_samples.get(ctx, '')
                    row = ctk.CTkFrame(self._diag_agg_frame, fg_color='transparent')
                    row.pack(fill='x', padx=4, pady=1)
                    ctk.CTkLabel(row, width=340, anchor='w', text=ctx, text_color=self.get_color('text_primary') if hasattr(self,'get_color') else None, font=ctk.CTkFont(*self.get_typography('caption')) if hasattr(self,'get_typography') else None).pack(side='left')
                    ctk.CTkLabel(row, width=60, anchor='e', text=str(cnt), text_color=self.get_color('text_secondary') if hasattr(self,'get_color') else None, font=ctk.CTkFont(*self.get_typography('caption')) if hasattr(self,'get_typography') else None).pack(side='left', padx=(4,10))
                    ctk.CTkLabel(row, anchor='w', text=sample[:160], text_color=self.get_color('gray_600') if hasattr(self,'get_color') else None, font=ctk.CTkFont(*self.get_typography('micro')) if hasattr(self,'get_typography') else None).pack(side='left', fill='x', expand=True)
            # Recent errors
            try:
                for w in list(self._diag_recent_frame.winfo_children()):
                    w.destroy()
            except Exception as ex_destroy_recent:
                try:
                    self._record_suppressed_error('diag.refresh.recent.destroy', ex_destroy_recent)
                except Exception:
                    pass
            recent = list(getattr(self, '_recent_errors', []) or [])[:120]
            if not recent:
                ctk.CTkLabel(self._diag_recent_frame, text=self._t("Keine Fehler erfasst") if hasattr(self,'_t') else "No errors", text_color=self.get_color('gray_600') if hasattr(self,'get_color') else None).pack(anchor='w', padx=4, pady=2)
            else:
                for entry in recent:
                    row = ctk.CTkFrame(self._diag_recent_frame, fg_color='transparent')
                    row.pack(fill='x', padx=4, pady=1)
                    ts = entry.get('ts','')
                    ctx = entry.get('context','')
                    err = entry.get('error','')
                    ctk.CTkLabel(row, width=110, text=ts, anchor='w', text_color=self.get_color('text_secondary') if hasattr(self,'get_color') else None, font=ctk.CTkFont(*self.get_typography('micro')) if hasattr(self,'get_typography') else None).pack(side='left')
                    ctk.CTkLabel(row, width=260, text=ctx, anchor='w', text_color=self.get_color('text_primary') if hasattr(self,'get_color') else None, font=ctk.CTkFont(*self.get_typography('caption')) if hasattr(self,'get_typography') else None).pack(side='left')
                    ctk.CTkLabel(row, text=err[:400], anchor='w', justify='left', wraplength=400, text_color=self.get_color('gray_600') if hasattr(self,'get_color') else None, font=ctk.CTkFont(*self.get_typography('micro')) if hasattr(self,'get_typography') else None).pack(side='left', fill='x', expand=True)
            # Auto-refresh alle 2s solange Fenster offen
            try:
                if self._diagnostics_win and self._diagnostics_win.winfo_exists():
                    self._diagnostics_win.after(2000, self._refresh_diagnostics_window)
            except Exception as ex_auto:
                try:
                    self._record_suppressed_error('diag.refresh.autorefresh', ex_auto)
                except Exception:
                    pass
        except Exception as e:
            try:
                self._handle_error(e, context='diagnostics.refresh', toast=False)
            except Exception as ex_refresh_handle:
                try:
                    self._record_suppressed_error('diag.refresh.error_handle_fail', ex_refresh_handle)
                except Exception:
                    pass

    def _export_diagnostics_json(self):
        """Exportiert aktuelle Diagnostics (unterdrückte + jüngste Fehler) als JSON Datei."""
        try:
            import json, time
            payload = {
                'export_ts': time.time(),
                'suppressed_totals': getattr(self, '_suppressed_error_totals', {}),
                'suppressed_first_sample': getattr(self, '_suppressed_error_first_sample', {}),
                'recent_errors': list(getattr(self, '_recent_errors', []) or [])[:300]
            }
            target = 'diagnostics_export.json'
            with open(target, 'w', encoding='utf-8') as f:
                json.dump(payload, f, indent=2, ensure_ascii=False)
            if hasattr(self, 'show_toast'):
                try:
                    self.show_toast(self._t("Diagnostics exportiert") if hasattr(self,'_t') else "Diagnostics exported", "success")
                except Exception as ex_diag_toast:
                    try:
                        self._record_suppressed_error('diagnostics.export.toast', ex_diag_toast)
                    except Exception:
                        pass
            try:
                self.logger.info(f"Diagnostics export created: {target}")
            except Exception as ex_diag_log:
                try:
                    self._record_suppressed_error('diagnostics.export.logger', ex_diag_log)
                except Exception:
                    pass
        except Exception as e:
            try:
                self._handle_error(e, context='diagnostics.export', toast=False)
            except Exception as ex_export_handle:
                try:
                    self._record_suppressed_error('diagnostics.export.error_handle_fail', ex_export_handle)
                except Exception:
                    pass

