    def upload_multiple_files_type(self, file_type):
        """Enhanced upload multiple files with progress tracking"""
        filenames = filedialog.askopenfilenames(
            title=f"Mehrere {file_type.title()}-Dateien auswählen",
            filetypes=[
                ("Text-Dateien", "*.txt"),
                ("Word-Dokumente", "*.docx"),
                ("PDF-Dateien", "*.pdf"),
                ("Alle Dateien", "*.*")
            ]
        )
        
        if not filenames:
            return
        
        # Use progress dialog for many files
        if len(filenames) > 3:
            self._upload_files_with_progress(filenames, file_type)
        else:
            # Simple upload for few files
            added_count = 0
            for filename in filenames:
                if filename not in self.uploaded_files[file_type]:
                    self.uploaded_files[file_type].append(filename)
                    added_count += 1
            
            self._update_file_displays()
            self._check_analysis_ready()
            self.update_status(f"{added_count} {file_type}-Datei(en) hinzugefügt")
    
    def _upload_files_with_progress(self, file_paths, file_type):
        """Upload files with progress dialog for better UX"""
        # Create progress dialog
        progress_window = ctk.CTkToplevel(self.root)
        progress_window.title("Dateien hochladen...")
        progress_window.geometry("450x180")
        progress_window.transient(self.root)
        progress_window.grab_set()
        
        # Center window
        progress_window.update_idletasks()
        x = (progress_window.winfo_screenwidth() // 2) - (450 // 2)
        y = (progress_window.winfo_screenheight() // 2) - (180 // 2)
        progress_window.geometry(f"450x180+{x}+{y}")
        
        # Progress bar with modern styling
        progress_bar = ModernProgressBar(progress_window, width=400)
        progress_bar.pack(fill='x', padx=20, pady=20)
        
        # Cancel button
        cancel_btn = EnhancedButton.create_secondary_button(
            progress_window,
            text="Abbrechen",
            command=lambda: progress_window.destroy(),
            width=120
        )
        cancel_btn.pack(pady=10)
        
        # Process files in background
        def process_files():
            try:
                total_files = len(file_paths)
                added_count = 0
                
                for i, file_path in enumerate(file_paths):
                    if progress_window.winfo_exists():  # Check if dialog still exists
                        progress = (i + 1) / total_files
                        filename = os.path.basename(file_path)
                        status = f"Verarbeite: {filename[:30]}{'...' if len(filename) > 30 else ''}"
                        
                        # Update progress in main thread
                        self.root.after(0, lambda p=progress, s=status: progress_bar.update_progress(p, s))
                        
                        # Add file if not duplicate
                        if file_path not in self.uploaded_files[file_type]:
                            self.uploaded_files[file_type].append(file_path)
                            added_count += 1
                        
                        # Small delay for smooth progress animation
                        time.sleep(0.05)
                    else:
                        break  # Dialog was cancelled
                
                # Complete the process
                if progress_window.winfo_exists():
                    final_status = f"Abgeschlossen: {added_count} von {total_files} Dateien hinzugefügt"
                    self.root.after(0, lambda: progress_bar.update_progress(1.0, final_status))
                    time.sleep(0.8)
                    
                    # Update UI and close
                    self.root.after(0, lambda: [
                        self._update_file_displays(),
                        self._check_analysis_ready(),
                        progress_window.destroy(),
                        self.update_status(f"Upload abgeschlossen: {added_count} {file_type}-Dateien")
                    ])
                    
            except Exception as e:
                if progress_window.winfo_exists():
                    error_msg = f"Fehler: {str(e)[:50]}..."
                    self.root.after(0, lambda: [
                        progress_bar.update_progress(0, error_msg),
                        messagebox.showerror("Upload-Fehler", f"Fehler beim Hochladen:\n{str(e)}"),
                        progress_window.destroy()
                    ])
        
        # Start processing in background thread
        threading.Thread(target=process_files, daemon=True).start()

