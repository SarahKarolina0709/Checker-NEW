    def _upload_source_files(self):
        """🎯 ENHANCED SOURCE FILE UPLOAD with UX Improvements"""
        from tkinter import filedialog
        import os
        
        # Show initial user guidance
        self.show_toast("📁 Select your source documents for quality analysis...", "info", 2000)
        
        file_types = [
            ("All supported", "*.txt;*.pdf;*.docx;*.rtf"),
            ("Text files", "*.txt"),
            ("PDF files", "*.pdf"),
            ("Word documents", "*.docx"),
            ("Rich text", "*.rtf"),
            ("All files", "*.*")
        ]
        
        files = filedialog.askopenfilenames(
            title="Select Source Files - Translation Quality Framework",
            filetypes=file_types,
            initialdir=os.path.expanduser("~/Documents")  # Start in Documents
        )
        
        if files:
            # Prevent duplicates with user-friendly handling
            new_files = []
            existing_files = []
            
            for file in files:
                if file not in self.uploaded_files['source']:
                    new_files.append(file)
                else:
                    existing_files.append(os.path.basename(file))
            
            if new_files:
                self.uploaded_files['source'].extend(new_files)
                count = len(new_files)
                
                # Enhanced success feedback
                file_names = [os.path.basename(f) for f in new_files[:3]]  # Show first 3 names
                preview = ", ".join(file_names)
                if len(new_files) > 3:
                    preview += f" and {len(new_files) - 3} more"
                
                self.show_toast(f"✅ {count} source file{'s' if count != 1 else ''} added: {preview}", "success", 4000)
                self.update_status(f"{len(self.uploaded_files['source'])} total source files")
                
                # Auto-switch to files view for immediate feedback
                self.show_files_view()
            
            if existing_files:
                skip_names = ", ".join(existing_files[:2])
                if len(existing_files) > 2:
                    skip_names += f" and {len(existing_files) - 2} more"
                self.show_toast(f"ℹ️ Skipped duplicate files: {skip_names}", "warning", 3000)
        else:
            self.show_toast("📁 No files selected", "info", 2000)
    
