            def simulate_work():
                tasks = [
                    "Initializing system...",
                    "Loading files...", 
                    "Processing documents...",
                    "Analyzing quality...",
                    "Generating reports...",
                    "Finalizing results..."
                ]
                
                for i, task in enumerate(tasks):
                    for j in range(20):
                        progress = ((i * 20) + j) / (len(tasks) * 20)
