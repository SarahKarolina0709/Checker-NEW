    def _get_customer_list(self):
        """Get list of customers for dropdown"""
        if not self.customer_manager:
            return ["Keine Kundenverwaltung verfÃ¼gbar"]
        
        try:
            customers = []
            if hasattr(self.customer_manager, 'customers_data') and self.customer_manager.customers_data:
                if isinstance(self.customer_manager.customers_data, list):
                    for customer in self.customer_manager.customers_data:
                        if 'name' in customer and 'id' in customer:
                            customers.append(f"{customer['name']} ({customer['id']})")
                elif isinstance(self.customer_manager.customers_data, dict):
                    for customer_id, customer_data in self.customer_manager.customers_data.items():
                        if 'name' in customer_data:
                            customers.append(f"{customer_data['name']} ({customer_id})")
            
            if not customers:
                return ["Keine Kunden vorhanden"]
            
            return ["Kunde auswÃ¤hlen..."] + sorted(customers)
        except Exception as e:
            logger.error(f"Error loading customers: {e}")
            return ["Fehler beim Laden der Kunden"]
    
    def _on_customer_selection_changed(self, selection):
        """Handle customer selection change"""
        try:
            if selection == "Kunde auswÃ¤hlen..." or "keine" in selection.lower() or "fehler" in selection.lower():
                self.current_customer_id = None
                self.current_customer_data = None
                self.update_status("Kein Kunde ausgewÃ¤hlt")
                return
            
            # Extract customer ID from selection (format: "Name (ID)")
            import re
            match = re.search(r'\(([^)]+)\)$', selection)
            if match:
                customer_id = match.group(1)
                self.current_customer_id = customer_id
                
                # Find customer data
                self.current_customer_data = self._find_customer_data(customer_id)
                
                if self.current_customer_data:
                    # Initialize project structure
                    self._initialize_project_structure()
                    
                    # Update status
                    customer_name = self.current_customer_data.get('name', 'Unbekannt')
                    self.update_status(f"âœ… Kunde ausgewÃ¤hlt: {customer_name} (ID: {customer_id})")
                    
                    logger.info(f"Customer selected: {customer_name} (ID: {customer_id})")
                else:
                    self.update_status("âŒ Kundendaten nicht gefunden")
            
        except Exception as e:
            logger.error(f"Error handling customer selection: {e}")
            self.update_status("âŒ Fehler bei Kundenauswahl")

    def _find_customer_data(self, customer_id):
        """Find customer data by ID"""
        if not self.customer_manager or not self.customer_manager.customers_data:
            return None
        
        try:
            if isinstance(self.customer_manager.customers_data, list):
                for customer in self.customer_manager.customers_data:
                    if customer.get('id') == customer_id:
                        return customer
            elif isinstance(self.customer_manager.customers_data, dict):
                return self.customer_manager.customers_data.get(customer_id)
            
            return None
            
        except Exception as e:
            logger.error(f"Error finding customer data: {e}")
            return None

