{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Welcome Screen",
			"type": "shell",
			"command": "python",
			"args": [
				"${workspaceFolder}/welcome_screen.py"
			],
			"group": "build",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Run Quality GUI",
			"type": "shell",
			"command": "python",
			"args": [
				"${workspaceFolder}/quality_gui_main_app.py"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Run Current File",
			"type": "shell",
			"command": "python",
			"args": [
				"${file}"
			],
			"group": "build",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Run Pytest",
			"type": "shell",
			"command": "python",
			"args": [
				"-m",
				"pytest",
				"-q"
			],
			"group": "test",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always"
			}
		},
		{
			"label": "Backup all .py files",
			"type": "shell",
			"command": "${workspaceFolder}/backup_py.bat",
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Run Quality GUI",
			"type": "shell",
			"command": ".venv/Scripts/python.exe",
			"args": [
				"quality_gui_main_app.py"
			]
		},
		{
			"label": "Test Dashboard",
			"type": "shell",
			"command": ".venv/Scripts/python.exe",
			"args": [
				"quality_gui_main_app.py"
			]
		},
		{
			"label": "Start Quality GUI",
			"type": "shell",
			"command": ".venv/Scripts/python.exe",
			"args": [
				"quality_gui_main_app.py"
			]
		},
		{
			"label": "Test UI Changes",
			"type": "shell",
			"command": ".venv/Scripts/python.exe",
			"args": [
				"quality_gui_main_app.py"
			]
		},
		{
			"label": "Test Upload Dashboard",
			"type": "shell",
			"command": "python",
			"args": [
				"quality_gui_main_app.py"
			],
			"group": "build"
		}
	]
}