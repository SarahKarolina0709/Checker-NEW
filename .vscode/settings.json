{
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        ".",
        "-p",
        "*test.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "files.exclude": {
        "**/*.md": true,
        "**/*.log": true,
        "**/*.txt": true,
        "**/*.db": true,
        "**/*.pdf": true,
        "**/*.png": true,
        "**/*.ico": true,
        "**/*.ps1": true,
        "**/*.bat": true,
        "**/*_test.py": true,
        "**/*_test_suite.py": true,
        "**/*_temp.py": true,
        "**/*_fixed.py": true,
        "**/*_new.py": true,
        "**/export.py.new": true,
        "**/__pycache__": true,
        "venv": true,
        "backup_files": true,
        "cleanup_backup_*": true,
        "production_backup_*": true
    },
    "search.exclude": {
        "**/*.md": true,
        "**/*.log": true,
        "**/*.txt": true,
        "**/*.db": true,
        "**/*.pdf": true,
        "**/*.png": true,
        "**/*.ico": true,
        "**/*.ps1": true,
        "**/*.bat": true,
        "**/*_test.py": true,
        "**/*_test_suite.py": true,
        "**/*_temp.py": true,
        "**/*_fixed.py": true,
        "**/*_new.py": true,
        "**/export.py.new": true,
        "**/__pycache__": true,
        "venv": true,
        "backup_files": true,
        "cleanup_backup_*": true,
        "production_backup_*": true
    },
    "python.linting.enabled": false,
    "python.analysis.autoSearchPaths": false,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "files.autoSave": "afterDelay",
    "editor.minimap.enabled": false,
    "breadcrumbs.enabled": false,
    "editor.formatOnSave": false,
    "python.analysis.typeCheckingMode": "off"
}